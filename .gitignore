GM_VIP_Automation/.env

# CANoe build cache – generated by CANoe when it compiles .cfg projects.
# Never commit these; they are regenerated automatically on each bench PC.
STLA_SWTest/BVTRBS/CVADAS_RBS_TRSC/.run/

# Flashing binary artifacts – ECU hex/binary files live on each bench PC
# at a local path (not inside this repository).
STLA_SWTest/BVTRBS/CVADAS_RBS_TRSC/Release/
STLA_SWTest/BVTRBS/CVADAS_RBS_TRSC/NAND_Standard_binaries/

# CANoe / bench runtime logs – regenerated each run.
STLA_SWTest/BVTRBS/CVADAS_RBS_TRSC/Command_List.log
STLA_SWTest/BVTRBS/CVADAS_RBS_TRSC/python/Command_List.log

# GM VIP GUI – persisted state (restored automatically on next launch)
GM_VIP_Automation_Framework/gui_state.json

