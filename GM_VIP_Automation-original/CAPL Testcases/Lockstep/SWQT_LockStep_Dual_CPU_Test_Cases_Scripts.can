 // A_DBGR_BreakpointDeleteAll();
//  A_DBGR_VariableSet("coreId", "0");   
  E_DBGR_VariableCheck("cpuId", 0, Equal);
  
  
 
  
  /******************************************************************************************************************************************************************/    
    // Test Step 9 to 11: set breakpoint in file lockstep_hwio.c in function BYTE GetHWIO_b_LockstepStN( BYTE cpuId ) at line retval = NO_FAILURE;
  /******************************************************************************************************************************************************************/

