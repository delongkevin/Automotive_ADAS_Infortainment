  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function void Test_GetHWIO_b_LockstepStN( void ) at line retval = GetHWIO_b_LockstepSt();");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("Test_GetHWIO_b_LockstepStN");

  A_DBGR_Go_Safe();
  E_DBGR_BreakpointCheckForHalt("Test_GetHWIO_b_LockstepStN");
  
  
  
   
  /*******************************************************************************************************************************************************/    
    // Test Step 4: Add coreId Variable in watch window and update value to 0.
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Add coreId Variable in watch window and update value to 0."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Variable added in watch window and updated the value coreId = 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
 // A_DBGR_BreakpointDeleteAll();
  A_DBGR_VariableSet("coreId", "0");   
  E_DBGR_VariableCheck("coreId", 0, Equal);   //variable is not updating in watch window when we disable task as TRUE, therfore checking 0 value here

  
    
  /******************************************************************************************************************************************************************/    
    // Test Step 5 to 7: set breakpoint in file lockstep_hwio.c in function BYTE GetHWIO_b_LockstepStN( BYTE cpuId ) at line BYTE GetHWIO_b_LockstepStN( BYTE cpuId )
  /******************************************************************************************************************************************************************/

