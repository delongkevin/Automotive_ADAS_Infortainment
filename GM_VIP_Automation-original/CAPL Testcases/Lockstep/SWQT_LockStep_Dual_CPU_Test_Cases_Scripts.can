  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "The_Software_shall_Report_GetHWIO_b_LockstepStN_status_as_'NoFailure'_of_the_Lockstep_Dual-CPU_comparison_for_the_specified_CPU_Core_0." );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:The_Software_shall_Report_GetHWIO_b_LockstepStN_status_as_'NoFailure'_of_the_Lockstep_Dual-CPU_comparison_for_the_specified_CPU_Core_0.");
