  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("GetHWIO_b_LockstepStN\\69");    
  
  
  
  
  
   /*******************************************************************************************************************************************************/    
    // Test Step 15: Add retval  Variable in watch window and check value is NO_FAILURE.
  /*******************************************************************************************************************************************************/

//  snprintf( chActionText, elCount(chActionText), "Add retval  Variable in watch window and check value is NO_FAILURE."); 
//  snprintf( chExpectedText, elCount(chExpectedText), "Variable added in watch window and Verified the value retval  = NO_FAILURE"); 
//  TestStepAddActionExpected( chActionText, chExpectedText );
//  E_DBGR_VariableCheck("retval ", NO_FAILURE, Equal);
  
  
  
  
  
  
