  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("GetHWIO_b_LockstepStN\\64");   
  
  
  
  /******************************************************************************************************************************************************************/    
    // Test Step 12 to 14: set breakpoint in file lockstep_hwio.c in function BYTE GetHWIO_b_LockstepStN( BYTE cpuId ) at line LockstepStatus[cpuId].lockstepStatus = retval;
