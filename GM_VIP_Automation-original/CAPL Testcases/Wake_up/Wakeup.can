  byte CANA_Wakeup[8] =  {0x08,0x08,0x00,0x00,0x00,0x00,0x00,0x01};
  byte CANA_Wakeup_1[8] =  {0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x01};
  byte CANA_Wakeup_2[8] =  {0x08,0x00,0x00,0x00,0x00,0x00,0x00,0x00};
  byte CANB_Wakeup[4] =  {0x00,0x00,0x01,0x00};
  int Stress =0;
  long CANID[70] = {0x00000401, 0x00000301, 0x00000201, 0x00000042, 0x0000039E, 0x00000211, 0x00000212, 0x0000039D, 0x0000020D, 0x0000039B, 0x0000003E, 0x000002B3, 0x00000398, 0x000000BA, 0x00000397, 0x00000270, 0x00000585, 0x0000056B, 0x0000052C, 0x000002D7, 0x00000523, 0x00000568, 0x00000522, 0x00000505, 0x00000593, 0x00000594, 0x00000582, 0x000005A4, 0x000000B6, 0x00000584, 0x000003C3, 0x000003C4, 0x000003C2, 0x000002D5, 0x000003A2, 0x000002D6, 0x0000057F, 0x00000590, 0x000005A1, 0x000005F9, 0x000000C0, 0x000002BF, 0x000003AA, 0x000003B1, 0x00000596, 0x000005C9, 0x000003A5, 0x0000003F, 0x000003A6, 0x000005D2, 0x000004F0, 0x00000599, 0x0000006F, 0x000005CA, 0x000005CB, 0x000005BA, 0x0000059B, 0x00000293, 0x000004E1, 0x000004DC, 0x000000AF, 0x000000AE, 0x00000595, 0x000005C4, 0x00000140, 0x000002D8, 0xC0000100, 0x00007000, 0x00000140, 0x00000140 };
  byte dat_64byte[64] = {0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55,0xAA,0x55};
  
  message 0x123 msg_2; // Define the CAN message with ID 0x123
  message 0x456 msg_8; // Define the CAN message with ID 0x456
  
  msTimer periodicTimer_CAN2; // Define a timer variable
  msTimer periodicTimer_CAN8; // Define a timer variable
  msTimer periodicTimer_Multiple;
  msTimer periodic_error_8;
  msTimer periodic_error_2;
}

on timer periodicTimer_CAN2 {
  // Set the data for the CAN message
  msg_2.byte(0) = 0x08;
  msg_2.byte(1) = 0x00;
  msg_2.byte(2) = 0x00;
  msg_2.byte(3) = 0x00;
  msg_2.byte(4) = 0x00;
  msg_2.byte(5) = 0x00;
  msg_2.byte(6) = 0x00;
  msg_2.byte(7) = 0x01;

  // Set the DLC for the CAN message
  msg_2.dlc = 8;
  msg_2.can = 1;
  // Send the CAN message
   output(msg_2);

  // Restart the timer for the next period
  setTimer(periodicTimer_CAN2, 1);
  
}


on timer periodicTimer_CAN8 {
  // Set the data for the CAN message
  msg_8.byte(0) = 0x00;
  msg_8.byte(1) = 0x00;
  msg_8.byte(2) = 0x01;
  msg_8.byte(3) = 0x00;
  
  // Set the DLC for the CAN message
  msg_8.dlc = 4;
  msg_8.can = 2;
  // Send the CAN message
  output(msg_8);
  
  // Restart the timer for the next period
  setTimer(periodicTimer_CAN8, 1);
  
}

on timer periodicTimer_Multiple {
 
  msg_2.byte(0) = 0x08;
  msg_2.byte(1) = 0x00;
  msg_2.byte(2) = 0x00;
  msg_2.byte(3) = 0x00;
  msg_2.byte(4) = 0x00;
  msg_2.byte(5) = 0x00;
  msg_2.byte(6) = 0x00;
  msg_2.byte(7) = 0x01;

  // Set the DLC for the CAN message
  msg_2.dlc = 8;
  msg_2.can = 1;
  
  // Set the data for the CAN message
  msg_8.byte(0) = 0x00;
  msg_8.byte(1) = 0x00;
  msg_8.byte(2) = 0x01;
  msg_8.byte(3) = 0x00;
  
  // Set the DLC for the CAN message
  msg_8.dlc = 4;
  msg_8.can = 2;
  
  // Send the CAN message
   output(msg_2);

  // Send the CAN message
  output(msg_8);
  output(msg_2);

  // Restart the timer for the next period
  setTimer(periodicTimer_Multiple, 1);
  
}

on timer periodic_error_8 {

  canOutputErrorFrame(CAN2.errorFrame, 12, 0);
  // Restart the timer for the next period
  setTimer(periodic_error_8, 1);
  
}


on timer periodic_error_2 {

  canOutputErrorFrame(CAN1.errorFrame, 12, 0);
  // Restart the timer for the next period
  setTimer(periodic_error_2, 1);
  
}

testcase Verify_that_the_GetHWIO_e_WakeupSigSt_reports_Last_wakeup_event_is_equal_to_0_if_the_wakeup_events_are_not_detected()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_that_the_GetHWIO_e_WakeupSigSt_reports_Last_wakeup_event_is_equal_to_0_if_the_wakeup_events_are_not_detected" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the GetHWIO_e_WakeupSigSt interface  ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36712263", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
   snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_R();
  A_DBGR_Go_Safe();
  /***************************************************************************************************************/    
                                              // Test Step 1 Set a breakpoint at line return ( uint8 )wakeEvent;
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in Test_GetHWIO_e_WakeupSigSt\\33 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set Test_GetHWIO_e_WakeupSigSt\\33"); 
  
  A_DBGR_BreakpointSet("Test_GetHWIO_e_WakeupSigSt\\33");

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in Test_GetHWIO_e_WakeupSigSt\\33 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in Test_GetHWIO_e_WakeupSigSt\\33 function"); 
  
  E_DBGR_BreakpointCheckForHalt("Test_GetHWIO_e_WakeupSigSt\\33");
  
  /***************************************************************************************************************/    
                                              // Test Step 2 verify is wakeEvent having 0.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure wakeEvent values "); 
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure wakeEvent values"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("wakeEvent",0,Equal);
  
}

testcase Verify_that_the_software_reports_wkupPwrOn_for_GetHWIO_e_WakeupSigSt_function_when_the_wakeup_event_detected_is_Battery_wakeup()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_that_the_software_reports_wkupPwrOn_for_GetHWIO_e_WakeupSigSt_function_when_the_wakeup_event_detected_is_Battery_wakeup" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the GetHWIO_e_WakeupSigSt interface ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36542354", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  
  A_DBGR_BreakpointDeleteAll();
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
 
  A_DBGR_R();
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
 // TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();
  A_DBGR_Go();
  /***************************************************************************************************************/    
                                              // Test Step 1  Call the function Test_SetHWIO_PowerDown by setting StartPowerDown to 1 then check transceiver is in the SLEEP mode and PMIC to STANDBY mode
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure StartPowerDown variable to invoke Test_SetHWIO_PowerDown interface"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify StartPowerDown is configured as 1"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("StartPowerDown","1");
 // E_DBGR_VariableCheck("StartPowerDown",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Check Trace32 is stopped"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Trace32 is stopped"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_CheckState(T32_State_Down);
  
 
  /***************************************************************************************************************/    
                                              // Test Step  Run the Software and capture UART log using python
  /***************************************************************************************************************/
  SysExec("powershell", "-ExecutionPolicy Bypass -File ./serial_logging.ps1", automation_root);
  /***************************************************************************************************************/    
                                              // Test Step 2 Disconnect the Battery and verify battery is disconnected
  /***************************************************************************************************************/
  Power_OFF_ON(powersupply_port,0);
  
  /***************************************************************************************************************/    
                                              // Test Step 5  Verify Transceiver wakeUp or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01"); 
  TestStepAddActionExpected( chActionText, chExpectedText ); 
  E_CAN_WaitForMessageByID(0x00000101,10000,cc_eCAN_ABSENT,"CAN1");
  
  /***************************************************************************************************************/    
                                              // Test Step 3 Reconnect the battery power and set the supply voltage to 12V.
  /***************************************************************************************************************/
  
  Power_OFF_ON(powersupply_port,1);
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01"); 
  TestStepAddActionExpected( chActionText, chExpectedText ); 
  E_CAN_WaitForMessageByID(0x00000101,100000,cc_eCAN_PRESENT,"CAN1");
  
  /***************************************************************************************************************/    
    // Test Step 6 Check UART log in the Tera Term window is update: Last wakeup event is: 1 (wkupPwrOn).
  /***************************************************************************************************************/ 
  strncpy(searchString,"Last wakeup event is: 1",256);
  
  snprintf( chActionText, elCount(chActionText), "waiting for UART log"); 
  snprintf( chExpectedText, elCount(chExpectedText), "waiting for UART log"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_GENERIC_SetTimeout(25000,"waiting for battery disconnect");
  
  snprintf(chActionText, elCount(chActionText), "Run Python script to check battConnectionStatus in log file");
  snprintf(chExpectedText, elCount(chExpectedText), "Python script should execute successfully");
  result =iFcnt_READFILE_SearchKeywordInFile(teraterm,searchString,"string is present");
  
  if(result == 1)
  {
    testStepPass("0","string is present");
  }
  else
  {
    testStepFail("1","string is not present");
  }
}

testcase Verify_that_the_software_reports_wkupCanBusA_for_GetHWIO_e_WakeupSigSt_LLSI_CAN_A_bus_wakeup_scenario_1()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_that_the_software_reports_wkupCanBusA_for_GetHWIO_e_WakeupSigSt_LLSI_CAN_A_bus_wakeup_scenario_1" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the GetHWIO_e_WakeupSigSt interface ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36542355", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
