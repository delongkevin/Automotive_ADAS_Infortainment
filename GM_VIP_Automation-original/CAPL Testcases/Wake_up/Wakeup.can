  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnFrameDlc","8");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnFrameDlc",8,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnEnabled variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnEnabled is configured as 1"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnEnabled","1");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnEnabled",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvChannelId variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvChannelId is configured as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[0].CanTrcvChannelId","0");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[0].CanTrcvChannelId",0,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvChannelUsed variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvChannelUsed is configured as 1"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[0].CanTrcvChannelUsed","1");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[0].CanTrcvChannelUsed",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPinWakeupEnabled variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPinWakeupEnabled is configured as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[0].CanTrcvPinWakeupEnabled","0");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[0].CanTrcvPinWakeupEnabled",0,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvNumberOfChannels variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvNumberOfChannels is configured as 2"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels","2");
  E_DBGR_VariableCheck("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels",2,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();
  
  /***************************************************************************************************************/    
                                              // Test Step 3  Call the function Test_SetHWIO_PowerDown by setting StartPowerDown to 1 then check transceiver is in the SLEEP mode and PMIC to STANDBY mode
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure StartPowerDown variable to invoke Test_SetHWIO_PowerDown interface"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify StartPowerDown is configured as 1"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("StartPowerDown","1");
 // E_DBGR_VariableCheck("StartPowerDown",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Check Trace32 is stopped"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Trace32 is stopped"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_CheckState(T32_State_Down);
  
   /***************************************************************************************************************/    
                                              // Test Step 4 Run the Software and capture UART log using python
  /***************************************************************************************************************/
  
  SysExec("powershell", "-ExecutionPolicy Bypass -File ./serial_logging.ps1", automation_root);
  
  snprintf( chActionText, elCount(chActionText), "waiting for UART log"); 
  snprintf( chExpectedText, elCount(chExpectedText), "waiting for UART log"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_GENERIC_SetTimeout(3000,"waiting for UART log");
 
  
  /***************************************************************************************************************/    
                                              // Test Step 5  This step involves sending a CAN wakeup frame with ID 0x123 and 8 bytes of data from Canoe.
  /***************************************************************************************************************/
//  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x123"); 
//  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x123"); 
//  //TestStepAddActionExpected( chActionText, chExpectedText );
//  A_CAN_SendMessage(0x123, CANA_Wakeup, 8, 1);
//  A_CAN_SendMessage(0x123, CANA_Wakeup, 8, 1);
//  A_CAN_SendMessage(0x456, CANB_Wakeup, 4, 2);
  
  setTimer(periodicTimer_Multiple,1);
  
  /***************************************************************************************************************/    
                                              // Test Step 6  Verify Transceiver wakeUp or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01"); 
  //TestStepAddActionExpected( chActionText, chExpectedText ); 
  
  E_CAN_WaitForMessageByID(0x00000101,10000,cc_eCAN_PRESENT,"CAN1");
  
  /***************************************************************************************************************/    
                          // Test Step 7 Check UART log in the Tera Term window is update: Last wakeup event is: 2 (wkupCanBusA).
  /***************************************************************************************************************/ 
  strncpy(searchString,"Last wakeup event is: 6",256);
  
  snprintf( chActionText, elCount(chActionText), "waiting for UART log"); 
  snprintf( chExpectedText, elCount(chExpectedText), "waiting for UART log"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_GENERIC_SetTimeout(25000,"waiting for UART log");
  
  snprintf(chActionText, elCount(chActionText), "Run Python script to check battConnectionStatus in log file");
  snprintf(chExpectedText, elCount(chExpectedText), "Python script should execute successfully");
  result =iFcnt_READFILE_SearchKeywordInFile(teraterm,searchString,"string is present");
  
  if(result == 1)
  {
    testStepPass("0","string is present");
  }
  else
  {
    testStepFail("1","string is not present");
  }
 
  cancelTimer(periodicTimer_Multiple);
  testWaitForTimeout(1000);
}

