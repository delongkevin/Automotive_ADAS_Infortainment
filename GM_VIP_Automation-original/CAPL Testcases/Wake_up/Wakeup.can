  A_DBGR_VariableSet("VsCANR_TrcvChannels[1].CanTrcvChannelUsed","1");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[1].CanTrcvChannelUsed",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPinWakeupEnabled variable"); 
