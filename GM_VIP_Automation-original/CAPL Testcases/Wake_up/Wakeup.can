  A_DBGR_BreakpointSet("TestCan_Init");  
  A_DBGR_Go();
  
  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in TestCan_Init "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCan_Init function"); 
 // TestStepAddActionExpected( chActionText, chExpectedText );  
  E_DBGR_BreakpointCheckForHalt("TestCan_Init");
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMaskIndex variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMaskIndex is configured as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
