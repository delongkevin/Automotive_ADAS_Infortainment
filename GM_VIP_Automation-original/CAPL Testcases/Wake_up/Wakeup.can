  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvChannelUsed as 1"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[1].CanTrcvChannelUsed","1");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[1].CanTrcvChannelUsed",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPinWakeupEnabled variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPinWakeupEnabled as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[1].CanTrcvPinWakeupEnabled","0");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[1].CanTrcvPinWakeupEnabled",0,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvNumberOfChannels variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvNumberOfChannels as 2"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels","2");
  E_DBGR_VariableCheck("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels",2,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();
  
  /***************************************************************************************************************/    
                                              // Test Step 3  Call the function Test_SetHWIO_PowerDown by setting StartPowerDown to 1 then check transceiver is in the SLEEP mode and PMIC to STANDBY mode
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure StartPowerDown variable to invoke Test_SetHWIO_PowerDown interface"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify StartPowerDown is configured as 1"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("StartPowerDown","1");
 // E_DBGR_VariableCheck("StartPowerDown",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Check Trace32 is stopped"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Trace32 is stopped"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_CheckState(T32_State_Down);
  
   /***************************************************************************************************************/    
                                              // Test Step 4 Run the Software and capture UART log using python
  /***************************************************************************************************************/
  
  SysExec("powershell", "-ExecutionPolicy Bypass -File ./serial_logging.ps1", automation_root);
  
  snprintf( chActionText, elCount(chActionText), "waiting for UART log"); 
  snprintf( chExpectedText, elCount(chExpectedText), "waiting for UART log"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_GENERIC_SetTimeout(3000,"waiting for UART log");
 
  
  /***************************************************************************************************************/    
                                              // Test Step 4  This step involves sending a CAN wakeup frame with ID 0x456 and 4 bytes of data from Canoe.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x123"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x123"); 
 // TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(0x446, CANB_Wakeup, 4, 2);
  A_CAN_SendMessage(0x446, CANB_Wakeup, 4, 2);
  
  
//  setTimer(periodicTimer_CAN8,1);
  /***************************************************************************************************************/    
                                              // Test Step 6  Verify Transceiver wakeUp or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01"); 
  //TestStepAddActionExpected( chActionText, chExpectedText ); 
  
  E_CAN_WaitForMessageByID(0x00000101,10000,cc_eCAN_ABSENT,"CAN1");
  
  /***************************************************************************************************************/    
                          // Test Step 7 Check UART log in the Tera Term window is update: Last wakeup event is: 2 (wkupCanBusA).
  /***************************************************************************************************************/ 
  strncpy(searchString,"Last wakeup event is: 4",256);
  
  snprintf( chActionText, elCount(chActionText), "waiting for UART log"); 
  snprintf( chExpectedText, elCount(chExpectedText), "waiting for UART log"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_GENERIC_SetTimeout(25000,"waiting for UART log");
  
  snprintf(chActionText, elCount(chActionText), "Run Python script to check battConnectionStatus in log file");
  snprintf(chExpectedText, elCount(chExpectedText), "Python script should execute successfully");
  result =iFcnt_READFILE_SearchKeywordInFile(teraterm,searchString,"string is present");
  
  if(result == 1)
  {
    testStepFail("0","string is present");
  }
  else
  {
    testSteppass("1","string is not present");
  }
 
  setTimer(periodicTimer_CAN8,1);
  testWaitForTimeout(1000);
  
  cancelTimer(periodicTimer_CAN8);
  testWaitForTimeout(1000);
}

testcase Stress_for_WakeUp_Sleep()
{
    /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 


  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 


  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_MngCNDD_CanTrcvInitialize_interface_for_CAN_Transceiver_Initialization_for_CANA_CAN2" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the MngCNDD_CanTrcvInitialize interface for CAN2 channel");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403647", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  /***************************************************************************************************************/    
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_R();
  A_DBGR_Go();
  /***************************************************************************************************************/    
                                              // Test Step 1 debugger Running
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();
  while(1)
  {
  /***************************************************************************************************************/    
                                              // Test Step 3  Call the function Test_SetHWIO_PowerDown by setting StartPowerDown to 1 then check transceiver is in the SLEEP mode and PMIC to STANDBY mode
  /***************************************************************************************************************/
  if(Stress != 0)
  {
    TestStepAddActionExpected( chActionText, chExpectedText );
  }
  A_GENERIC_SetTimeout(1000,"waiting to move ECU to SLEEP");
  snprintf( chActionText, elCount(chActionText), "ECU is moving to Sleep mode");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU is in sleep mode");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_CAN_WaitForMessageByID(0x00000101,10000,cc_eCAN_ABSENT,"CAN1");

  snprintf( chActionText, elCount(chActionText), "ECU is in sleep mode");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU is in sleep mode");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_CheckState(T32_State_Down);
  /***************************************************************************************************************/    
                                              // Test Step Verify Transceiver is in sleep or not.
  /***************************************************************************************************************/

  /***************************************************************************************************************/    
                                              // Test Step 4  This step involves sending a CAN wakeup frame with ID 0x123 and 8 bytes of data from Canoe.
  /***************************************************************************************************************/
  if(Stress % 2 == 1)
  {
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x123"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x123"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
// setTimer(periodicTimer_CAN2, 1);
  A_CAN_SendMessage(0x123, CANA_Wakeup, 8, 1);
  A_CAN_SendMessage(0x123, CANA_Wakeup, 8, 1);
  }
  else
  {
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x456"); 
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x456"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(0x456, CANB_Wakeup, 4, 2);
  A_CAN_SendMessage(0x456, CANB_Wakeup, 4, 2);
  //testWaitForTimeout(1500);

  }
  /***************************************************************************************************************/    
                                              // Test Step 5  Verify Transceiver wakeUp or not.
  /***************************************************************************************************************/
  snprintf(chActionText, elCount(chActionText), "ECU wakeup Stress Test count %d",Stress);
	snprintf(chExpectedText, elCount(chExpectedText), "ECU is running Stress Test count %d",Stress);
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_CAN_WaitForMessageByID(0x105,10000,cc_eCAN_PRESENT,"CAN1");
  Stress = Stress+1;

  /***************************************************************************************************************/    
                                              // Test Step 1 debugger Running
  /***************************************************************************************************************/

  if(Stress == 50)
  {
    Stress =0;
    break;
  }
  }
}

testcase Stres_Test_Power_Reset()
{
   /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
