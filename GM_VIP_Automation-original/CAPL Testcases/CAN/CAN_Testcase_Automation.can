  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the CntrlCNDD_h_CanWrt interface CAN8 for TX msgs  ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403599", chTestDescription );

  /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

  /***************************************************************************************************************/
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("TestCan_Init");
  A_DBGR_R();
  A_DBGR_Go_Safe();
  /***************************************************************************************************************/
                                              // Test Step 1 Define PDU info and call CntrlCNDD_h_CanWrt with PDU info
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set TestCan_Init");


  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCan_Init function");

  E_DBGR_BreakpointCheckForHalt("TestCan_Init");

  snprintf( chActionText, elCount(chActionText), "Configure CanId values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanId values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsPdu[17].e_e_CAN_ID","0x40000301");
  E_DBGR_VariableCheck("VsPdu[17].e_e_CAN_ID",0x40000301,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanMessageLen values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanMessageLen values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsPdu[17].e_Cnt_Length","64");
  E_DBGR_VariableCheck("VsPdu[17].e_Cnt_Length",64,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure PDU ID ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify PDU ID");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsPdu[17].e_e_PDU_ID","17");
  E_DBGR_VariableCheck("VsPdu[17].e_e_PDU_ID",17,Equal);

   /***************************************************************************************************************/
                                              // Test Step 2 Keep a breakpoint in SetCANR_e_CanIfTxConfirmation and check CAN PDU ID.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Debugger running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Debugger go");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();


  /***************************************************************************************************************/
                                              // Test Step 5 verify canoe trace that msg is transmitted.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101,PDU info:0x01");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101,PDU info:0x01");

  E_CAN_WaitForMessageByID(0x00000301,15000,cc_eCAN_PRESENT,"CAN2");
  TestStepAddActionExpected( chActionText, chExpectedText );
}



