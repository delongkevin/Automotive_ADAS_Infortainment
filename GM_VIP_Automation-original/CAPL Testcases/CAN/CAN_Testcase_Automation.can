testcase Verify_MngCNDD_CanTrcvInitialize_interface_negative_scenario_by_sending_different_CANID_Wakeup_frame_for_CANB_CAN8()
{
  /***************************************************************************************************************/
                                                // Variable Definition
  /***************************************************************************************************************/



  /***************************************************************************************************************/
                                               // Local Values
  /***************************************************************************************************************/



  /***************************************************************************************************************/
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_MngCNDD_CanTrcvInitialize_interface_negative_scenario_by_sending_different_CANID_Wakeup_frame_for_CANB_CAN8" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the MngCNDD_CanTrcvInitialize interface for CAN8 channel");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403650", chTestDescription );

 /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

  /***************************************************************************************************************/
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("TestCanTrcv_Init");
  A_DBGR_BreakpointSet("TestCan_Init");
  A_DBGR_R();
  A_DBGR_Go();
  /***************************************************************************************************************/
                                              // Test Step 1 Call the function MngCNDD_CanTrcvInitialize to initialize the CAN transceiver.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint TestCanTrcv_Init callback function ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in TestCanTrcv_Init");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in TestCanTrcv_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCanTrcv_Init function");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_BreakpointCheckForHalt("TestCanTrcv_Init");

  /***************************************************************************************************************/
                                              // Test Step 2 Configure the values for the structure TsCNDD_CanTrcvCnfgType for CAN2 Channel.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint is Set in TestCan_Init");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCan_Init function");
 // TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_BreakpointCheckForHalt("TestCan_Init");

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMaskIndex variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMaskIndex is configured as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnFrameData1[0].CanTrcvPnFrameDataMaskIndex","0");
  E_DBGR_VariableCheck("VsCANR_PnFrameData1[0].CanTrcvPnFrameDataMaskIndex",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMask variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMask is configured as 1");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnFrameData1[0].CanTrcvPnFrameDataMask","1");
  E_DBGR_VariableCheck("VsCANR_PnFrameData1[0].CanTrcvPnFrameDataMask",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMaskIndex variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMaskIndex is configured as 7");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnFrameData1[7].CanTrcvPnFrameDataMaskIndex","7");
  E_DBGR_VariableCheck("VsCANR_PnFrameData1[7].CanTrcvPnFrameDataMaskIndex",7,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMask variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMask is configured as 8");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnFrameData1[7].CanTrcvPnFrameDataMask","8");
  E_DBGR_VariableCheck("VsCANR_PnFrameData1[7].CanTrcvPnFrameDataMask",8,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameCanId variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameCanId is configured as 0x123");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnFrameCanId","0x123");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnFrameCanId",0x123,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameCanIdMask variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameCanIdMask is configured as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnFrameCanIdMask","0");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnFrameCanIdMask",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameIdType variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameIdType is configured as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnFrameIdType","0");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnFrameIdType",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDlc variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDlc is configured as 8");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnFrameDlc","8");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnFrameDlc",8,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnEnabled variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnEnabled is configured as 1");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[0].CanTrcvPnEnabled","1");
  E_DBGR_VariableCheck("VsCANR_PnConfig[0].CanTrcvPnEnabled",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvChannelId variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvChannelId is configured as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[0].CanTrcvChannelId","0");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[0].CanTrcvChannelId",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvChannelUsed variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvChannelUsed is configured as 1");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[0].CanTrcvChannelUsed","1");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[0].CanTrcvChannelUsed",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPinWakeupEnabled variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPinWakeupEnabled is configured as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[0].CanTrcvPinWakeupEnabled","0");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[0].CanTrcvPinWakeupEnabled",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvNumberOfChannels variable");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvNumberOfChannels is configured as 2");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels","2");
  E_DBGR_VariableCheck("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels",2,Equal);

  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();

  /***************************************************************************************************************/
                                              // Test Step 3  Call the function Test_SetHWIO_PowerDown by setting StartPowerDown to 1 then check transceiver is in the SLEEP mode and PMIC to STANDBY mode
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure StartPowerDown variable to invoke Test_SetHWIO_PowerDown interface");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify StartPowerDown is configured as 1");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("StartPowerDown","1");
 // E_DBGR_VariableCheck("StartPowerDown",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Check Trace32 is stopped");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Trace32 is stopped");
 // TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_CheckState(T32_State_Down);
   /***************************************************************************************************************/
                                              // Test Step Verify Transceiver is in sleep or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01");
  TestStepAddActionExpected( chActionText, chExpectedText );

  E_CAN_WaitForMessageByID(0x00000101,15000,cc_eCAN_ABSENT,"CAN1");

  /***************************************************************************************************************/
                                              // Test Step 4  This step involves sending a CAN wakeup frame with ID 0x123 and 8 bytes of data from Canoe.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x444");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x444");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(0x444, CANA_Wakeup, 8, 2);
  A_CAN_SendMessage(0x444, CANA_Wakeup, 8, 2);

  /***************************************************************************************************************/
                                              // Test Step 5  Verify Transceiver wakeUp or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01");
  //TestStepAddActionExpected( chActionText, chExpectedText );

  E_CAN_WaitForMessageByID(0x00000101,15000,cc_eCAN_ABSENT,"CAN1");

    /***************************************************************************************************************/
                                              // Test Step 6  This step involves sending a CAN wakeup frame with ID 0x123 and 8 bytes of data from Canoe.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x444");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x444");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(0x123, CANA_Wakeup, 8, 1);
  A_CAN_SendMessage(0x123, CANA_Wakeup, 8, 1);
}



