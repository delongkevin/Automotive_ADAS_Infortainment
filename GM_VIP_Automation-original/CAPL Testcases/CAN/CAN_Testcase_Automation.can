//  snprintf( chActionText, elCount(chActionText), "Set voltage to 12 volts ");
//  snprintf( chExpectedText, elCount(chExpectedText), "Voltage is 12");
//  Set_voltage(powersupply_port,12);

  @sysvar::PowGeneral_Variables::VoltageVal = 12000;
  @sysvar::PowGeneral_Variables::ReadVoltage = 1;


  A_GENERIC_SetTimeout(10000,"waiting for power supply change");

  snprintf( chActionText, elCount(chActionText), "Configure CheckCanLoEvent values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CheckCanLoEvent values");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CanTrcv_UvSupCount_0",1,Equal);

}



