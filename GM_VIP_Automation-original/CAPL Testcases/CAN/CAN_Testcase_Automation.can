  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x456,PDU info:0x01");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(0x456, dat_tcno, 0x01, 2);

   /***************************************************************************************************************/
                                              // Test Step 7 Verify SetCANR_h_CanIfRxIndication callback function invoked with relevant CAN_RECEIVE_MSG_INDEX, CAN_PDU_MESSAGE_ID, CAN_PDU_DATA_LENGTH, CAN_PDU_DATA_POINTER.
