  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x401,PDU info:0x01");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(1025, dat_tcno, 0x01, 1);

   /***************************************************************************************************************/
                                              // Test Step 6 Verify SetCANR_h_CanIfRxIndication callback function invoked with relevant CAN_RECEIVE_MSG_INDEX, CAN_PDU_MESSAGE_ID, CAN_PDU_DATA_LENGTH, CAN_PDU_DATA_POINTER.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), " Verify Breakpoint should hit in SetCANR_h_CanIfRxIndication ");
