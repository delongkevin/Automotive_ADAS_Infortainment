  snprintf( chTestTitle, elCount(chTestTitle), "To_verify_MngCNDD_CanRxInit_Interface_that_the_CAN_controller_for_CANA_CAN2_is_initialized_correctly_and_messages_are_transmitted_as_expected" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the RX message intialized of CAN2");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403648", chTestDescription );

  /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

  /***************************************************************************************************************/
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("TestCan_Init");
  A_DBGR_R();
  A_DBGR_Go();
  /***************************************************************************************************************/
                                              // Test Step 1 Configure the values for the structure TsCNDD_CanCnfgType for CANA.
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set TestCan_Init");

  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCan_Init function");

  E_DBGR_BreakpointCheckForHalt("TestCan_Init");

  snprintf( chActionText, elCount(chActionText), "Configure CanId values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanId values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VaCANR_CanRxMsgs[0].CanId","0x40000456");
  E_DBGR_VariableCheck("VaCANR_CanRxMsgs[0].CanId",0x40000456,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanFilterMask values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanFilterMask values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VaCANR_CanRxMsgs[0].CanFilterMask","0x7FF");
  E_DBGR_VariableCheck("VaCANR_CanRxMsgs[0].CanFilterMask",0x7FF,Equal);

   snprintf( chActionText, elCount(chActionText), "Configure CanRxMessageIdx values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanRxMessageIdx values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VaCANR_CanRxMsgs[0].CanRxMessageIdx","0");
  E_DBGR_VariableCheck("VaCANR_CanRxMsgs[0].CanRxMessageIdx",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanMessageLen values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanMessageLen values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VaCANR_CanRxMsgs[0].CanMessageLen","64");
  E_DBGR_VariableCheck("VaCANR_CanRxMsgs[0].CanMessageLen",64,Equal);

   snprintf( chActionText, elCount(chActionText), "Configure CanIdType values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanIdType values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VaCANR_CanRxMsgs[0].CanIdType","2");
  E_DBGR_VariableCheck("VaCANR_CanRxMsgs[0].CanIdType",2,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanControllerId values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanControllerId values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VaCANR_CanRxMsgs[0].CanControllerId","0");
  E_DBGR_VariableCheck("VaCANR_CanRxMsgs[0].CanControllerId",0,Equal);

   /***************************************************************************************************************/
                                              // Test Step 2 Call the function MngCNDD_CanRxInit with the configured structure. MngCNDD_CanRxInit(&canConfigA);
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in MngCNDD_CanRxInit ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set MngCNDD_CanRxInit");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointSet("MngCNDD_CanRxInit");
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in MngCNDD_CanRxInit ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in MngCNDD_CanRxInit function");
  E_DBGR_BreakpointCheckForHalt("MngCNDD_CanRxInit");

 /***************************************************************************************************************/
                                              // Test Step 3 Call SetCNDD_e_CanControllerMode with start mode. SetCNDD_e_CanControllerMode(0, 2); // Start mode for CAN controller 0
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in SetCNDD_e_CanControllerMode funtion ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in SetCNDD_e_CanControllerMode");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("SetCNDD_e_CanControllerMode");
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), " Verify Breakpoint should hit in SetCNDD_e_CanControllerMode ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCNDD_e_CanControllerMode function");
  E_DBGR_BreakpointCheckForHalt("SetCNDD_e_CanControllerMode");

   /***************************************************************************************************************/
                                              // Test Step 4 set Breakpoint in SetCANR_h_CanIfRxIndication.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "set Breakpoint inSetCANR_h_CanIfRxIndication callback function ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in SetCANR_h_CanIfRxIndication");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("SetCANR_h_CanIfRxIndication");
  A_DBGR_Go();
  A_DBGR_Go();

  /***************************************************************************************************************/
                                              // Test Step 5 Verify that the transmitted message with minimum message length using canoe.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x401,PDU info:0x01");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x456,PDU info:0x01");
  A_CAN_SendMessage(0x40000456, dat_64byte, 64, 1,cc_eCAN_FD);
   /***************************************************************************************************************/
                                              // Test Step 6 Verify SetCANR_h_CanIfRxIndication callback function invoked with relevant CAN_RECEIVE_MSG_INDEX, CAN_PDU_MESSAGE_ID, CAN_PDU_DATA_LENGTH, CAN_PDU_DATA_POINTER.
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), " Verify Breakpoint should hit in SetCANR_h_CanIfRxIndication ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCANR_h_CanIfRxIndication function");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_BreakpointCheckForHalt("SetCANR_h_CanIfRxIndication");

  snprintf( chActionText, elCount(chActionText), "verify CanrxmsgIdx");
  snprintf( chExpectedText, elCount(chExpectedText), "CanrxmsgIdx as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CanrxmsgIdx",0,Equal);
  snprintf( chActionText, elCount(chActionText), "Verify CanpdumsgId ");
  snprintf( chExpectedText, elCount(chExpectedText), " CanpdumsgId as 0x40000456");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CanpdumsgId ",0x40000456,Equal);
   snprintf( chActionText, elCount(chActionText), "Verify Canpdudatalength");
  snprintf( chExpectedText, elCount(chExpectedText), "Canpdudatalength as 64");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("Canpdudatalength",64,Equal);
}



