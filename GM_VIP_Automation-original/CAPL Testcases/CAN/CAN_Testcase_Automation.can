  snprintf( chActionText, elCount(chActionText), " Verify Breakpoint should hit in SetCANR_h_CanIfRxIndication ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCANR_h_CanIfRxIndication function");
