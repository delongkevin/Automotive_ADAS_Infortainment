  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("SetCNDD_e_CanControllerMode");
  A_DBGR_R();
  A_DBGR_Go_Safe();

  /***************************************************************************************************************/
                                              // Test Step 1 Call SetCNDD_e_CanControllerMode with stop mode to put CAN controller in invalid mode.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in SetCNDD_e_CanControllerMode ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCNDD_e_CanControllerMode function");

  E_DBGR_BreakpointCheckForHalt("SetCNDD_e_CanControllerMode");

  snprintf( chActionText, elCount(chActionText), "Configure Controller mode");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure Controller mode");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck_until("channelid",1,Equal);
  A_DBGR_VariableSet("can_modetransition","2");
  E_DBGR_VariableCheck("can_modetransition",2,Equal);

  snprintf( chActionText, elCount(chActionText), "Delete all Breakpoints");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Delete all Breakpoints");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();

   /***************************************************************************************************************/
                                              // Test Step 2 Keep a breakpoint in SetCANR_e_CanIfCntrlrModeIndication callback function.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in SetCANR_e_CanIfCntrlrModeIndication ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set SetCANR_e_CanIfCntrlrModeIndication");
  A_DBGR_BreakpointSet("SetCANR_e_CanIfCntrlrModeIndication");  
  snprintf( chActionText, elCount(chActionText), "Run software");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Software is running");
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in SetCANR_e_CanIfCntrlrModeIndication ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCANR_e_CanIfCntrlrModeIndication function");

  E_DBGR_BreakpointCheckForHalt("SetCANR_e_CanIfCntrlrModeIndication");

  cnt = 0;
  while(1)
  {
    if (cnt >= MAX_POLL_ATTEMPTS)
    {
      testStepFail("Timeout", "ChannelId polling exceeded maximum attempts");
      break;
    }
    if(cnt == 0)
    {
      snprintf( chActionText, elCount(chActionText), "Run software");
      snprintf( chExpectedText, elCount(chExpectedText), "verify Software is running");
      TestStepAddActionExpected( chActionText, chExpectedText );
    }
  A_DBGR_Go();

    snprintf( chActionText, elCount(chActionText), "Verify ChannelId ");
    snprintf( chExpectedText, elCount(chExpectedText), " ChannelId as 1");
    A_DBGR_VariableRead("ChannelId",val);
    if (val == 1)
    {
      cnt =0;
      break;
    }
    cnt = cnt +1;
  }
  snprintf( chActionText, elCount(chActionText), "Verify Cancontrollermode");
  snprintf( chExpectedText, elCount(chExpectedText), "Cancontrollermode as 1");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("Cancontrollermode",1,Equal);

  snprintf( chActionText, elCount(chActionText), "ECU in Running state ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify ECU in Running state");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_Go();
  E_DBGR_CheckState(T32_State_Running);

}



