  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the RX message intialized of CAN2 and CAN8");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403601", chTestDescription );

  /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

