  /***************************************************************************************************************/
                                                // Variable Definition
  /***************************************************************************************************************/



  /***************************************************************************************************************/
                                               // Local Values
  /***************************************************************************************************************/



  /***************************************************************************************************************/
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_that_the_GetCNDD_e_CanTrcvSpcfcFlts_function_correctly_reports_multiple_fault_conditions_for_CANA_CAN2" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check GetCNDD_e_CanTrcvSpcfcFlts ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403681", chTestDescription );

  /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

  /***************************************************************************************************************/
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
   snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("TestCantrcv_GetCanTrcvSpcfcFlts\\2");
  A_DBGR_R();
  A_DBGR_Go();

  /***************************************************************************************************************/
                                              // Test Step 1 Call TestCantrcv_GetCanTrcvSpcfcFlts with channel ID as 0
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in TestCantrcv_GetCanTrcvSpcfcFlts\\2 ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set TestCantrcv_GetCanTrcvSpcfcFlts\\2");

  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in TestCantrcv_GetCanTrcvSpcfcFlts\\2 ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCantrcv_GetCanTrcvSpcfcFlts\\2 function");

  E_DBGR_BreakpointCheckForHalt("TestCantrcv_GetCanTrcvSpcfcFlts\\2");

  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  /***************************************************************************************************************/
                                              // Test Step 2 Set CheckCanTrcvSpcFaults value as 1
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Configure CheckCanTrcvSpcFaults values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CheckCanTrcvSpcFaults values");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("CheckCanTrcvSpcFaults","1");

  snprintf( chActionText, elCount(chActionText), "Configure CheckCanTrcvSpcFaults values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CheckCanTrcvSpcFaults values");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CheckCanTrcvSpcFaults",1,Equal);

   /***************************************************************************************************************/
                                              // Test Step 3 Call GetCNDD_e_CanTrcvSpcfcFlts and verify channel ID as 0
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in GetCNDD_e_CanTrcvSpcfcFlts ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set GetCNDD_e_CanTrcvSpcfcFlts");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("GetCNDD_e_CanTrcvSpcfcFlts");

  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in GetCNDD_e_CanTrcvSpcfcFlts ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in GetCNDD_e_CanTrcvSpcfcFlts function");

  E_DBGR_BreakpointCheckForHalt("GetCNDD_e_CanTrcvSpcfcFlts");

  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();

  snprintf( chActionText, elCount(chActionText), "Configure Channel_ID values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure Channel_ID values");
 // TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("Channel_ID","0");
  E_DBGR_VariableCheck("Channel_ID",0,Equal);

  /***************************************************************************************************************/
                                              // Test Step 4 Simulate Multiple Faults
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvFaultStatus[0].trcvSpcfcFlt.uVsupFltSts values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvFaultStatus[0].trcvSpcfcFlt.uVsupFltSts values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("CanTrcvFaultStatus[0].trcvSpcfcFlt.uVccFltSts","1");
  E_DBGR_VariableCheck("CanTrcvFaultStatus[0].trcvSpcfcFlt.uVccFltSts",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvFaultStatus[0].trcvSpcfcFlt.wkErrFltSts values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvFaultStatus[0].trcvSpcfcFlt.wkErrFltSts values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("CanTrcvFaultStatus[0].trcvSpcfcFlt.TXDDOMFltSts","1");
  E_DBGR_VariableCheck("CanTrcvFaultStatus[0].trcvSpcfcFlt.TXDDOMFltSts",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in TestCantrcv_GetCanTrcvSpcfcFlts\\2 ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set TestCantrcv_GetCanTrcvSpcfcFlts\\2");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("TestCantrcv_GetCanTrcvSpcfcFlts\\2");
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in TestCantrcv_GetCanTrcvSpcfcFlts\\2 ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in TestCantrcv_GetCanTrcvSpcfcFlts\\2 function");

  E_DBGR_BreakpointCheckForHalt("TestCantrcv_GetCanTrcvSpcfcFlts\\2");

  /***************************************************************************************************************/
                                              // Test Step 5 verify that value which represents CanTrcv_FaultStatus
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcv_FaultStatus values ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcv_FaultStatus values");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CanTrcv_FaultStatus",9216,Equal);

}



