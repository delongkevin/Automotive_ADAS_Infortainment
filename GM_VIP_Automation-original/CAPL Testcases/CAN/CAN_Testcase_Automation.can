  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the Standard type of CAN2 RX  ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403609", chTestDescription );

  /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

  /***************************************************************************************************************/
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("TestCan_Init");
  A_DBGR_R();
  A_DBGR_Go_Safe();


  /***************************************************************************************************************/
                                              // Test Step 1 Configure the values for the structure TsCNDD_CanCnfgType with the minimum message length for CANA. TsCNDD_CanCntrlrType canControllerA = {0, 1}; // CAN controller ID 0, Enabled TsCNDD_CanRxMessageType canRxMsgsA = { {0x123, 0x7FF, 0, 1, 2, 0} // Standard ID, 1 byte }; TsCNDD_CanCnfgSetType canConfigSetA = {&canControllerA, canRxMsgsA, 1}; TsCNDD_CanCnfgType canConfigA = {&canConfigSetA, 1};
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in TestCan_Init ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set TestCan_Init");

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in TestCan_Init ");
