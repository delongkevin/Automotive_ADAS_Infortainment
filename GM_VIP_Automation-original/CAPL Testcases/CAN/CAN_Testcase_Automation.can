//  snprintf( chExpectedText, elCount(chExpectedText), "waiting for TX Buf");
//  A_GENERIC_SetTimeout(25000,"waiting for TX Buf ");

  snprintf( chActionText, elCount(chActionText), "Read CAN_1_TX_BUFFER_MAX_LEVEL for GetCNDD_Cnt_CanTxBufMax");
  snprintf( chExpectedText, elCount(chExpectedText), "verify CAN_1_TX_BUFFER_MAX_LEVEL for GetCNDD_Cnt_CanTxBufMax");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CAN_1_TX_BUFFER_MAX_LEVEL",0,Greater);
}







