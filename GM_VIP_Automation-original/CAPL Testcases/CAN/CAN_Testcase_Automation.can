  E_DBGR_VariableCheck("VsCANR_PnFrameData2[1].CanTrcvPnFrameDataMask",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameCanId variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPnFrameCanId as 0x456");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[1].CanTrcvPnFrameCanId","0x456");
  E_DBGR_VariableCheck("VsCANR_PnConfig[1].CanTrcvPnFrameCanId",0x456,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameCanIdMask variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPnFrameCanIdMask as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[1].CanTrcvPnFrameCanIdMask","0");
  E_DBGR_VariableCheck("VsCANR_PnConfig[1].CanTrcvPnFrameCanIdMask",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameIdType variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPnFrameIdType as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[1].CanTrcvPnFrameIdType","0");
  E_DBGR_VariableCheck("VsCANR_PnConfig[1].CanTrcvPnFrameIdType",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDlc variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPnFrameDlc as 4");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[1].CanTrcvPnFrameDlc","4");
  E_DBGR_VariableCheck("VsCANR_PnConfig[1].CanTrcvPnFrameDlc",4,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnEnabled variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPnEnabled as 1");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_PnConfig[1].CanTrcvPnEnabled","1");
  E_DBGR_VariableCheck("VsCANR_PnConfig[1].CanTrcvPnEnabled",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvChannelId variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvChannelId as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[1].CanTrcvChannelId","1");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[1].CanTrcvChannelId",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvChannelUsed variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvChannelUsed as 1");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[1].CanTrcvChannelUsed","1");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[1].CanTrcvChannelUsed",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPinWakeupEnabled variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvPinWakeupEnabled as 0");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_TrcvChannels[1].CanTrcvPinWakeupEnabled","0");
  E_DBGR_VariableCheck("VsCANR_TrcvChannels[1].CanTrcvPinWakeupEnabled",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvNumberOfChannels variable");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure CanTrcvNumberOfChannels as 2");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels","2");
  E_DBGR_VariableCheck("VsCANR_CanTrcvConfig.CanTrcvNumberOfChannels",2,Equal);

  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();

  /***************************************************************************************************************/
                                              // Test Step 3  Call the function Test_SetHWIO_PowerDown by setting StartPowerDown to 1 then check transceiver is in the SLEEP mode and PMIC to STANDBY mode
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure StartPowerDown variable to invoke Test_SetHWIO_PowerDown interface");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify StartPowerDown is configured as 1");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("StartPowerDown","1");
 // E_DBGR_VariableCheck("StartPowerDown",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Check Trace32 is stopped");
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Trace32 is stopped");
 // TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_CheckState(T32_State_Down);
  /***************************************************************************************************************/
                                              // Test Step Verify Transceiver is in sleep or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01");
  TestStepAddActionExpected( chActionText, chExpectedText );

  E_CAN_WaitForMessageByID(0x00000101,15000,cc_eCAN_ABSENT,"CAN1");
  /***************************************************************************************************************/
                                              // Test Step 4  This step involves sending a CAN wakeup frame with ID 0x456 and 4 bytes of data from Canoe.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x123");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x123");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_CAN_SendMessage(0x456, CANB_Wakeup, 4, 2);
  A_CAN_SendMessage(0x456, CANB_Wakeup, 4, 2);

  /***************************************************************************************************************/
                                              // Test Step 5  Verify Transceiver wakeUp or not.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Transmit CAN message. ID:0x40000101, PDU info:0x01");
  snprintf( chExpectedText, elCount(chExpectedText), "CAN message transmitted. ID:0x40000101, PDU info:0x01");
  //TestStepAddActionExpected( chActionText, chExpectedText );

  E_CAN_WaitForMessageByID(0x00000102,15000,cc_eCAN_PRESENT,"CAN2");
}

testcase Verify_MngCNDD_CanTrcvMain_interface_Functionality_for_CANB_CAN8()
{
  /***************************************************************************************************************/
                                                // Variable Definition
  /***************************************************************************************************************/



  /***************************************************************************************************************/
                                               // Local Values
  /***************************************************************************************************************/



  /***************************************************************************************************************/
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_MngCNDD_CanTrcvMain_interface_Functionality_for_CANB_CAN8" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the interface MngCNDD_CanTrcvMain for CAN8 ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36403709", chTestDescription );

  /***************************************************************************************************************/
                                              // Start of Test Case
  /***************************************************************************************************************/

   /***************************************************************************************************************/
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("SetCNDD_e_CanTrcvOpMode");
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state");
  A_DBGR_R();
  A_DBGR_Go();
  /***************************************************************************************************************/
                                              // Test Step 1 Call SetCNDD_e_CanTrcvOpMode with stop mode to put CAN controller in normal mode.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in SetCNDD_e_CanTrcvOpMode ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set SetCNDD_e_CanTrcvOpMode");

  A_DBGR_Go();
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in SetCNDD_e_CanTrcvOpMode ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCNDD_e_CanTrcvOpMode function");

  E_DBGR_BreakpointCheckForHalt("SetCNDD_e_CanTrcvOpMode");

  snprintf( chActionText, elCount(chActionText), "Configure Transciver mode");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure Transciver mode");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("can_trcv_mode","0");
  E_DBGR_VariableCheck("can_trcv_mode",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Delete all Breakpoints");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Delete all Breakpoints");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("MngCNDD_CanTrcvMain");

  /***************************************************************************************************************/
                                              // Test Step 2 Call MngCNDD_CanTrcvMain function in a periodic 5ms or 10ms task. This step involves setting up a periodic task to call MngCNDD_CanTrcvMain every 5ms or 10ms.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in MngCNDD_CanTrcvMain ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set MngCNDD_CanTrcvMain");

  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in MngCNDD_CanTrcvMain ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in MngCNDD_CanTrcvMain function");

  E_DBGR_BreakpointCheckForHalt("MngCNDD_CanTrcvMain");

   snprintf( chActionText, elCount(chActionText), "Delete all Breakpoints");
  snprintf( chExpectedText, elCount(chExpectedText), "verify Delete all Breakpoints");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_BreakpointSet("SetCANR_e_CanIfTrcvModeIndication");
   /***************************************************************************************************************/
                                              // Test Step 3 Keep a breakpoint in SetCANR_e_CanIfTrcvModeIndication callback function.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in SetCANR_e_CanIfTrcvModeIndication ");
  snprintf( chExpectedText, elCount(chExpectedText), "verify is Breakpoint Set SetCANR_e_CanIfTrcvModeIndication");
  //TestStepAddActionExpected( chActionText, chExpectedText );

  snprintf( chActionText, elCount(chActionText), "ECU Running ");
  snprintf( chExpectedText, elCount(chExpectedText), " ECU Running");
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "verify Breakpoint should hit in SetCANR_e_CanIfTrcvModeIndication ");
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in SetCANR_e_CanIfTrcvModeIndication function");
  E_DBGR_BreakpointCheckForHalt("SetCANR_e_CanIfTrcvModeIndication");

  E_DBGR_VariableCheck_until("channelid",1,Equal);



  snprintf( chActionText, elCount(chActionText), "Verify TranscMode");
  snprintf( chExpectedText, elCount(chExpectedText), "TranscMode as 0");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("Cantrcvmode",0,Equal);

  snprintf( chActionText, elCount(chActionText), "Delete BP's");
  snprintf( chExpectedText, elCount(chExpectedText), " BP's Deleted");
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();

  snprintf( chActionText, elCount(chActionText), "ECU Running ");
  snprintf( chExpectedText, elCount(chExpectedText), " ECU Running");
  //TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "ECU Running ");
  snprintf( chExpectedText, elCount(chExpectedText), " ECU Running");
  E_DBGR_CheckState(T32_State_Running);
}



