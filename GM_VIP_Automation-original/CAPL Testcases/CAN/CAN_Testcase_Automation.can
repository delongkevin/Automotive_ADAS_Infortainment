  snprintf( chActionText, elCount(chActionText), "Verify CanpdumsgId ");
  snprintf( chExpectedText, elCount(chExpectedText), " CanpdumsgId as 0x456");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("CanpdumsgId ",0x456,Equal);
   snprintf( chActionText, elCount(chActionText), "Verify Canpdudatalength");
  snprintf( chExpectedText, elCount(chExpectedText), "Canpdudatalength as 1");
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("Canpdudatalength",1,Equal);

  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running ");
  snprintf( chExpectedText, elCount(chExpectedText), "Ecu is should be in running state");
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();


  A_DBGR_Go();

  snprintf( chActionText, elCount(chActionText), "set Breakpoint inSetCANR_h_CanIfRxIndication callback function ");
