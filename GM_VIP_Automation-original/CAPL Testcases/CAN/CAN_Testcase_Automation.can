 /***************************************************************************************************************/
                                              // Test Step 3 Call SetCNDD_e_CanControllerMode with start mode. SetCNDD_e_CanControllerMode(0, 2); // Start mode for CAN controller 0
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint in SetCNDD_e_CanControllerMode funtion ");
