testcase Testcase_Verify_BINVDM_Initial_Read_Status()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_Verify_BINVDM_Initial_Read_Status" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:The software shall set the BINVDM read status to Idle during Reset Initialization until an operation is requested.");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_QT_36619138", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  
  /*******************************************************************************************************************************************************/    
    // Test Step 3: Set a breakpoint at "TstReadstatus = ( Binvdmreadstatus )GetHWIO_e_BatNonVltlReadSt();" inside "BYTE TestBinvdm_ReadGetStatus( void )" in test_binvdm_hwio.c and run the application
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at TstReadstatus = ( Binvdmreadstatus )GetHWIO_e_BatNonVltlReadSt(); inside BYTE TestBinvdm_ReadGetStatus( void ) in test_binvdm_hwio.c and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("TestBinvdm_ReadGetStatus\\3");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("TestBinvdm_ReadGetStatus\\3");
    
  /*******************************************************************************************************************************************************/    
    // Test Step 4: Verify TstReadstatus value in trace32 watch window
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Verify TstReadstatus value in trace32 watch window"); 
  snprintf( chExpectedText, elCount(chExpectedText), "TstReadstatus = BINVDM_READ_IDLE"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("TstReadstatus",0,Equal);
}

testcase Testcase_Verify_Default_Read_Status_Until_Operation_Completion_in_Blocking_Mode()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  long taskvalue;
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 

  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_Verify_Default_Read_Status_Until_Operation_Completion_in_Blocking_Mode" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:The software shall return the BINVDM Read status as InProgress from the time of the read request operation until Completed, MemoryError or Canceled statuses have been determined.");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_QT_36728636", chTestDescription );
  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  
  
  
    
   
  /*******************************************************************************************************************************************************/    
    // Test Step 2: Set a breakpoint at "TstReadstatus = ( Binvdmreadstatus )ReadHWIO_h_BatNonVltl( BLOCKING_MODE, &binvdmaddr, 72U, ( BYTE *)&Nvmdataread );" and run the application
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at TstReadstatus = ( Binvdmreadstatus )ReadHWIO_h_BatNonVltl( BLOCKING_MODE, &binvdmaddr, 72U, ( BYTE *)&Nvmdataread ); and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("TestBinvdm_NonblockingRead\\5");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("TestBinvdm_NonblockingRead\\5");
 
   /*******************************************************************************************************************************************************/    
    // Test Step 3: Set a breakpoint at "TstReadstatus = ( Binvdmreadstatus )ReadHWIO_h_BatNonVltl( BLOCKING_MODE, &binvdmaddr, 72U, ( BYTE *)&Nvmdataread );" and run the application
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set binvdmreadrequest = TRUE in trace32 watch window"); 
  snprintf( chExpectedText, elCount(chExpectedText), "binvdmreadrequest = TRUE"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("binvdmreadrequest", "1"); 
  E_DBGR_VariableCheck("binvdmreadrequest",1,Equal);
  
   /*******************************************************************************************************************************************************/    
    // Test Step 4: Set a breakpoint at "if( BINVDM_BLOCKING_MODE == binvdmSchmode )
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at return( ( BYTE )Readstatus ); and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("ReadHWIO_h_BatNonVltl\\14");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("ReadHWIO_h_BatNonVltl\\14");
  
  
  snprintf( chActionText, elCount(chActionText), "Set binvdmSchmode = 0 in trace32 watch window"); 
  snprintf( chExpectedText, elCount(chExpectedText), "binvdmSchmode = 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("binvdmSchmode", "0"); 
  E_DBGR_VariableCheck("binvdmSchmode",0,Equal);
   /*******************************************************************************************************************************************************/    
    // Test Step 5: Set a breakpoint at "ret = MemAcc_Read( Address_Instance, ( Targetaddr - BINVDM_DFLASH_PHY_START_ADDR ), binvdmramaddr,\

  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), " 1 - set run"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("ReadHWIO_h_BatNonVltl\\32");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("ReadHWIO_h_BatNonVltl\\32");
  
  
   /*******************************************************************************************************************************************************/    
    // Test Step 6: check Readstatus = BINVDM_READ_INPROGRESS
  /*******************************************************************************************************************************************************/
  
  
  snprintf( chActionText, elCount(chActionText), " complete state "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("ReadHWIO_h_BatNonVltl\\124");  
  A_DBGR_Go();
   A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("ReadHWIO_h_BatNonVltl\\124");
  
  snprintf( chActionText, elCount(chActionText), "Verify Readstatus  value in trace32 watch window"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Readstatus = BINVDM_READ_INPROGRESS"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("Readstatus",2,Equal);
 /*******************************************************************************************************************************************************/    
    // Test Step 7:check  Readstatus = BINVDM_READ_IDLE
  /*******************************************************************************************************************************************************/
  
//  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at TstReadstatus = ( Binvdmreadstatus )GetHWIO_e_BatNonVltlReadSt(); inside BYTE TestBinvdm_ReadGetStatus( void ) in test_binvdm_hwio.c and run the application"); 
//  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
//  TestStepAddActionExpected( chActionText, chExpectedText );
//  //A_DBGR_R();
//  A_DBGR_BreakpointSet("TestBinvdm_NonblockingRead\\5");  
//  A_DBGR_Go();
//  E_DBGR_BreakpointCheckForHalt("TestBinvdm_NonblockingRead\\5");
  
  
//  snprintf( chActionText, elCount(chActionText), "Verify TstReadstatus value in trace32 watch window"); 
//  snprintf( chExpectedText, elCount(chExpectedText), "Readstatus = BINVDM_READ_IDLE"); 
//  TestStepAddActionExpected( chActionText, chExpectedText );
//  E_DBGR_VariableCheck("Readstatus",0,Equal);  
 
}


