testcase Testcase_Verify_Successful_Read_Operation_Status_in_Blocking_Mode()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  long taskvalue;
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 

  /***************************************************************************************************************/    
