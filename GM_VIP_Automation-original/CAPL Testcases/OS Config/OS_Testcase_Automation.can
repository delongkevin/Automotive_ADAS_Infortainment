  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core4 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core4 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
