/***************************************************************************************************
----------------------------------------------------------------------------------------------------
Test case name:  TC_L30SW_Q-36651093: Testcase to verify the functionality of interface GetHWIO_b_CPU_St to check the status after disabling CPU1
----------------------------------------------------------------------------------------------------
Description:   test case to verify the functionality of interface GetHWIO_b_CPU_St to check the status after disabling CPU1

***************************************************************************************************/
testcase Testcase_to_verify_the_functionality_of_interface_GetHWIO_b_CPU_St_to_check_the_status_after_disabling_CPU1()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
