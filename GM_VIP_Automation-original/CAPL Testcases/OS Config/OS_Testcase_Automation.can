  snprintf( chExpectedText, elCount(chExpectedText), "Verify CpuUtilizatio  variable in funtion Os_Test_GetHWIO_Pct_CPU_Utilization() "); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "CpuUtilization", taskvalue);
  E_DBGR_VariableCheck("FlagCore_OS_3", 1, Equal);
  
  
  CPUUtilization_after_delay=taskvalue*(0.003051);
  write("CPUUtilization_after_delay for core3 is %f",CPUUtilization_after_delay);
  
  
  if(CPUUtilization_after_delay > CPUUtilization_before_delay)
  {
    CPUUtilization = CPUUtilization_after_delay - CPUUtilization_before_delay;
    testStepPass("","CpuUtilization for Core3 is %f",CPUUtilization);
  }
  else
  {
    CPUUtilization = CPUUtilization_after_delay - CPUUtilization_before_delay;
    testStepFail("","CpuUtilization fore Core3 is %f",CPUUtilization);
  }
  
  
  /*******************************************************************************************************************************************************/    
    // Test Step 7: Remove dealy in Core3 by setting FlagCore_OS_3=0
  /*******************************************************************************************************************************************************/ 
  
