  snprintf( chTestDescription, elCount(chTestDescription), "Purpose: test_case_to_verify_the_functionality_of_interface_DsblHWIO_Interrupt_to_prohibits_all_interrupts_from_pre_empting_the_core3_task_and_interrupt__for_CPU3.");
