  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead("CpuUtilization", taskvalue);
  E_DBGR_VariableCheck("CPU_Utilization_Core0", 1, Equal);
    
  CPUUtilization_before_delay=taskvalue*(0.003051);
  write("CPUUtilization_before_delay is %f",CPUUtilization_before_delay);
  
  /******************************************************************************************************************************************************/ 
 // Test Step 5: Set dealy in Core0 by setting FlagCore_OS_0=1
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Set dealy in Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "check dealy in Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("FlagCore_OS_0", "1");
  E_DBGR_VariableCheck("FlagCore_OS_0", 1, Equal);
  
  /******************************************************************************************************************************************************/    
    // Test Step 6: Read CpuUtilization for Core 0 after delay
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Call funtion Os_Test_GetHWIO_Pct_CPU_Utilization() "); 
  snprintf( chExpectedText, elCount(chExpectedText), "After delay verify CpuUtilization  variable in funtion Os_Test_GetHWIO_Pct_CPU_Utilization() "); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "CpuUtilization", taskvalue);
  E_DBGR_VariableCheck("FlagCore_OS_0", 1, Equal);
  
  
  CPUUtilization_after_delay=taskvalue*(0.003051);
  write("CPUUtilization_after_delay is %f",CPUUtilization_after_delay);
  
  
  if(CPUUtilization_after_delay > CPUUtilization_before_delay)
  {
    CPUUtilization = CPUUtilization_after_delay - CPUUtilization_before_delay;
    testStepPass("","CpuUtilization is %f",CPUUtilization);
  }
  else
  {
    CPUUtilization = CPUUtilization_after_delay - CPUUtilization_before_delay;
    testStepFail("","CpuUtilization is %f",CPUUtilization);
  }

  
  /*******************************************************************************************************************************************************/    
    // Test Step 7: Remove dealy in Core0 by setting FlagCore_OS_0=0
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Remove dealy in Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Remove dealy in Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("FlagCore_OS_0", "0");
  E_DBGR_VariableCheck("FlagCore_OS_0", 0, Equal);
  
  /*******************************************************************************************************************************************************/    
    // Test Step 8: Set CPU_Utilization_Core0=0 for Core0
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Set CPU_Utilization_Core0=0 for Core0"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Set CPU_Utilization_Core0=0 for Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("CPU_Utilization_Core0", "0");
  E_DBGR_VariableCheck("CPU_Utilization_Core0", 0, Equal);

}

