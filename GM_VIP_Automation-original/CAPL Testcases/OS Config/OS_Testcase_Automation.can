Description:   Test case to verify the functionality of interface EnblHWIO_GM_TaskInits to Allows application defined RTOS tasks and ISRs to receive their event triggers on the CPU4

***************************************************************************************************/
testcase Testcase_to_verify_interface_EnblHWIO_GM_TaskInits_to_Allow_application_RTOS_tasks_and_ISRs_to_receive_event_triggers_on_CPU4()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
