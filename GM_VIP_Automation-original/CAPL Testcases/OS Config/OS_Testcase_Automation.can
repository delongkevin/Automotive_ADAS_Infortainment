Test case name:  TC_L30SW_Q-36684462: Testcase_to_verify_interface_EnblHWIO_GM_TaskInits_to_Allow_application_RTOS_tasks_and_ISRs_to_receive_event_triggers_on_CPU3.
----------------------------------------------------------------------------------------------------
Description:   Test case to verify the functionality of interface EnblHWIO_GM_TaskInits to Allows application defined RTOS tasks and ISRs to receive their event triggers on the CPU3.

***************************************************************************************************/
testcase Testcase_to_verify_interface_EnblHWIO_GM_TaskInits_to_Allow_application_RTOS_tasks_and_ISRs_to_receive_event_triggers_on_CPU3()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_to_verify_interface_EnblHWIO_GM_TaskInits_to_Allow_application_RTOS_tasks_and_ISRs_to_receive_event_triggers_on_CPU3" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose: Test case to verify the functionality of interface EnblHWIO_GM_TaskInits to Allows application defined RTOS tasks and ISRs to receive their event triggers on the CPU3.");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36684462", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  

   /***************************************************************************************************************/    
            // Test Step 2: Check all cores are in running state                                   
  /***************************************************************************************************************/
  
  //Check Core0 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core0 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core0_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core0_1000ms_Count", taskvalue, Greater);
  
  //Check Core1 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core1 "); 
