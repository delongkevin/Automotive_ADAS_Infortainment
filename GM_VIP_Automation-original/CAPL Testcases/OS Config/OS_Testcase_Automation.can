----------------------------------------------------------------------------------------------------
Test case name:  TC_L30SW_Q-36649772: Test case to verify the functinality of interface DsblHWIO_CPU for disabling the CPU3
----------------------------------------------------------------------------------------------------
Description:   Test case to verify the functionality of interface DsblHWIO_CPU for disabling the CPU3.

***************************************************************************************************/
testcase Testcase_to_verify_the_functionality_of_interface_DsblHWIO_CPU_for_disabling_the_CPU2()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  ;
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_to_verify_the_functionality_of_interface_DsblHWIO_CPU_for_disabling_the_CPU2." );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose: Test case to verify the functionality of interface DsblHWIO_CPU for disabling the CPU2");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36649772", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  

   /***************************************************************************************************************/    
                      // Test Step 2 
                     // Check all cores are in running state
                    // stub Code to Check ISR Counter incrementing 
