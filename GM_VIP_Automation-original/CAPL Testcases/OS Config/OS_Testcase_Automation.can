  A_DBGR_VariableRead( "CpuUtilization", taskvalue);
  E_DBGR_VariableCheck("CPU_Utilization_Core3", 1, Equal);
  
  CPUUtilization_before_delay=taskvalue*(0.003051);
  write("CPUUtilization_before_delay fore core3 is %f",CPUUtilization_before_delay);
  
    /******************************************************************************************************************************************************/ 
 // Test Step 5: Set dealy in Core3 by setting FlagCore_OS_3=1
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Set dealy in Core3 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "check dealy in Core3"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
