  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core5 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core5_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core5_1000ms_Count", taskvalue, Greater);
  
   /*******************************************************************************************************************************************************/    
    // Test Step 3: Set TaskExecution_Core0 for Core0
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Set TaskExecution_Core0 for Core0"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Set TaskExecution_Core0 for Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("TaskExecution_Core0", "1");
  E_DBGR_VariableCheck("TaskExecution_Core0", 1, Equal);
  
  /******************************************************************************************************************************************************/    
    // Test Step 4: Read exectiontime for Core 0
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Call funtion Os_Test_GetHWIO_t_OS_TaskExecution() "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify exectiontime  variable in funtion Os_Test_GetHWIO_t_OS_TaskExecution() "); 
  TestStepAddActionExpected( chActionText, chExpectedText );
   A_DBGR_VariableRead( "exectiontime", taskvalue);
   E_DBGR_VariableCheck("TaskExecution_Core0", 1, Equal);
  
  execution_time_before_delay=taskvalue*(0.007812);
  write("execution_time_before_delay for Core 0 is %f",execution_time_before_delay);
  
    /******************************************************************************************************************************************************/ 
 // Test Step 5: Set dealy in Core0 by setting FlagCore0_Task__1000ms=1
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Set dealy in Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "check dealy in Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("FlagCore0_Task__1000ms", "1");
  E_DBGR_VariableCheck("FlagCore0_Task__1000ms", 1, Equal);
  testWaitForTimeout(1000);
  
  /******************************************************************************************************************************************************/    
    // Test Step 6: Read exectiontime for Core 0
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Call funtion Os_Test_GetHWIO_t_OS_TaskExecution() "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify exectiontime  variable in funtion Os_Test_GetHWIO_t_OS_TaskExecution() "); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "exectiontime", taskvalue);
  E_DBGR_VariableCheck("FlagCore0_Task__1000ms", 1, Equal);
  
  execution_time_after_delay=taskvalue*(0.007812);
  write("execution_time_after_delay for Core0 is %f",execution_time_after_delay);
  
  
   if(execution_time_after_delay > execution_time_before_delay)
  {
    execution_time = execution_time_after_delay - execution_time_before_delay;
    testStepPass("","execution_time for Core0 is %f",execution_time);
  }
  else
  {
    execution_time = execution_time_after_delay - execution_time_before_delay;
    testStepFail("","execution_time for Core0 is %f",execution_time);
  }
  
  /*******************************************************************************************************************************************************/    
    // Test Step 7: Remove dealy in Core0 by setting FlagCore0_Task__1000ms=0
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Remove dealy in Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Remove dealy in Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("FlagCore0_Task__1000ms", "0");
  E_DBGR_VariableCheck("FlagCore0_Task__1000ms", 0, Equal);
  
  /*******************************************************************************************************************************************************/    
    // Test Step 8: Set CPU_Utilization_Core0=0 for Core0
  /*******************************************************************************************************************************************************/ 
  
  snprintf( chActionText, elCount(chActionText), "Set TaskExecution_Core0=0 for Core0"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Set TaskExecution_Core0=0 for Core0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("TaskExecution_Core0", "0");
  E_DBGR_VariableCheck("TaskExecution_Core0", 0, Equal);

}

