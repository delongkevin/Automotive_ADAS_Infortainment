  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core2_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core2_1000ms_Count", taskvalue, Greater);
    
  //Check Core3 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core3 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core3 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core3_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core3_1000ms_Count", taskvalue, Greater);
    
