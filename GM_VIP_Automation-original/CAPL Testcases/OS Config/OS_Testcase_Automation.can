----------------------------------------------------------------------------------------------------
Description:   Test case to verify the functionality of interface DsblHWIO_CPU for disabling the CPU0.

***************************************************************************************************/
testcase Testcase_to_verify_the_functionality_of_interface_DsblHWIO_CPU_for_disabling_the_CPU0()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
