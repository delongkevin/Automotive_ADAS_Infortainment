----------------------------------------------------------------------------------------------------
Test case name:  TC_L30SW_Q-36684437: Testcase_to_verify_the_functionality_of_interface_DsblHWIO_GM_TaskInits_to_prohibits_all_application_defined_RTOS_tasks_and_application_ISRs_from_pre_empting_the_current_task_or_ISR_on_the_CPU1.
----------------------------------------------------------------------------------------------------
Description:   Test case to verify the functionality of interface GetHWIO_e_CPU() to check the ActiveCPU_ID for currently executing CPU1.

***************************************************************************************************/
testcase Testcase_to_verify_DsblHWIO_GM_TaskInits_to_prohibits_all_RTOS_tasks_and_ISRs_from_preempting_current_task_or_ISR_on_the_CPU2()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
