  A_DBGR_VariableRead( "Task_Core5_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core5_1000ms_Count", taskvalue, Greater);
  
  /***************************************************************************************************************/    
    // Test Step 3 Disable All Task using interface DisableHWIO_AllTasks() & Check Tasks from each Core is stopped
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Disable core 0 tasks"); 
  snprintf( chExpectedText, elCount(chExpectedText), "core 0 disabled"); 
