  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in Test_GetHWIO_e_BusStatus"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );   
  A_DBGR_BreakpointSet("Test_GetHWIO_e_BusStatus\\11");  
  
//   /***************************************************************************************************************/    
//                                              // Test Step 5 Run the debugger
//  /***************************************************************************************************************/
 
//  A_DBGR_Go();
  
   /***************************************************************************************************************/    
                                              // Test Step 3 Wait for the breakpoint to hit
  /***************************************************************************************************************/
 
  
  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in Test_GetHWIO_e_BusStatus "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in Test_GetHWIO_e_BusStatus function"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );  
  E_DBGR_BreakpointCheckForHalt("Test_GetHWIO_e_BusStatus\\11");
  
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMaskIndex variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMaskIndex is configured as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("INTERNAL_BUS_STATUS",3,Smaller);
  
}

