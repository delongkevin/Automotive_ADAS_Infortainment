testcase Verify_default_value_of_INTERNAL_BUS_STATUS_parameter()
{
   /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Verify_default_value_of_INTERNAL_BUS_STATUS_parameter" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To check the GetHWIO_e_BusStatus interface ");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36629478", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 0 PRECONDITIONS
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
 
  A_DBGR_R();
  A_DBGR_Go();
  /***************************************************************************************************************/    
                                              // Test Step 1 	Set a breakpoint at line INTERNAL_BUS_STATUS = GetHWIO_e_BusStatus(void); inside function void Test_GetHWIO_e_BusStatus(void).
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint Test_GetHWIO_e_BusStatus callback function "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in Test_GetHWIO_e_BusStatus"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );   
  A_DBGR_BreakpointSet("Test_GetHWIO_e_BusStatus\\5");  
  
   /***************************************************************************************************************/    
                                              // Test Step 2 Run the debugger
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Run the software "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  A_DBGR_Go();
  
   /***************************************************************************************************************/    
                                              // Test Step 3 Wait for the breakpoint to hit
  /***************************************************************************************************************/
 
  
  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in Test_GetHWIO_e_BusStatus "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in Test_GetHWIO_e_BusStatus function"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );  
  E_DBGR_BreakpointCheckForHalt("Test_GetHWIO_e_BusStatus\\5");
  
  /***************************************************************************************************************/    
                                              // Test Step 3 verify INTERNAL_BUS_STATUS is having 2.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure CanTrcvPnFrameDataMaskIndex variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify CanTrcvPnFrameDataMaskIndex is configured as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("INTERNAL_BUS_STATUS",2,Equal);
}

