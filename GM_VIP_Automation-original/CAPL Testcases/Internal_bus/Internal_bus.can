  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
 
  A_DBGR_R();
  
  A_DBGR_Go();
  /***************************************************************************************************************/    
                                              // Test Step 2 Set a breakpoint at line TestCanTrcv_Getmode(void); in OS_Tasks.c file
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint Os_Entry_Task_Core0_5ms\\13 callback function "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in Os_Entry_Task_Core0_5ms\\13"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );   
  A_DBGR_BreakpointSet("Os_Entry_Task_Core0_5ms\\13");  
  
  
   /***************************************************************************************************************/    
                                              // Test Step 3 Run the debugger
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Run the software "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  A_DBGR_Go();
  
   /***************************************************************************************************************/    
                                              // Test Step 4 Wait for the breakpoint to hit
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in Os_Entry_Task_Core0_5ms\\13 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in Os_Entry_Task_Core0_5ms\\13 function"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );  
  E_DBGR_BreakpointCheckForHalt("Os_Entry_Task_Core0_5ms\\13");
  
   snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  /***************************************************************************************************************/    
                                              // Test Step 5 MCALUTIL_SFRWRITE(SPI_HW_MODULE[KernelId].MC.U, ((uint32)TransferCount<<IFX_QSPI_MC_MCOUNT_OFF));
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint Spi_lQspiHWSetJobConfig\\18 callback function "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in Spi_lQspiHWSetJobConfig\\18"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );   
