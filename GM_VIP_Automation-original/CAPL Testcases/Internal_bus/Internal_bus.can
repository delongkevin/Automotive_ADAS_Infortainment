testcase Verify_GetHWIO_e_BusStatus_function_returns_1_if_Fault_is_present_in_Bus_Network()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
