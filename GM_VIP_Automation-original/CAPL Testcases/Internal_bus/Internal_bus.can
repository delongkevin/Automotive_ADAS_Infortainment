   /***************************************************************************************************************/    
                                              // Test Step 6 Run the debugger
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Run the software "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  A_DBGR_Go();
  
   /***************************************************************************************************************/    
                                              // Test Step 7 Wait for the breakpoint to hit
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Verify Breakpoint should hit in Os_Entry_Task_Core0_5ms\\13 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint hit in Os_Entry_Task_Core0_5ms\\13 function"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );  
  E_DBGR_BreakpointCheckForHalt("Spi_lQspiHWSetJobConfig\\18");
  
  /***************************************************************************************************************/    
                                              // Test Step 8 set TransferCount variable to 5 to inject TxFIFO overflow fault.
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Configure TransferCount variable"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify TransferCount is configured as 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("TransferCount","5");
  E_DBGR_VariableCheck("TransferCount",5,Equal);
  
  
  /***************************************************************************************************************/    
                                              // Test Step 9 Delete all Breakpoints
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  
   /***************************************************************************************************************/    
                                              // Test Step  Set a breakpoint at line INTERNAL_BUS_STATUS = GetHWIO_e_BusStatus(void); 
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Set Breakpoint Test_GetHWIO_e_BusStatus callback function "); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is Set in Test_GetHWIO_e_BusStatus"); 
  //TestStepAddActionExpected( chActionText, chExpectedText );   
  A_DBGR_BreakpointSet("Test_GetHWIO_e_BusStatus\\8");
  
  
  /***************************************************************************************************************/    
                                              // Test Step 10 Run the debugger
  /***************************************************************************************************************/
  snprintf( chActionText, elCount(chActionText), "Run the software "); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  A_DBGR_Go();

  /***************************************************************************************************************/    
