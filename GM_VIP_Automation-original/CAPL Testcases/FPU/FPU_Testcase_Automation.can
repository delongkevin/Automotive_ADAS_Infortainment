----------------------------------------------------------------------------------------------------
Description:   The FP_Config_Inihibit_Reset interface shall, when defined, prevent the Floating-Point Exception Running Reset from occurring.

***************************************************************************************************/
testcase Testcase_Verify_Invalid_Operations_FP_CONFIG_INIHIBIT_RESET_defined_x_NaN_Core0()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_Verify_Invalid_Operations_FP_CONFIG_INIHIBIT_RESET_defined_x_NaN_Core0" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:The FP_Config_Inihibit_Reset interface shall, when defined, prevent the Floating-Point Exception Running Reset from occurring.");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_QT_36425917", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  /*******************************************************************************************************************************************************/    
    // Test Step 1: Configure FPU_Core0 mode
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at Os_Entry_Task_Core0_1000ms and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_R();
  A_DBGR_BreakpointSet("Os_Entry_Task_Core0_1000ms\\2");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Os_Entry_Task_Core0_1000ms\\2");
  
  snprintf( chActionText, elCount(chActionText), "Configure FPU_Core0 mode"); 
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure FPU_Core0 mode"); 
  TestStepAddActionExpected( chActionText, chExpectedText ); 
  A_DBGR_VariableSet("FPU_Core0","1");
  E_DBGR_VariableCheck("FPU_Core0",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at BYTE coreId = GetHWIO_e_CPU(); inside Test_Float(void) function and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("Test_Float\\5");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\5");
 
  /*******************************************************************************************************************************************************/    
    // Test Step 2: Verify the coreId
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Verify the coreId"); 
  snprintf( chExpectedText, elCount(chExpectedText), "coreId is 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("coreId",0,Equal);  
 
  /*******************************************************************************************************************************************************/    
    // Test Step 3: Verify the test_exc_address and test_exc_cnt value
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Verify the test_exc_address and test_exc_cnt value"); 
  snprintf( chExpectedText, elCount(chExpectedText), "test_exc_address is 0 and test_exc_cnt is 0"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead("test_exc_address",test_exc_address_value);  
  E_DBGR_VariableCheck("test_exc_cnt",0,Equal);

  /*******************************************************************************************************************************************************/    
    // Test Step 4: Set a breakpoint at "VeTEST_InvalidOperations1 = VeTEST_DivByZeroNum / VeTEST_FloatSignalingNan.myFloat;" inside Test_Float(void) function.
  /*******************************************************************************************************************************************************/
    
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at if (testflag == 1) inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointSet("Test_Float\\11");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\11");
  
  snprintf( chActionText, elCount(chActionText), "Set testflag = 1"); 
  snprintf( chExpectedText, elCount(chExpectedText), "testflag = 1"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("testflag", "1");  
  E_DBGR_VariableCheck("testflag", 1, Equal);  
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at VeTEST_InvalidOperations1 = VeTEST_DivByZeroNum / VeTEST_FloatSignalingNan.myFloat; inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\13");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\13");  
  
  /*******************************************************************************************************************************************************/    
    // Test Step 5: Set a breakpoint at test_exc_address = GetHWIO_Ptr_FP_Exception(coreId); inside Test_Float(void) function.
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at BYTE coreId = GetHWIO_e_CPU(); inside Test_Float(void) function and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\2");  
  A_DBGR_Go();
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\2");
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at test_exc_address = GetHWIO_Ptr_FP_Exception(coreId);; inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\5");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\5");
  
  /*******************************************************************************************************************************************************/    
    // Test Step 6: Set a breakpoint at test_exc_cnt = GetHWIO_Cnt_FP_Exceptions(coreId); inside Test_Float(void) function.
  /*******************************************************************************************************************************************************/
   
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at test_exc_cnt = GetHWIO_Cnt_FP_Exceptions(coreId); inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\7");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\7");
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at if (testflag == 1) inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\11");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\11"); 
  
  /*******************************************************************************************************************************************************/    
    // Test Step 7: Verify the VeTEST_InvalidOperations1, test_exc_address and test_exc_cnt value
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Verify the test_exc_address and test_exc_cnt value"); 
  snprintf( chExpectedText, elCount(chExpectedText), "test_exc_address is 0xXXXXXXXX and test_exc_cnt is 2"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_Go();
  A_DBGR_VariableRead("VeTEST_InvalidOperations1",VeTEST_InvalidOperations_value_NAN);
  write ("VeTEST_InvalidOperations1 = %ld", VeTEST_InvalidOperations_value_NAN);
  A_DBGR_VariableRead("test_exc_address",test_exc_address_value); 
  write ("test_exc_address = %ld", test_exc_address_value);
  E_DBGR_VariableCheck("test_exc_cnt",2,Equal);
}

