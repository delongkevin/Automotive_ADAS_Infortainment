/***************************************************************************************************
----------------------------------------------------------------------------------------------------
Test case name:  TC_L30SW_QT_36645804: Verify Divide by Zero Scenerio 1
----------------------------------------------------------------------------------------------------
Description:   Verify the software shall be configured to provide result of the format’s largest finite number with the sign of the intermediate result, upon the occurrence of a division by zero exception.

***************************************************************************************************/
testcase Testcase_Verify_Divide_by_Zero_Scenerio_1_Core5()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_Verify_Divide_by_Zero_Scenerio_1_Core5" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:Verify the software shall be configured to provide result of the format’s largest finite number with the sign of the intermediate result, upon the occurrence of a division by zero exception.");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_QT_36645804", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  
  /*******************************************************************************************************************************************************/    
    // Test Step 1: Set a breakpoint at BYTE coreId = GetHWIO_e_CPU(); inside Test_Float(void) function and run the application
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Configure FPU_Core5 mode"); 
  snprintf( chExpectedText, elCount(chExpectedText), "verify Configure FPU_Core5 mode"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("FPU_Core5","1");
  E_DBGR_VariableCheck("FPU_Core5",1,Equal);
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at BYTE coreId = GetHWIO_e_CPU(); inside Test_Float(void) function and run the application"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\2");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\2");
    
  /*******************************************************************************************************************************************************/    
    // Test Step 2: Verify the coreId
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Verify the coreId"); 
  snprintf( chExpectedText, elCount(chExpectedText), "coreId is 5"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("coreId",5,Equal);
  
  /*******************************************************************************************************************************************************/    
    // Test Step 3: Set VeTEST_DivByZeroNum = 5.0f and VeTEST_PosZero = 0.0f
  /*******************************************************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Set VeTEST_DivByZeroNum = 5.0f"); 
  snprintf( chExpectedText, elCount(chExpectedText), "VeTEST_DivByZeroNum = 5.0f"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VeTEST_DivByZeroNum", "5.0");  
  E_DBGR_VariableCheck("VeTEST_DivByZeroNum", 5.0, Equal);
  
  snprintf( chActionText, elCount(chActionText), "Set VeTEST_PosZero = 0.0f"); 
  snprintf( chExpectedText, elCount(chExpectedText), "VeTEST_PosZero = 0.0f"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("VeTEST_PosZero", "0.0");
  E_DBGR_VariableCheck("VeTEST_PosZero", 0.0, Equal);
  
  /*******************************************************************************************************************************************************/    
    // Test Step 4: Set a breakpoint at "VeTEST_DivideByPosZero = VeTEST_DivByZeroNum / VeTEST_PosZero;" inside Test_Float(void) function.
  /*******************************************************************************************************************************************************/
    
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at VeTEST_DivideByPosZero = VeTEST_DivByZeroNum / VeTEST_PosZero; inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float\\10");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float\\10");
  
  snprintf( chActionText, elCount(chActionText), "Set a breakpoint at VeTEST_DivideByPosZero = VeTEST_DivByZeroNum / VeTEST_PosZero; inside Test_Float(void) function."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Breakpoint is set."); 
  TestStepAddActionExpected( chActionText, chExpectedText );  
  A_DBGR_BreakpointSet("Test_Float");  
  A_DBGR_Go();
  E_DBGR_BreakpointCheckForHalt("Test_Float");
  
  /*******************************************************************************************************************************************************/    
    // Test Step 5: Verify the VeTEST_DivideByPosZero value
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Verify the VeTEST_DivideByPosZero value"); 
  snprintf( chExpectedText, elCount(chExpectedText), "VeTEST_DivideByPosZero is 340.28235E36"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  E_DBGR_VariableCheck("VeTEST_DivideByPosZero",340.28235E36,Equal);
}

