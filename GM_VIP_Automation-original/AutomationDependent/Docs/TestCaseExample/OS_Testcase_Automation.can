  /***************************************************************************************************************/    
    // Test Step 3: Disable CPU Core 0 with interface disableCPU[0] = TRUE
  /***************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Disable core 0 tasks"); 
  snprintf( chExpectedText, elCount(chExpectedText), "core 0 disabled"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableSet("disableCpu[1]", "1");
