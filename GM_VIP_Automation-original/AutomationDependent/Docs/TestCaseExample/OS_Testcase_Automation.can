  snprintf( chTestDescription, elCount(chTestDescription), "Purpose: test case to verify the functionality of interface GetHWIO_b_CPU_St to check the status after disabling CPU1");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_QT_36651093", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
