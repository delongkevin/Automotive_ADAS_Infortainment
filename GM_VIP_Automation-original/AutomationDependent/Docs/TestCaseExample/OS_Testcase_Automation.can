  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core2 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core2_1000ms_Count", taskvalue);
