  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_to_verify_the_functionality_of_interface_MngTSKR_e_PreTask_shall_be_triggred_before_the_task_is_invoked_for_CPU0" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purose: Test case to verify the functionality of interface MngTSKR_e_PreTask() shall be triggred before the task is invoked.");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_Q-36542212", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  

   /***************************************************************************************************************/    
            // Test Step 2: Check all cores are in running state                                   
  /***************************************************************************************************************/
  
  //Check Core0 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core0 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core0_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core0_1000ms_Count", taskvalue, Greater);
  
  //Check Core1 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core1 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core1 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core1_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core1_1000ms_Count", taskvalue, Greater);
  
