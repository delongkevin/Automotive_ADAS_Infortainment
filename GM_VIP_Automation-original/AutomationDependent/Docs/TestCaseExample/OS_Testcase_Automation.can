/***************************************************************************************************
----------------------------------------------------------------------------------------------------
Test case name:  TC_L30SW_Q-36651094: Testcase to verify the functionality of interface GetHWIO_b_CPU_St to check the status after disabling CPU0
----------------------------------------------------------------------------------------------------
Description:   test case to verify the functionality of interface GetHWIO_b_CPU_St to check the status after disabling CPU0

***************************************************************************************************/
testcase Testcase_to_verify_the_functionality_of_interface_GetHWIO_b_CPU_St_to_check_the_status_after_disabling_CPU0()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Testcase_to_verify_the_functionality_of_interface_GetHWIO_b_CPU_St_to_check_the_status_after_disabling_CPU0" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose: test case to verify the functionality of interface GetHWIO_b_CPU_St to check the status after disabling CPU0");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_QT_36651094", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo();
  E_DBGR_CheckState(T32_State_Running);
  

   /***************************************************************************************************************/    
                      // Test Step 2 Check all cores are in running state      
					 // Check cpuState for all Cores = CPU_Enabled
                                     
  /***************************************************************************************************************/
  
  //Check Core0 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core0 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core0 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core0_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core0_1000ms_Count", taskvalue, Greater);
  
  //Check Core1 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core1 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core1 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core1_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core1_1000ms_Count", taskvalue, Greater);
  
  //Check Core2 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core2 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core2 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_VariableRead( "Task_Core2_1000ms_Count", taskvalue);
  E_DBGR_VariableCheck("Task_Core2_1000ms_Count", taskvalue, Greater);
    
  //Check Core3 is running
  snprintf( chActionText, elCount(chActionText), "Check 1000ms Task Counter from Core3 "); 
  snprintf( chExpectedText, elCount(chExpectedText), "1000ms Counter from Core3 is incrementing"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
