      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
   waitForNotRunning(5000);  // Reading is typically only ever wanted when stopped at a breakpoint.  Optimization risk mitigation.
}

/// <REGISTER>
/*! void A_DBGR_RegisterSetByMask(char aAddress[], char aMask[])
*  \brief Function that SET a value of a specific mask from register by address in TRACE32.
* 
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[in] aMask - the mask
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 15.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_RegisterSetByMask(char aAddress[], char aMask[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  char chT32Cmd[128] = "";
  char chT32Cmd1[128]= "";
  char chT32Cmd2[128]= "";
  char chT32Cmd3[128]= "";
  char chT32Cmd4[128]= "";
  
  bDebugFlag = NotOk;
  bResultAction = NotOk;
  snprintf(chT32Cmd1, elcount(chT32Cmd1), "\"PER.Set.simple %s %%", aAddress);
  snprintf(chT32Cmd2, elcount(chT32Cmd2), "Long (d.l(%s)", aAddress);
  snprintf(chT32Cmd3, elcount(chT32Cmd3), "&~%s)", aMask);
  snprintf(chT32Cmd4, elcount(chT32Cmd4), "|%s\"", aMask);
  strncat(chT32Cmd1, chT32Cmd2, elcount(chT32Cmd));
  strncat(chT32Cmd1, chT32Cmd3, elcount(chT32Cmd));
  strncat(chT32Cmd1, chT32Cmd4, elcount(chT32Cmd));
  strncpy(chT32Cmd, chT32Cmd1, elcount(chT32Cmd));
  
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RegisterSetByMask() entered.");
  
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Set a value of a specific mask: '%s' from register by address: '%s'.", aMask, aAddress);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Register with address: %s was set to value: 0x%s.", aAddress, aMask);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
   waitForNotRunning(5000);
}

