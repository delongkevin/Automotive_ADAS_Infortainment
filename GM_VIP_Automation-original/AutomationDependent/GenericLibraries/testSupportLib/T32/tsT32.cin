    lFctn_CallT32API("\"STEP.OVER\"", chApiMessage, lApiExitCode);
    waitForNotRunning(10000);
}


/// <GENERIC>
/*! void  A_DBGR_Go_Safe()
*  \brief Function that sends GO command with reset detection and retry logic.
*         If the ECU stops at the reset vector (PP register = 0A0000000), it will
*         automatically retry the GO command up to 25 times.
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 31.01.26              Copilot         Created function with soft-reset detection and retry logic.
*/
export testfunction A_DBGR_Go_Safe()
{
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[128];
  char chPPValue[128];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  int maxRetries;
  int retryCount;

  bDebugFlag = NotOk;
  bResultAction = NotOk;
  maxRetries = 25;
  retryCount = 0;

  writeDbgLevel(DebugFuncCalls, "Function A_DBGR_Go_Safe() checking if already running.");
  if (isRunning())
  {
    snprintf(chPassText, elcount(chPassText), "ECU is already running.");
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
    vFctn_REPORTActionEvaluation(chPassText, PASS);
    return;
  }

  writeDbgLevel(DebugFuncCalls, "Function A_DBGR_Go_Safe() entered.");

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Set the ECU in running mode (safe mode with reset detection).");
  bResultAction = bFctn_REPORTAction(chAction);

    while (retryCount < maxRetries)
    {
      snprintf(chT32Cmd, elcount(chT32Cmd), "\"GO\"");
      lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

      testWaitForTimeoutSilent(200);  // Allow ECU to hit the soft-reset.  It may not be instant, so giving a small buffer.
      if (isRunning())
      {
        if (retryCount > 0)
        {
          snprintf(chPassText, elcount(chPassText), "ECU is running. Soft-Reset Recovered after %d retries.", retryCount);
        }
        else
        {
          snprintf(chPassText, elcount(chPassText), "ECU is running.");
        }
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
        return;
      }

      // ECU is not running, check if stopped at reset vector
      readPPRegister(chPPValue);

      if (strncmp(chPPValue, "0A0000000", 9) == 0)
      {
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "WARNING: Soft-Reset Detected!");
        retryCount++;
      }
      else
      {
        // Stopped for another reason (breakpoint, etc.) - exit normally
        snprintf(chPassText, elcount(chPassText), "ECU stopped (breakpoint or other reason).");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
        return;
      }
    }

    // Max retries exhausted
    snprintf(chFailText, elcount(chFailText), "ECU is NOT running! Indefinite Soft-Resets Detected after %d retries.", maxRetries);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);

  // `Go` is used to either `Go` or `Proceed to next breakpoint`.  Doing a `Is running` - `Is not running` should shorten when breakpoints are intended to be hit
  waitForRunning(250);  // Ensure T32 has given PLENTY of opportunity to start.  (overkill)
}


/// <GENERIC>
/*! void  A_DBGR_Break()
*  \brief Function that STOP the ECU from running.
* 
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 31.08.20              CrJu         Refactoring the code.
* 16.02.22              IuSo         Refactoring the variable chT32Cmd.
*/
void A_DBGR_Break()
{
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[128];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];

  bDebugFlag = NotOk;
  bResultAction = NotOk;

  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_Break() entered.");

  snprintf(chT32Cmd, elcount(chT32Cmd),"\"BREAK\"");
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Stop the ECU from running mode.");
  bResultAction = bFctn_REPORTAction(chAction);

  if(bResultAction)
  {
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "ECU is stopped.");
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void A_DBGR_R()
*  \brief Function that reset the ECU without reloading symbols
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 16.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_R()
{
  long lResult;
  char chCommand[1024];
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  long lEvaluationResult;
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  long lApiExitCode[1];
  byte bResultAction;
  byte bDebugFlag;
  
  // initial values
  lResult = Error;
  bResultAction = NotOk;
  bDebugFlag = NotOk;
  lEvaluationResult = Error;
  
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_R() entered.");
  
  snprintf(chT32Cmd, elcount(chT32Cmd),"\"SYStem.RESetTarget\"");
  lResult = lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  testWaitForTimeoutSilent(250);

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Send the 'R' command to T32.");
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  { 
    if ((lResult==Ok)||(lResult==NotOk))
    {

      if ((waitForNotRunning(cc_dwT32_MaxTimeout)) && (NotOk != lFctn_G_T32_GET_STATE())) // condition evaluation has returned: True
      {
        snprintf(chPassText, elcount(chPassText), "The ECU has been reseted.");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command R !!!");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command R !!!");
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Error: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void A_DBGR_RnGo()
*  \brief Function that reset the ECU without reloading symbols, deletes all the BPs & put the ECU in running mode.
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 16.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_RnGo()
{
  long lResult;
  char chCommand[1024];
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  long lEvaluationResult;
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  long lApiExitCode[1];
  byte bResultAction;
  byte bDebugFlag;
  
  // initial values
  lResult = Error;
  bResultAction = NotOk;
  bDebugFlag = NotOk;
  lEvaluationResult = Error;
  
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RnGo() entered.");


  A_DBGR_R();
  A_DBGR_Go();

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Send the 'RnGO' command to T32.");
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  { 
    if ((lResult==Ok)||(lResult==NotOk))
    {
      lEvaluationResult = isRunning();

      if (lEvaluationResult) // condition evaluation has returned: True 
      {
        snprintf(chPassText, elcount(chPassText), "The ECU has been reseted and now is in Running.");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command RnGO !!!");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command RnGO !!!");
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Error: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void  A_DBGR_RunCommand(char aCommand[])
*  \brief Function that RUN practice command line.
* 
*  \param[in] aCommand - the command to run
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 10.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_RunCommand(char aCommand[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  char chT32Cmd[128] = "";
 
  bDebugFlag = NotOk;
  bResultAction = NotOk;
  snprintf(chT32Cmd, elcount(chT32Cmd), "\"%s\"", aCommand);
 
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RunCommand() entered.");
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Run practice cmm line: '%s'.", aCommand);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Command '%s' was succesfully executed.", aCommand);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void E_DBGR_CheckState(char aAddress[])
*  \brief Function to verify current T32 state
*  \param[in]   aT32State      - Expected T32 State (Values : T32_State_Down, ..., T32_State_Running --> See eT32State)
*  \return None
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 03.11.21              AnPu            Created and implemented
* 24.11.21				      AnPu			      Implement remarks after review
*/
void E_DBGR_CheckState(enum eT32State aT32State)
{
  long lState;
  char chPassText[250];
  char chFailText[250];
  byte bDebugFlag;
  
  bDebugFlag = NotOk;
  lState = Error;
  
  writeDbgLevel (DebugFuncCalls , "Function E_DBGR_CheckState() called.");
  lState = lFctn_G_T32_GET_STATE(msgInfo);
  if (lState == aT32State)
    {
      snprintf(chPassText, elcount(chPassText),  msgInfo);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTStepEvaluation(chPassText, PASS);
    }
    else{
      snprintf(chFailText, elcount(chFailText),  msgInfo);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }

  
  if((byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal, msgInfo);
}

/// <BREAKPOINTS>
