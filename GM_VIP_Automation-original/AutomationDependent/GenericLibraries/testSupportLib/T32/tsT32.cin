/// <REGISTER>
/*! \fn void E_DBGR_RegisterCheckBitStatus(char aAddress[], int aBit_Number, enum eBitStatus aBitStatus)
*  \brief Function that will check the status of a specific bit number of a specific address
*  \param[in]  char aAddress[]            - address from where the register value is read
*  \param[in]  byte aBit_Number            - the bit number to be verified. (bit numbers start from 0, e.g. to verify the Port2 Pin7 the aBit_Number param should be 8 )
*                                                                                                    (e.g. to verify bit 0 of an address the aBit_Number param should be 1)
*  \param[in]  enum eBitStatus aBitStatus -   BitStatus_NotSet = 0 
*                                             BitStatus_Set = 1
* Change History: 
* Date(DD.MM.YY)        Author              Change info                                                          
* 20.05.22               AnPa            Created and implemented
*/
void E_DBGR_RegisterCheckBitStatus(char aAddress[], byte aBit_Number, enum eBitStatus aBitStatus)
{
  int iRet_val;
  char chMappedResponseInfo[256];
  
  writeDbgLevel (DebugFuncCalls , "Function E_DBGR_RegisterCheckBitStatus() called.");
  
  iRet_val = lFctn_T32_Register_Check_Bit_Status( aAddress, aBit_Number, aBitStatus,chMappedResponseInfo);

  if(iRet_val == Ok)    
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, PASS); 
  else
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);  
}


/**
 * Helper function to poll for STATE.RUN()==FALSE() with timeout
 * Returns 1 if not running, 0 if still running after timeout
 */
long waitForNotRunning(long timeoutMs)
{
  long elapsed;
  long result;
  long pollInterval;
  int apiWait = 60;

  pollInterval = 500;
  elapsed = 0;
  result = 0;

  while (elapsed < timeoutMs)
  {
    result = !isRunning();
    elapsed += apiWait;

    if (result)
      return 1; // Not running

    if (pollInterval > apiWait)
    {
      testWaitForTimeoutSilent(pollInterval - apiWait);
      elapsed += pollInterval;
    }
  }
  return 0; // Timed out, still running
}

long waitForRunning(long timeoutMs)
{
  long elapsed;
  long result;
  long pollInterval;
  int apiWait = 60;

  pollInterval = 100;
  elapsed = 0;
  result = 0;

  while (elapsed < timeoutMs)
  {
    result = isRunning();
    elapsed += apiWait;

    if (result)
      return 1; // Running

    if (pollInterval > apiWait)
    {
      testWaitForTimeoutSilent(pollInterval - apiWait);
      elapsed += pollInterval;
    }
  }
  return 0; // Timed out, still not running
}

long isRunning()
{
  long lApiExitCode[1];
  char chApiMessage[128];
  char chT32Cmd[32] =  "\"EVAL STATE.RUN()==TRUE()\"";
  long result;

  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  return atol(chApiMessage);
}

/// <GENERIC>
/*! void readPPRegister(char aResult[])
*  \brief Function that reads the PP (Program Pointer) register value.
*
*  \param[out] aResult - the PP register value as a string
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 31.01.26              Copilot         Created function to support A_DBGR_Go_Safe reset detection.
*/
void readPPRegister(char aResult[])
{
  long lApiExitCode[1];
  char chApiMessage[128];
  char chT32Cmd[32] = "\"PRINT Register(PP)\"";

  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  strncpy(aResult, chApiMessage, elcount(aResult));
}

