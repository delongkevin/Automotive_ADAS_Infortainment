/// <BREAKPOINTS>
/*! void E_DBGR_BreakpointCheckForHalt(char aAddress[])
*  \brief Function that verify if a specific BP is halted.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 09.09.20              CrJu         Refactoring the code.
*/
void E_DBGR_BreakpointCheckForHalt(char aAddress[])
{
  byte bDebugFlag;
  long lEvaluationResult;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[500] = "";
  char chPassText[500];
  char chFailText[500];

  bDebugFlag = NotOk;
  writeDbgLevel(DebugFuncCalls , "Function E_DBGR_BreakpointCheckForHalt() entered.");

  // Poll for not running with timeout
  if ( waitForNotRunning(15000))
  {
    snprintf(chT32Cmd, elcount(chT32Cmd),"\"EVAL (P:R(PC)==%s)\"", aAddress);
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
    
    if (lApiExitCode[0] == 0)
    {
      snprintf(chT32Cmd, elcount(chT32Cmd),  "\"PRINT EVAL()\"");
      lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
      lEvaluationResult = atol(chApiMessage);
      if(lEvaluationResult)
      {
        snprintf(chPassText, elcount(chPassText), "Breakpoint at: %s was reached.", aAddress);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTStepEvaluation(chPassText, PASS);
      }
      else 
      {
        snprintf(chFailText, elcount(chFailText), "Breakpoint at: %s was NOT reached. API error message: %s", aAddress, chApiMessage);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTStepEvaluation(chFailText, FAIL);
      }
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
  else 
  {
    snprintf(chFailText, elcount(chFailText), "Timeout: ECU did not halt (STATE.RUN()!=FALSE) within %d ms.", cc_dwT32_MaxTimeout);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

