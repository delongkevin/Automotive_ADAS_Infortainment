    }
  }
}

/*! \fn void E_BUS_CheckSigValue4TimePhysical(Signal* aSignalName, dword aTimeToWaitForSignal, float aSignalValue, char aBusContext[])
*  \brief Function Wait and check if a signal physical value is not changing his value during a given time.
*  \param[in]  aSignalName          - Signal name from the database.
*  \param[in]  aTimeToWaitForSignal - The given time that the tester expects that the signal value is not changed
*  \param[in]  aSignalValue         - the expected signal value
*  \param[in] aBusContext           - the bus name context
*
*  \return no return
*  \note 
*        - An timeout must be set before this step
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  14.05.2019            CrJu        Created and implemented
*/

void E_BUS_CheckSigValue4TimePhysical(Signal* aSignalName, dword aTimeToWaitForSignal, float aSignalValue, char aBusContext[])
{
  char chMappedResponseInfo[250];
  long lResult;
  byte bDebugFlag;

  //Initialization of local variables
  lResult = NotOk;
  bDebugFlag = tsc_bBUS_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function E_BUS_CheckSigValue4TimePhysical entered.");
  
  if( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: Signal* aSignalName --%s--, dword aTimeToWaitForSignal --%d--, float aSignalValue --%10.2f--, char aBusContext[] --%s-- ",aSignalName.name,aTimeToWaitForSignal,aSignalValue,aBusContext ); 

  lResult = lFctn_BUS_CheckSigValue4TimePhysical(aSignalName, aTimeToWaitForSignal, aSignalValue, aBusContext, chMappedResponseInfo);
  
  if(Error == lResult) 
  {
    //an error occured
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);
  }
  else
  {
    if(Ok == lResult)
    {
      //the signal did not change his value
      vFctn_REPORTStepEvaluation(chMappedResponseInfo, PASS);
    }
    else
    {
      //the signal has changed his value
      vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);
    }
  }
}

/*! \fn void E_BUS_CheckSigValue4TimeRaw(Signal* aSignalName, dword aTimeToWaitForSignal, dword aMsgCycleTime, float aSignalValue, char aBusContext[])
*  \brief Function Wait and check if a signal raw value is not changing his value during a given time.
*  \param[in]  aSignalName          - Signal name from the database.
*  \param[in]  aTimeToWaitForSignal - The given time that the tester expects that the signal value is not changed
*  \param[in]  aMsgCycleTime        - The message cycle time (from database)
*  \param[in]  aSignalValue         - the expected signal value
*  \param[in] aBusContext           - the bus name context
*
*  \return no return
*  \note 
*        - An timeout must be set before this step
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  14.05.2019            CrJu        Created and implemented
*/

void E_BUS_CheckSigValue4TimeRaw(Signal* aSignalName, dword aTimeToWaitForSignal, dword aMsgCycleTime, int64 aSignalValue)
{
  char chMappedResponseInfo[250];
  long lResult;
  byte bDebugFlag;

  //Initialization of local variables
  lResult = NotOk;
  bDebugFlag = tsc_bBUS_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function E_BUS_CheckSigValue4TimePhysical entered.");
  
  if( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: Signal* aSignalName --%s--, dword aTimeToWaitForSignal --%d--, float aSignalValue --%lld--, char aBusContext[] --%s-- ",aSignalName.name, aTimeToWaitForSignal, aSignalValue); 

  
  lResult = lFctn_BUS_CheckSigValue4TimeRaw(aSignalName, aTimeToWaitForSignal, aMsgCycleTime, aSignalValue, chMappedResponseInfo);
  
  if(Error == lResult)
  {
    //an error occured
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);
  }
  else
  {
    if(Ok == lResult)
    {
      //the signal did not change his value
      vFctn_REPORTStepEvaluation(chMappedResponseInfo, PASS);
    }
    else
    {
      //the signal has changed his value
      vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);
    }
  }
}

