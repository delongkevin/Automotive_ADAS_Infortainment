  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest aDiagReq: -- %s --, char aParameterName[]: -- %s --,  char aStringToCompareWithParam[]: -- %s --.", chServiceRequestToString, aParameterName, aStringToCompareWithParam);      

	  bResult = bFctn_DIAGSendAndCompareParamString(aDiagReq, aParameterName, aStringToCompareWithParam, chCompareOutputInfo);
	  
	  if ( Ok == bResult  ) // string is identical with expected value
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chPassText, Ok);
	  }
	  else // compare result is not as expected, parameter name is not correct, request not sent/response not received or conversion failed
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}


/*! \fn void A_DIAG_SendAndGetPrimitiveData(diagRequest *aDiagReq, dword aStartByte, dword aStopByte, byte aPrimitiveDataOuputArray[])
*  \brief Function that sends a specific request and stores the primitive data, between start and stop byte position, in an output byte array.
*  \param[in]  aDiagReq 		              - Diagnostic request.
*  \param[in]  aStartByte 	              - The byte position from where the data will START to be copied (check note).
*  \param[in]  aStopByte 		              - The byte position where the data will STOP copying.
*  \param[out] aPrimitiveDataOuputArray   - The output array where the primitive data will be copied.
* 
*  \note  Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \htmlonly <PRE>Counting starts from the "Data" response, without taking into consideration the eco bytes from service and DID.
	Example: 
	Request:          <font color="orange">22 D4 00</font>
	
  Positive respose: <font color="blue">62</font> <font color="green">D4 00</font> <font color="red">01 00 23 01 9B 00 78 01 66 8C 1E</font>
                    <font color="blue">|</font>  <font color="green"> \/</font>   <font color="red">\_____________________________/</font>
                    <font color="blue">serv</font> <font color="green">DID</font>                <font color="red">Data</font>
	Counting starts from byte number 0 (elements on the start and end position are copied as well).
    "Data" response byte 0 is <font color="red">0x62</font>,
    "Data" response byte 1 is <font color="red">0xD4</font>,
    "Data" response byte 2 is <font color="red">0x00</font>
    "Data" response byte 3 is <font color="red">0x01</font>, etc...
    
    If start byte = 2, stop byte = 5 => selected bytes: <font color="green">00<font color="red">01 00 23</font>
    If start byte = 0, stop byte = 0 => selected byte is: <font color="red">0x62</font>
	</PRE> 
*	\endhtmlonly
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  05.09.18             RoBi        	  Created and implemented
*  11.11.19             CrJu            Changed the doxygen example. The function will now save the whole response of the request. / Added a message in the raport in case of failing the Action function.
*/
void A_DIAG_SendAndGetPrimitiveData(diagRequest *aDiagReq, dword aStartByte, dword aStopByte, byte aPrimitiveDataOuputArray[])
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chCopyPrimitiveDataInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  bResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendAndGetPrimitiveData().");

  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )  
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, dword aStartByte: -- %d --, dword aStopByte: -- %d --.", chServiceRequestToString, aStartByte, aStopByte);      
	  
	  snprintf(chAction, elcount(chAction), "Send diag request: %s and copy primitive data from response, starting with byte position: %d and stop at: %d.", chServiceRequestToString, aStartByte, aStopByte);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  bResult = bFctn_DIAGSendAndGetPrimitiveData(aDiagReq, aStartByte, aStopByte, aPrimitiveDataOuputArray, chCopyPrimitiveDataInfo);
	  }
    else //The reporting function has failed
    {
      snprintf(chFailText, elcount(chFailText),"FAILED: Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, chFailText);
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
    }
	  
	  if ( Ok == bResult ) // primitive data read/store ok
	  {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: Primitive data from position: %d to %d, has been successfully stored in output array.", aStartByte, aStopByte);
			if ( (byte)DebugFuncInternal & bDebugFlag)
			  writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else // primitive data could not be copied
	  {
      // start/stop value invalid, output array to small, primitive byte could not be read (internal error) or response of request not as expected.
		  snprintf(chFailText, elcount(chFailText),"FAILED: %s", chCopyPrimitiveDataInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, chCopyPrimitiveDataInfo);
		  vFctn_REPORTActionEvaluation(chCopyPrimitiveDataInfo, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void E_DIAG_SendAndComparePrimitiveData(diagRequest *aDiagReq, dword aStartByte, dword aStopByte, byte aPrimitiveDataArrayToBeCompared[])
*  \brief Function that will send the request, get the primitive data, between start and stop byte position, and compare it with the specified array (works only with 2 DID bytes).
*  \param[in]  aDiagReq 		                    - Diagnostic request.
*  \param[in]  aStartByte 	                    - The byte position from where the data will START to be compared (check note).
*  \param[in]  aStopByte                        - The byte position where the data will STOP copying.
*  \param[in]  aPrimitiveDataArrayToBeCompared  - The byte array which will be compared with the actual primitive data, of the response.
*
*  \note  Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \htmlonly <PRE>Counting starts from the "Data" response, without taking into consideration the eco bytes from service and DID.
	Example (works only for 2 DID bytes): 
	Request: <font color="orange">22 D4 00</font>
	Positive respose: <font color="blue">62</font> <font color="green">D4 00</font> <font color="red">01 00 23 01 9B 00 78 01 66 8C 1E</font>
                      <font color="blue">|</font>  <font color="green"> \/</font>   <font color="red">\_____________________________/</font>
                     <font color="blue">serv</font> <font color="green">DID</font>                <font color="red">Data</font>
	Counting starts from byte number 0 (elements on the start and end position are copied as well).
    "Data" response byte 0 is <font color="red">0x01</font>,
    "Data" response byte 1 is <font color="red">0x00</font>,
    "Data" response byte 2 is <font color="red">0x23</font>, etc...
    If start byte = 4, stop byte = 7 => selected bytes: <font color="red">9B 00 78 01</font>
    If start byte = 0, stop byte = 0 => selected byte is: <font color="red">0x01</font>
	</PRE> 
*	\endhtmlonly
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  06.09.18             RoBi        	  Created and implemented
*/
void E_DIAG_SendAndComparePrimitiveData(diagRequest *aDiagReq, dword aStartByte, dword aStopByte, byte aPrimitiveDataArrayToBeCompared[])
{
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chCompareOutputInfo[128];
  byte bResult;
  byte bDebugFlag;
 
  bResult		= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_SendAndComparePrimitiveData().");
  
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest aDiagReq: -- %s --, dword aStartByte: -- %d --, dword aStopByte: -- %d --.", chServiceRequestToString, aStartByte, aStopByte);      

	  bResult = bFctn_DIAGSendAndComparePrimitiveData(aDiagReq, aStartByte, aStopByte, aPrimitiveDataArrayToBeCompared, chCompareOutputInfo);
	  
	  if ( Ok == bResult  ) // compare result is as expected
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chPassText, Ok);
	  }
	  else // compare result is not as expected, request not sent/response not received or conversion failed
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}

/*! \fn void E_DIAG_SendAndComparePrimitiveData(byte aDiagCR[], dword aStartByte, dword aStopByte, byte aPrimitiveDataArrayToBeCompared[])
*  \brief Function that will send the custom request, get the primitive data, between start and stop byte position, and compare it with the specified array (works only with 2 DID bytes).
*  \param[in]  aDiagCR 		                      - Array with the custom request elements (Representation example of DefaultSession_Start: aDiagCustomReqArray[0] = 0x10, aDiagCustomReqArray[1] = 0x01).
*  \param[in]  aStartByte 	                    - The byte position from where the data will START to be compared (check note).
*  \param[in]  aStopByte                        - The byte position where the data will STOP copying.
*  \param[in]  aPrimitiveDataArrayToBeCompared  - The byte array which will be compared with the actual primitive data, of the response.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  24.02.20             CrJu        	  Created and implemented
*/
void E_DIAG_SendAndComparePrimitiveData(byte aDiagCR[], dword aStartByte, dword aStopByte, byte aPrimitiveDataArrayToBeCompared[])
{
  char chCompareOutputInfo[128];
  byte bResult;
  byte bDebugFlag;
  diagRequest * req_CustomRequestCreated; // use the pre-defined data diag object to create the custom request

  bResult	= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_CRSendAndComparePrimitiveData().");
    
  // Calculate the total number of desired bytes 
  if( bFctn_CONV_ConvertByteArrayToDiagObject(aDiagCR, req_CustomRequestCreated ))
  {
    bResult = bFctn_DIAGSendAndComparePrimitiveData(req_CustomRequestCreated, aStartByte, aStopByte, aPrimitiveDataArrayToBeCompared, chCompareOutputInfo);
	
    if ( Ok == bResult ) // compare result is as expected
	  {
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Test action PASSED: %s", chCompareOutputInfo);
		  vFctn_REPORTStepEvaluation(chCompareOutputInfo, PASS);
	  }
    else // compare result is not as expected, request not sent/response not received or conversion failed
    {
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Test action FAILED: %s", chCompareOutputInfo);
		  vFctn_REPORTStepEvaluation(chCompareOutputInfo, FAIL);
    }
  }
  else //Conversion failed
  {
    snprintf(chCompareOutputInfo, elCount(chCompareOutputInfo), "ERROR: Conversion failed to diag object.");
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "Test action FAILED: %s", chCompareOutputInfo);
		vFctn_REPORTStepEvaluation(chCompareOutputInfo, FAIL);
  }
}

/*! \fn void A_DIAG_SendPrimitiveData(diagRequest *aDiagReq, byte aByteArrayToSend[])
*  \brief Function that modify all of the primitive data, of a provided diag request, send it with the data from the provided byte array and restore the request back to its original data.
*  \param[in]  aDiagReq             - Diagnostic request which will be modified and sent.
*  \param[in]  aByteArrayToSend     - Data which will replace the content of the provided diag request. 
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  22.11.18             RoBi        	  Created and implemented
*/
void A_DIAG_SendPrimitiveData(diagRequest *aDiagReq, byte aByteArrayToSend[])
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chSendPrimitiveDataInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
  byte bResizedArray[8];
  char chElementsOfTheArray[128];
  byte bConvResult;
 
  bResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendPrimitiveData().");
  
  // In case of large arrays, for readability purpose, it is good to avoid printing all the bytes in the report
  if ( (elCount(aByteArrayToSend) > 8) // check if the request size is larger than 8 bytes (counting starts at 0)
    && (Ok == bFctn_CONV_CopyByteArray(aByteArrayToSend, bResizedArray, 8)) ) // Copy only the first 8 elements of the array
  {
    // Convert to string only the first 8 elements
    bConvResult = bFctn_CONV_ConvertByteArrayToString(bResizedArray, chElementsOfTheArray); 
    strncat(chElementsOfTheArray,"...", strlen(chElementsOfTheArray) + 3);
  }
  else // The request is <= 8 elements - convert it directly to string
  {
    bConvResult = bFctn_CONV_ConvertByteArrayToString(aByteArrayToSend, chElementsOfTheArray);
  }

  // Convert the diag request to string, in order to print it in the report
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) && Ok == bConvResult)  
  {
    if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, byte chElementsOfTheArray[] -- %d --.", chServiceRequestToString, chElementsOfTheArray);      
    
    snprintf(chAction, elcount(chAction), "Modify diag request: %s, and send it with primitive data: 0x%s.", chServiceRequestToString, chElementsOfTheArray);
    bResultAction = bFctn_REPORTAction(chAction);
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
    
    if(bResultAction)
    {
      bResult = bFctn_DIAGSendPrimitiveData(aDiagReq, aByteArrayToSend, chSendPrimitiveDataInfo);
    }
    
    if ( Ok == bResult ) // primitive data of the request was modified, sent and restored successfully
    {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: Provided request has been successfully sent with data: 0x%s.", chElementsOfTheArray);
      if ( (byte)DebugFuncInternal & bDebugFlag)
	      writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
      vFctn_REPORTActionEvaluation(chPassText, Ok);
    }
    else // failed: request could not be modified, sent or restored to initial value
    {
      snprintf(chFailText, elcount(chFailText),"FAILED: %s", chSendPrimitiveDataInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
	      writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
      vFctn_REPORTActionEvaluation(chFailText, NotOk);
    }
  }
  else // conversion failed
  {
    snprintf(chFailText,elcount(chFailText),"FAILED: Conversion of the byte array or diagnostic request to string could not be done !");
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SetP2Timeouts(char aECU_Target[], dword aNewP2Timeout_ms, dword aNewP2ExtendedTimeout_ms)
*  \brief Function that will modify the P2 and P2*Extended timeouts, for the correctly specified ECU Target.
*  \param[in]  aECU_Target                - The ECU Target for which the P2/P2* timeouts will apply.
*  \param[in]  aNewP2Timeout_ms           - The new value, in miliseconds, for the P2 timeout.
*  \param[in]  aNewP2ExtendedTimeout_ms   - The new value, in miliseconds, for the P2* Extended timeout.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  23.11.18             RoBi            Created and implemented
*/
void A_DIAG_SetP2Timeouts(char aECU_Target[], dword aNewP2Timeout_ms, dword aNewP2ExtendedTimeout_ms)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chSetP2TimeoutsInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  bResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_DIAG_SetP2Timeouts().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel(DebugFuncParam, "Parameters: char aECU_Target[]: -- %s --, dword aNewP2Timeout_ms: -- %d --, dword aNewP2ExtendedTimeout_ms -- %d --.", aECU_Target, aNewP2Timeout_ms, aNewP2ExtendedTimeout_ms);      
    
  snprintf(chAction, elcount(chAction), "Change the timeout values of the target ECU: %s, to: P2 = %d and P2*Extended = %d.", aECU_Target, aNewP2Timeout_ms, aNewP2ExtendedTimeout_ms);
  bResultAction = bFctn_REPORTAction(chAction);
  if ( (byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel(DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);

  if(bResultAction)
  {
    bResult = bFctn_DIAGSetP2Timeouts(aECU_Target, aNewP2Timeout_ms, aNewP2ExtendedTimeout_ms, chSetP2TimeoutsInfo);
  }

  if ( Ok == bResult ) // the P2 timeouts were successfully modified
  {
    snprintf(chPassText, elcount(chPassText),"SUCCESS: The P2 timeouts of the target ECU: %s, are changed to: P2 = %d and P2*Extended = %d.", aECU_Target, aNewP2Timeout_ms, aNewP2ExtendedTimeout_ms);
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chPassText, Ok);
  }
  else // failed: could not modify the P2 timeouts
  {
    snprintf(chFailText, elcount(chFailText),"FAILED: %s", chSetP2TimeoutsInfo);
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_RestoreP2Timeouts(char aECU_Target[])
*  \brief Function that will restore the P2 and P2*Extended timeouts, to the values specified in the .ini file, for the specified ECU Target.
*  \param[in]  aECU_Target                - The ECU Target for which the P2/P2* timeouts will apply.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  26.11.18             RoBi            Created and implemented
