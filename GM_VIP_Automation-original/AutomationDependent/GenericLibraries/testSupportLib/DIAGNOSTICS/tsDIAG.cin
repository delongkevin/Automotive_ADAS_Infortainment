*/
void A_DIAG_RestoreP2Timeouts(char aECU_Target[])
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chRestoreP2TimeoutsInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  bResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_DIAG_RestoreP2Timeouts().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel(DebugFuncParam, "Parameters: char aECU_Target[]: -- %s --.", aECU_Target);      
    
  snprintf(chAction, elcount(chAction), "Change the timeout values of the target ECU: %s, to the values specified in the .cdd/configuration.", aECU_Target);
  bResultAction = bFctn_REPORTAction(chAction);
  if ( (byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel(DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);

  if(bResultAction)
  {
    bResult = bFctn_DIAGRestoreP2Timeouts(aECU_Target, chRestoreP2TimeoutsInfo);
  }

  if ( Ok == bResult ) // the P2 timeouts were successfully modified
  {
    snprintf(chPassText, elcount(chPassText),"SUCCESS: %s", chRestoreP2TimeoutsInfo);
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chPassText, Ok);
  }
  else // failed: could not modify the P2 timeouts
  {
    snprintf(chFailText, elcount(chFailText),"FAILED: %s", chRestoreP2TimeoutsInfo);
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SetResponseTimeout( dword aTimeoutValue )
*  \brief Function that will set the maximum timeout for the next diag response
*  \param[in]  aTimeoutValue   - Value in ms for the diag response timeout.
*  \note Function will have effect only for the function which do not have wait time as argument
*  \note In case that is not used the default value from tester ini file will be used ( entry DefaultDiagWaitTime)
*  \note Function will have effect only for the next waiting for response function
*  \note    
*         A_DIAG_SetResponseTimeout(9000); -> set max timeout for response to 9000 ms
*         E_DIAG_SendAndWaitForResponse(req_Extended_Start, cc_eDIAGPhysical, cc_eDIAG_PositiveResponse ); -> function will wait max 9000 ms for response to come
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  25.02.20             CiCo            Created and implemented
*/
void A_DIAG_SetResponseTimeout( dword aTimeoutValue )
{
  char chMappedResponse[256];
  char chAction[128];
  char chPassText[128];
  char chFailText[128]; 
  byte bResult;
  byte bDebugFlag;
  
  bResult	= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;// use only for debug
  snprintf( chMappedResponse, elcount(chMappedResponse), "" );
  
  writeDbgLevel(DebugFuncCalls, "Entered A_DIAG_SetResponseTimeout().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel(DebugFuncParam, "Parameters: char aTimeoutValue: -- %d [ms] --.", aTimeoutValue);      
    
  snprintf(chAction, elcount(chAction), "Set the max. diag response timeout to %d [ms] for the next request/response.", aTimeoutValue);
  bResult = bFctn_REPORTAction(chAction);
  
  if( bResult )
  {
    bResult =  bFctn_DIAGSetResponseTimeout( aTimeoutValue, chMappedResponse );
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "bFctn_DIAGSetResponseTimeout return: -- %d --. Response %s.", bResult, chMappedResponse);
    
    if ( Ok == bResult ) // requested value will be taken in consideration for the next request/response
    {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: %s", chMappedResponse);
      vFctn_REPORTActionEvaluation(chPassText, Ok);
    }
    else // failed: Timeout was not set to requested value
    {
      snprintf(chFailText, elcount(chFailText),"FAILED: %s", chMappedResponse);
      vFctn_REPORTActionEvaluation(chFailText, NotOk);
    }
  }  
}

/*! \fn long A_DIAG_SendAndGetPrimitiveData(byte aDiagCR[], dword aStartByte, byte aPrimitiveDataOuputArray[])
*  \brief Sendd a custom request and stores the primitive data, from start position until the end of the response, in an output byte array.
*  \param[in]  aDiagCR                  - Array with the custom request elements (Representation example of DefaultSession_Start: aDiagCustomReqArray[0] = 0x10, aDiagCustomReqArray[1] = 0x01).
*  \param[in]  aStartByte               - The byte position from where the data will START to be copied.
*  \param[in]  aPrimitiveDataOuputArray - The output array which store the data of the response.
* 
*  \note  Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  11.05.20             CrJu        	  Created and implemented
*/
void A_DIAG_SendAndGetPrimitiveData(byte aDiagCR[], dword aStartByte, byte aPrimitiveDataOuputArray[])
{
  char chAction[128];
  char chPassText[250];
  char chFailText[250];
  char chMessageResponseInfo[250];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  lResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendAndGetPrimitiveData().");

  snprintf(chAction, elcount(chAction), "Send custom diag request and copy primitive data from response, starting with byte position: %d untill the end.", aStartByte);
	bResultAction = bFctn_REPORTAction(chAction);
	  
  if ( (byte)DebugFuncInternal & bDebugFlag)
	  writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	if(bResultAction)
	{
    lResult = lFctn_DIAG_CRSendAndGetPrimitiveDataWithOffset(aDiagCR, aStartByte, aPrimitiveDataOuputArray, chMessageResponseInfo);
    
    if ( Error != lResult ) // primitive data read/store ok
	  {
      snprintf(chPassText, elcount(chPassText), "SUCCESS: Primitive data from position: %d, has been successfully stored in output array. Total of %d bytes.", aStartByte, lResult);
      if ( (byte)DebugFuncInternal & bDebugFlag)
			  writeDbgLevel (DebugFuncInternal, chMessageResponseInfo);
		  vFctn_REPORTActionEvaluation(chPassText, PASS);
	  }
    else // primitive data could not be copied
	  {
      // start value invalid, output array to small, primitive byte could not be read (internal error) or response of request not as expected.
		  snprintf(chFailText, elcount(chFailText),"FAILED: %s", chMessageResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, chFailText);
		  vFctn_REPORTActionEvaluation(chMessageResponseInfo, FAIL);
	  }
	}
  else //The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText),"FAILED: Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		if ( (byte)DebugFuncInternal & bDebugFlag)
		  writeDbgLevel (DebugFuncInternal, chFailText);
		vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_DIAG_SendAndComparePrimitiveData(diagRequest *aDiagReq, dword aStartByte, dword aStopByte, qword aPrimitiveDataToBeCompared, enum eCompareType aExpectedCompareAction)
*  \brief Function that will send the request, get the primitive data, between start and stop byte position, convert and compare it with the specified qword element (works only with 2 DID bytes).
*  \param[in]  aDiagReq 		              - Diagnostic request.
*  \param[in]  aStartByte 	              - The byte position from where the data will START to be compared (check note).
*  \param[in]  aStopByte                  - The byte position where the data will STOP copying.
*  \param[in]  aPrimitiveDataToBeCompared - The qword element which will be compared with the actual primitive data, of the response.
*  \param[in]  aExpectedCompareAction     - The expected comparation beetwen actual data and given data: Equal / NotEqual / Greater / Smaller.
*
*  \note  Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \htmlonly <PRE>Counting starts from the "Data" response, without taking into consideration the eco bytes from service and DID.
	Example (works only for 2 DID bytes): 
	Request: <font color="orange">22 D4 00</font>
	Positive respose: <font color="blue">62</font> <font color="green">D4 00</font> <font color="red">01 00 23 01 9B 00 78 01 66 8C 1E</font>
                      <font color="blue">|</font>  <font color="green"> \/</font>   <font color="red">\_____________________________/</font>
                     <font color="blue">serv</font> <font color="green">DID</font>                <font color="red">Data</font>
	Counting starts from byte number 0 (elements on the start and end position are copied as well).
    "Data" response byte 0 is <font color="red">0x01</font>,
    "Data" response byte 1 is <font color="red">0x00</font>,
    "Data" response byte 2 is <font color="red">0x23</font>, etc...
    If start byte = 4, stop byte = 7 => selected bytes: <font color="red">9B 00 78 01</font>
    If start byte = 0, stop byte = 0 => selected byte is: <font color="red">0x01</font>
	</PRE> 
*	\endhtmlonly
*
* /note A qword element can contain maximum 8 bytes.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  30.09.20             CrJu        	  Created and implemented
*/
void E_DIAG_SendAndComparePrimitiveData(diagRequest *aDiagReq, dword aStartByte, dword aStopByte, qword aPrimitiveDataToBeCompared, enum eCompareType aExpectedCompareAction)
{
  char chPassText[128];
  char chFailText[128];
  char chAditionalInfo[128];
  char chServiceRequestToString[128];
  qword qwActualPrimitiveValue;
  byte bResult;
  byte bDebugFlag;
  byte bActualPrimitiveData[8];
  byte bConvertPrimitiveDataResult;
  
  bResult	= NotOk;
  bConvertPrimitiveDataResult = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_SendAndComparePrimitiveData().");
  
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest aDiagReq: -- %s --, dword aStartByte: -- %d --, dword aStopByte: -- %d --.", chServiceRequestToString, aStartByte, aStopByte);      

    //Qword can contain a maximum 8 Bytes
    if((aStopByte - aStartByte) < 8)
    {
  	  bResult = bFctn_DIAGSendAndGetPrimitiveData(aDiagReq, aStartByte, aStopByte, bActualPrimitiveData, chAditionalInfo);
  	  
      if ( bResult ) // request sent, response received and actual primitive data can be compared
      {
        // convert actual primitive data received after sending the specified request into a qword Value
        bConvertPrimitiveDataResult = bFctn_CONV_ConvertByteArrToWordLength(bActualPrimitiveData, Type_Qword, qwActualPrimitiveValue);
        if((aStopByte - aStartByte) != 7)
          qwActualPrimitiveValue = qwActualPrimitiveValue >> (8 * (8 - (aStopByte - aStartByte + 1)));
        
        if(bConvertPrimitiveDataResult)// && bConvertPrimitiveDataToString)
        {
      	  if ( Equal == aExpectedCompareAction ) // Expect to be EQUAL
      	  {
            //SUCCESS: Primitive data is IDENTICAL, as expected
            if ( aPrimitiveDataToBeCompared == qwActualPrimitiveValue )
            {
              snprintf(chPassText,elcount(chPassText), "SUCCESS: Primitive data of diag request: -%s- is IDENTICAL with expected value: 0x%llX.", chServiceRequestToString, aPrimitiveDataToBeCompared);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chPassText);
      		    vFctn_REPORTStepEvaluation(chPassText, PASS);
            }
            else //FAIL: Primitive data is not IDENTICAL, as not expected
            {
              snprintf(chFailText,elcount(chFailText), "FAILED: Primitive data of diag request: -%s- is NOT IDENTICAL with expected value: 0x%llX(!= 0x%llX).", chServiceRequestToString, aPrimitiveDataToBeCompared, qwActualPrimitiveValue);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chFailText);
      		    vFctn_REPORTStepEvaluation(chFailText, FAIL);
            }
          }
          else if (NotEqual == aExpectedCompareAction) // Expect to not be equal
          {
            //SUCCESS: Primitive data is NOT IDENTICAL, as expected
            if ( aPrimitiveDataToBeCompared != qwActualPrimitiveValue )
            {
              snprintf(chPassText,elcount(chPassText), "SUCCESS: Primitive data of diag request: -%s- is NOT IDENTICAL with expected value: 0x%llX(!= 0x%llX).", chServiceRequestToString, aPrimitiveDataToBeCompared);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chPassText);
      		    vFctn_REPORTStepEvaluation(chPassText, PASS);
            }
            else //FAIL: Primitive data is IDENTICAL, as not expected
            {
              snprintf(chFailText,elcount(chFailText), "FAILED: Primitive data of diag request: -%s- is IDENTICAL, as not expected, with value: 0x%llX.", chServiceRequestToString, aPrimitiveDataToBeCompared, qwActualPrimitiveValue);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chFailText);
      		    vFctn_REPORTStepEvaluation(chFailText, FAIL);
            }
          }
      	  else if (Greater == aExpectedCompareAction) // Expect to be Greater
      	  {
      		  //SUCCESS: Primitive data is not IDENTICAL or GREATER, as expected
            if ( aPrimitiveDataToBeCompared < qwActualPrimitiveValue )
            {
              snprintf(chPassText,elcount(chPassText), "SUCCESS: As expected, primitive data of diag request: -%s- is GREATER than expected value: 0x%llX > 0x%llX.", chServiceRequestToString, qwActualPrimitiveValue, aPrimitiveDataToBeCompared);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chPassText);
      		    vFctn_REPORTStepEvaluation(chPassText, PASS);
            }
            else //FAIL: Primitive data is IDENTICAL or not GREATER, as not expected
            {
              snprintf(chFailText,elcount(chFailText), "FAILED: As not expected, primitive data of diag request: -%s- is NOT GREATER than expected value: 0x%llX <= 0x%llX.", chServiceRequestToString, qwActualPrimitiveValue, aPrimitiveDataToBeCompared);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chFailText);
      		    vFctn_REPORTStepEvaluation(chFailText, FAIL);
            }
      	  }
          else if (Smaller == aExpectedCompareAction) // Expect to be Smaller
      	  {
      		  //SUCCESS: Primitive data is not IDENTICAL or SMALLER, as expected
            if ( aPrimitiveDataToBeCompared > qwActualPrimitiveValue )
            {
              snprintf(chPassText,elcount(chPassText), "SUCCESS: As expected, primitive data of diag request: -%s- is SMALLER than expected value: 0x%llX > 0x%llX.", chServiceRequestToString, qwActualPrimitiveValue, aPrimitiveDataToBeCompared);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chPassText);
      		    vFctn_REPORTStepEvaluation(chPassText, PASS);
            }
            else //FAIL: Primitive data is IDENTICAL or not SMALLER, as not expected
            {
              snprintf(chFailText,elcount(chFailText), "FAILED: As not expected, primitive data of diag request: -%s- is NOT SMALLER than expected value: 0x%llX >= 0x%llX.", chServiceRequestToString, qwActualPrimitiveValue, aPrimitiveDataToBeCompared);
      		    if ( (byte)DebugFuncInternal & bDebugFlag)
      		      writeDbgLevel (DebugFuncInternal, chFailText);
      		    vFctn_REPORTStepEvaluation(chFailText, FAIL);
            }
      	  }
        }
        else // csonversion of the received primitive failed: bFctn_CONV_ByteArrayToSpecificNumberBaseString or bFctn_CONV_ConvertStringToUnsignedDataType
        {
          snprintf(chAditionalInfo, elcount(chAditionalInfo), "ERROR: Check functions for convert: bFctn_CONV_ByteArrayToSpecificNumberBaseString() or bFctn_CONV_ConvertStringToUnsignedDataType() for more info.");
      		if ( (byte)DebugFuncInternal & bDebugFlag)
    		    writeDbgLevel (DebugFuncInternal, chAditionalInfo);
    		  vFctn_REPORTStepEvaluation(chAditionalInfo, FAIL);
        }
      }
      else // bFctn_DIAGSendAndGetPrimitiveData() failed
      {
        if ( (byte)DebugFuncInternal & bDebugFlag)
  	      writeDbgLevel (DebugFuncInternal, chAditionalInfo);
  	    vFctn_REPORTStepEvaluation(chAditionalInfo, FAIL);
      }
    }
    else // more than 8 bytes are trying to be stacked in a qword
    {
      snprintf(chFailText,elcount(chFailText), "ERROR: More than 8 bytes are trying to be stacked in a qword. Check start and stop position!");
  	  if ( (byte)DebugFuncInternal & bDebugFlag)
  	    writeDbgLevel (DebugFuncInternal, chFailText);
  	  vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText), "ERROR: Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, chFailText);
	  vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/*! @}*/
