/*! \fn void A_DIAG_SendRequest(diagRequest *aDiagReq, enum cc_eAddressingModeDIAG aSendMode)
*  \brief Function that sends a specific diagnostic request. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagReq     - Diagnostic request.
*  \param[in]  aSendMode    - Functional or physical (cc_eDIAGFunctional = 0, cc_eDIAGPhysical = 1)
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  21.12.17             CiCo            First Revision.
*  03.07.18             RoBi            Refactoring code.
*/
void A_DIAG_SendRequest(diagRequest *aDiagReq, enum cc_eAddressingModeDIAG aSendMode)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
  
  lResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendRequest().");

  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, enum cc_eAddressingModeDIAG: -- %d -- (0 - functional, 1 - physical).", chServiceRequestToString, aSendMode);      
	  
	  snprintf(chAction, elcount(chAction), "Send diagnostic request: %s, using addressing mode: %d (0 - functional, 1 - physical)", chServiceRequestToString, aSendMode);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  lResult = lFctn_DIAGSendRequest(aDiagReq, aSendMode);
	  }

	  if(!lResult)
	  {
		  snprintf(chPassText, elcount(chPassText), "Request: %s - sent successfully.", chServiceRequestToString);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText, elcount(chFailText), "Request: %s - NOT sent. Received ErrorCode: %d", chServiceRequestToString, lResult); 
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void E_DIAG_WaitForDiagResponse(diagRequest *aDiagReq, dword aWaitTime, enum cc_eResponseCodeDIAG aResponseCode)
*  \brief Function that wait for a specific diagnostic response and report the response. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagReq       - Diagnostic request.
*  \param[in]  aWaitTime      - Waiting time in miliseconds for the response from when diag request was sent (if 0 - default value from .ini file will be used).
*  \param[in]  aResponseCode  - Response code expected (cc_eDIAG_PositiveResponse, cc_eDIAG_NoResponse, cc_eDIAG_NRCXX, cc_eDIAG_GeneralNegativeResponse)
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  21.12.17             CiCo            First Revision.
*  05.07.18             RoBi            Refactoring code.
*/
void E_DIAG_WaitForDiagResponse(diagRequest *aDiagReq, dword aWaitTime, enum cc_eResponseCodeDIAG aResponseCode)
{
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chMappedResponseInfo[128];
  long lResult;
  byte bDebugFlag;
 
  lResult	= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_WaitForDiagResponse().");

  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, dword aWaitTime: -- %d --, enum tsc_eResponseCodeDIAG aResponseCode: -- %d --.", chServiceRequestToString, aWaitTime, aResponseCode);  
	  
	  aWaitTime = dwFctn_DIAGCheckIfWaitTimeIsValid(aWaitTime); // default to 4 seconds if value provided is < 1
	  
	  if (tsc_eDIAG_NoResponse == aResponseCode)
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait no response from %s request in %d ms.", chServiceRequestToString, aWaitTime);
	  }
	  else if (tsc_eDIAG_PositiveResponse == aResponseCode)
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait for positive response from %s request to be received in %d ms.", chServiceRequestToString, aWaitTime);
	  }
	  else
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait for NRC_%X from %s request to be received in %d ms.", aResponseCode, chServiceRequestToString, aWaitTime);
	  }

	  lResult = lFctn_DIAGWaitForResponse(aDiagReq, aWaitTime, aResponseCode, chMappedResponseInfo);
    
	  if ( tsc_eDIAG_ResponseExpected == lResult  ) // Positive or negative response, as expected.
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"ERROR: Conversion of the diagnostic request to string failed ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_TesterPresent(enum tsc_eFeatureStateDIAG aStateRequested)
*  \brief Function that enables or disables tester present. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aStateRequested    - Disabled or Enabled. See the definition of enum tsc_eFeatureStateDIAG.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  06.07.18             RoBi            Created and implemented
*/
void A_DIAG_TesterPresent(enum tsc_eFeatureStateDIAG aStateRequested)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  lResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_TesterPresent().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: enum tsc_eFeatureStateDIAG aStateRequested: -- %d -- (0 - Disable, 1 - Enable).", aStateRequested);      
  
  snprintf(chAction, elcount(chAction), "Change state of tester present to: %d (0 - Disable, 1 - Enable).", aStateRequested);
  
  bResultAction = bFctn_REPORTAction(chAction);
  if ( (byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
  
  if(bResultAction)
  {
    if ( tsc_eDIAG_Disable == aStateRequested )
	  {
		  lResult = lFctn_DIAGTesterPresentOFF();
	  }
	  else // tsc_eDIAG_Enable == aStateRequested
	  {
		  lResult = lFctn_DIAGTesterPresentON();
	  }
  }

  if(!lResult)
  {
	  snprintf(chPassText, elcount(chPassText), "Successfully changed state of tester present to: %d (0 - Disable, 1 - Enable).", aStateRequested);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chPassText, Ok);
  }
  else
  {
	  snprintf(chFailText, elcount(chFailText), "Failed changing the state of tester present. Error Code: %d.", lResult);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_NRC78(enum tsc_eFeatureStateDIAG aStateRequested)
*  \brief Function that enables or disables NRC78 (requestCorrectlyReceived-ResponsePending). NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aStateRequested    - Disabled or Enabled. See the definition of enum tsc_eFeatureStateDIAG.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  10.07.18             RoBi            Created and implemented
*/
void A_DIAG_NRC78(enum tsc_eFeatureStateDIAG aStateRequested)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  lResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_NRC78().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: enum tsc_eFeatureStateDIAG aStateRequested: -- %d -- (0 - Disable, 1 - Enable).", aStateRequested);      
  
  snprintf(chAction, elcount(chAction), "Change state NRC_78 to: %d (0 - Disable, 1 - Enable).", aStateRequested);
  
  bResultAction = bFctn_REPORTAction(chAction);
  if ( (byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
  
  if(bResultAction)
  {
    if ( tsc_eDIAG_Disable == aStateRequested )
	  {
		  lResult = lFctn_DIAG_NRC78_OFF();
	  }
	  else // tsc_eDIAG_Enable == aStateRequested
	  {
		  lResult = lFctn_DIAG_NRC78_ON();
	  }
  }

  if(!lResult)
  {
	  snprintf(chPassText, elcount(chPassText), "Successfully changed state of NRC_78 to: %d (0 - Disable, 1 - Enable).", aStateRequested);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chPassText, Ok);
  }
  else
  {
	  snprintf(chFailText, elcount(chFailText), "Failed changing the state of NRC_78. Error Code: %d.", lResult);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
    vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SetTarget(char aECUName[])
*  \brief Function that sets the target to the specified ECU name.
*  \param[in]  aECUName[]   - Name of the desired ECU target.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  11.07.18             RoBi            Created and implemented
*  20.11.18             RoBi            Added a condition to limit the characters displayed (in case of really large text).
*/
void A_DIAG_SetTarget(char aECUName[])
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chECUNameDisplayLimit[25];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  lResult = NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SetTarget().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: char aECUName: -- %s --.", aECUName);
  
  // in case of really large ECU name, limit the display to 25 characters
  if ( 1 == bFctn_CONV_GetSubString(aECUName, 0, 24, chECUNameDisplayLimit) ) 
  {
	  snprintf(chAction, elcount(chAction), "Set target to: %s.", chECUNameDisplayLimit);
	  
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  lResult = lFctn_DIAGSetTarget(aECUName);
	  }

	  if(!lResult)
	  {
		  snprintf(chPassText, elcount(chPassText), "Successfully changed the target to: %s.", chECUNameDisplayLimit);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText, elcount(chFailText), "Failed changing the target. Check if the name is correct. Error Code: %d.", lResult);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else
  {
	  snprintf(chFailText, elcount(chFailText), "Failed when trying to get a sub string of aECUName, using function: bFctn_CONVGetSubString().");
		if ( (byte)DebugFuncInternal & bDebugFlag)
		  writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SendAndWaitForResponse(diagRequest *aDiagReq, enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
*  \brief Function that sends a specific diagnostic request and checks if the received response is the expected one.
*  \param[in]  aDiagReq       - Diagnostic request.
*  \param[in]  aSendMode      - Functional or physical (cc_eDIAGFunctional = 0, cc_eDIAGPhysical = 1).
*  \param[in]  aResponseCode  - Response code expected (cc_eDIAG_PositiveResponse, cc_eDIAG_NoResponse, cc_eDIAG_NRCXX, cc_eDIAG_GeneralNegativeResponse)
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  13.07.18             RoBi            Created and implemented
*/
void A_DIAG_SendAndWaitForResponse(diagRequest *aDiagReq, enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chMappedResponseInfo[128];
  char chExpectedResponseText[128];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  lResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendAndWaitForResponse().");

  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, enum cc_eAddressingModeDIAG aSendMode: -- %d --, enum cc_eResponseCodeDIAG aResponseCode: -- %d --.", chServiceRequestToString, aSendMode, aResponseCode);      
	  
    vFctn_DIAG_FormExpectedResponseText(aResponseCode, chExpectedResponseText);
    
	  snprintf(chAction, elcount(chAction), "Send diagnostic request: %s and wait for the following response: %s", chServiceRequestToString, chExpectedResponseText);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  if (tsc_eDIAG_NoResponse == aResponseCode)
		  {
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Wait no response from %s request.", chServiceRequestToString);
		  }
		  else if (tsc_eDIAG_PositiveResponse == aResponseCode)
		  {
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Wait for positive response from %s request to be received.", chServiceRequestToString);
		  }
		  else
		  {
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Wait for NRC_%X from %s request to be received.", aResponseCode, chServiceRequestToString);
		  }
		
		  lResult = lFctn_DIAGSendAndWaitForResponse(aDiagReq, aSendMode, aResponseCode, chMappedResponseInfo);
	  }
	  
	  if ( tsc_eDIAG_ResponseExpected == lResult  ) // Positive or negative response, as expected.
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void E_DIAG_SendAndWaitForResponse(diagRequest *aDiagReq, enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
*  \brief Function that ends a test step, by sending a specific diagnostic request and checking if the received response is the expected one.
*  \param[in]  aDiagReq       - Diagnostic request.
*  \param[in]  aSendMode      - Functional or physical (cc_eDIAGFunctional = 0, cc_eDIAGPhysical = 1).
*  \param[in]  aResponseCode  - Response code expected (cc_eDIAG_PositiveResponse, cc_eDIAG_NoResponse, cc_eDIAG_NRCXX, cc_eDIAG_GeneralNegativeResponse)
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  21.12.17             CiCo            First Revision.
*  05.07.18             RoBi            Refactoring code.
*/
void E_DIAG_SendAndWaitForResponse(diagRequest *aDiagReq, enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
{
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chMappedResponseInfo[128];
  long lResult;
  byte bDebugFlag;
 
  lResult		= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_SendAndWaitForResponse().");
 
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, enum cc_eAddressingModeDIAG aSendMode: -- %d --, enum cc_eResponseCodeDIAG aResponseCode: -- %d --.", chServiceRequestToString, aSendMode, aResponseCode);      
	  
	  if (tsc_eDIAG_NoResponse == aResponseCode)
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait no response from %s request.", chServiceRequestToString);
	  }
	  else if (tsc_eDIAG_PositiveResponse == aResponseCode)
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait for positive response from %s request to be received.", chServiceRequestToString);
	  }
	  else
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait for NRC_%X from %s request to be received.", aResponseCode, chServiceRequestToString);
	  }

	  lResult = lFctn_DIAGSendAndWaitForResponse(aDiagReq, aSendMode, aResponseCode, chMappedResponseInfo);
	  
	  if ( tsc_eDIAG_ResponseExpected == lResult  ) // Positive or negative response, as expected.
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SendCustomRequest(byte aDiagCustomReq[], enum cc_eAddressingModeDIAG aSendMode)
*  \brief Function that sends a custom diagnostic request (whole byte array is sent). NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagCustomReq   - Custom diagnostic array request.
*  \param[in]  aSendMode        - Functional or physical (cc_eDIAGFunctional = 0, cc_eDIAGPhysical = 1).
* 
*  \note 
*   - It is required that A_DIAG_SetTarget(char aECUName[]) is previously called, else -98 error code is returned (handle not assigned to a diag object). 
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  16.07.18             RoBi            Created and implemented
*/
void A_DIAG_SendCustomRequest(byte aDiagCustomReq[], enum cc_eAddressingModeDIAG aSendMode)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chCustomRequestByteToStr[128];
  byte bResizedArray[16];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
  byte bConvResult;
  
  lResult		= NotOk;
  bResultAction = NotOk;
  bConvResult = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendCustomRequest().");
  
  // In case of large requests, for readability purpose, it is good to avoid printing all the bytes in the report
  if ( elCount(aDiagCustomReq) > 8 ) // check if the request size is larger than 8 bytes
  {
    // Copy the first 8 elements of the array
    if ( Ok == bFctn_CONV_CopyByteArray(aDiagCustomReq, bResizedArray, 8) )
    { // Convert to string only the 8 elements
      bConvResult = bFctn_CONV_ConvertByteArrayToString(bResizedArray, chCustomRequestByteToStr);
    }  
  }
  else // The request is <= 8 elements - convert it directly to string
  {
    bConvResult = bFctn_CONV_ConvertByteArrayToString(aDiagCustomReq, chCustomRequestByteToStr);
  }
  
  if ( Ok == bConvResult )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagCustomReq: -- 0x%s --, enum cc_eAddressingModeDIAG aSendMode: -- %d --.", chCustomRequestByteToStr, aSendMode);      
	  
	  snprintf(chAction, elcount(chAction), "Send custom diagnostic request: 0x%s, using addressing mode: %d (0 - functional, 1 - physical)", chCustomRequestByteToStr, aSendMode);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  lResult = lFctn_DIAGSendCustomRequest(aDiagCustomReq, aSendMode);
	  }
	  
	  if ( !lResult )
	  {
		  snprintf(chPassText,elcount(chPassText),"Custom request: 0x%s - sent successfully.", chCustomRequestByteToStr);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else // NotOk == lResult
	  {
		  snprintf(chFailText,elcount(chFailText),"Custom request: 0x%s - NOT sent. Received ErrorCode: %d", chCustomRequestByteToStr, lResult);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the byte array: FAILED ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SendAndWaitForResponseCR(byte aDiagCustomReq[], enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
*  \brief Function that sends a custom diagnostic request and checks if the received response is the expected one. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagCustomReq   - Custom diagnostic array request.
*  \param[in]  aWaitTime        - Waiting time in miliseconds for the response from when diag request was sent (if 0 - default value from .ini file will be used).
*  \param[in]  aSendMode        - Functional or physical (cc_eDIAGFunctional = 0, cc_eDIAGPhysical = 1).
*  \param[in]  aResponseCode    - Response code expected (cc_eDIAG_PositiveResponse, cc_eDIAG_NoResponse, cc_eDIAG_NRCXX, cc_eDIAG_GeneralNegativeResponse)
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  17.07.18             RoBi            Created and implemented
*/
void A_DIAG_SendAndWaitForResponseCR(byte aDiagCustomReq[], dword aWaitTime, enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chCustomRequestByteToStr[128];
  char chMappedResponseInfo[128];
  char chExpectedResponseText[128];
  byte bResizedArray[16];
  byte bConvResult;
  long lResult;
  byte bDebugFlag;
  byte bResultAction;
 
  lResult		    = NotOk;
  bConvResult   = NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendAndWaitForResponseCR().");
  
  // In case of large requests, for readability purpose, it is good to avoid printing all the bytes in the report
  if ( elCount(aDiagCustomReq) > 8 ) // check if the request size is larger than 8 bytes
  {
    // Copy the first 8 elements of the array
    if ( Ok == bFctn_CONV_CopyByteArray(aDiagCustomReq, bResizedArray, 8) )
    { // Convert to string only the 8 elements
      bConvResult = bFctn_CONV_ConvertByteArrayToString(bResizedArray, chCustomRequestByteToStr);
    }
  }
  else // The request is <= 8 elements - convert it directly to string
  {
    bConvResult = bFctn_CONV_ConvertByteArrayToString(aDiagCustomReq, chCustomRequestByteToStr);
  }
  
  // if wait time < 1, it will use the default wait time from .ini file
  aWaitTime = dwFctn_DIAGCheckIfWaitTimeIsValid(aWaitTime); 
  
  if ( Ok == bConvResult )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: byte aDiagCustomReq[]: -- 0x%s --, enum cc_eAddressingModeDIAG aSendMode: -- %d --, enum cc_eResponseCodeDIAG aResponseCode: -- %d --.", chCustomRequestByteToStr, aSendMode, aResponseCode);      
	  
    vFctn_DIAG_FormExpectedResponseText(aResponseCode, chExpectedResponseText);
    
	  snprintf(chAction, elcount(chAction), "Send custom diagnostic request: 0x%s and wait: %d ms, for the following response: %s", chCustomRequestByteToStr, aWaitTime, chExpectedResponseText);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  if (tsc_eDIAG_NoResponse == aResponseCode)
		  {
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Wait no response from 0x%s request.", chCustomRequestByteToStr);
		  }
		  else if (tsc_eDIAG_PositiveResponse == aResponseCode)
		  {
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Wait for positive response from 0x%s request to be received.", chCustomRequestByteToStr);
		  }
		  else
		  {
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Wait for NRC_%X from 0x%s request to be received.", aResponseCode, chCustomRequestByteToStr);
		  }
		
		  lResult = lFctn_DIAGSendAndWaitForResponseCR(aDiagCustomReq, aWaitTime, aSendMode, aResponseCode, chMappedResponseInfo);
	  }
	  
	  if ( tsc_eDIAG_ResponseExpected == lResult  ) // Positive or negative response, as expected.
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the byte array: FAILED ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void E_DIAG_SendAndWaitForResponseCR(byte aDiagCustomReq[], enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
*  \brief Function that ends a test step, by sending a custom diagnostic request and checking if the received response is the expected one. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagCustomReq   - Custom diagnostic array request.
*  \param[in]  aWaitTime        - Waiting time in miliseconds for the response from when diag request was sent (if 0 - default value from .ini file will be used).
*  \param[in]  aSendMode        - Functional or physical (cc_eDIAGFunctional = 0, cc_eDIAGPhysical = 1).
*  \param[in]  aResponseCode    - Response code expected (cc_eDIAG_PositiveResponse, cc_eDIAG_NoResponse, cc_eDIAG_NRCXX, cc_eDIAG_GeneralNegativeResponse)
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  18.07.18             RoBi            Created and implemented
*/
void E_DIAG_SendAndWaitForResponseCR(byte aDiagCustomReq[], dword aWaitTime, enum cc_eAddressingModeDIAG aSendMode, enum cc_eResponseCodeDIAG aResponseCode)
{
  char chPassText[128];
  char chFailText[128];
  char chCustomRequestByteToStr[128];
  char chMappedResponseInfo[128];
  byte bResizedArray[16];
  long lResult;
  byte bDebugFlag;
  byte bConvResult;
 
  lResult		= NotOk;
  bConvResult = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_SendAndWaitForResponseCR().");
  
  // In case of large requests, for readability purpose, it is good to avoid printing all the bytes in the report
  if ( elCount(aDiagCustomReq) > 8 ) // check if the request size is larger than 8 bytes
  {
    // Copy the first 8 elements of the array
    if ( Ok == bFctn_CONV_CopyByteArray(aDiagCustomReq, bResizedArray, 8) )
    { // Convert to string only the 8 elements
      bConvResult = bFctn_CONV_ConvertByteArrayToString(bResizedArray, chCustomRequestByteToStr);
    }  
  }
  else // The request is <= 8 elements - convert it directly to string
  {
    bConvResult = bFctn_CONV_ConvertByteArrayToString(aDiagCustomReq, chCustomRequestByteToStr);
  }
  
  // if wait time < 1, it will use the default wait time from .ini file
  aWaitTime = dwFctn_DIAGCheckIfWaitTimeIsValid(aWaitTime); 
  
  if ( Ok == bConvResult )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: byte aDiagCustomReq[]: -- %s --, enum cc_eAddressingModeDIAG aSendMode: -- %d --, enum cc_eResponseCodeDIAG aResponseCode: -- %d --.", chCustomRequestByteToStr, aSendMode, aResponseCode);      
	  
	  if (tsc_eDIAG_NoResponse == aResponseCode)
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait no response from %s request.", chCustomRequestByteToStr);
	  }
	  else if (tsc_eDIAG_PositiveResponse == aResponseCode)
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait for positive response from %s request to be received.", chCustomRequestByteToStr);
	  }
	  else
	  {
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Wait for NRC_%X from %s request to be received.", aResponseCode, chCustomRequestByteToStr);
	  }
    
	  lResult = lFctn_DIAGSendAndWaitForResponseCR(aDiagCustomReq, aWaitTime, aSendMode, aResponseCode, chMappedResponseInfo);
	  
	  if ( tsc_eDIAG_ResponseExpected == lResult  ) // Positive or negative response, as expected.
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chMappedResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the byte array: FAILED ! Check if the array size is greater than zero.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_GetParamRaw(diagRequest *aDiagReq, char aParameterName[], byte aRawParamValue[])
*  \brief Stores the parameter value of a specific previously sent diagnostic request. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagReq         - Diagnostic request.
*  \param[in]  aParameterName   - The parameter name of the diagnostic request (ex: "P2s_CAN_ECU_max").
*  \param[out] aRawParamValue   - The raw output value of the specified parameter (ex: "00 00").
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  26.07.18             RoBi            Created and implemented
*/
void A_DIAG_GetParamRaw(diagRequest *aDiagReq, char aParameterName[], byte aRawParamValue[])
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chRawByteToStr[128];
  char chResponseInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  bResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_GetParamRaw().");

  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )  
  {	
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, char aParameterName[]: -- %s --.", chServiceRequestToString, aParameterName);      
	  
	  snprintf(chAction, elcount(chAction), "Read RAW parameter value: %s of previously sent diagnostic request: %s.", aParameterName, chServiceRequestToString);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  bResult = bFctn_DIAGGetParamRaw(aDiagReq, aParameterName, aRawParamValue, chResponseInfo);
	  }
	  
	  if ( Ok == bResult ) // parameter read/store ok
	  {   
		  if ( Ok == bFctn_CONV_ConvertByteArrayToString(aRawParamValue, chRawByteToStr) )
		  {
			  snprintf(chPassText, elcount(chPassText),"SUCCESS: Raw value: 0x%s of the parameter: %s has been stored.", chRawByteToStr, aParameterName);
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		    vFctn_REPORTActionEvaluation(chPassText, Ok);
		  }
	  }
	  else
	  {
		  // invalid parameter or unexpected response (detailed info in variable: chResponseInfo)
		  snprintf(chFailText, elcount(chFailText),"FAILED: %s", chResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}


/*! \fn void A_DIAG_SendAndGetParamRaw(diagRequest *aDiagReq, char aParameterName[], byte aRawParamValue[])
