/*! \fn void E_DIAG_CheckResponseLength(byte aDiagCR[], long aExpectedRespLength)
*  \brief Function that will get the response from a previously sent custom request and checks the length of it with the expected value. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagCR 		                  - Diagnostic custom request.
*  \param[in]  aExpectedRespLength 	        - Value of the expected response length.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  12.08.20             CrJu        	  Created and implemented
*/
void E_DIAG_CheckResponseLength(byte aDiagCR[], long aExpectedRespLength)
{
  char chPassText[128];
  char chFailText[128];
  char chCompareOutputInfo[128];
  byte bResult;
  byte bDebugFlag;
  diagRequest * req_CustomRequestCreated;
 
  bResult		 = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_CheckResponseLength().");
  
  if ( Ok == bFctn_CONV_ConvertByteArrayToDiagObject(aDiagCR, req_CustomRequestCreated) )
  {
	  bResult = bFctn_DIAGCheckResponseLength(req_CustomRequestCreated, aExpectedRespLength, chCompareOutputInfo);

	  if ( Ok == bResult  ) // response length is as expected
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. %s", chCompareOutputInfo);
		  vFctn_REPORTStepEvaluation(chPassText, PASS);
	  }
	  else // response length is not as expected, response not received or internal error code encountered
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. %s", chCompareOutputInfo);
		  vFctn_REPORTStepEvaluation(chFailText, FAIL);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the custom request to a diagnostic request FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, chFailText);
	  vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_DIAG_GetAndCompareParamRange(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double aMinValue, double aMaxValue)
*  \brief Function that will get the PHYSICAL value of a parameter(from request already sent) and check if it is within a specified range. Note: If minVal=10, maxVal=10 and paramVal=10, the parameter is within range. 
*  \param[in]  aDiagReq 		    - Diagnostic request.
*  \param[in]  aParameterName   - The parameter name of the diagnostic request (ex: "P2s_CAN_ECU_max").
*  \param[in]  aParamValAcces   - cc_eDIAG_ModeNumerical -> for numerical read
*                                 cc_eDIAG_ModePhysical  -> for pysical value(if conversion is definede from numerical)
*                                 cc_eDIAG_ModeCoded     -> for codded, immediate transformation into a numeric type (up to 32 bit)
*  \param[in]  aMinValue 			  - The minimum range value.
*  \param[in]  aMaxValue 		    - The maximum range value.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  03.09.18             RoBi        	  Created and implemented
*  20.11.18             RoBi        	  Added condition to check that aMinValue <= aMaxValue (invalid range is avoided).
*  30.07.19             CiCo            Updated with aParamValAcces parameter
*/
void E_DIAG_GetAndCompareParamRange(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double aMinValue, double aMaxValue)
{
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chCompareOutputInfo[128];
  byte bResult;
  byte bDebugFlag;
 
  bResult		= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_GetAndCompareParamRange().");
  
  if ( aMinValue <= aMaxValue ) // no point to allow a MinValue greater than the MaxValue
  {
    if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
    {
  	  if ( (byte)DebugFuncParam & bDebugFlag )
	      writeDbgLevel (DebugFuncParam, "Parameters: diagRequest aDiagReq: -- %s --, char aParameterName[]: -- %s --, enum cc_eParamCompareDIAG aCompareMode: -- %d --, enum cc_eParamCompareDIAG aCompareMode: -- %d --, double aMinValue: -- %g --, double aMaxValue: -- %g --.", chServiceRequestToString, aParameterName, aParamValAcces, aMinValue, aMaxValue);      

  	  bResult = bFctn_DIAGGetAndCompareParamRange(aDiagReq, aParameterName, aParamValAcces, aMinValue, aMaxValue, chCompareOutputInfo);
  	  
  	  if ( Ok == bResult  ) // compared value is within range
  	  {
  		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chCompareOutputInfo);
  		  if ( (byte)DebugFuncInternal & bDebugFlag)
		      writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
  		  vFctn_REPORTStepEvaluation(chPassText, Ok);
  	  }
  	  else // compared value is NOT within range, parameter name is not correct, request not sent/response not received
  	  {
  		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chCompareOutputInfo);
  		  if ( (byte)DebugFuncInternal & bDebugFlag)
		      writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
  		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  	  }
    }
    else // conversion failed
    {
  	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
  	  if ( (byte)DebugFuncInternal & bDebugFlag)
	      writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
  	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
    }
  }
  else // invalid range specified
  {
    snprintf(chFailText,elcount(chFailText),"Invalid range specified. Minimum Value: %g, must be less or equal than Maximum Value: %g !", aMinValue, aMaxValue);
  	if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
  	vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}

