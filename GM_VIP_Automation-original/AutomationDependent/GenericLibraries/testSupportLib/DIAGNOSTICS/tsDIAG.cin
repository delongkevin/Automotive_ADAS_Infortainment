*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  04.09.18             RoBi        	  Created and implemented
*/
void E_DIAG_SendAndCompareParamString(diagRequest *aDiagReq, char aParameterName[], char aStringToCompareWithParam[])
{
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chCompareOutputInfo[128];
