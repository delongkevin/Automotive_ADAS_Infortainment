	  if(bResultAction)
	  {
		  bResult = bFctn_DIAGSendAndGetParamRaw(aDiagReq, aParameterName, aRawParamValue, chResponseInfo);
	  }
	  
	  if ( Ok == bResult ) // parameter read/store ok
	  {
		  if ( Ok == bFctn_CONV_ConvertByteArrayToString(aRawParamValue, chRawByteToStr) )
		  {
			  snprintf(chPassText, elcount(chPassText),"SUCCESS: Raw value: 0x%s of the parameter: %s has been stored.", chRawByteToStr, aParameterName);
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		    vFctn_REPORTActionEvaluation(chPassText, Ok);
		  }
	  }
	  else
	  {
		  // invalid parameter or unexpected response (detailed info in variable: chResponseInfo)
		  snprintf(chFailText, elcount(chFailText),"FAILED: %s", chResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}

/*! \fn void A_DIAG_SetSupressPositiveResponse(diagRequest *aDiagReq, enum tsc_eFeatureStateDIAG aStateRequested)
*  \brief Function that enables or disables the send of a positive response, for a specific diag request. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagReq           - Diagnostic request.
*  \param[in]  aStateRequested    - Disabled or Enabled (tsc_eDIAG_Disable = 0, tsc_eDIAG_Enable = 1).
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  21.08.18             RoBi            Created and implemented
*/
void A_DIAG_SetSupressPositiveResponse(diagRequest *aDiagReq, enum tsc_eFeatureStateDIAG aStateRequested)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  long lResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  lResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SetSupressPositiveResponse().");
  
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )  
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, enum tsc_eFeatureStateDIAG aStateRequested: -- %d -- (0 - Disable, 1 - Enable).", chServiceRequestToString, aStateRequested);      
	  
	  snprintf(chAction, elcount(chAction), "Set Suppress positive response functionality to: %d (0 - Disable, 1 - Enable), for request: %s.", aStateRequested, chServiceRequestToString);
	  
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  if ( tsc_eDIAG_Disable == aStateRequested )
		  {
			  lResult = lFctn_DIAGSetSuppressPosResponse_OFF(aDiagReq);
		  }
		  else // tsc_eDIAG_Enable == aStateRequested
		  {
			  lResult = lFctn_DIAGSetSuppressPosResponse_ON(aDiagReq);
		  }
	  }

	  if( !lResult )
	  {
		  snprintf(chPassText, elcount(chPassText), "SUCCESS: Suppress positive response functionality is changed to: %d (0 - Resp. Not Suppressed, 1 - Resp. Suppressed).", aStateRequested);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else // Suppress Bit has failed / Error code
	  {
      snprintf(chFailText, elcount(chFailText), "FAILED: Suppress bit could not be set. Received the following error code: %d.", lResult);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}


/*! \fn void A_DIAG_GetParameter(diagRequest *aDiagReq, char aParameterName[],  enum cc_eParamValueAccessDIAG aParamValAcces, double aParamValue)
*  \brief Function that will store the physical parameter value of a specific previously sent diagnostic request. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagReq             - Diagnostic request.
*  \param[in]  aParameterName       - The parameter name of the diagnostic request (ex: "P2s_CAN_ECU_max").
*  \param[in]  aParamValAcces       - cc_eDIAG_ModeNumerical -> for numerical read
*                                     cc_eDIAG_ModePhysical -> for pysical value(if conversion is definede from numerical)
*                                     cc_eDIAG_ModeCoded -> for codded, immediate transformation into a numeric type (up to 32 bit)
*  \param[in]  aParamValue          - The output value of the specified parameter (Example: "-327.68").
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  22.08.18             RoBi            Created and implemented
*  30.07.19             CiCo            Updated with aParamValAcces parameter
*/
void A_DIAG_GetParameter(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double &aParamValue)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chResponseInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  bResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;

  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_GetParameter().");
  
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )  
  {	
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, char aParameterName[]: -- %s --, enum cc_eParamValueAccessDIAG:-- %d --.", chServiceRequestToString, aParameterName, aParamValAcces);      
    
	  snprintf(chAction, elcount(chAction), "Read physical parameter value: %s of previously sent diagnostic request: %s.", aParameterName, chServiceRequestToString);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		    bResult = bFctn_DIAGGetParameter(aDiagReq, aParameterName, aParamValAcces, aParamValue, chResponseInfo);
	  }
	  
	  if ( Ok == bResult ) // parameter read/store ok
	  {   
			  snprintf(chPassText, elcount(chPassText),"SUCCESS: Physical value: %g, of the parameter: %s, has been stored.", aParamValue, aParameterName);
			  if ( (byte)DebugFuncInternal & bDebugFlag)
			    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		    vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else
	  {
		  // invalid parameter or unexpected response (detailed info in variable: chResponseInfo)
		  snprintf(chFailText, elcount(chFailText),"FAILED: %s", chResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}


/*! \fn void A_DIAG_SendAndGetParam(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double &aParamValue)
*  \brief Function that will send a specific request and stores the mentioned parameter, as physical value, in an output parameter. NOTE: Based on how the request is defined, if a specific target is necessary, first use the function A_DIAG_SetTarget().
*  \param[in]  aDiagReq         - Diagnostic request.
*  \param[in]  aParameterName   - The parameter name of the diagnostic request (ex: "P2s_CAN_ECU_max").
*  \param[in]  aParamValAcces   - cc_eDIAG_ModeNumerical -> for numerical read
*                                 cc_eDIAG_ModePhysical  -> for pysical value(if conversion is definede from numerical)
*                                 cc_eDIAG_ModeCoded     -> for codded, immediate transformation into a numeric type (up to 32 bit)
*  \param[out] aParamValue      - The output value of the specified parameter (ex: "-327.67").
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  27.08.18             RoBi            Created and implemented
*/
void A_DIAG_SendAndGetParam(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double &aParamValue)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chResponseInfo[128];
  byte bResult;
  byte bDebugFlag;
  byte bResultAction; 
 
  bResult		= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered A_DIAG_SendAndGetParam().");

  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )  
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest *aDiagReq: -- %s --, char aParameterName[]: -- %s --, enum cc_eParamCompareDIAG aCompareMode: -- %d --.", chServiceRequestToString, aParameterName);      
	  
	  snprintf(chAction, elcount(chAction), "Send diagnostic request: %s, and read physical value of parameter: %s.", chServiceRequestToString, aParameterName);
	  bResultAction = bFctn_REPORTAction(chAction);
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
	  
	  if(bResultAction)
	  {
		  bResult = bFctn_DIAGSendAndGetParam(aDiagReq, aParameterName, aParamValAcces, aParamValue, chResponseInfo);
	  }
	  
	  if ( Ok == bResult ) // parameter read/store ok
	  {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: Physical value: %g, of the parameter: %s, has been stored.", aParamValue, aParameterName);
			if ( (byte)DebugFuncInternal & bDebugFlag)
			  writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chPassText, Ok);
	  }
	  else
	  {
      // invalid parameter or unexpected response (detailed info in variable: chResponseInfo)
		  snprintf(chFailText, elcount(chFailText),"FAILED: %s", chResponseInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
		  vFctn_REPORTActionEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTActionEvaluation().");
	  vFctn_REPORTActionEvaluation(chFailText, NotOk);
  }
}


/*! \fn void E_DIAG_GetAndCompareParam(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double aValueToCompareWithParam, enum cc_eParamCompareDIAG aCompareMode)
*  \brief Function that will get the PHYSICAL value of a parameter(from request already sent) and compare it with the specified value. 
*  \param[in]  aDiagReq                 - Diagnostic request.
*  \param[in]  aParameterName           - The parameter name of the diagnostic request (ex: "P2s_CAN_ECU_max").
*  \param[in]  aParamValAcces           - cc_eDIAG_ModeNumerical -> for numerical read
*                                         cc_eDIAG_ModePhysical  -> for pysical value(if conversion is definede from numerical)
*                                         cc_eDIAG_ModeCoded     -> for codded, immediate transformation into a numeric type (up to 32 bit)
*  \param[in]  aValueToCompareWithParam - The actual value of the parameter will be compared with this reference value (ex: "0", "327.68").
*  \param[in]  aCompareMode             - How the actual value of the parameter will be compared to the provided reference value (cc_eDIAG_Equal, cc_eDIAG_NotEqual, cc_eDIAG_Greater, cc_eDIAG_Less).
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  28.08.18             RoBi            Created and implemented
*  30.07.19             CiCo            Updated with aParamValAcces parameter
*/
void E_DIAG_GetAndCompareParam(diagRequest *aDiagReq, char aParameterName[], enum cc_eParamValueAccessDIAG aParamValAcces, double aValueToCompareWithParam, enum cc_eParamCompareDIAG aCompareMode)
{
  char chPassText[128];
  char chFailText[128];
  char chServiceRequestToString[128];
  char chCompareOutputInfo[128];
  byte bResult;
  byte bDebugFlag;
 
  bResult		= NotOk;
  bDebugFlag = tscDIAG_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_DIAG_GetAndCompareParam().");
  
  if ( Ok == bFctn_CONV_ConvertDiagReqToString(aDiagReq, chServiceRequestToString) )
  {
	  if ( (byte)DebugFuncParam & bDebugFlag )
	    writeDbgLevel (DebugFuncParam, "Parameters: diagRequest aDiagReq: -- %s --, char aParameterName[]: -- %s --, enum cc_eParamCompareDIAG aCompareMode: -- %d --, double aValueToCompareWithParam: -- %g --.", chServiceRequestToString, aParameterName, aParamValAcces, aValueToCompareWithParam, aCompareMode);      

	  bResult = bFctn_DIAGGetAndCompareParam(aDiagReq, aParameterName, aParamValAcces, aValueToCompareWithParam, aCompareMode, chCompareOutputInfo);
	  
	  if ( Ok == bResult  ) // compare result is as expected
	  {
		  snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action PASSED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chPassText, Ok);
	  }
	  else // compare result is not as exepcted, parameter name is not correct, request not sent/response not received
	  {
		  snprintf(chFailText,elcount(chFailText),"FAILED: %s", chCompareOutputInfo);
		  if ( (byte)DebugFuncInternal & bDebugFlag)
		    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
		  vFctn_REPORTStepEvaluation(chFailText, NotOk);
	  }
  }
  else // conversion failed
  {
	  snprintf(chFailText,elcount(chFailText),"Conversion of the diagnostic request to string: FAILED ! Check if a valid diag request was provided.");
	  if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel (DebugFuncInternal, "Test action FAILED. Calling function vFctn_REPORTStepEvaluation().");
	  vFctn_REPORTStepEvaluation(chFailText, NotOk);
  }
}

