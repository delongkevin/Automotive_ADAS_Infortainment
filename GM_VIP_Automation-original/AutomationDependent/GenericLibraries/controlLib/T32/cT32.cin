/*! \fn void vFctn_T32_CommandCreate_Cmm_Commands(char aOutputStringCommand[],char aCommand[])
*  \brief Function that will generate the string with the path to the specified command(cmm/bat file).
*  \param[out]  aOutputStringCommand  - The string which will be generated.
*  \param[in]   char aCommand[]       - The command(name of cmm/bat file) used
*
*  \return No Return.
*
* Change History: 
* Date(DD.MM.YY)        Author              Change info                                                          
* 04.05.22               AnPa            Created and implemented
*/
void vFctn_T32_CommandCreate_Cmm_Commands(char aOutputStringCommand[], char aCommand[])
{
  byte bDebugFlag;
  
  bDebugFlag = cc_bT32_GlobalDebugFlag; 
  writeDbgLevel (DebugFuncCalls , "Function vFctn_T32_CommandCreate_Cmm_Commands() called.");

  vFctn_T32_ConfigPathCreate(aOutputStringCommand);                                                     //get initial path (first 4 folders structure until Canoe folder)
  
  strncat(aOutputStringCommand,"TestSuites\\AutomationDependent\\Generic_Tools\\Lauterbach\\TC4_Aurix\\Cmm_Commands\\", 1024);   //concatenate next folder structure untill Cmm_Commands folder is reached
  strncat(aOutputStringCommand, aCommand, 1024);                                                    //concatenate the aCommand param which is the name of the cmm used
  
  if ( (byte)DebugFuncInternal & bDebugFlag)
     writeDbgLevel (DebugFuncInternal, "Generated command string aOutputStringCommand = %s.", aOutputStringCommand);
  
}

