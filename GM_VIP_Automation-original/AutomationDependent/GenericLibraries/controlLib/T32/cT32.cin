/*!\fn void vFctn_T32_ConfigPathCreate(char aOutputStringPath[])
*  \brief Function that will return the modified path generated from absolute configuration path. 
*  \brief This function will be used to generate the string with the path to the specified command
*
*  \param[out]  aOutputStringPath     - The byte array which will be modified.
*
*  \return No Return.
*
* Change History: 
* Date(DD.MM.YY)        Author              Change info                                                          
* 04.05.22               AnPa            Created and implemented
*/
void vFctn_T32_ConfigPathCreate(char aOutputStringPath[])
{
  char chCfgPath[500]; 
  dword dwMatchNbr;
  dword dwPosArray[20];
  byte bDebugFlag;
  
  bDebugFlag = cc_bT32_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function vFctn_T32_ConfigPathCreate() called.");

  strncpy(aOutputStringPath,"",1024); //clear the string
  
  lFctn_READFILEConfigurationPath(chCfgPath);                                 //  get absolute configuration path 
  
  dwMatchNbr = dwFctn_CONV_FindCharPosInStr( chCfgPath,'\\', dwPosArray);     //  split path by '\'
  bFctn_CONV_GetSubString(chCfgPath,0, dwPosArray[dwMatchNbr-4], aOutputStringPath);     //  get substring untill the last 3 '\'
 
  strncat(aOutputStringPath,"\\",strlen(aOutputStringPath)+2);                //  concatenate "\\" character at the end of the base directory string
  
  if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "The modified path aOutputStringPath = %s.", aOutputStringPath); 
  
 }

