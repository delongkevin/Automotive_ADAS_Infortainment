/*@!Encoding:1252*/
includes
{
  
}

variables
{
  const long DEBUG = 0;
  
  long PORT_NUMBER = 0; // will be initialized from sysvar
  const long BITS_PER_SECOND = 9600;
  const long DATA_BITS = 8;
  const long STOP_BITS = 1;
  const long PARITY = 0;
  
   // GLOBAL
  const int kBUFFER_SIZE = 1000;
  const int kINFO        = 1;
  const int kWARN        = 2;
  const int kERROR       = 3;  
    
   // data is copied from callback buffer to gReceiverBuffer (collects data)
  byte gReceiverCallbackBuffer[kBUFFER_SIZE];

  byte gReceiverBuffer[kBUFFER_SIZE];
  byte gEmptyBuffer   [kBUFFER_SIZE];
  long gNumberOfReceivedBytes = 0;

  // state variable
  byte gSending = 0;

  // timer for indication of data reception 
  msTimer tBytesReceived;
  
  // enum for power supply state
  enum PsOutputState
  {
    PS_DISABLE = 0,
    PS_ENABLE = 1
  };
  
  msTimer tPoolRequests, tStartTimer;
  char ptPreviousCommand[kBUFFER_SIZE];
  char TENMA_REQUEST_VOLTAGE[8] = "VOUT1?";
  char TENMA_REQUEST_CURRENT[8] = "IOUT1?";
    
  byte stateMachine;
  
  float prevSetVolgate;
  long prevOutputState;
}

