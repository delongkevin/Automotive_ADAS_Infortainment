/*@!Encoding:1252*/
/*
   LIB Diagnostic  - collection of simple diagnostic functions (SendDiagRequestTS with 3 different overloads)
   with support for mask response.

   Last modification: 16 Jun 2020
              Author: Radoslaw Karasinski
*/
              
includes
{
  #include "LIB_Report_Utility.cin"  
}

variables
{
  const long LIB_DIAG_DEBUG = 0;
  const long MAX_ECU_QUALIFIER_LEN = 256;
  const long MAX_DIAG_REQ_SIZE = 4096;
  const long MAX_DIAG_REQ_REPORT = 200;
  const long MAX_P2_TIMEOUT_MS = 5*1000; // time to wait in tests for response - when exceed time defined in diagnostic console, 
                                         // step will be FAILED anyway
    
  enum DiagFlags
  {
    DF_IS_FUNCTIONAL = 0x0001,
    DF_ASCII = 0x0002,
    DF_PRINT_REQ_TYPE = 0x0004
  };
  
  enum DiagStatus
  {
    DS_IDLE,
    DS_REQUEST_PREPARED,
    DS_REQUEST_ERROR,
    DS_REQUEST_SENT,
    DS_WAITING_FOR_RESPONSE,
    DS_NO_RESPONSE,
    DS_RESPONSE_UNKNOWN,
    DS_RESPONSE_PENDING,
    DS_RESPONSE_NEGATIVE,
    DS_RESPONSE_POSITIVE
  };
  
  enum DiagNrcCode
  {
    generalReject = 0x10,
    serviceNotSupported = 0x11,
    subFunctionNotSupported = 0x12,
    incorrectMessageLengthOrInvalidFormat = 0x13,
    responseTooLong = 0x14,
    busyRepeatReques = 0x21,
    conditionsNotCorrect = 0x22,
    requestSequenceError = 0x24,
    requestOutOfRange = 0x31,
    securityAccessDenied = 0x33,
    invalidKey = 0x35,
    exceedNumberOfAttempts = 0x36,
    requiredTimeDelayNotExpired = 0x37,
    uploadDownloadNotAccepted = 0x70,
    transferDataSuspended = 0x71,
    generalProgrammingFailure = 0x72,
    wrongBlockSequenceCounter = 0x73,
    responsePending = 0x78,
    subFunctionNotSupportedInActiveSession = 0x7E,
    serviceNotSupportedInActiveSession = 0x7F,
    rpmTooHigh = 0x81,
    rpmTooLow = 0x82,
    engineIsRunning = 0x83, 
    engineIsNotRunning = 0x84,
    engineRunTimeTooLow = 0x85,
    temperatureTooHigh = 0x86,
    temperatureTooLow = 0x87,
    vehicleSpeedTooHigh = 0x88,
    vehicleSpeedTooLow = 0x89,
    throttleOrPedalTooHigh = 0x8A,
    throttleOrPedalTooLow = 0x8B,
    transmissionRangeNotInNeutral = 0x8C,
    transmissionRangeNotInGear = 0x8D,
    brakeSwitchNotClosed = 0x8F,
    shifterLeverNotInPark = 0x90,
    torqueConverterClutchLocked = 0x91,
    voltageTooHigh = 0x92,
    voltageTooLow = 0x93
  };
  
  struct diagEcu
  {
    char ecuQualifier[MAX_ECU_QUALIFIER_LEN];
    char ecuName[MAX_ECU_QUALIFIER_LEN];
    
    byte diagReq[MAX_DIAG_REQ_SIZE];
    long diagReqLen;
    byte diagRespExpected[MAX_DIAG_REQ_SIZE];
    long diagRespExpectedLen;
    byte diagRespMask[MAX_DIAG_REQ_SIZE];
    long diagRespMaskLen;
    byte diagResp[MAX_DIAG_REQ_SIZE];
    long diagRespLen;
    
    dword usedFlags;    
    enum DiagStatus status;
    enum DiagStatus expectedResponse;
    enum ReportObservedType observedResult;
    float sentTimestampMs;
    float receiveTimestampMs;
  };
  
  #pragma warning(disable: 2058)  // disable warning "Struct is only partially initialized."
  struct diagEcu MFK5 = {"BV_FrontSensoDriveAssisSysteUDS_Physical", "MFK5"};
}

void _parseResponse(struct diagEcu ecu, char consoleName[], diagResponse * resp)
{
  if( strncmp(ecu.ecuQualifier, consoleName, elCount(consoleName)) == 0)
  {
    ecu.receiveTimestampMs = timeNowFloat()/100.0;
    ecu.diagRespLen = resp.GetPrimitiveData(ecu.diagResp, elCount(ecu.diagResp));
        
    if(ecu.diagResp[0] == ecu.diagReq[0] + 0x40)
    {
      _setDiagStatus(ecu, DS_RESPONSE_POSITIVE);
    }
    else if(ecu.diagResp[0] == 0x7F)
    {
      _setDiagStatus(ecu, DS_RESPONSE_NEGATIVE);
    }
    else
    {
      _setDiagStatus(ecu, DS_RESPONSE_UNKNOWN);
    }
  }
}

on diagResponse *
{
  char consoleName[MAX_ECU_QUALIFIER_LEN];  
  char str[1024];
  long byteIdx;
  
  snprintf(str, elCount(str), "%f diagResponse:", timeNowFloat()/100000.0);  
  for(byteIdx=0; byteIdx<this.GetPrimitiveSize(); byteIdx++)
  {
    snprintf(str, elCount(str), "%s %02X", str, this.GetPrimitiveByte(byteIdx));
  }  
  if(LIB_DIAG_DEBUG) write(str);
    
  diagGetCurrentEcu( consoleName, elcount(consoleName));
  _parseResponse(MFK5, consoleName, this);  
}

