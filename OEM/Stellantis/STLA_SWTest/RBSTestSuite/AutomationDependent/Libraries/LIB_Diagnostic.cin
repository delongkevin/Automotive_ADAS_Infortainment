void _setDiagStatus(struct diagEcu ecu, enum DiagStatus status)
{
  ecu.status = status;
  TestSupplyTextEvent(ecu.status.name());
  if(LIB_DIAG_DEBUG) { write("%f _setDiagStatus: ecuName: %s, status: %s", timeNowFloat()/100000.0, ecu.ecuName, status.Name()); }
}

enum DiagStatus _sendPreparedDiagRequest(long isFunctional, struct diagEcu ecu)
{
  diagRequest * req;
  
  diagSetTarget(ecu.ecuQualifier);
  DiagSetP2Extended(-1);
  req.Resize(ecu.diagReqLen);
  req.SetPrimitiveData(ecu.diagReq, ecu.diagReqLen);  
  _setDiagStatus(ecu, DS_REQUEST_PREPARED);
  
  if(isFunctional)
  {
    diagSendFunctional(req);
  }
  else
  {
    diagSendRequest(req);
  }
  
  if(testWaitForDiagRequestSent(req, MAX_P2_TIMEOUT_MS) == 1)
  {
    _setDiagStatus(ecu, DS_REQUEST_SENT);
    return DS_REQUEST_SENT; 
  }
  
  return DS_REQUEST_ERROR;
}

void _verifyReceivedMessage(struct diagEcu ecu)
{
  long idx, errorCounter;
  
  errorCounter = 0;
  
  /* ========== new check added - to be verified ========== */
  if(ecu.diagRespExpectedLen != ecu.diagRespMaskLen)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s, expected response length (%d bytes) is different than given mask (%d bytes)", stepTemporaryString, ecu.diagRespExpectedLen, ecu.diagRespMaskLen);
    errorCounter++;
  }
  
  if(ecu.diagRespLen < ecu.diagRespExpectedLen)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s, wrong size of response (expected response length is %d bytes, received %d bytes)", stepTemporaryString, ecu.diagRespExpectedLen, ecu.diagRespLen);
    errorCounter++;
  }
  else if(ecu.diagRespLen < ecu.diagRespMaskLen)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s, wrong size of response (expected response mask length is %d bytes, received %d bytes)", stepTemporaryString, ecu.diagRespMaskLen, ecu.diagRespLen);
    errorCounter++;
  }
  /* ==================== */
  
  for(idx=0; (idx<ecu.diagRespLen) && (idx<ecu.diagRespMaskLen); idx++)
  {
    if((ecu.diagResp[idx] & ecu.diagRespMask[idx]) != ecu.diagRespExpected[idx] )
    {
      errorCounter++;
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s, error on byte %d", stepTemporaryString, idx+1 );
    }
  }
  
  if((errorCounter == 0) && (ecu.expectedResponse == ecu.status) )
  {
    ReportObservedPassed(stepTemporaryString);
    ecu.observedResult = REPORT_PASSED;
  }
  else
  {
    ReportObservedFailed(stepTemporaryString);
    ecu.observedResult = REPORT_FAILED;
  }
}

void _negativeMessageFormatString(struct diagEcu ecu, char str[])
{
  long idx;
  snprintf(str, elCount(str), "Negative response from %s received:", ecu.ecuName);
  for(idx=0; idx<ecu.diagRespLen; idx++)
  {
    snprintf(str, elCount(str), "%s %02X", str, ecu.diagResp[idx] );
  }
  snprintf(str, elCount(str), "%s (%s)", str, ((enum DiagNrcCode)ecu.diagResp[2]).name() );
  
  if(ecu.usedFlags & DF_ASCII)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (ASCII value: '", stepTemporaryString, ecu.diagResp[idx] );
    for(idx=3; idx<ecu.diagRespLen; idx++)
    {
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s%c", stepTemporaryString, ecu.diagResp[idx] );
    }
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s')", stepTemporaryString);
  }
}

enum DiagStatus _waitForDiagnosticResponse(struct diagEcu ecu)
{
  long idx;
  
  TestJoinTextEvent(DS_RESPONSE_UNKNOWN.name());
  TestJoinTextEvent(DS_RESPONSE_NEGATIVE.name());
  TestJoinTextEvent(DS_RESPONSE_POSITIVE.name());
  
  if(testWaitForAnyJoinedEvent(MAX_P2_TIMEOUT_MS) > 0)
  {
    if(ecu.status == DS_RESPONSE_NEGATIVE)
    {
      if((ecu.diagResp[1] == ecu.diagReq[0]) && (ecu.diagResp[2] == responsePending) )
      {
        _setDiagStatus(ecu, DS_RESPONSE_PENDING);
        ReportObserved("ResponsePending received!");
        //ReportObservedWarning("ResponsePending received!");
        if(ecu.expectedResponse != DS_RESPONSE_PENDING)
        {
          _waitForDiagnosticResponse(ecu);
        }
        else
        {
          _negativeMessageFormatString(ecu, stepTemporaryString);
          _verifyReceivedMessage(ecu);
        }
      }
      else
      {
        _negativeMessageFormatString(ecu, stepTemporaryString);
        _verifyReceivedMessage(ecu);
      }
    }
    else if(ecu.status == DS_RESPONSE_POSITIVE)
    {
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "Positive response from %s received:", ecu.ecuName);
      for(idx=0; idx<ecu.diagRespLen; idx++)
      {
        snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s %02X", stepTemporaryString, ecu.diagResp[idx] );
      }      
      if(ecu.usedFlags & DF_ASCII)
      {
        snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (ASCII value: '", stepTemporaryString, ecu.diagResp[idx] );
        for(idx=3; idx<ecu.diagRespLen; idx++)
        {
          snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s%c", stepTemporaryString, ecu.diagResp[idx] );
        }
        snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s')", stepTemporaryString);
      }
      
      _verifyReceivedMessage(ecu);
    } 
  }
  else
  {
    _setDiagStatus(ecu, DS_NO_RESPONSE);
    
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "No response from %s within %d ms.", ecu.ecuName, MAX_P2_TIMEOUT_MS);
    
    if(ecu.expectedResponse == ecu.status)
    {
      ReportObservedPassed(stepTemporaryString);
    }
    else
    {
      ReportObservedFailed(stepTemporaryString);
    }
  }
  
  return ecu.status;  
}

void SendDiagRequestTS(struct diagEcu ecu, dword flags, char descryption[], char request[], char expectedResponse[], char responseMask[])
{
  char requestStr[4*MAX_DIAG_REQ_SIZE], respStr[4*MAX_DIAG_REQ_SIZE], respMaskStr[4*MAX_DIAG_REQ_SIZE];
  long errorCode;
  char errorString[1024];
  diagRequest * req;
  char name[512];
  
  if(LIB_DIAG_DEBUG) { write("\nSendDiagRequestTS data in: ecuName: %s, request: {%s}, expectedResponse: {%s}, responseMask: {%s}", ecu.ecuName, request, expectedResponse, responseMask); }
  
  ecu.usedFlags = flags;
  
  FindStringMultiplications(request, requestStr);
  ecu.diagReqLen = ParseHexStringToByteArray(requestStr, ecu.diagReq);
  FindStringMultiplications(expectedResponse, respStr);
  ecu.diagRespExpectedLen = ParseHexStringToByteArray(respStr, ecu.diagRespExpected);
  FindStringMultiplications(responseMask, respMaskStr);
  ecu.diagRespMaskLen = ParseHexStringToByteArray(respMaskStr, ecu.diagRespMask);
  
  if(ecu.diagReqLen > MAX_DIAG_REQ_REPORT)
  {
    requestStr[MAX_DIAG_REQ_REPORT] = 0;
    snprintf(requestStr ,elCount(requestStr), "%s... (request length: %d)", requestStr, ecu.diagReqLen);
  }
  
  ReportStep();
  if(strlen(descryption) > 0)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s - send diagnostic request", descryption);
  }
  else
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "Send diagnostic request");
  }  
  if(flags & DF_IS_FUNCTIONAL)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (functional)", stepTemporaryString);
  }
  
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s to %s: %s", stepTemporaryString, ecu.ecuName, requestStr);
  
  if(flags & DF_PRINT_REQ_TYPE)
  {
    diagSetTarget(ecu.ecuQualifier);  
    req.Resize(ecu.diagReqLen);
    req.SetPrimitiveData(ecu.diagReq, ecu.diagReqLen);  
    
    DiagGetObjectName(req, name, elcount( name));    
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (%s", stepTemporaryString, name);    
    
    if((ecu.diagReq[0] == 0x22) || (ecu.diagReq[0] == 0x2E))
    {
      diagGetParameter(req, "Param_RecorDataIdent", name, elcount( name));
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s - %s)", stepTemporaryString, name); 
    }
    else if(ecu.diagReq[0] == 0x31)
    {
      diagGetParameter(req, "Param_RoutiIdent", name, elcount( name));
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s - %s)", stepTemporaryString, name); 
    }
    else
    {
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s)", stepTemporaryString);    
    }
  }
  
  ReportAction(stepTemporaryString);
  
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s should respond with: %s", ecu.ecuName, respStr);
  if(ecu.diagRespExpected[0] == 0x7F)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (%s)", stepTemporaryString, ((enum DiagNrcCode)ecu.diagRespExpected[2]).name() );
  }
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s - checked with mask: %s", stepTemporaryString, respMaskStr);
  ReportExpected(stepTemporaryString);
  
  if(ecu.diagRespExpected[0] == ecu.diagReq[0] + 0x40)
  {
    ecu.expectedResponse = DS_RESPONSE_POSITIVE;
  }
  else if((ecu.diagRespExpected[0] == 0x7F) && (ecu.diagRespExpected[2] == responsePending) )
  {
    ecu.expectedResponse = DS_RESPONSE_PENDING;
  }
  else if((ecu.diagRespExpected[0] == 0x7F))
  {
    ecu.expectedResponse = DS_RESPONSE_NEGATIVE;
  }
  else if(ecu.diagRespExpected[0] == 0x00)
  {
    ecu.expectedResponse = DS_NO_RESPONSE;
  }
  else
  {
    ecu.expectedResponse = DS_RESPONSE_UNKNOWN;
  }
      
  if(_sendPreparedDiagRequest((flags & DF_IS_FUNCTIONAL), ecu) == DS_REQUEST_SENT)
  {
    _setDiagStatus(ecu, DS_WAITING_FOR_RESPONSE);
    _waitForDiagnosticResponse(ecu);
  }
  else
  {
    errorCode = DiagGetLastCommunicationError();
    DiagGetCommunicationErrorString(errorCode, errorString, elcount(errorString));
    snprintf(errorString, elCount(errorString), "Diagnostic message wasn't send succesfully: %s (errorCode: %d)", errorString, errorCode);    
    if(errorCode == 161)  // DoIP - Connection was closed by the peer	
    {
      // try to reconnect
      ReportObservedFailed(errorString);  // untill will find workaround
    }
    else
    {      
      ReportObservedFailed(errorString);
      write(errorString);
    }
  }
}

void SendDiagRequestTS(struct diagEcu ecu, char descryption[], char request[], char expectedResponse[], char responseMask[])
{
  //SendDiagRequestTS(ecu, 0, descryption, request, expectedResponse, responseMask);
  SendDiagRequestTS(ecu, DF_PRINT_REQ_TYPE, descryption, request, expectedResponse, responseMask);
}

void SendDiagRequestTS(struct diagEcu ecu, char request[], char expectedResponse[], char responseMask[])
{
  SendDiagRequestTS(ecu, 0, "", request, expectedResponse, responseMask);
}

