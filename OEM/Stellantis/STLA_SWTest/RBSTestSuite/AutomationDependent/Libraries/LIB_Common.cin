void CheckIfEcuInVisionViaDiagnosticTS()
{
  SendDiagRequestTS(MFK5, "Enter Extended Session", "10 03", "50 03 00 32 01 F4", "FF FF FF FF FF FF");
  SendDiagRequestTS(MFK5, "Check if ECU is in VISION mode.", "22 10 00", "62 10 00 02", "FF FF FF FF");
}

