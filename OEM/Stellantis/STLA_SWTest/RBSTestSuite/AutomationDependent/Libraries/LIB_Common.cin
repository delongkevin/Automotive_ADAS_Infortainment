  TestWaitForValueInRangeSysVarIntTS(sVar, expectedValue, expectedValue, maxTimeout);
  endTimeMs = timeNowFloat()/100.0;
  
  settingTime = endTimeMs - startTimeMs;
  CheckSigValueEqualTS(sVar.name, expectedValue, maxTimeout, settingTime, @sVar);  
}

