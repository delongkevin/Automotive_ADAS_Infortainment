long TestWaitForRawSignalInRange(signal * sig, int64 lowLimit, int64 highLimit, dword maxTimeout)
{
  float startTimeMs, endTimeMs;
  
  startTimeMs = timeNowFloat()/100.0;
  while( ((timeNowFloat()/100.0)-startTimeMs) < maxTimeout )
  {
    if(((getRawSignal(sig) >= lowLimit) && (getRawSignal(sig) <= highLimit)))
    {
      break;
    }
    testWaitForTimeout(1);
  }    
  endTimeMs = timeNowFloat()/100.0;
  
  if((endTimeMs-startTimeMs) < maxTimeout)
  {
    if((lowLimit <= getRawSignal(sig)) && (getRawSignal(sig) <= highLimit))
    {
      return 1; // Wait state is exited due to condition fulfillment
    }
    else
    {
      return -2;  // Signal is not valid  
    }
  }
  else
  {
    return 0; // Wait state is exited due to a timeout
  }
}






long TestWaitForValueInRangeSig(signal * sig, int64 minValue, int64 maxValue, long maxTimeout, long boundary)
{
  float startTimeMs;
  long shouldBreak;
  int64 tmpVal;
  
  
  if(maxTimeout < 0)
  {
    maxTimeout = 0;
  }
  shouldBreak = 0;
  startTimeMs = timeNowFloat()/100.0;
  
  while(((timeNowFloat()/100.0)-startTimeMs) < maxTimeout )
  {
    tmpVal = getRawSignal(sig);
    switch(boundary)
    {
      case BOUNDARY_LEFT_OPEN_RIGHT_OPEN:    if(((tmpVal > minValue) && (tmpVal < maxValue))) { shouldBreak = 1; } break;
      case BOUNDARY_LEFT_OPEN_RIGHT_CLOSED: if(((tmpVal > minValue) && (tmpVal <= maxValue))) { shouldBreak = 1; } break;
      case BOUNDARY_LEFT_CLOSED_RIGHT_OPEN:  if(((tmpVal >= minValue) && (tmpVal < maxValue))) { shouldBreak = 1; } break;        
      default:
      case BOUNDARY_LEFT_CLOSED_RIGHT_CLOSED:  if(((tmpVal >= minValue) && (tmpVal <= maxValue))) { shouldBreak = 1; } break;
    }
    
    if(shouldBreak)
    {
      return 1;
    }
    
    testWaitForTimeout(1);
  }
  return 0;
}

