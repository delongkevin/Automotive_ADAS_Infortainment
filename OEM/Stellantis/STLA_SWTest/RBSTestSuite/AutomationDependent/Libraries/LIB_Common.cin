{
  float startTimeMs, endTimeMs;
  long settingTime;
  
  startTimeMs = timeNowFloat()/100.0;
  /*
  if(maxTimeout > 0)
  {    
    while((@sVar != expectedValue)  && (((timeNowFloat()/100.0)-startTimeMs) < maxTimeout)) // wait until signal will reach expected value
    {
      testWaitForTimeout(1);
    }    
  }
  */
  TestWaitForValueInRangeSysVarFloatTS(sVar, expectedValue, expectedValue, maxTimeout);
  endTimeMs = timeNowFloat()/100.0;
  
  settingTime = endTimeMs - startTimeMs;
  CheckSigValueEqualTS(sVar.name, expectedValue, maxTimeout, settingTime, @sVar);  
}


void TestSetSignalTS(signal * sig, float setSigValue, long timeoutMs)
{
  float getSigValue;
  
  ReportStep();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Set signal %s value to %.05f.", sig.name, setSigValue);
  ReportAction(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Signal %s should be set to %.05f.", sig.name, setSigValue);
  ReportExpected(stepTemporaryString);
  $sig = setSigValue;
  if(timeoutMs > 0)
  {
    testWaitForTimeout(timeoutMs);
  }
  getSigValue = $sig;
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Signal %s is set to %.05f.", sig.name, getSigValue);
  if(CompareFloatsWithAccuracy(setSigValue, getSigValue, 5))
  {
    ReportObservedPassed(stepTemporaryString);    
  }
  else
  {
    ReportObservedFailed(stepTemporaryString);
  }
}

void DisableAllTxMessagesTS()
{
  ReportStep();
  ReportAction("Disable all TX messages on RBS.");
  ReportExpected("All TX messages send by RBS should be disabled.");
  @MEnv_StopAllTxMessages_SET_INT_2 = 1;
  ReportObservedPassed("All TX messages sent by RBS were disabled.");
}

void EnableAllTxMessagesTS()
{
  ReportStep();
  ReportAction("Enable all TX messages on RBS.");
  ReportExpected("All TX messages send by RBS should be enabled.");
  @MEnv_StopAllTxMessages_SET_INT_2 = 0;
  ReportObservedPassed("All TX messages sent by RBS were enabled.");
}

long TestWaitForEcuGoToSleep(long timeoutMs)
{
  const float MAX_SLEEP_CURRENT = 0.010;  // 10 mA
  float startTimeMs, endTimeMs;
  
  startTimeMs = timeNowFloat()/100.0;
  while(timeNowFloat()/100.0 < startTimeMs + timeoutMs)
  {
    if(GetKL30CurrentConsumption() < MAX_SLEEP_CURRENT)
    {
      break;
    }
    testWaitForTimeout(1);
  }
  endTimeMs = timeNowFloat()/100.0;
  
  return endTimeMs < (startTimeMs + timeoutMs);
}

void TestWaitForEcuGoToSleepTS(long timeoutMs)
{
  float startTimeMs, endTimeMs;
  
  ReportStep();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Wait maximum %d ms untill ECU will go to sleep.", timeoutMs);
  ReportAction(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU should go to sleep below %d ms.", timeoutMs);
  ReportExpected(stepTemporaryString);
  
  startTimeMs = timeNowFloat()/100.0;
  TestWaitForEcuGoToSleep(timeoutMs);
  endTimeMs = timeNowFloat()/100.0;
  
  if(endTimeMs < (startTimeMs + timeoutMs))
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU went to sleep in %d ms.", (long)(endTimeMs-startTimeMs));
    ReportObservedPassed(stepTemporaryString);
  }
  else
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU did not went to sleep in %d ms.", timeoutMs);
    ReportObservedFailed(stepTemporaryString);
  }  
}

void CheckKL30CurrentConsumptionTS(float desiredConsumption)
{
  float consumption;
  
  ReportStep();
  ReportAction("Check KL_30 power consumption.");
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "KL_30 power consumption should be below %.3f [A].", desiredConsumption);
  ReportExpected(stepTemporaryString);
  
  consumption = GetKL30CurrentConsumption();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Actual KL_30 power consumption is equal %.3f [A].", consumption);
  if(consumption < desiredConsumption)
  {
    ReportObservedPassed(stepTemporaryString);
  }
  else
  {
    ReportObservedFailed(stepTemporaryString);
  }  
}
