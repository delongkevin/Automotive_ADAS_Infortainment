variables
{
  const long MAX_WAITING_TIME_FOR_VISION_MS = 40*1000;  
  const long LDA_TIMESTAMP_UPDATE_WAIT_VALUE = 100;
  
  enum ValueBoundaryCheck
  {
    BOUNDARY_LEFT_OPEN_RIGHT_OPEN,
    BOUNDARY_LEFT_OPEN_RIGHT_CLOSED,
    BOUNDARY_LEFT_CLOSED_RIGHT_OPEN,
    BOUNDARY_LEFT_CLOSED_RIGHT_CLOSED
  };
}

testcase Stop_CANoe(char TestDescription[], char TestRequirements[], char TestParameters[])
{
  stop();
}

void TestWaitTS(long timeout)
{
  if(timeout>0)
  {
    ReportStep();
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "Wait %d milliseconds.", timeout);
    ReportAction(stepTemporaryString);
    
    testWaitForTimeout(timeout);
  }
}

void SetSpeedValueMeterPerSecondsTS(float speedMeterPerSeconds)
{
  ReportStep();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Set speed value to %.02f m/s.", speedMeterPerSeconds);
  ReportAction(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Speed value should be set to %.02f m/s.", speedMeterPerSeconds);
  ReportExpected(stepTemporaryString);
  @MEnv_VDSOVx3dXIXVDSO05XIXVLANFAS_SET_FLT_1 = speedMeterPerSeconds;
  testWaitForTimeout(100);
  
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Speed value was set to %.02f m/s.", @MEnv_VDSOVx3dXIXVDSO05XIXVLANFAS_GET_FLT_1);
  if(CompareFloatsWithAccuracy(speedMeterPerSeconds, @MEnv_VDSOVx3dXIXVDSO05XIXVLANFAS_GET_FLT_1, PERCENTAGE_ACCURACY))
  {
    ReportObservedPassed(stepTemporaryString);    
  }
  else
  {
    ReportObservedFailed(stepTemporaryString);
  }  
}

void SetSpeedValueKilometersPerHourTS(float speedKilometersPerHour)
{
  SetSpeedValueMeterPerSecondsTS(0.277777778 * speedKilometersPerHour);
}

