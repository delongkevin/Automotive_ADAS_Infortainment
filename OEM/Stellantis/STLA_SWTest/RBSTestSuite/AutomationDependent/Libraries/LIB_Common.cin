}

void TestWaitForValueInRangeSigTS(signal * sig, int64 minValue, int64 maxValue, long maxTimeout, long boundary)
{
  int64 tmpSignalValue;
  float startTimeMs, endTimeMs;
  long settingTime, ret;
  
  startTimeMs = timeNowFloat()/100.0;
  ret = TestWaitForValueInRangeSig(sig, minValue, maxValue, maxTimeout, boundary);
  endTimeMs = timeNowFloat()/100.0;
  
  settingTime = endTimeMs - startTimeMs;
  AddToReportValueInRangeIntTS(sig.name, minValue, maxValue, maxTimeout, settingTime, getRawSignal(sig), ret);
}

void TestWaitForValueInRangeSigTS(signal * sig, int64 minValue, int64 maxValue, long maxTimeout)
{
  TestWaitForValueInRangeSigTS(sig, minValue, maxValue, maxTimeout, BOUNDARY_LEFT_CLOSED_RIGHT_CLOSED);
}

