void AddToReportValueInRangeIntTS(char sVarName[], int64 minValue, int64 maxValue, long maxTimeout, long settingTime, int64 value, long verdict)
{  
  ReportStep();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Check value of signal %s.", sVarName);
  ReportAction(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Signal %s should be in range (%lld - %lld).", sVarName, minValue, maxValue);
  ReportExpected(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Signal %s is set to %lld", sVarName, value);
  if(verdict)
  {
    if((maxTimeout > 0) && (settingTime > 0))
    {
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (was set after %d ms)", stepTemporaryString, settingTime);
    }
    strncat(stepTemporaryString, ".", elCount(stepTemporaryString)); 
    ReportObservedPassed(stepTemporaryString);    
  }
  else
  {
    strncat(stepTemporaryString, ".", elCount(stepTemporaryString)); 
    ReportObservedFailed(stepTemporaryString);
  }
}

