long CheckIfEcuInVisionViaEthernetSignals()
{
  // return 1 if is in VISION, 0 if not
  dword prevValue; 
  
  prevValue = $WLA_FC1_TimestampNanoseconds_XIX_WLA_FC1_Obj_Header_XIX_VLAN_FAS.raw;
  testWaitForTimeout(LDA_TIMESTAMP_UPDATE_WAIT_VALUE);  // wait for signal update
  if( ($WLA_FC1_TimestampNanoseconds_XIX_WLA_FC1_Obj_Header_XIX_VLAN_FAS.raw != WLA_FC1_TimestampNanoseconds_XIX_WLA_FC1_Obj_Header_XIX_VLAN_FAS.DefaultValue) &&
      ($WLA_FC1_TimestampNanoseconds_XIX_WLA_FC1_Obj_Header_XIX_VLAN_FAS.raw != prevValue) )
  {
    return 1; // ECU in VISION
  }
  
  return 0; // ECU not in VISION
}

long TestWaitForEnteringVision(long timeout)
{
  // function return 1 if reached VISION in defined time, or 0 if it don't entered
  
  float startTime;
  
  startTime = timeNowFloat()/100.0;  
  while(timeNowFloat()/100.0 - startTime < timeout)
  {    
    if(CheckIfEcuInVisionViaEthernetSignals())
    {
      return 1;
    }
    testWaitForTimeout(1);
  }
  return 0;  
}

long TestWaitForEnteringVision()
{
  return TestWaitForEnteringVision(MAX_WAITING_TIME_FOR_VISION_MS);
}

long TestWaitForEnteringVisionTS(long timeout)
{
  // function return 1 if reached VISION in defined time, or 0 if it don't entered
  float checkingStartTime;
  
  ReportStep();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Wait maximum %d ms untill ECU will enter VISION.", timeout);
  ReportAction(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU should enter VISION in %d ms.", timeout);
  ReportExpected(stepTemporaryString);
  
  checkingStartTime = timeNowFloat()/100.0;
  if(TestWaitForEnteringVision(timeout))
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU entered VISION in %d ms.", (long)((timeNowFloat()/100.0)-checkingStartTime));
    ReportObservedPassed(stepTemporaryString);    
    return 1;
  }
  else
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU didn't entered VISION in %d ms.", timeout);
    ReportObservedFailed(stepTemporaryString);
    return 0;
  }
}

long TestWaitForEnteringVisionTS()
{
  return TestWaitForEnteringVisionTS(MAX_WAITING_TIME_FOR_VISION_MS);
}

void TestWaitForEnteringVisionWithResetsTS()
{
  float checkingStartTime;
  long visionEnteringTime;
  
  ReportStep();
  ReportAction("Wait untill ECU will enter VISION (reset KL30 if needed).");
  ReportExpected("ECU should enter VISION");
  
  checkingStartTime = timeNowFloat()/100.0;
  while(TestWaitForEnteringVision() == 0)
  {
    KL30ResetTS();
  }
  
  visionEnteringTime = (long)((timeNowFloat()/100.0)-checkingStartTime);
  
  if(visionEnteringTime == LDA_TIMESTAMP_UPDATE_WAIT_VALUE)
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU was already in VISION.");
  }
  else
  {
    snprintf(stepTemporaryString, elCount(stepTemporaryString), "ECU entered VISION in %d ms.", visionEnteringTime);
  }
  ReportObservedPassed(stepTemporaryString);   
}

