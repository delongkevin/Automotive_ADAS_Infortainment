void CheckSigValueEqualTS(char varName[], int64 expectedValue, long maxTimeout, long settingTime, int64 value)
{
  ReportStep();
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Check value of signal %s.", varName);
  ReportAction(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Signal %s should be set to %lld.", varName, expectedValue);
  ReportExpected(stepTemporaryString);
  snprintf(stepTemporaryString, elCount(stepTemporaryString), "Signal %s is set to %lld", varName, value);
  if(value == expectedValue)
  {
    if((maxTimeout > 0) && (settingTime > 0))
    {
      snprintf(stepTemporaryString, elCount(stepTemporaryString), "%s (was set after %d ms)", stepTemporaryString, settingTime);
    }
    strncat(stepTemporaryString, ".", elCount(stepTemporaryString)); 
    ReportObservedPassed(stepTemporaryString);    
  }
  else
  {
    strncat(stepTemporaryString, ".", elCount(stepTemporaryString)); 
    ReportObservedFailed(stepTemporaryString);
  } 
}

void TestWaitForValueSigTS(signal * sig, int64 expectedValue, long maxTimeout)
{
  float startTimeMs, endTimeMs;
  long settingTime;
  
  startTimeMs = timeNowFloat()/100.0;
  TestWaitForRawSignalMatch(sig, expectedValue, maxTimeout);
  endTimeMs = timeNowFloat()/100.0;
  
  settingTime = endTimeMs - startTimeMs;
  CheckSigValueEqualTS(sig.name, expectedValue, maxTimeout, settingTime, GetRawSignal(sig));
}

void TestWaitForValueSigByDescriptionTS(signal * sig, char value[], long maxTimeout)
{
  int64 tmpSignalValue;
  getSignalValueForDescription(sig, value, tmpSignalValue);  
  TestWaitForValueSigTS(sig, tmpSignalValue, maxTimeout); 
}

