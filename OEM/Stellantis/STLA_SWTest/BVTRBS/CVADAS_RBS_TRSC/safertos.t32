  (
    PRIVATE &nMagic
    &nMagic=address.offset(track.address())
    TASK.&(sInfix)MsgBuf &nMagic
  )
  menuitem "Display message buffer struct"
  (
    PRIVATE &pAddress
    &pAddress=track.address()
    Var.View %Open (StreamBuffer_t*)(&pAddress)
