    @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::SelectedPeriod = 0;
  }
}

on sysvar_update sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::SetNewCycleContinously
{
  if (@this == 1 && @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::EnableCyclic)
  {
    @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::SelectedPeriod = -1;
  }
}

on sysvar_update sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::SelectedPeriod
{
  if (@this == 0 && @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::EnableCyclic)
  {
    SetBusContext(gILCAN2_BusContext);
    gCAN2DisturbancePeriod = @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::NormalCyclePeriod;
    ILFaultInjectionResetMsgCycleTime(FDCAN14::BSM2::BRAKE2_FD_3);
  }
  else if (@this == 1 && @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::EnableCyclic)
  {
    SetBusContext(gILCAN2_BusContext);
    gCAN2DisturbancePeriod = @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::ActiveCyclePeriod;
    ILFaultInjectionSetMsgCycleTime(FDCAN14::BSM2::BRAKE2_FD_3, gCAN2DisturbancePeriod);
  }
  else if (@this == -1 && @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::EnableCyclic)
  {
    SetBusContext(gILCAN2_BusContext);
    gCAN2DisturbancePeriod = @sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::CyclePeriod;
    ILFaultInjectionSetMsgCycleTime(FDCAN14::BSM2::BRAKE2_FD_3, gCAN2DisturbancePeriod);
  }
}

on sysvar_update sysvar::IL_CAN2::NODES::N_BSM2::MESSAGES::BRAKE2_FD_3::TIMINGS::SendOnce
{
  if (@this == 1)
  {
    SetBusContext(gILCAN2_BusContext);
    ILSetMsgEvent(FDCAN14::BSM2::BRAKE2_FD_3);
  }
}

on sysvar_update sysvar::NM_CAN2::NODES::N_BSM2::OpenNodePanel
{
  OpenNodePanel("FDCAN14::BSM2", 1);
}

on sysvar_update sysvar::NM_CAN2::StateControl::CloseNodePanels
{
  OpenNodePanel("FDCAN14::BSM2", 0);
}

