//----------------------------------------------------------------
on timer t_Emc_AutoMode // related to the Task 3018688
{
    @MEnv_ViewButtonState_SET_INT_1 = 1;
    setTimer(t_ResetViewButtonState, 50);
  
    setTimer(t_Emc_AutoMode_Delay, 500);
}

on timer t_Emc_AutoMode_Delay
{
    @MEnv_StwAngleSweep_SET_INT_1 = 1;

    if (@MEnv_EmvMode_SET_INT_2 == 1) // 360 Mode
    {
        @MEnv_ViewSwitchSweep_SET_BOL_1 = 1;
    }
    else if (@MEnv_EmvMode_SET_INT_2 == 2) // CHMSL Mode
    {
        @MEnv_VcDgtlChmslCamPrsnt_SET_INT_1 = 1;
      
        setTimer(t_TouchCommand, 1000); // to insert a delay, because 1. the Size of the panel is send and after this it should chang the view earliest
    }
}

on envVar MEnv_EmvMode_SET_INT_2
{
    if(@this == 1) // 360 Mode
    {
        @MEnv_SweepRearAndTop_SET_BOL_1 = 1;
        @MEnv_SweepRearCross_SET_BOL_1 = 0;
        @MEnv_SweepFrontCross_SET_BOL_1 = 0;
        @MEnv_SweepFrontAndTop_SET_BOL_1 = 1;
        @MEnv_SweepTowBallView_SET_BOL_1 = 0;
    }
    else if (@this == 2) // CHMSL Mode
    {
        /*
        @MEnv_SweepRearAndTop_SET_BOL_1 = 1;
        @MEnv_SweepRearCross_SET_BOL_1 = 0;
        @MEnv_SweepFrontCross_SET_BOL_1 = 0;
        @MEnv_SweepFrontAndTop_SET_BOL_1 = 0;
        @MEnv_SweepTowBallView_SET_BOL_1 = 1;
        */
    }
    else
    {
        // do nothing
    }
}

on timer t_ResetViewButtonState
{
    @MEnv_ViewButtonState_SET_INT_1 = 0;
}

on timer t_ResetTouch
{
    @MEnv_ViewButtonState_SET_INT_1 = 0;
}

on timer t_TouchCommand
{
    @MEnv_ViewButtonState_SET_INT_1 = 4; // CHMSL_NV (View 4)
      
    setTimer(t_ResetTouch, 50);
  
    setTimer(t_TouchCommand, 2000);
}
