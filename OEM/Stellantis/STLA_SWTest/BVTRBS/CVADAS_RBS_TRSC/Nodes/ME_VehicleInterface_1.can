  //Display
// Configuration for CVPM-Display-Resolution
on envVar MEnv_DisplayRes_SET_INT_1
{
//  write("Configuration for CVPM-Display-Resolution");
    if(@this == 0) //RES_DT_1024x768
    {
        closePanel("DisplayResolution");
        //Enable / disable soft-buttons on display
        setControlVisibility("DisplayControl", "Zoom_Button", 1);
        setControlVisibility("DisplayControl", "Cancel_Button", 1);
        setControlVisibility("DisplayControl", "RearAndTop_Button", 1);
        setControlVisibility("DisplayControl", "RearCross_Button", 1);
        setControlVisibility("DisplayControl", "FrontCross_Button", 1);
        setControlVisibility("DisplayControl", "FrontAndTop_Button", 1);
        setControlVisibility("DisplayControl", "BackupRear_Button", 1);
      setControlVisibility("DisplayControl", "CHMSL_Button", 1);
      setControlVisibility("DisplayControl", "TRGV_Button", 1);
      setControlVisibility("DisplayControl", "BUNRV_Button", 1);
      setControlVisibility("DisplayControl", "Aux_Button", 1);
      setControlVisibility("DisplayControl", "CHMSL_Discription", 1);
      setControlVisibility("DisplayControl", "TRGLeft_Button", 1);
      setControlVisibility("DisplayControl", "TRGRight_Button", 1);
      setControlVisibility("DisplayControl", "TRG_Discription", 1);
      setControlVisibility("DisplayControl", "CHMSLAccept_Button", 1);
        //Enable/disable Sweep functions and buttons
        setControlVisibility("DisplayControl", "GroupSweepControls", 1);
      
        //set coordinates which are send in timer
        @MEnv_DisplayResX_SET_INT_1 = 1024;
        @MEnv_DisplayResY_SET_INT_1 = 768;
      
        //start timer to trigger sendMsg event with ButtonPressed (TCH_PSD)
        SetDisplayResState = 0;
        setTimer(t_SetDisplayRes, 10);
    }
    else if(@this == 1) //RES_RU_640x480
    {
        closePanel("DisplayResolution");
        //Enable / disable soft-buttons on display
        setControlVisibility("DisplayControl", "Zoom_Button", 1);
        setControlVisibility("DisplayControl", "Cancel_Button", 1);
        setControlVisibility("DisplayControl", "RearAndTop_Button", 1);
        setControlVisibility("DisplayControl", "RearCross_Button", 1);
        setControlVisibility("DisplayControl", "FrontCross_Button", 1);
        setControlVisibility("DisplayControl", "FrontAndTop_Button", 1);
        setControlVisibility("DisplayControl", "BackupRear_Button", 1);
      setControlVisibility("DisplayControl", "CHMSL_Button", 1);
      setControlVisibility("DisplayControl", "TRGV_Button", 1);
      setControlVisibility("DisplayControl", "BUNRV_Button", 1);
      setControlVisibility("DisplayControl", "Aux_Button", 1);
      setControlVisibility("DisplayControl", "CHMSL_Discription", 1);
      setControlVisibility("DisplayControl", "TRGLeft_Button", 1);
      setControlVisibility("DisplayControl", "TRGRight_Button", 1);
      setControlVisibility("DisplayControl", "TRG_Discription", 1);
      setControlVisibility("DisplayControl", "CHMSLAccept_Button", 1);
        //Enable/disable Sweep functions and buttons
        setControlVisibility("DisplayControl", "GroupSweepControls", 1);
      
        //set coordinates which are send in timer
        @MEnv_DisplayResX_SET_INT_1 = 640;
        @MEnv_DisplayResY_SET_INT_1 = 480;
      
        //start timer to trigger sendMsg event with ButtonPressed (TCH_PSD)
        SetDisplayResState = 0;
        setTimer(t_SetDisplayRes, 10);
    }
    else if(@this == 2) //RES_MANUAL_SELECTED
    {
        // Activate panel to set desired resolution
        openPanel("DisplayResolution");
    }
}

on envVar MEnv_ManualDisplayRes_SET_INT_1
{
    if(@this == 1) //MANUAL_SEND_PRESSED
    {
        //Enable / disable soft-buttons on display
        setControlVisibility("DisplayControl", "Zoom_Button", 0);
        setControlVisibility("DisplayControl", "Cancel_Button", 0);
        setControlVisibility("DisplayControl", "RearAndTop_Button", 0);
        setControlVisibility("DisplayControl", "RearCross_Button", 0);
        setControlVisibility("DisplayControl", "FrontCross_Button", 0);
        setControlVisibility("DisplayControl", "FrontAndTop_Button", 0);
        setControlVisibility("DisplayControl", "BackupRear_Button", 0);
      setControlVisibility("DisplayControl", "CHMSL_Button", 0);
      setControlVisibility("DisplayControl", "TRGV_Button", 0);
      setControlVisibility("DisplayControl", "BUNRV_Button", 0);
      setControlVisibility("DisplayControl", "Aux_Button", 0);
      setControlVisibility("DisplayControl", "CHMSL_Discription", 0);
      setControlVisibility("DisplayControl", "TRGLeft_Button", 0);
      setControlVisibility("DisplayControl", "TRGRight_Button", 0);
      setControlVisibility("DisplayControl", "TRG_Discription", 0);
      setControlVisibility("DisplayControl", "CHMSLAccept_Button", 0);
        //Enable/disable Sweep functions and buttons
        setControlVisibility("DisplayControl", "GroupSweepControls", 0);
        @MEnv_SweepTowBallView_SET_BOL_1 = 0;
        @MEnv_SweepFrontAndTop_SET_BOL_1 = 0;
        @MEnv_SweepFrontCross_SET_BOL_1 = 0;
        @MEnv_SweepRearCross_SET_BOL_1 = 0;
        @MEnv_SweepRearAndTop_SET_BOL_1 = 0;
      
        //start timer to trigger sendMsg event with ButtonPressed (TCH_PSD)
        //@MEnv_DisplayRes_Val... are always set directly from panel
        SetDisplayResState = 0;
        setTimer(t_SetDisplayRes, 10);
    }
    else
    {
        // Do nothing for @this == 0 (MANUAL_SEND_RELEASED)
    }
}

//The timer creates the sequence to set the display resolution (see PTC task 218252)
on timer t_SetDisplayRes
{
    switch (SetDisplayResState)
    {
        default:
        {
            write("Magna Warning: Wrong value for the Variable *SetDisplayResState*!");
            break;
        }
        case 0:
        {
            setSignal(CM_TCH_STAT, 0); //TCH_NOT_PSD
          
            setTimer(this, 30);
            break;
        }
        case 1:
        {
            setSignal(CM_TCH_X_COORD, @MEnv_DisplayResX_SET_INT_1);
            setSignal(CM_TCH_Y_COORD, @MEnv_DisplayResY_SET_INT_1);
            setSignal(CM_TCH_STAT, 4); //TCH_CFG_RES
            
            setTimer(this, 30);
            break;
        }
        case 2:
        {
            setSignal(CM_TCH_STAT, 0); //TCH_NOT_PSD
          
            setTimer(this, 30);
            break;
        }
        case 3:
        {
            setSignal(CM_TCH_STAT, 6); //TCH_CFG_MAX
          
            setTimer(this, 30);
            break;
        }
        case 4:
        {
            setSignal(CM_TCH_STAT, 0); //TCH_NOT_PSD

            setTimer(this, 30);
            break;
        }
        case 5:
        {
            setSignal(CM_TCH_X_COORD, 0);
            setSignal(CM_TCH_Y_COORD, 0);
            setSignal(CM_TCH_STAT, 5); //TCH_CFG_OFFSET
          
            setTimer(this, 30);
            break;
        }
        case 6:
        {
            setSignal(CM_TCH_STAT, 0); //TCH_NOT_PSD
            break;
        }
    }
    SetDisplayResState++;
}

on envVar MEnv_ViewButtonState_SET_INT_1
{
    switch (@this)
    {
        case 1:
        {
            @MEnv_CameraDisplaySts2_SET_INT_1 = 1;
            
            //@MEnv_DisplayStatus_SET_INT_1 = 7; replaced by @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            setTimer(t_ResetCameraDisplayState, 30);
            break; 
        }
        case 2:
        {
            @MEnv_CameraDisplaySts2_SET_INT_1 = 2;
          
            //@MEnv_DisplayStatus_SET_INT_1 = 7; replaced by @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            setTimer(t_ResetCameraDisplayState, 30);
            break; 
        }
        case 3:
        {
            @MEnv_CameraDisplaySts2_SET_INT_1 = 3;
          
            //@MEnv_DisplayStatus_SET_INT_1 = 7; replaced by @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            setTimer(t_ResetCameraDisplayState, 30);
            break; 
        }
        case 4:
        {
            @MEnv_CameraDisplaySts2_SET_INT_1 = 4;
          
            //@MEnv_DisplayStatus_SET_INT_1 = 7; replaced by @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            @MEnv_TGWCameraDispSts_SET_INT_1 = 4;
            setTimer(t_ResetCameraDisplayState, 30);
            break; 
        }
    }
}

on timer t_ResetCameraDisplayState
{
    @MEnv_CameraDisplaySts2_SET_INT_1 = 0;
}


  //View Switch Sweep
on envVar MEnv_ViewSwitchSweep_SET_BOL_1
{
    if(@this == 1)
    {
        if(@MEnv_ViewSwitchSweepTime_SET_INT_1 > 80) // 75 ms are the minimum
        {
            Repeat_Count = 1;
          
            setTimer(t_ViewSwitch_Sweep, @MEnv_ViewSwitchSweepTime_SET_INT_1);
        }
        else
        {
            //putvalue(MEnv_SysMessage_GET_STG_2, "Warning: The Time between View Switch Sweep is to short!");
            write("Magna Warning: The Time between View Switch Sweep is to short!");
        }
    }
    else
    {
        cancelTimer(t_ViewSwitch_Sweep);
    }
}

on timer t_ViewSwitch_Sweep
{
    for(;;)
    {
        if(Repeat_Count == 1) // Rear and Top
        {
            if(@MEnv_SweepRearAndTop_SET_BOL_1 == 1)
            {
                Repeat_Count = Repeat_Count + 1;
              
                @MEnv_Touch_SET_INT_1 = 1;
                //write("Rear and Top");
              
                setTimer(t_ResetViewSwitchButtons, 40);
              
                break;
            }
            else
            {
                Repeat_Count = Repeat_Count + 1;
            }
        }
        else if(Repeat_Count == 2) // Rear Cross
        {
            if(@MEnv_SweepRearCross_SET_BOL_1 == 1)
            {
                Repeat_Count = Repeat_Count + 1;
              
                @MEnv_Touch_SET_INT_1 = 2;
                //write("Rear Cross");
              
                setTimer(t_ResetViewSwitchButtons, 40);
              
                break;
            }
            else
            {
                Repeat_Count = Repeat_Count + 1;
            }
        }
        else if(Repeat_Count == 3) // Front Cross
        {
            if(@MEnv_SweepFrontCross_SET_BOL_1 == 1)
            {
                Repeat_Count = Repeat_Count + 1;
              
                @MEnv_Touch_SET_INT_1 = 3;
                //write("Front Cross");
              
                setTimer(t_ResetViewSwitchButtons, 40);
              
                break;
            }
            else
            {
                Repeat_Count = Repeat_Count + 1;
            }
        }
        else if(Repeat_Count == 4) // Front and Top
        {
            if(@MEnv_SweepFrontAndTop_SET_BOL_1 == 1)
            {
                Repeat_Count = Repeat_Count + 1;
              
                @MEnv_Touch_SET_INT_1 = 4;
                //write("Front and Top");
              
                setTimer(t_ResetViewSwitchButtons, 40);
              
                break;
            }
            else
            {
                Repeat_Count = Repeat_Count + 1;
            }
        }
        else if(Repeat_Count == 5) // Tow Ball View
        {
            if(@MEnv_SweepTowBallView_SET_BOL_1 == 1)
            {
                Repeat_Count = 10;
              
                @MEnv_Touch_SET_INT_1 = 6;
                //write("TowBall View");
              
                setTimer(t_ResetViewSwitchButtons, 40);
              
                break;
            }
            else
            {
                Repeat_Count = Repeat_Count + 1;
            }
        }
        else if(Repeat_Count == 10) // Cancel Button
        {
            Repeat_Count = 1;
          
            @MEnv_Touch_SET_INT_1 = 5;
            //write("Cancel Button");
          
            setTimer(t_ResetViewSwitchButtons, 40);
          
            break;
        }
        else
        {
            Repeat_Count = 1;
        }
        
        if ((@MEnv_SweepRearAndTop_SET_BOL_1 == 0) && (@MEnv_SweepRearCross_SET_BOL_1 == 0) && (@MEnv_SweepFrontCross_SET_BOL_1 == 0) && (@MEnv_SweepFrontAndTop_SET_BOL_1 == 0) && (@MEnv_SweepTowBallView_SET_BOL_1 == 0))
        {
            //putvalue(MEnv_SysMessage_GET_STG_2, "Warning: There is no View active for the View Switch Sweep function!");
            write("Warning: There is no View active for the View Switch Sweep function!");
            
            @MEnv_ViewSwitchSweep_SET_BOL_1 = 0; // deactivate the View Switch Mode, else the loop could crash the system.
          
            break;
        }
    }
  
    if(@MEnv_ViewSwitchSweepTime_SET_INT_1 > 80) // 75 ms are the minimum
    {
        setTimer(t_ViewSwitch_Sweep, @MEnv_ViewSwitchSweepTime_SET_INT_1);
    }
    else
    {
       // putvalue(MEnv_SysMessage_GET_STG_2, "Warning: The Time between View Switch Sweep is to short!");
        write("Magna Warning: The Time between View Switch Sweep is to short!");
    }
}
