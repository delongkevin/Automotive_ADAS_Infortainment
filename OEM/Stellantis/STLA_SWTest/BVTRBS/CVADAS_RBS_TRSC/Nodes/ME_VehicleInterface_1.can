//Steering Wheel Angle: #Sweep#

on envVar MEnv_StwAngleSweep_SET_INT_1
{
	  if (@this == 1)
    {
        if (@MEnv_StwAngleSweepTime_SET_INT_1 != 0)
        {
            setTimer(t_StwAngle_Sweep, @MEnv_StwAngleSweepTime_SET_INT_1);
        }
        else
        {
            write(" Magna Warning: Sweep time = %d, please enter a valid timer value! ", @MEnv_StwAngleSweepTime_SET_INT_1);
        }
    }
    else
    {
        cancelTimer(t_StwAngle_Sweep);
    }
}

on timer t_StwAngle_Sweep
{
    @MEnv_StwAngleFlt_SET_BOL_1 = 0;
  
    if (STEERINGDIRECTION == 1)
    {
        ANGLE = @MEnv_StwAngle_SET_INT_1 + @MEnv_StwAngleSweepDel_SET_INT_1;
      
        if (ANGLE >= @MEnv_StwAngleSweepMax_SET_INT_1)
        {
            ANGLE = @MEnv_StwAngleSweepMax_SET_INT_1;
            STEERINGDIRECTION = -1;
        }
        else
        {
            // take the calculated ANGLE value
        }
    }
    else if (STEERINGDIRECTION == -1)
    {
        ANGLE = @MEnv_StwAngle_SET_INT_1 - @MEnv_StwAngleSweepDel_SET_INT_1;
        
        if (ANGLE <= @MEnv_StwAngleSweepMin_SET_INT_1)
        {
            ANGLE = @MEnv_StwAngleSweepMin_SET_INT_1;
            STEERINGDIRECTION = 1;
        }
        else
        {
            // take the calculated ANGLE value
        }
    }
    else 
    {
        write(" Magna Warning: Steering Direction is not correct: %d! ", STEERINGDIRECTION);
    }
    
    @MEnv_StwAngle_SET_INT_1 = ANGLE;
    
    setTimer(t_StwAngle_Sweep, @MEnv_StwAngleSweepTime_SET_INT_1);
}

