on envVar MEnv_AscmStatusFlt_SET_BOL_1
{
    if(@this==1)    // checkbox checked
    {
       ASCMSTATUS_BUFFER = @MEnv_AscmStatus_GET_INT_1;
        @MEnv_AscmStatus_SET_INT_1 = 0x0F;
    }
    else
    {
        //checkbox unchecked, put last value before fault
        @MEnv_AscmStatus_SET_INT_1 = ASCMSTATUS_BUFFER;
    }
} 
