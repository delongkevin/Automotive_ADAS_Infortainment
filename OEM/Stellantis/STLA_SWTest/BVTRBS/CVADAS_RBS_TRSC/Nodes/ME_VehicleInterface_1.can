on envVar MEnv_BatteryVoltFlt_SET_BOL_1
{
    if (@this == 1)
    {
        BATTERYVOLT_BUFFER = @MEnv_BatteryVolt_GET_FLT_1;
      
        enableControl("Main", "BatteryVolt_Input/Output", 0);
      
        @MEnv_BatteryVolt_SET_FLT_1 = BATTERYVOLT_FAULT;
    }
    else
    {
        @MEnv_BatteryVolt_SET_FLT_1 = BATTERYVOLT_BUFFER;
      
        enableControl("Main", "BatteryVolt_Input/Output", 1);
    }
}
