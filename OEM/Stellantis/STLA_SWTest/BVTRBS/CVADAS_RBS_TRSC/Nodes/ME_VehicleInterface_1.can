on envVar MEnv_Touch_SET_INT_1
{
    switch(@this)
    {
        case 0: // Jump back to Not Pressed
        {
            setSignal(CM_TCH_STAT, 0);         
            setSignal(CM_TCH_X_COORD, 0);
            setSignal(CM_TCH_Y_COORD, 0);
        }
        break;
        
        
        case 1: // Rear & Top
        {
            @MEnv_EmvViewState_GET_INT_1 = 1;
            if (@MEnv_DisplayRes_SET_INT_1 == 0)  //RES_DT_1024x768
            {
              setSignal(CM_TCH_X_COORD, 410);
              setSignal(CM_TCH_Y_COORD, 700);
            }
            else                                  //RES_DT_640x480 and all others
            {
              setSignal(CM_TCH_X_COORD, 258);
              setSignal(CM_TCH_Y_COORD, 437);
            }
            setSignal(CM_TCH_STAT, 1);
        }
        break;
        
        
        case 2: // Rear Cross
        {
            @MEnv_EmvViewState_GET_INT_1 = 2;
            if (@MEnv_DisplayRes_SET_INT_1 == 0)  //RES_DT_1024x768
            {
              setSignal(CM_TCH_X_COORD, 550);
              setSignal(CM_TCH_Y_COORD, 700);
            }
            else                                  //RES_DT_640x480 and all others
            {
              setSignal(CM_TCH_X_COORD, 344);
              setSignal(CM_TCH_Y_COORD, 437);
            }
            setSignal(CM_TCH_STAT, 1);
        }
        break;
        
        
        case 3: // Front Cross
        {
            @MEnv_EmvViewState_GET_INT_1 = 3;
            if (@MEnv_DisplayRes_SET_INT_1 == 0)  //RES_DT_1024x768
            {
              setSignal(CM_TCH_X_COORD, 690);
