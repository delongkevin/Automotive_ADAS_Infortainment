on envVar MEnv_IgnStatus_SET_INT_1
{
    setSignal(CmdIgnSts, @this);
}

on signal CmdIgnSts
{
    @MEnv_IgnStatus_GET_INT_1 = this;
}

on envVar MEnv_IgnStatusFlt_SET_BOL_1
{
    if(@this==1)    // checkbox checked
    {
        IGNSTATUS_BUFFER = @MEnv_IgnStatus_SET_INT_1;
        @MEnv_IgnStatus_SET_INT_1 = IGNITION_FAULT;
    }
    else
    {
        //checkbox unchecked, put last value before fault
        @MEnv_IgnStatus_SET_INT_1 = IGNSTATUS_BUFFER;
    }
}

