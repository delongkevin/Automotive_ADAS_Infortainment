on preStart
{
  
}

on start
{
//initial values from the DBC---------------

//------------------------------------------
  
//initial values general--------------------
    @MEnv_StwAngleSweepTime_SET_INT_1 = 60;  
    @MEnv_StwAngleSweepMin_SET_INT_1 = -500;
    @MEnv_StwAngleSweepMax_SET_INT_1 = 500;
    @MEnv_StwAngleSweepDel_SET_INT_1 = 8;
    @MEnv_StwAngleSweep_SET_INT_1 = 0; 
    @MEnv_EmvViewSweepTime_SET_INT_1 = 2000;
    @MEnv_EmvViewSweep_SET_BOL_1 = 0;
  
    @MEnv_SweepRearAndTop_SET_BOL_1 = 1;
    @MEnv_SweepRearCross_SET_BOL_1 = 1;
    @MEnv_SweepFrontCross_SET_BOL_1 = 1;
    @MEnv_SweepFrontAndTop_SET_BOL_1 = 1;
    @MEnv_SweepTowBallView_SET_BOL_1 = 1;
    @MEnv_ViewSwitchSweepTime_SET_INT_1 = 1000;
  
    @MEnv_VehSpeedSweepTime_SET_INT_1 = 2000;  
    @MEnv_VehSpeedSweepMin_SET_INT_1 = 0;
    @MEnv_VehSpeedSweepMax_SET_INT_1 = 60;
    @MEnv_VehSpeedSweepDel_SET_INT_1 = 10;
    @MEnv_VehSpeedSweep_SET_BOL_1 = 0; 

    @MEnv_DisplayRes_SET_INT_1 = 0xFF; // undefined
//------------------------------------------
  
//initial variant
    @MEnv_DefaultVariant_SET_INT_1 = 7; // Vehicle Variant JT
  
  
    @MEnv_EmvMode_SET_INT_2 = 0;
}

on preStop
{
    @MEnv_Default_SET_BOL_1 = 0;
}

on envVar MEnv_Default_SET_BOL_1
{
    // Sets all MAGNA ENVs and SYSVARs to valid values
    if(@this == 1)
    {
        //PROXI string default values
        @MEnv_DriverSide_SET_INT_3 = 0;
        @MEnv_Wheelbase_SET_INT_3 = 1;
        @MEnv_SideDistanceWarning_SET_INT_3 = 1;
        @MEnv_SteeringRatioRackPinionType_SET_INT_3 = 2;
        @MEnv_GearBoxType_SET_INT_3 = 4;
        @MEnv_VehicleLineConfiguration_SET_INT_3 = 93;
        @MEnv_PamConfiguration_SET_INT_3 = 1;
        @MEnv_SurroundViewCamera_SET_INT_3 = 1;
        @MEnv_CountryCode_SET_INT_3 = 2;
        @MEnv_CarShapeConfiguration_SET_INT_3 = 8;
        @MEnv_ModelYear_SET_INT_3 = 0x15;
      
        @MEnv_SendProxiString_SET_INT_3 = 1;
      
        //---------------------------------------------
      
        ANGLE = @MEnv_StwAngle_SET_INT_1;
      
        enableControl("Main", "DefaultVariant_TrackBar", 0);
      
        @MEnv_ActivateAllNodes_SET_BOL_2 = 1; // start the nodes
      
        @MEnv_StwAngle_SET_INT_1 = 0;
        @MEnv_StwAngleSensor_SET_INT_1 = 0; // OK
        @MEnv_VehSpeed_SET_FLT_1 = 0;
        @MEnv_TransmissionType_SET_INT_1 = 0; // Automatic
        @MEnv_VcVehCfg7Stat_SET_INT_1 = 1;
        @MEnv_VcSvcPrsnt_SET_INT_1 = 1;
        @MEnv_VcBodyStyle_SET_INT_1 = 7; // 4DP
        @MEnv_VcCountry_SET_INT_1 = 2; // USA
        @MEnv_VcModelYear_SET_INT_1 = 2019;
        @MEnv_VcVehCfg1Stat_SET_INT_1 = 1;
        @MEnv_NetCfgStatInt_SET_INT_1 = 1;
        @MEnv_VcVehCfg3Stat_SET_INT_1 = 1;
        @MEnv_VcChassisType_SET_INT_1 = 0;
        @MEnv_Odo_SET_FLT_1 = 0;
        @MEnv_GearAutomatic_SET_INT_1 = 0; // LVR_P
        @MEnv_BatteryVolt_SET_FLT_1 = 12;
        @MEnv_BatteryVoltFlt_SET_BOL_1 = 0;
        @MEnv_IgnStatus_SET_INT_1 = 4;
//        @EnvClamp15 = 1;
//        @EnvClamp30 = 1;
        @MEnv_VcVehCfg2Stat_SET_INT_1 = 1;
        @MEnv_VcVehCfg8Stat_SET_INT_1 = 1;
        @MEnv_VcWhlBaseLength_SET_INT_1 = 2;
        @MEnv_VcSteeringCfactor_SET_INT_1 = 0;
        @MEnv_AscmStatus_SET_INT_1 = 4;
        @MEnv_VcVehCfg5Stat_SET_INT_1 = 1;
        @MEnv_VcOFFroadCamera_SET_INT_1 = 1;
      
        @MEnv_AuxCameraStat_SET_INT_1 = 0;
        @MEnv_VcAuxTrailerCamPrsnt_SET_BOL_1 = 0;
        @MEnv_VcSpecialPkgIc_SET_INT_1 = 0;
      
        switch(@MEnv_DefaultVariant_SET_INT_1)
        {
            case 0: // Vehicle Variant DF
            {
                @MEnv_VcVehLine_SET_INT_1 = 48;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 9;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 1;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 0;  
                break;
            }
            case 1: // Vehicle Variant DD
            {
                @MEnv_VcVehLine_SET_INT_1 = 32;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 8;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 1;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 0;  
                break;
            }
            case 2: // Vehicle Variant DP
            {
                @MEnv_VcVehLine_SET_INT_1 = 33;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 11;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 2;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 1;  
                break;
            }
            case 3: // Vehicle Variant Magna Jeep
            {
                @MEnv_VcVehLine_SET_INT_1 = 254;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 2;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 0;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 0;  
                break;
            }
            /*
            case 4: // Vehicle Variant DT
            {
                @MEnv_VcVehLine_SET_INT_1 = 53;
                break;
            }
            */
            case 5: // Vehicle Variant D2
            {
                @MEnv_VcVehLine_SET_INT_1 = 31;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 5;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 0;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 0;  
                break;
            }
            case 6: // Vehicle Variant DJ
            {
                @MEnv_VcVehLine_SET_INT_1 = 34;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 2;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 0;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 0;              
                break;
            }
            case 7: // Vehicle Variant JT
            {
                @MEnv_VcVehLine_SET_INT_1 = 55;
              
                @MEnv_VcWhlBaseLength_SET_INT_1 = 2;
                @MEnv_VcSteeringCfactor_SET_INT_1 = 0;
                @MEnv_VcRrDuallyPrsnt_SET_INT_1 = 0;              
                break;
            }
            case 99: // no Variant choosed
            {
                write("Magna Warning: No Default Variant is choosed!");
                break;
            }
        }
        
        @MEnv_DisplayRes_SET_INT_1 = 0xFF; // undefined
      
        setTimer(t_DefaultDelay, 5000); // Delay to initilize the Signals after the Nodes are started
    }
    else
    {
        // ignore button release
    }
}

