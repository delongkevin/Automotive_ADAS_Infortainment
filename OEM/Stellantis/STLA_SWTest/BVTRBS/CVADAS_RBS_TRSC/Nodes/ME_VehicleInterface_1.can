on envVar MEnv_VehSpeed_SET_FLT_1
{
    setsignal(VehicleSpeedVSOSig, @this);
}

on envVar MEnv_VehSpeedFlt_SET_BOL_1
{
    if (@this == 1)
    {
        VEHSPEED_BUFFER = @MEnv_VehSpeed_GET_FLT_1;
      
        enableControl("Main", "Speed_TrackBar", 0);
        enableControl("Main", "Speed_Input/Output", 0); 
      
        @MEnv_VehSpeed_SET_FLT_1 = VEHSPEED_FAULT;
    }
    else
    {
        @MEnv_VehSpeed_SET_FLT_1 = VEHSPEED_BUFFER;
      
        enableControl("Main", "Speed_TrackBar", 1);
        enableControl("Main", "Speed_Input/Output", 1); 
    }
}

on signal VehicleSpeedVSOSig
{
    @MEnv_VehSpeed_GET_FLT_1 = this;
}

//Speed: #Sweep#

on envVar MEnv_VehSpeedSweep_SET_BOL_1
{
	  if (@this == 1)
    {
        if (@MEnv_VehSpeedSweepTime_SET_INT_1 != 0)
        {
            setTimer(t_VehSpeed_Sweep, @MEnv_VehSpeedSweepTime_SET_INT_1);
        }
        else
        {
            write(" Magna Warning: Speed Sweep time = %d, please enter a valid timer value! ", @MEnv_VehSpeedSweepTime_SET_INT_1);
        }
    }
    else
    {
        cancelTimer(t_VehSpeed_Sweep);
    }
}

on timer t_VehSpeed_Sweep
{
    @MEnv_VehSpeedFlt_SET_BOL_1 = 0;
  
    if (SPEEDDIRECTION == 1)
    {
        SPEED = @MEnv_VehSpeed_SET_FLT_1 + @MEnv_VehSpeedSweepDel_SET_INT_1;
      
        if (SPEED >= @MEnv_VehSpeedSweepMax_SET_INT_1)
        {
            SPEED = @MEnv_VehSpeedSweepMax_SET_INT_1;
            SPEEDDIRECTION = -1;
        }
        else
        {
            // take the calculated ANGLE value
        }
    }
    else if (SPEEDDIRECTION == -1)
    {
        SPEED = @MEnv_VehSpeed_SET_FLT_1 - @MEnv_VehSpeedSweepDel_SET_INT_1;
        
        if (SPEED <= @MEnv_VehSpeedSweepMin_SET_INT_1)
        {
            SPEED = @MEnv_VehSpeedSweepMin_SET_INT_1;
            SPEEDDIRECTION = 1;
        }
        else
        {
            // take the calculated SPEED value
        }
    }
    else 
    {
        write(" Magna Warning: Speed Direction is not correct: %d! ", SPEEDDIRECTION);
    }
    
    @MEnv_VehSpeed_SET_FLT_1 = SPEED;
    
    setTimer(t_VehSpeed_Sweep, @MEnv_VehSpeedSweepTime_SET_INT_1);
}

