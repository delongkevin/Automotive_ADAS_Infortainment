{
    setSignal(TotalOdometer, @this);
}

on signal TotalOdometer
{
    @MEnv_Odo_GET_FLT_1 = this;
}

on envVar MEnv_OdoFlt_SET_BOL_1
{
    if (@this == 1)
    {
        ODOMETER_BUFFER = @MEnv_Odo_GET_FLT_1;
      
        enableControl("Main", "Odometer_Input/Output", 0);
      
        @MEnv_Odo_SET_FLT_1 = ODOMETER_FAULT;
    }
    else
    {
        @MEnv_Odo_SET_FLT_1 = ODOMETER_BUFFER;
      
        enableControl("Main", "Odometer_Input/Output", 1);
    }
}
