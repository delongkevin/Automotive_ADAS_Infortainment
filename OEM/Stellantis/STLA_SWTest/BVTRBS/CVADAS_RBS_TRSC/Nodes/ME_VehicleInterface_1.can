        {
            @MEnv_DoorFl_SET_INT_1 = 0;
            @MEnv_DoorFr_SET_INT_1 = 0;
            @MEnv_DoorRl_SET_INT_1 = 0;
            @MEnv_DoorRr_SET_INT_1 = 0;
            @MEnv_DoorDrv_SET_INT_1 = 0;
            @MEnv_DoorPsg_SET_INT_1 = 0;
        }
        break;
        
        case (2):         // OPN
        {
            @MEnv_DoorFl_SET_INT_1 = 1;
            @MEnv_DoorFr_SET_INT_1 = 1;
            @MEnv_DoorRl_SET_INT_1 = 1;
            @MEnv_DoorRr_SET_INT_1 = 1;
            @MEnv_DoorDrv_SET_INT_1 = 1;
            @MEnv_DoorPsg_SET_INT_1 = 1;
        }
        break;
        
        case (3):         // SNA
        {
            @MEnv_DoorFl_SET_INT_1 = 3;
            @MEnv_DoorFr_SET_INT_1 = 3;
            @MEnv_DoorRl_SET_INT_1 = 3;
            @MEnv_DoorRr_SET_INT_1 = 3;
            @MEnv_DoorDrv_SET_INT_1 = 3;
            @MEnv_DoorPsg_SET_INT_1 = 3;
        }
        break;
    }
}

