//-----------------------------------------------------------

// VIN
//-----------------------------------------------------------
on message VIN
{
    byte b_set[20];
    char c_set[20];
  
    getValue(MEnv_Vin_SET_STG_1, c_set);
  
    b_set[0] = c_set[0];
    b_set[1] = c_set[1];
    b_set[2] = c_set[2];
    b_set[3] = c_set[3];
    b_set[4] = c_set[4];
    b_set[5] = c_set[5];
    b_set[6] = c_set[6];
    b_set[7] = c_set[7];
    b_set[8] = c_set[8];
    b_set[9] = c_set[9];
    b_set[10] = c_set[10];
    b_set[11] = c_set[11];
    b_set[12] = c_set[12];
    b_set[13] = c_set[13];
    b_set[14] = c_set[14];
    b_set[15] = c_set[15];
    b_set[16] = c_set[16];
  
    if (@MEnv_VinMsgFlt_SET_BOL_2 == 1)
    {
        setSignal(VIN_MSG, 3);
    }
    else
    {
        if(getSignal(VIN_MSG) == 0)
        {
            VIN_SET_BUFFER = 0x00;
            VIN_SET_BUFFER = b_set[7];
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[8];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[9];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[10];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[11];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[12];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[13];// || VIN_SET_BUFFER;
          
            setRawSignal(VIN_DATA, VIN_SET_BUFFER);
            setSignal(VIN_MSG, 1);
        }
        else if(getSignal(VIN_MSG) == 1)
        {
            VIN_SET_BUFFER = 0x00;
            VIN_SET_BUFFER = b_set[14];
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[15];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[16];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + 0x00;// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + 0x00;// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + 0x00;// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + 0x00;// || VIN_SET_BUFFER;
          
            setRawSignal(VIN_DATA, VIN_SET_BUFFER);
            setSignal(VIN_MSG, 2);
        }
        else if(getSignal(VIN_MSG) == 2)
        {   
            VIN_SET_BUFFER = 0x00;
            VIN_SET_BUFFER = b_set[0];
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[1];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[2];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[3];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[4];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[5];// || VIN_SET_BUFFER;
            VIN_SET_BUFFER = VIN_SET_BUFFER << 8;
            VIN_SET_BUFFER = VIN_SET_BUFFER + b_set[6];// || VIN_SET_BUFFER;
          
            setRawSignal(VIN_DATA, VIN_SET_BUFFER);
            setSignal(VIN_MSG, 0);
        }
        else
        {
            setSignal(VIN_MSG, 0);
        }
    }
}

on signal VIN_MSG
{
    byte b[20];
    char c[20];
  
    @MEnv_VinMsg_GET_INT_1 = this;
  
    VIN_BUFFER = getRawSignal(VIN_DATA);
    
    if (this == 0)
    {
        b[0] = VIN_BUFFER >> 48;
        b[1] = VIN_BUFFER >> 40;
        b[2] = VIN_BUFFER >> 32;
        b[3] = VIN_BUFFER >> 24;
        b[4] = VIN_BUFFER >> 16;
        b[5] = VIN_BUFFER >> 8;
        b[6] = VIN_BUFFER >> 0;
    }
    else if (this == 1)
    {
        b[7] = VIN_BUFFER >> 48;
        b[8] = VIN_BUFFER >> 40;
        b[9] = VIN_BUFFER >> 32;
        b[10] = VIN_BUFFER >> 24;
        b[11] = VIN_BUFFER >> 16;
        b[12] = VIN_BUFFER >> 8;
        b[13] = VIN_BUFFER >> 0;
    }
    else if (this == 2)
    {
        b[14] = VIN_BUFFER >> 48;
        b[15] = VIN_BUFFER >> 40;
        b[16] = VIN_BUFFER >> 32;
        //b[3] = VIN_BUFFER >> 24;
        //b[4] = VIN_BUFFER >> 16;
        //b[5] = VIN_BUFFER >> 8;
        //b[6] = VIN_BUFFER >> 0;
    }
    
    c[0] = b[0];
    c[1] = b[1];
    c[2] = b[2];
    c[3] = b[3];
    c[4] = b[4];
    c[5] = b[5];
    c[6] = b[6];
    c[7] = b[7];
    c[8] = b[8];
    c[9] = b[9];
    c[10] = b[10];
    c[11] = b[11];
    c[12] = b[12];
    c[13] = b[13];
    c[14] = b[14];
    c[15] = b[15];
    c[16] = b[16];
    
    putValue(MEnv_Vin_GET_STG_1, c);
}
//-----------------------------------------------------------

on message *
{
int init_state[100];  
  
    switch(this.id)
    {
        case 0x3E6: // Steering Wheel Angle
        {
            if (init_state[0] == 0)
            {
                //setSignal(LWSAngle, @MEnv_StwAngle_SET_INT_1);

                //setSignal(LWSFailSts, @MEnv_StwAngleSensor_SET_INT_1);
              
                setSignal(ShiftLeverPosition , @MEnv_GearAutomatic_SET_INT_1);
              
                init_state[0] = 1;
            }
        }
        break;
        
        case 0x322: // Vehicle Speed
        {
            if (init_state[1] == 0)
            {
                setsignal(VehicleSpeedVSOSig, @MEnv_VehSpeed_SET_FLT_1);
              
                init_state[1] = 1;
            }
        }
        break;
        
        case 0x381: // Gear
        {
            if (init_state[2] == 0)
            {
//                setsignal(VC_Trans_Equipped, @MEnv_TransmissionType_SET_INT_1); // Signal Control 0 = Automatic and 1 = Manual

//                setsignal(VC_VehCfg7_Stat, @MEnv_VcVehCfg7Stat_SET_INT_1);

//                setSignal(VC_SVC_Prsnt, @MEnv_VcSvcPrsnt_SET_INT_1);
              
                init_state[2] = 1;
            }
        }
        break;
        
        case 0x5BC: // Vehicle Config
        {
            if (init_state[3] == 0)
            {
//                setsignal(VC_BODY_STYLE, @MEnv_VcBodyStyle_SET_INT_1);

                setsignal(LanguageSelection, @MEnv_VcCountry_SET_INT_1);

//                setsignal(VC_MODEL_YEAR, @MEnv_VcModelYear_SET_INT_1);
              
//                setsignal(VC_VEH_LINE, @MEnv_VcVehLine_SET_INT_1);

//                setsignal(VC_VehCfg1_Stat, @MEnv_VcVehCfg1Stat_SET_INT_1);
                              
                init_state[3] = 1;
            }
        }
        break;
        
        case 0x3E3: // Net Config
        {
            if (init_state[4] == 0)
            {
//                setsignal(NET_CFG_STAT_INT, @MEnv_NetCfgStatInt_SET_INT_1);
                                            
                init_state[4] = 1;
            }
        }
        break;
        
        case 0x3EA: // VehCfg3
        {
            if (init_state[5] == 0)
            {
//                setsignal(VC_VehCfg3_Stat, @MEnv_VcVehCfg3Stat_SET_INT_1);

//                setSignal(VC_ChassisType, @MEnv_VcChassisType_SET_INT_1);
                                                          
                init_state[5] = 1;
            }
        }
        break;
        
        case 0x3D2: // GW_C4
        {
            if (init_state[6] == 0)
            {
                //setSignal(ODO, @MEnv_Odo_SET_FLT_1);
                                                                        
                init_state[6] = 1;
            }
        }
        break;
        
        case 0x332: // GW_C_I3
        {
            if (init_state[7] == 0)
            {
                setSignal(ShiftLeverPosition , @MEnv_GearAutomatic_SET_INT_1);
                                                                                      
                init_state[7] = 1;
            }
        }
        break;
        
        case 0x46C: // CBC_I3
        {
            if (init_state[8] == 0)
            {
               // setSignal(BatteryVoltageLevel, @MEnv_BatteryVolt_SET_FLT_1);
                     
                setSignal(CmdIgnSts, @MEnv_IgnStatus_SET_INT_1);
              
                init_state[8] = 1;
            }
        }
        break;
        
        case 0x122: // CBC_I4
        {
            if (init_state[9] == 0)
            {
                setSignal(CmdIgnSts, @MEnv_IgnStatus_SET_INT_1);
                                                                                                    
                init_state[9] = 1;
            }
        }
        break; 
        
        case 0x3E9: // VehCfg2
        {
            if (init_state[10] == 0)
            {
//                setsignal(VC_VehCfg2_Stat, @MEnv_VcVehCfg2Stat_SET_INT_1);
              
//                setSignal(VC_SpecialPKG_IC, @MEnv_VcSpecialPkgIc_SET_INT_1);
              
                init_state[10] = 1;
            }
        }
        break;
        
        case 0x38A: // VehCfg8
        {
            if (init_state[11] == 0)
            {
//                setsignal(VC_VehCfg8_Stat, @MEnv_VcVehCfg8Stat_SET_INT_1);

                //setSignal(VC_WHL_BASE_LENGTH, @MEnv_VcWhlBaseLength_SET_INT_1);
              
//                setSignal(VC_Steering_Cfactor, @MEnv_VcSteeringCfactor_SET_INT_1);
                
//                setSignal(VC_OFFroad_Camera, @MEnv_VcOFFroadCamera_SET_INT_1);
              
                init_state[11] = 1;
            }
        }
        break;
        
        case 0x2E0: // GW_C_I_11
        {
            if (init_state[12] == 0)
            {
                //setsignal(ASCM_Stat, @MEnv_AscmStatus_SET_INT_1);
              
                init_state[12] = 1;
            }
        }
        break;
        
        case 0x44A: // VehCfg5
        {
            if (init_state[13] == 0)
            {
//                setsignal(VC_VehCfg5_Stat, @MEnv_VcVehCfg5Stat_SET_INT_1);
              
//                setSignal(VC_RR_DuallyPrsnt, @MEnv_VcRrDuallyPrsnt_SET_INT_1);
              
                init_state[13] = 1;
            }
        }
        break;
    }
}

