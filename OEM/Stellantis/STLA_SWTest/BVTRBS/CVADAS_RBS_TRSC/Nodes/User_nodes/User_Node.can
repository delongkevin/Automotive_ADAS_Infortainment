on sysvar User_Node::X_Cordinate_SET_INT_1
{
  if(@User_Node::X_Cordinate_SET_INT_1!=0)
  {
  write("XCord");
  
  $TELEMATIC_FD_5::CM_TCH_X_COORD=@User_Node::X_Cordinate_SET_INT_1;
    @User_Node::X_Cordinate_SET_INT_1=0;
  }
}


on sysvar User_Node::Y_Cordinate_SET_INT_1
{
  if(@User_Node::Y_Cordinate_SET_INT_1!=0)
  {
  write("YCord");
  
  $TELEMATIC_FD_5::CM_TCH_Y_COORD=@User_Node::Y_Cordinate_SET_INT_1;
    @User_Node::Y_Cordinate_SET_INT_1=0;
  }
}

on sysvar User_Node::CM_TCH_STAT_SET_INT_1
{
  if(@User_Node::CM_TCH_STAT_SET_INT_1!=0)
  {
  write("CM_TCH_STAT");
  $TELEMATIC_FD_5::CM_TCH_STAT=@User_Node::CM_TCH_STAT_SET_INT_1;
  setTimer(CM_TCH_STAT, 2000);
  @User_Node::CM_TCH_STAT_SET_INT_1=0;
  }
}

on timer CM_TCH_STAT
{
  
  $TELEMATIC_FD_5::CM_TCH_STAT=0;
  cancelTimer(CM_TCH_STAT);
}

on envVar MEnv_ManualDisplayRes_SET_INT_1
{
  if(@this==1)
   {
  @User_Node::CM_TCH_STAT_SET_INT_1=1;
  @User_Node::X_Cordinate_SET_INT_1=@MEnv_DisplayResX_SET_INT_1;
  @User_Node::Y_Cordinate_SET_INT_1=@MEnv_DisplayResY_SET_INT_1;
  }
  
  else 
    { 
       }
}

on sysvar Message_Control::CameraDisplaySta2
{
  $CameraDisplaySts2 = @this;
}

on signal CameraDisplaySts2
{
  @Message_Control::CameraDisplaySta2 = this;
}