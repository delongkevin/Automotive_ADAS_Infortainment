/*@!Encoding:1252*/
  variables
{
  diagRequest CVADAS_0001_00000000_000.* diag_Request;
  byte diag_Response[300];
  msTimer CM_TCH_STAT;
}



on start
{
  @IL::Klemme15=0;
  @IL::Klemme30=0;
  $CmdIgnSts=0;
  @MEnv_Read_Proxi_DID_0x2024=0;
  sendDiagRequestFor_Read_Proxi_DID_0x2024();
  @User_Node::CM_TCH_STAT_SET_INT_1=0;
  @User_Node::X_Cordinate_SET_INT_1=0;
  @User_Node::Y_Cordinate_SET_INT_1=0;
  @MEnv_IgnStatus_GET_INT_1 = 0;
  @MEnv_IgnStatus_SET_INT_1 = 0;
  @MEnv_DisplayResX_SET_INT_1=0;
  @MEnv_DisplayResY_SET_INT_1=0;
  @MEnv_ManualDisplayRes_SET_INT_1=0;
  
}

On envVar MEnv_Send_Read_Proxi_DID_0x2024
{
   if(@this==1) sendDiagRequestFor_Read_Proxi_DID_0x2024();
}


void sendDiagRequestFor_Read_Proxi_DID_0x2024()
{
  @MEnv_Read_Proxi_DID_0x2024=0;
  diagResize(diag_Request,3);
  DiagSetPrimitiveByte(diag_Request,0,0x22);
  DiagSetPrimitiveByte(diag_Request,1,0x20);
  DiagSetPrimitiveByte(diag_Request,2,0x24);
  diagSendRequest(diag_Request);
  write("Request Sent for Read_Proxi_DID_0x2024");
  
}


on diagResponse CVADAS_0001_00000000_000.*{
  int i;
  
  this.GetPrimitiveData(diag_Response,elCount(diag_Response));
  if(diag_Response[2] != 0x78)
  
     if((diag_Response[0] == 0x62) && (diag_Response[1] == 0x20) && (diag_Response[2] == 0x24))
    {
       @MEnv_Read_Proxi_DID_0x2024=1;
       write("Response received for Read_Proxi_DID_0x2024");
       @MEnv_Proxi_Radio_Display_Type_SET_INT_1=(diag_Response[187] & 0xF);
        @MEnv_Forward_facing_camera_SET_INT_1=(diag_Response[179] & 0x2);
    }
    else if(diag_Response[0] == 0x7F)
    {
      
      write("Proxi data read error");
    }
   

}




on envVar MEnv_Rear_360_soft_button_SET_INT_1
{
  if(@this==1)
   { 
   
      if(@MEnv_Proxi_Radio_Display_Type_SET_INT_1==0x07)
      { 
        @User_Node::CM_TCH_STAT_SET_INT_1=1;
        @User_Node::X_Cordinate_SET_INT_1=80;
        @User_Node::Y_Cordinate_SET_INT_1=830;
    }
    else if(@MEnv_Proxi_Radio_Display_Type_SET_INT_1== 0x02 || @MEnv_Proxi_Radio_Display_Type_SET_INT_1 == 0x09 )
    {  @User_Node::CM_TCH_STAT_SET_INT_1=1;
       @User_Node::X_Cordinate_SET_INT_1=80;
       @User_Node::Y_Cordinate_SET_INT_1=710;
    }

  else {
  //do nothing 
        }
  }
  
}
