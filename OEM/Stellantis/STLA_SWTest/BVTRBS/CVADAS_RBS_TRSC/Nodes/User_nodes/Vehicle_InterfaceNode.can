on sysvar User_Node::Set_PreCondition_FPA
{
  setsignal(CmdIgnSts, 4);
  setSignal(GearEngaged, 1);
  setSignal(VehicleSpeedVSOSig, 6);
  setSignal(Shifter_ADAS_Inhibit, 1);
  setSignal(EngineSts_W, 2);
  setSignal(Active_Park_Mode, 0);
  setSignal(TRANS_ADAS_Inhibit, 1);
  setSignal(EPBSts,0);
  setSignal(TrailerConnectionSts, 0);
  setSignal(TCASERANGESTATUS, 2);
  setSignal(ITBM_TrlrStat, 0);
 @MEnv_close_all_doors = 1;
  
}
on sysvar User_Node::ENABLE_FPA
{
  setSignal (FT_PAMRequestSts, 1);
  setTimer(msTimer_FT_PAMRequestSts, 1000); 
  
  
}
on timer msTimer_FT_PAMRequestSts
{
  $FT_PAMRequestSts = 0;
}

//on signal FT_PAMRequestSts
//{
