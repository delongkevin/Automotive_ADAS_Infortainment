//      setTimer(msTimer_FT_PAMRequestSts, 1000); 
//  }
//}

on sysvar User_Node::Set_PreCondition_RPA
{
  setsignal(CmdIgnSts, 4);
  setSignal(GearEngaged, 1);
  setSignal(VehicleSpeedVSOSig, 6);
  setSignal(Shifter_ADAS_Inhibit, 1);
  setSignal(EngineSts_W, 2);
  setSignal(Active_Park_Mode, 0);
  setSignal(TRANS_ADAS_Inhibit, 1);
  setSignal(EPBSts,0);
  setSignal(TrailerConnectionSts, 0);
  setSignal(TCASERANGESTATUS, 2);
  setSignal(ITBM_TrlrStat, 0);
 @MEnv_close_all_doors = 1;
}
on sysvar User_Node::ENABLE_RPA
{
  setSignal (PAMRequestSts, 1);
  setTimer(msTimer_PAMRequestSts, 1000); 
}
on timer msTimer_PAMRequestSts
{
  $PAMRequestSts = 0;
}



on sysvar User_Node::Set_PreCondition_Full_Autopark
{
  setsignal(CmdIgnSts, 4);
  setSignal(GearEngaged, 1);
  setSignal(VehicleSpeedVSOSig, 6);
  setSignal(Shifter_ADAS_Inhibit, 1);
  setSignal(EngineSts_W, 2);
  setSignal(Active_Park_Mode, 0);
  setSignal(TRANS_ADAS_Inhibit, 1);
  setSignal(EPBSts,0);
  setSignal(TrailerConnectionSts, 0);
  setSignal(TCASERANGESTATUS, 2);
  setSignal(ITBM_TrlrStat, 0);
 @MEnv_close_all_doors = 1;
}
on sysvar User_Node::ENABLE_AutoPark
{
  setSignal (APARequestSts, 1);
  setTimer(msTimer_APARequestSts, 1000); 
}
on timer msTimer_APARequestSts
{
  $APARequestSts = 0;
}