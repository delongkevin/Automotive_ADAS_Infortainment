/*@!Encoding:1252*/
includes
{
  
}

variables
{
  msTimer msVehSpeedSweepTimer;
  msTimer msStwAngleSweepTimer, msTimer_FT_PAMRequestSts, msTimer_PAMRequestSts, msTimer_APARequestSts;
  int sweepVehSpeed=0;
  int sweepStwAngle=0;
  Timer IGN_ON;
  Timer CANreset;
  msTimer msCANresetreturn;
}


on start
{
  
  @MEnv_StwAngleSweep_SET_BOL_1 = 0;
  @MEnv_StwAngleSweepDel_SET_FLT_1 = 1;
  @MEnv_StwAngleSweepMax_SET_FLT_1 = 720;
  @MEnv_StwAngleSweepMin_SET_FLT_1 = -720;
  @MEnv_StwAngleSweepTime_SET_INT_1 = 100;
  @MEnv_VehSpeedSweep_SET_BOL_1 = 0;
  @MEnv_VehSpeedSweepDel_SET_INT_1 = 1;
  @MEnv_VehSpeedSweepMax_SET_INT_1 = 511.875;
  @MEnv_VehSpeedSweepMin_SET_INT_1 = 0;
  @MEnv_VehSpeedSweepTime_SET_INT_1 = 100;
  // Default button pressed on Start
  @IL::Klemme15 =1;
  @IL::Klemme30 = 1;
  @MEnv_IgnStatus_SET_INT_1 = 0;
 
  setSignal(ESS_ENG_ST_W,3);
  setSignal(EngineSts_W,2);
  setSignal(SBR1RowDriverSeatSts, 2);
  //For DTC C41800
  setSignal(REF_VEH_SPEED, 0);
  setSignal(VehicleStandStillSts, 0);
  setSignal(LHR_Spin, 0);
  setSignal(RHR_Spin, 0);
  setSignal(EPBSts, 0);
  setSignal(LatAcceleration_BSM, 0);
  setSignal(LongAcceleration_BSM, 0);
  setSignal(YawRate_BSM, 0);
  setSignal(LongAccelerationOffset_BSM, 0);
  setSignal(LatAccelerationOffset_BSM, 0);
  
  
  //For DTC C42000
  setSignal(LwsAngle, 0);
  setSignal(LwsSpeed, 0);
  setSignal(EPS_SteeringTouchStat, 1);
  
  
  // For DTC C42200
  setSignal(ShiftLeverPositionReq, 3);
  setSignal(TurnIndicatorSts, 0);
  setSignal(ExternalTemperature, 0);
  setSignal(LanguageSelection, 2);
  setSignal(TargetGear, 0);
  setSignal(TRANS_ADAS_Inhibit, 1);
  setSignal(VIN_MSG, 0);
  setSignal(FL_Lvl, 0);
  setSignal(FR_Lvl, 0);
  setSignal(RL_Lvl, 0);
  setSignal(RR_Lvl, 0);
  setSignal(FL_Lvl_Adj, 1);
  setSignal(FR_Lvl_Adj, 1);
  setSignal(RL_Lvl_Adj, 1);
  setSignal(RR_Lvl_Adj, 1);
  setSignal(GearEngagedForDisplay, 0);
  setSignal(Shifter_ADAS_Inhibit, 1);
  setTimer (IGN_ON, 6);
  setTimer (CANreset, 1);  // Setting this timer to reset CAN 2 and CAN 14 IL control reset.
  resetFault();
  
}

//on stopMeasurement
//{
//  // setsignal(CmdIgnSts,0);
// 
// // @ IL::Klemme15=0;
//}


  


on timer msStwAngleSweepTimer
{
  if($LwsAngle<@MEnv_StwAngleSweepMax_SET_FLT_1)
  {
  $LwsAngle = @MEnv_StwAngleSweepMin_SET_FLT_1+ sweepStwAngle;
  sweepStwAngle = sweepStwAngle + @MEnv_StwAngleSweepDel_SET_FLT_1;
  setTimer(msStwAngleSweepTimer, @MEnv_StwAngleSweepTime_SET_INT_1);
  }
  else
  {
    @MEnv_StwAngleSweep_SET_BOL_1=0;
  }
}
  
on timer msVehSpeedSweepTimer
{
  if($VehicleSpeedVSOSig<@MEnv_VehSpeedSweepMax_SET_INT_1)
  {
  $VehicleSpeedVSOSig = @MEnv_VehSpeedSweepMin_SET_INT_1+ sweepVehSpeed;
  sweepVehSpeed = sweepVehSpeed +  @MEnv_VehSpeedSweepDel_SET_INT_1 ;
  setTimer(msVehSpeedSweepTimer,  @MEnv_VehSpeedSweepTime_SET_INT_1);
  }
   else
  {
    @MEnv_VehSpeedSweep_SET_BOL_1=0;
  }
}

on timer CANreset
{
  @sysvar::IL_CAN1::enable_AllNodes = 0;
  @sysvar::IL_CAN2::enable_AllNodes = 0;
  setTimer(msCANresetreturn, 1);
}

on timer IGN_ON
{
  @IL::Klemme15 = 1;
  @IL::Klemme30 = 1;
  @MEnv_IgnStatus_SET_INT_1 = 4;

  
}

on timer msCANresetreturn
{
  @sysvar::IL_CAN1::enable_AllNodes = 1;
  @sysvar::IL_CAN2::enable_AllNodes = 1;
  
  @IL::Klemme15 =1;
  @IL::Klemme30 = 1;
}

on sysvar_update DLC_FAULT_INJECTION::ResetFault
{
  if (@this == 1)
  {
    resetFault();
  }
}

