on start
{
  
  
    write("the byte value of 86 at on start is %x",writeproxi[86]);
    write("the byte value of 85 at on start is %x",writeproxi[85]);
    DiagSetTarget("CVADAS_0001_00000000_000");
  
    putValue(MEnv_CTNCandelaQualifier_SET_STG_14, "CVADAS_0001_00000000_000");
  
    putValue(MEnv_CandelaQualifier_SET_STG_3, "CVADAS_0001_00000000_000");
  
    setTimer(t_Initial_Lock, 50);
  
    @MEnv_DiagTesterPresent_SET_BOL_3 = diagGetTesterPresentState();

//initial values from the DBC---------------

//------------------------------------------
  
//initial values general--------------------
    AFTER_EXTENDED_REQUEST = 99;
  
    @MEnv_SessionFallbackTime_SET_INT = 5000;
//------------------------------------------´
    @MEnv_SendProxiString_SET_INT_3 = 0;
  
  	//SetDefaultProxi();  

}

on diagResponse Level1Seed_Request
{
    byte seed[4];
    
    byte gSeedArray[4];
    int gSeedArraySize    = 4;
    int gSecurityLevel    = 0x01;
    char gVariant[200]    = "common";
    char gOption[200]     = "option";
    byte gKeyArray[255];
    int  gMaxKeyArraySize = 255;
    DWORD gActualSize     = 0;
    char gDebugBuffer[2000];
    int x;
    
    if (this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 1: // ECU Unlock
            {  
                diagGetParameterRaw (this, "Seed", seed, 4);

                //write("diagResponce SecuritySeed : %x, %x, %x, %x", seed[0], seed[1], seed[2], seed[3]);
                
                gSeedArray[0] = seed[0];
                gSeedArray[1] = seed[1];
                gSeedArray[2] = seed[2];
                gSeedArray[3] = seed[3];

                //write("Übergabe Seed: %x, %x, %x, %x", gSeedArray[0], gSeedArray[1], gSeedArray[2], gSeedArray[3]);

                x = DiagGenerateKeyFromSeed (gSeedArray, gSeedArraySize, gSecurityLevel, gVariant, gOption, gKeyArray, gMaxKeyArraySize, gActualSize);

                //write("ErrorCode Unlock Function: %d", x);
                //write("Calculated Key: %x, %x, %x, %x", gKeyArray[0], gKeyArray[1], gKeyArray[2], gKeyArray[3]);
                
                diagSetParameterRaw(diag_SendKey_Level1, "Key", gKeyArray, 4);
                diagSendRequest(diag_SendKey_Level1);
                
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
        }
    }
    else
    {
        //putvalue(MEnv_SysMessage_GET_STG_2, " Negative Response from Level 1 Seed Request!");
        write("Magna Warning: Negative Response from Level 1 Seed Request!");
    }
}

