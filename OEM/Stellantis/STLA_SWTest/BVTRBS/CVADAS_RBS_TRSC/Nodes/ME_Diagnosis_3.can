// Emv Panel
//---------------------------------------------
on envVar MEnv_EmvControl_SET_BOL_2
{
    if (@this == 1)
    {
        setTimer(t_Emv_AutoStart, 4000);
    }
    else
    {
        // do nothing
    }
}

on timer t_Emv_AutoStart
{
    @MEnv_EmvInputVoltMax_SET_FLT_3 = 15;
    @MEnv_EmvInputVoltMin_SET_FLT_3 = 9;
    @MEnv_EmvInVoltErrorC_GET_INT_3 = 0;
  
    setTimer(t_Emv_InputVoltage, 50);
}

on timer t_Emv_InputVoltage
{
    AFTER_EXTENDED_REQUEST = 2;
    diagSendRequest(diag_Read_InputVoltage);
  
    cancelTimer(t_Emv_Backup_InputVoltage); // if every thing is correct cancel the Backup Timer
    setTimer(t_Emv_Backup_InputVoltage, 5000); // start the Backup Timer again
}

on timer t_Emv_Backup_InputVoltage
{
    cancelTimer(t_Emv_InputVoltage); // make sure that the sequence is stoped first before start again
    setTimer(t_Emv_Backup_InputVoltage, 5000);
    setTimer(t_Emv_InputVoltage, 500);
}

on diagResponse ECU_Input_Voltage_Read
{
    if (this.IsPositiveResponse())
    {
        if (AFTER_EXTENDED_REQUEST == 2)  // EMV Read Input Voltage
        {
            @MEnv_EmvInputVoltage_GET_FLT_3 = diagGetParameter(this, "T15") / 10;
          
            //check that the input voltage is ok
            if((@MEnv_EmvInputVoltage_GET_FLT_3 >= @MEnv_EmvInputVoltMin_SET_FLT_3) && (@MEnv_EmvInputVoltage_GET_FLT_3 <= @MEnv_EmvInputVoltMax_SET_FLT_3))
            {
                @MEnv_EmvInputVoltLed_GET_BOL_3 = 1;
                DTC_ERROR_COUNTER_LOCK_INT = 1;
            }
            else
            {
                if (DTC_ERROR_COUNTER_LOCK_INT == 1)
                {
                    @MEnv_EmvInVoltErrorC_GET_INT_3 = @MEnv_EmvInVoltErrorC_GET_INT_3 + 1;
                    DTC_ERROR_COUNTER_LOCK_INT = 0;
                }
                else
                {
                    // do nothing
                }
                @MEnv_EmvInputVoltLed_GET_BOL_3 = 0;
            }
            //--------------------------------------------
            
            setTimer(t_Emv_InputVoltage, 2000);
            
            AFTER_EXTENDED_REQUEST = 99;
        }
        else
        {
            // an other mode calls this diagjob
        }
    }
    else
    {
        AFTER_EXTENDED_REQUEST = 99;
        write("Magna Warning: Diagjob #ECU Input Voltage Read# = negative Response");
    }
}
