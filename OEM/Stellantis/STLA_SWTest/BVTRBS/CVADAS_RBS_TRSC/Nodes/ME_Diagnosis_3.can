                //write("Übergabe Seed: %x, %x, %x, %x", gSeedArray[0], gSeedArray[1], gSeedArray[2], gSeedArray[3]);

                x = DiagGenerateKeyFromSeed (gSeedArray, gSeedArraySize, gSecurityLevel, gVariant, gOption, gKeyArray, gMaxKeyArraySize, gActualSize);

                //write("ErrorCode Unlock Function: %d", x);
                //write("Calculated Key: %x, %x, %x, %x", gKeyArray[0], gKeyArray[1], gKeyArray[2], gKeyArray[3]);
                
                diagSetParameterRaw(diag_SendKey_Level5, "Key", gKeyArray, 4);
                diagSendRequest(diag_SendKey_Level5);
                
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
        }
    }
    else
    {
//        putvalue(MEnv_SysMessage_GET_STG_2, " Negative Response from Level 5 Seed Request!");
//        write("Magna Warning: Negative Response from Level 5 Seed Request!");
    }
}

on diagResponse Security_Access_Mode_101_RequestSeed_Request
{
    byte seed[4];
    
    byte gSeedArray[4];
    int gSeedArraySize    = 4;
    int gSecurityLevel    = 0x65; // = 101
    char gVariant[200]    = "common";
    char gOption[200]     = "option";
    byte gKeyArray[255];
    int  gMaxKeyArraySize = 255;
    DWORD gActualSize     = 0;
    char gDebugBuffer[2000];
    int x;
    
    if (this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 4: // ECU Unlock Level 101
            {
                diagGetParameterRaw (this, "SecuritySeed", seed, 4);
              
                //write("diagResponce SecuritySeed : %x, %x, %x, %x", seed[0], seed[1], seed[2], seed[3]);
                
                gSeedArray[0] = seed[0];
                gSeedArray[1] = seed[1];
                gSeedArray[2] = seed[2];
                gSeedArray[3] = seed[3];

                //write("Übergabe Seed: %x, %x, %x, %x", gSeedArray[0], gSeedArray[1], gSeedArray[2], gSeedArray[3]);

                x = DiagGenerateKeyFromSeed (gSeedArray, gSeedArraySize, gSecurityLevel, gVariant, gOption, gKeyArray, gMaxKeyArraySize, gActualSize);

                //write("ErrorCode Unlock Function: %d", x);
                //write("Calculated Key: %x, %x, %x, %x", gKeyArray[0], gKeyArray[1], gKeyArray[2], gKeyArray[3]);
                
                diagSetParameterRaw(diag_SendKey_Level101, "SecurityKey", gKeyArray, 4);
                diagSendRequest(diag_SendKey_Level101);
                
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
            
            case 5: // Complete Calibration
            {
                diagGetParameterRaw (this, "SecuritySeed", seed, 4);
              
                //write("diagResponce SecuritySeed : %x, %x, %x, %x", seed[0], seed[1], seed[2], seed[3]);
                
                gSeedArray[0] = seed[0];
                gSeedArray[1] = seed[1];
                gSeedArray[2] = seed[2];
                gSeedArray[3] = seed[3];

                //write("Übergabe Seed: %x, %x, %x", gSeedArray[0], gSeedArray[1], gSeedArray[2]);

                x = DiagGenerateKeyFromSeed (gSeedArray, gSeedArraySize, gSecurityLevel, gVariant, gOption, gKeyArray, gMaxKeyArraySize, gActualSize);

                //write("ErrorCode Unlock Function: %d", x);
                //write("Calculated Key: %x, %x, %x, %x", gKeyArray[0], gKeyArray[1], gKeyArray[2], gKeyArray[3]);
                
                diagSetParameterRaw(diag_SendKey_Level101, "SecurityKey", gKeyArray, 4);
                diagSendRequest(diag_SendKey_Level101);
            }
            break;
        }
    }
    else
    {
       //putvalue(MEnv_SysMessage_GET_STG_2, " Negative Response from Level 101 Seed Request!");
        write("Magna Warning: Negative Response from Level 101 Seed Request!");
    }
}

on diagResponse Level1Key_Send
{
    if(this.IsPositiveResponse())
    {
        //putvalue(MEnv_SysMessage_GET_STG_2," Level 1 ECU Unlocked Successfully!");
      
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 1;
    }
    else
    {
       // putvalue(MEnv_SysMessage_GET_STG_2," Level 1 ECU Unlocked Failed!");
    }
}

on diagResponse Protected_Engineering_Access_Key_Send
{
    if(this.IsPositiveResponse())
    {
        //putvalue(MEnv_SysMessage_GET_STG_2," Level 5 ECU Unlocked Successfully!");
      
        @MEnv_DiagUnlockEcuLevel5_GET_BOL = 1;
    }
    else
    {
       // putvalue(MEnv_SysMessage_GET_STG_2," Level 5 ECU Unlocked Failed!");
    }
}

on diagResponse Security_Access_Mode_101_SendKey_Send
{
    if(this.IsPositiveResponse())
    {
        //putvalue(MEnv_SysMessage_GET_STG_2," Level 101 ECU Unlocked Successfully!");
      
        @MEnv_DiagUnlockEcuLevel101_GET_B = 1;
        
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 5: // Complete Calibration
            {
                // Set EOL Parameter to a defined value
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Pitch_Front", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Pitch_Left", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Pitch_Rear", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Pitch_Right", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Roll_Front", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Roll_Left", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Roll_Rear", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Roll_Right", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Yaw_Front", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Yaw_Left", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Yaw_Rear", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Angle_Corr_Yaw_Right", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_X_Front", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_X_Left", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_X_Rear", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_X_Right", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Y_Front", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Y_Left", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Y_Rear", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Y_Right", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Z_Front", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Z_Left", 2);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Z_Rear", 1);
                diagSetParameter(diag_Write_EOLCalibrationData, "Cam_Pos_Corr_Z_Right", 2);
                
                // Set EOL Status to Successful
                diagSetParameter(diag_Write_EOLCalibrationData, "Calibration_Status_Front", 3);
                diagSetParameter(diag_Write_EOLCalibrationData, "Calibration_Status_Left", 3);
                diagSetParameter(diag_Write_EOLCalibrationData, "Calibration_Status_Rear", 3);
                diagSetParameter(diag_Write_EOLCalibrationData, "Calibration_Status_Right", 3);
              
                diagSendRequest(diag_Write_EOLCalibrationData);
            }
            break;
        }
    }
    else
    {
       enableControl("Main", "Calibration_Button", 1);
     
       // putvalue(MEnv_SysMessage_GET_STG_2," Level 101 ECU Unlocked Failed!");
    }
}

on diagResponse ExtendedDiagnostic_Start
{
	  if (this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 0: // Network
            {
                
            }
            break;
           
            case 1: // Unlock ECU Level 1
            {
                diagSendRequest(diag_RequestSeed_Leve1);
            }
            break;
            
            case 3: // Unlock ECU Level 5
            {
                diagSendRequest(diag_RequestSeed_Leve5);
            }
            break;
            
            case 4: // Unlock ECU Level 101
            {
                diagSendRequest(diag_RequestSeed_Leve101);
            }
            break;
            
            case 5: // Complete Calibration
            {
                diagSendRequest(diag_RequestSeed_Leve101); // Unlock ECU Level 101 is necessary to write EOL Calibration Data
            }
            break;
        }
    }
    else
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 0: // 
            {
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
            
            case 1: // ECU Unlock 1
            {
              // putvalue(MEnv_SysMessage_GET_STG_2, " Extended Session: Negative Response!");
               AFTER_EXTENDED_REQUEST = 99;
            }
            break;
            
            case 4: // ECU Unlock Level 101
            {
              // putvalue(MEnv_SysMessage_GET_STG_2, " Extended Session: Negative Response!");
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
            
            case 5: // Complete Calibration
            {
              // putvalue(MEnv_SysMessage_GET_STG_2, " Extended Session: Negative Response!");
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
        }
    }
}

on diagResponse Programming_Start
{
    if (this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
      
            case 1: // Unlock ECU Level 1
            {
                diagSendRequest(diag_RequestSeed_Leve1);
            }
            break;
                       
            case 3: // Unlock ECU Level 5
            {
                diagSendRequest(diag_RequestSeed_Leve5);
            }
            break;
        }
    }
    else
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;

            case 3: // ECU Unlock Levle 5
            {
               //putvalue(MEnv_SysMessage_GET_STG_2, " Programming Session: Negative Response!");
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
        }
    }
}

