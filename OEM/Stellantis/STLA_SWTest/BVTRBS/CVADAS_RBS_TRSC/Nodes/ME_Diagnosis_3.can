on timer t_ResetTesterPresent // in case of no Responce from the ECU, this Timer will make shure that the Testerpresent will active if it was active before
{
    if(TesterPresentState == 1)
    {
        diagStartTesterPresent();
        TesterPresentState = 0;
    }
    else
    {
        //do nothing
    }
}
//---------------------------------------------------------------------------------------

on message 0x794 // Physikal Diagrequest
{
    if((this.byte(1) == 0x11) && (this.byte(2) == 81)) // suppressed Hardreset
    {
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel5_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
    }
    else if((this.byte(1) == 0x10) && (this.byte(2) == 81)) // suppressed Default Session
    {
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel5_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
    }
    else if((this.byte(1) == 0x10) && (this.byte(2) == 82)) // suppressed Programming Session
    {
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
    }
    else if((this.byte(1) == 0x10) && (this.byte(2) == 83)) // suppressed Extended Session
    {
        
    }
    
    cancelTimer(t_ResetSecUnlockStatusLEDs);
    
    setTimer(t_ResetSecUnlockStatusLEDs, @MEnv_SessionFallbackTime_SET_INT);
}

on message 0x441 // Functional Diagrequest
{
    if((this.byte(1) == 0x11) && (this.byte(2) == 81)) // suppressed Hardreset
    {
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel5_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
    }
    else if((this.byte(1) == 0x10) && (this.byte(2) == 81)) // suppressed Default Session
    {
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel5_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
    }
    else if((this.byte(1) == 0x10) && (this.byte(2) == 82)) // suppressed Programming Session
    {
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
    }
    else if((this.byte(1) == 0x10) && (this.byte(2) == 83)) // suppressed Extended Session
    {
        
    }
    
    cancelTimer(t_ResetSecUnlockStatusLEDs);
    
    setTimer(t_ResetSecUnlockStatusLEDs, @MEnv_SessionFallbackTime_SET_INT);
}

on timer t_ResetSecUnlockStatusLEDs // timer to reset the Security Unlock Status LEDs if no Diagjob is requested
{
    @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
    @MEnv_DiagUnlockEcuLevel5_GET_BOL = 0;
    @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
}

on envVar MEnv_EmvDeactivateFailsafe_SET_B
{
    if(@this == 1)
    {
        @MEnv_EmvDeactivateFailsafe_GET_I = 0; // LED Blue
      
        @MEnv_DiagTesterPresent_SET_BOL_3 = 1; // start Tester Present
      
        @MEnv_DiagUnlockEcuLevel101_SET_B = 1; // Unlock ECU Level 101
      
        setTimer(t_ResetUnlockButton, 100);
      
        setTimer(t_Emv_CheckUnlockState, 500);
      
        setTimer(t_Emv_Backup_DeactivateFailsafe, 10000);
      
        enableControl("EMV", "EmvDeactivateFailsafe_Button", 0);
    }
    else
    {
        // do nothing
    }
}

on timer t_Emv_Backup_DeactivateFailsafe
{
    cancelTimer(t_Emv_CheckUnlockState);
  
    @MEnv_EmvDeactivateFailsafe_GET_I = 1; // LED Red
      
    enableControl("EMV", "EmvDeactivateFailsafe_Button", 1);
}

on timer t_Emv_CheckUnlockState
{
    if (@MEnv_DiagUnlockEcuLevel101_GET_B == 1)
    {
        diagSendRequest(diag_StartRoutine_DeactivateFailSage);
    }
    else
    {
        setTimer(t_Emv_CheckUnlockState, 500);
    }
}

on diagResponse DEACTIVATION_OF_FAIL_SAFE_REACTIONS_Start
{
    if (this.IsPositiveResponse())
    {
        @MEnv_EmvDeactivateFailsafe_GET_I = 2; // LED Green
    }
    else
    {
        @MEnv_EmvDeactivateFailsafe_GET_I = 1; // LED Red
    }
    
    enableControl("EMV", "EmvDeactivateFailsafe_Button", 1);
      
    cancelTimer(t_Emv_Backup_DeactivateFailsafe);
}

on timer t_ResetUnlockButton
{
    @MEnv_DiagUnlockEcuLevel101_SET_B = 0; // Reset the Unlock ECU Button
}

