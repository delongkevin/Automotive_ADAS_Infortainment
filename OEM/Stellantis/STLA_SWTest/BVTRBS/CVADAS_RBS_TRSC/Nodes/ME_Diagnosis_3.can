   // putvalue(MEnv_SysMessage_GET_STG_2,"                                                                          ");
}

on envVar MEnv_DiagTesterPresent_SET_BOL_3
{
    if(@this == 1)
    {      
        DiagStartTesterPresent("_HALF_CUSW_9001_EI2685");
    }
    else
    {
        DiagStopTesterPresent("_HALF_CUSW_9001_EI2685");
    }
}

// ECU Unlock Level 1
//-----------------------------------------------------------
on envVar MEnv_DiagUnlockEcuLevel1_SET_BOL
{
    if(@this == 1)
    {
       // putvalue(MEnv_SysMessage_GET_STG_2,"");
        
        //Reset all Security Unlock Status LEDs
        @MEnv_DiagUnlockEcuLevel1_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel5_GET_BOL = 0;
        @MEnv_DiagUnlockEcuLevel101_GET_B = 0;
      
        setTimer(t_ResetSecUnlockStatusLEDs, @MEnv_SessionFallbackTime_SET_INT);
      
        AFTER_EXTENDED_REQUEST = 1; // 1 = ECU Unlock Level 1
        
        DiagSendRequest(diag_RequestProgramming);
    }
    else
    {
        // button press - do nothing
    }
}
