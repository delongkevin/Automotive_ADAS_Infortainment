on diagResponse _2E2023_System_Configuration_PROXI_Write
{
    if(this.IsPositiveResponse())
    {
        diagSendRequest(diag_CheckEOLConfigData);
    }
    else
    {
      //do nothing
    }
}

on diagResponse _22102A_Check_EOL_configuration_data_Read
{
    if(this.IsPositiveResponse())
    {
        getProxiValues = 1;
        diagSendRequest(diag_ReadProxi);
    }
    else
    {
      //do nothing
    }
}
//on key 'c'
//
//{
//  byte bufferval[4];
//  bufferval[0] = 0xFB;
//   bufferval[1] = 0x80;
//    bufferval[2] = 0x78;
//    bufferval[3] = 0xF6;
//  CRC = 0;
//
// //byte crc_array[5]={0,0,0,0,0};
//  CRC = aProxiM_F_CRCPROXI(bufferval, 4);
//  write("Calculated Final CRC =   %X", CRC);
//  
//}

word aProxiM_F_CRCPROXI_old(byte PROXI_message[], int nBytes)
{
    byte data;
    word calculated_crc = 0;
    int byte_index;

    data = 0;
    calculated_crc = 0;
    byte_index = 0;
    /*
    ** Divide the PROXI_message by the polynomial, one byte at a time.
    */
    for (byte_index = 0; byte_index < nBytes; byte_index++)
    {
        data = PROXI_message[byte_index] ^ (byte)(calculated_crc & 0xff);
        calculated_crc = Table_CRC_16_CCITT[data] ^ (calculated_crc >> 8);
    }
   // write("calculated_crc is %d",calculated_crc);

    /*
    ** The final calculated_crc is the CRC.
    */
    return (calculated_crc);
}



