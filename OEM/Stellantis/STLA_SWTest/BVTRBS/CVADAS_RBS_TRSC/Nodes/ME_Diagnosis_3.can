void set_default_proxi_data()
{
  @MEnv_CANnode27_SET_INT_3=1;
  @MEnv_CANnode63_GET_INT_3=1;
  @MEnv_CANnode67_SET_INT_3=1;
  @MEnv_CANnode95_SET_INT_3=1;
  @MEnv_StopAndStart_SET_INT_3=1;
  @MEnv_DriverSide_SET_INT_3=1;
  @MEnv_DgtlTlvFtr_SET_INT_3=0;
  @MEnv_Wheelbase_SET_INT_3=1;
  @MEnv_RearViewCamera_SET_INT_3=1;
  @MEnv_ParkWithStop_SET_INT_3=1;
  @MEnv_StrRtoRackPninTpe_SET_INT_3=0;
  @MEnv_DriveTypeVariant_SET_INT_3=0;
  @MEnv_GearBoxType_SET_INT_3=0;
  @MEnv_PAMTuningSet_SET_INT_3=0;
  @MEnv_SemiAutoParkSys_GET_INT_3=0;
  @MEnv_VehLineConfig_SET=0;
  @MEnv_CountryCode_SET_INT_3=0;
  @MEnv_SRT_SET_INT_3=0;
  @MEnv_PamConfig_SET_INT_3=0;
  @MEnv_ModelYear_SET_INT_3=0;
  @MEnv_HybridType_SET_INT_3=0;
  @MEnv_PullOutCtrlPrst_SET_INT_3=1;
  @MEnv_SurroundViewCam_SET_INT_3=1;
  @MEnv_FrwdFacCamera_SET_INT_3=1;
  @MEnv_AutonomyLevel_SET_INT_3=0;
  @MEnv_FullAutoParkSys_SET_INT_3=1;
  @MEnv_RadioDisplayType_SET_INT_3=1;
  @MEnv_MirrorsType_SET_INT_3=1;
  @MEnv_AuxiliaryTrailCam_SET_INT_3=1;
  @MEnv_TrailReverseGuidPreset_SET=1;
  @MEnv_TrailerSurroundPresence_SET=1;
  @MEnv_TrailerRevSteeringPrest_SET=1;
  @MEnv_TrailerHitchAssistPrest_SET=1;

  
  
}


void SetDefaultProxi()
{
  word TempParameterVal = 0;

  
TempParameterVal = writeproxi[28] & 0x08;
TempParameterVal = (TempParameterVal >> 3) & 0x01;
@MEnv_CANnode27_SET_INT_3 = TempParameterVal;
	  

TempParameterVal = writeproxi[32] & 0x80;
TempParameterVal = (TempParameterVal >> 7) & 0x01;
@MEnv_CANnode63_SET_INT_3 = TempParameterVal;


TempParameterVal = writeproxi[33] & 0x08;
TempParameterVal = (TempParameterVal >> 3) & 0x01;
@MEnv_CANnode67_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[36] & 0x80;
TempParameterVal = (TempParameterVal >> 7) & 0x01;
@MEnv_CANnode95_SET_INT_3= TempParameterVal;

TempParameterVal = writeproxi[57] & 0x01;
TempParameterVal = (TempParameterVal) & 0x01;
@MEnv_StopAndStart_SET_INT_3  = TempParameterVal;

TempParameterVal = writeproxi[57] & 0x08;
TempParameterVal = (TempParameterVal>>3) & 0x01;
@MEnv_DriverSide_SET_INT_3 = TempParameterVal;
  
TempParameterVal = writeproxi[63] & 0xFF;
TempParameterVal = TempParameterVal<<8;
TempParameterVal = (TempParameterVal & 0xFF00) | (writeproxi[64] & 0x00FF);
@MEnv_TyreSize_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[68] & 0x20;
TempParameterVal = (TempParameterVal>>3) & 0x01;
@MEnv_DgtlTlvFtr_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[70] & 0xF0;
TempParameterVal = (TempParameterVal>>4) & 0x0F;
@MEnv_Wheelbase_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[85] & 0x01;
TempParameterVal = (TempParameterVal>>0) & 0x01;
@MEnv_RearViewCamera_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[85] & 0x40;
TempParameterVal = (TempParameterVal>>6) & 0x01;
@MEnv_ParkWithStop_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[87] & 0x03;
TempParameterVal = (TempParameterVal>>0) & 0x01;
@MEnv_StrRtoRackPninTpe_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[90] & 0x10;
TempParameterVal = (TempParameterVal>>5) & 0x01;
@MEnv_DriveTypeVariant_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[100] & 0x07;
TempParameterVal = (TempParameterVal) & 0x07;
@MEnv_GearBoxType_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[103] & 0x07;
TempParameterVal = (TempParameterVal) & 0x01;
@MEnv_PAMTuningSet_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[103] & 0x08;
TempParameterVal = (TempParameterVal>>3) & 0x01;
@MEnv_SemiAutoParkSys_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[104] & 0xFF;
//TempParameterVal = (TempParameterVal) & 0x0F;
@MEnv_VehLineConfig_SET = TempParameterVal;

TempParameterVal = writeproxi[106] & 0xFF;
//TempParameterVal = (TempParameterVal) & 0x0F;
@MEnv_CountryCode_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[110] & 0x80;
TempParameterVal = (TempParameterVal>>7) & 0x07;
@MEnv_SRT_SET_INT_3 = TempParameterVal;


TempParameterVal = writeproxi[117] & 0x30;
TempParameterVal = (TempParameterVal>>4) & 0x07;
@MEnv_PamConfig_SET_INT_3= TempParameterVal;

TempParameterVal = writeproxi[124] & 0xFF;
//TempParameterVal = (TempParameterVal) & 0x01;
@MEnv_ModelYear_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[140] & 0x0F;
TempParameterVal = (TempParameterVal) & 0x0F;
@MEnv_HybridType_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[149] & 0x20;
TempParameterVal = (TempParameterVal>>5) & 0x07;
@MEnv_PullOutCtrlPrst_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[176] & 0x01;
TempParameterVal = (TempParameterVal) & 0x01;
@MEnv_SurroundViewCam_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[176] & 0x02;
TempParameterVal = (TempParameterVal>>1) & 0x01;
@MEnv_FrwdFacCamera_SET_INT_3 = TempParameterVal;
//write ("MEnv_Forward_facing_camera_SET_INT_1 = %d", TempParameterVal);
  
TempParameterVal = writeproxi[176] & 0x1C;
TempParameterVal = (TempParameterVal>>2) & 0x07;
@MEnv_AutonomyLevel_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[176] & 0x20;
TempParameterVal = (TempParameterVal>>5) & 0x01;
@MEnv_FullAutoParkSys_SET_INT_3 = TempParameterVal;

 // write ("MEnv_Forward_facing_camera_SET_INT_1 = %d", TempParameterVal);
  
  
TempParameterVal = writeproxi[184] & 0x0F;
TempParameterVal = (TempParameterVal) & 0x0F;
@MEnv_RadioDisplayType_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[202] & 0x18;
TempParameterVal = (TempParameterVal>>3) & 0x07;
@MEnv_MirrorsType_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[210] & 0x04;
TempParameterVal = (TempParameterVal>>2) & 0x01;
@MEnv_AuxiliaryTrailCam_SET_INT_3 = TempParameterVal;

TempParameterVal = writeproxi[210] & 0x08;
TempParameterVal = (TempParameterVal>>3) & 0x01;
@MEnv_TrailReverseGuidPreset_SET = TempParameterVal;

TempParameterVal = writeproxi[210] & 0x40;
TempParameterVal = (TempParameterVal>>6) & 0x01;
@MEnv_TrailerSurroundPresence_SET = TempParameterVal;

TempParameterVal = writeproxi[210] & 0x80;
TempParameterVal = (TempParameterVal>>7) & 0x01;
@MEnv_TrailerRevSteeringPrest_SET = TempParameterVal;

TempParameterVal = writeproxi[212] & 0x02;
TempParameterVal = (TempParameterVal>>1) & 0x01;
@MEnv_TrailerHitchAssistPrest_SET = TempParameterVal;
}














