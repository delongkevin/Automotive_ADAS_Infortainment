on diagResponse  EngineeringParameters_Read
{
    size=this.GetPrimitiveSize();              // To get the size of the response
    this.GetPrimitiveData(Diag_Buffer,size);
  @MEnv_ModelYear_GET_INT_3=Diag_Buffer[124];
    if (this.IsPositiveResponse())
    {
      
       for(i=0;i<size;i++)
         {
             Diag[i]=Diag_Buffer[i];
         }
      //putValueToControl("Diag_Proxi","Diag_Output",Diag);
        putValue(MEnv_DiagData_SET_STG_3, Diag);
    }
    else
    {
      diagSendRequest(diag_KeyOn);
    }
}

