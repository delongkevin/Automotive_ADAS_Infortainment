on envVar MEnv_FunctRequest_SET_STG_3
{
    char StringBuffer_char[25];
    int numberofchar;
    int numberofbyte;
    int k;
    
    numberofchar = 0;
    numberofbyte = 0;
  
    @MEnv_FunctResponceState_GET_INT_ = 0;
    
    //Clear Arrays
    //-------------------------------
    For(k = 0; k < elcount(StringBuffer_char); k++)
    {
        StringBuffer_char[k] = ' ';
    } 
    For(k = 0; k < elcount(Data_Byte); k++)
    {
        Data_Byte[k] = 0;
    }
    //-------------------------------

    getValue(MEnv_FunctRequest_SET_STG_3, StringBuffer_char);
    
    for(numberofchar = 0; numberofchar < strlen(StringBuffer_char) - 1; )
    {   
        if((StringBuffer_char[numberofchar] > 0x2F) && (StringBuffer_char[numberofchar] < 0x3A)) // check if current character is a number
        {
            RequestSignState = 1; // Sign valid
          
            Data_Byte[numberofbyte] = (StringBuffer_char[numberofchar] - 48);
        }
        else if((StringBuffer_char[numberofchar] > 0x40) && (StringBuffer_char[numberofchar] < 0x47)) // check if current character is an uppercase letter A-F
        { 
            RequestSignState = 1; // Sign valid
          
            Data_Byte[numberofbyte] = (StringBuffer_char[numberofchar] - 55);
        }
        else if((StringBuffer_char[numberofchar] > 0x60) && (StringBuffer_char[numberofchar] < 0x67)) // check if current character is an lowercase letter a-f
        {
            RequestSignState = 1; // Sign valid
          
            Data_Byte[numberofbyte] = (StringBuffer_char[numberofchar] - 87);
        }  
        else
        {
            RequestSignState = 2; // Signs not valid
          
            write("Magna Warning: Functional Request: string error, Byte %d is not a valid sign!", numberofchar);
            break;
        }
        
        Data_Byte[numberofbyte] = Data_Byte[numberofbyte] * 0x10; // high nibble
        
        numberofchar++; // next character
        
        if((StringBuffer_char[numberofchar] > 0x2F) && (StringBuffer_char[numberofchar] < 0x3A)) // check if current character is a number
        {
            RequestSignState = 1; // Sign valid
          
            Data_Byte[numberofbyte] = Data_Byte[numberofbyte] + (StringBuffer_char[numberofchar] - 48);
        }
        else if((StringBuffer_char[numberofchar] > 0x40) && (StringBuffer_char[numberofchar] < 0x47)) // check if current character is an uppercase letter A-F
        { 
            RequestSignState = 1; // Sign valid
          
            Data_Byte[numberofbyte] = Data_Byte[numberofbyte] + (StringBuffer_char[numberofchar] - 55);
        }
        else if((StringBuffer_char[numberofchar] > 0x60) && (StringBuffer_char[numberofchar] < 0x67)) // check if current character is an lowercase letter a-f
        {
            RequestSignState = 1; // Sign valid
          
            Data_Byte[numberofbyte] = Data_Byte[numberofbyte] + (StringBuffer_char[numberofchar] - 87);
        }
        else
        {
            RequestSignState = 2; // Signs not valid
          
            write("Magna Warning: Functional Request: string error, Byte %d is not a valid sign!", numberofchar);
            break;
        }
        
        numberofbyte++; // next data byte
        
        if (numberofchar < strlen(StringBuffer_char)-1) 
        {
            numberofchar++; // next character
          
            if (StringBuffer_char[numberofchar] != 0x20) // check if current character is a space
            {
                RequestSignState = 2; // Signs not valid
              
                write("Magna Warning: Functional Request: string error, Blanks not matching!");
                break;
            }
            else
            {
                RequestSignState = 1; // Sign valid
              
                numberofchar++; // skip space to next character
            }
        }
    }  
    
    // fill remaining bytes of data array with zeroes
    //-------------------------------
    for(; numberofbyte < 8; numberofbyte++)
    {
        Data_Byte[numberofbyte++] = 0;
    }
    //-------------------------------
}

