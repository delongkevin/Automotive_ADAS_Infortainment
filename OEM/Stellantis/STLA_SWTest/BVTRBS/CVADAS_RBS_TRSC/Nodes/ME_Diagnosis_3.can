on envVar MEnv_Calibration_SET_BOL_3
{
    if(@this == 1)
    {
        enableControl("Main", "Calibration_Button", 0);
      
      //  putvalue(MEnv_SysMessage_GET_STG_2,"");
      
        AFTER_EXTENDED_REQUEST = 5;
        diagSendRequest(diag_RequestExtended);
    }
    else
    {
        //do nothing
    }
}

on diagResponse EOL_Calibration_VPC_Current_Data_Write_Data
{
    if(this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 5: // Complete Calibration
            {
                diagSetParameter(diag_StartRoutine_CalibrationDataReset, "Calibration_Data", 0x3);
                diagSetParameter(diag_StartRoutine_CalibrationDataReset, "Camera_Identifier", 0xFF);
              
                diagSendRequest(diag_StartRoutine_CalibrationDataReset);
            }
            break;
        }
    }
    else
    {
        enableControl("Main", "Calibration_Button", 1);
      
        //putvalue(MEnv_SysMessage_GET_STG_2," Magna Warning: Diagjob #EOL Calibration VPC Current Data Write# = negative Response!");
    }
}

on diagResponse Calibration_Data_Reset_Start
{
    if(this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 5: // Complete Calibration
            {
                DiagjobDelay = 1;
              
                settimer(t_DiagjobDelay, 2000);
                
                //diagSendRequest(diag_HardReset);
            }
            break;
        }
    }
    else
    {
        enableControl("Main", "Calibration_Button", 1);
      
        //putvalue(MEnv_SysMessage_GET_STG_2," Magna Warning: Diagjob #Calibration Data Reset Start# = negative Response!");
    }
}

on timer t_DiagjobDelay
{
    if(DiagjobDelay == 1)
    {
        diagSendRequest(diag_HardReset);
    }
    else if (DiagjobDelay == 2)
    {
        diagSendRequest(diag_Read_CurrentCalibrationData);
    }
    else
    {
        // do nothing
    }
    
    DiagjobDelay = 99;
}
//---------------------------------------------

on diagResponse HardReset_Reset
{
    if(this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 5: // Complete Calibration
            {
                DiagjobDelay = 2;
              
                settimer(t_DiagjobDelay, 2000);

                //diagSendRequest(diag_Read_CurrentCalibrationData);
            }
            break;
        }
    }
    else
    {
        enableControl("Main", "Calibration_Button", 1);
      
        //putvalue(MEnv_SysMessage_GET_STG_2," Magna Warning: Diagjob #Hard Reset# = negative Response!");
    }
}

on diagResponse Current_Camera_Calibration_Data_Read_Data
{
    if(this.IsPositiveResponse())
    {
        switch(AFTER_EXTENDED_REQUEST)
        {
            case 99:
            {
                // an other Mode calls this Job
            }
            break;
            
            case 5: // Complete Calibration
            {
                buffer_UsedCalibration_Front = diagGetParameter(this, "Front_Cam_Used_Calibration");
                buffer_UsedCalibration_Left = diagGetParameter(this, "LeftCam_Used_Calibration");
                buffer_UsedCalibration_Rear = diagGetParameter(this, "RearCam_Used_Calibration");
                buffer_UsedCalibration_Right = diagGetParameter(this, "RightCam_Used_Calibration");
                
                if ((buffer_UsedCalibration_Front == 1) && (buffer_UsedCalibration_Left == 1) && (buffer_UsedCalibration_Rear == 1) && (buffer_UsedCalibration_Right == 1)) // EOL Successful ?
                {
                    //putvalue(MEnv_SysMessage_GET_STG_2," Complete Calibration Successfull!");
                }
                else
                {
                  //  putvalue(MEnv_SysMessage_GET_STG_2," Complete Calibration Failed!");
                }
                
                AFTER_EXTENDED_REQUEST = 99;
            }
            break;
        }
    }
    else
    {
       // putvalue(MEnv_SysMessage_GET_STG_2," Magna Warning: Diagjob #Read Current Camera Calibration Data# = negative Response!");
    }
    enableControl("Main", "Calibration_Button", 1);
}

