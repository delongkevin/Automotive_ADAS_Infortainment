word aProxiM_F_CRCPROXI(byte x[],int length)
{
  //1021  1 0001 0000 0010 0001
//8408  1000 0100 0000 1000 1
  
      int i, j,k;
      word data;
      word crc = 0x0000;
      word crc_poly =0x8408;
      //char crc_ch[10]="";
      
      word TempCRC = 0;
      word RemCRC = 0;
    //  write("%x %x %x %x %d", x[0], x[1], x[2], x[3],length );
      


     crc=0;
      if (length == 0)
            return (~crc);



     for(j=0;j<length;j++)
      {
        data=0xffff & x[j];
       
            for (i=0 ; i < 8; i++ )
            {
                  if ((crc & 0x0001) ^ (data & 0x0001))
                  {
                        crc = (crc >> 1) ^ crc_poly;
                  }
                       
                  else
                  {
                    crc >>= 1;
                  }
                  data >>= 1;  
            }
      }



//      crc = ~crc;
//      write("1  %X", crc);
//      data = crc;
//      write("2  %X", crc);
//      crc = (crc << 8) | (data >> 8 & 0xff);
//    if(crc<=9)  snprintf(crc_ch, elCount(crc_ch), "0000%d", crc);
//    else if(crc<=99) snprintf(crc_ch, elCount(crc_ch), "000%d", crc);
//    else if(crc<=999) snprintf(crc_ch, elCount(crc_ch), "00%d", crc);
//    else if(crc<=9999) snprintf(crc_ch, elCount(crc_ch), "0%d", crc);
//    write("aProxiM_F_CRCPROXI Final  %s", crc_ch);   
    
   // write ("CRC Byte value  %d",atol(crc_ch));
    TempCRC  = crc;//atol(crc_ch);
    RemCRC = TempCRC;
    TempCRC = TempCRC / 10000;
    // write ("CRC Byte value  %d",atol(crc_ch));
    crc_array [0] = TempCRC+ 0x30;
    
    TempCRC = RemCRC % 10000;
    RemCRC = TempCRC;
    TempCRC = RemCRC / 1000;
    crc_array [1] = TempCRC+ 0x30;
    
    TempCRC = RemCRC % 1000;
    RemCRC = TempCRC;
    TempCRC = RemCRC / 100;
    crc_array [2] = TempCRC+ 0x30;
    
    TempCRC = RemCRC % 100;
    RemCRC = TempCRC;
    TempCRC = RemCRC / 10;
    
    crc_array [3] = TempCRC+ 0x30;
    TempCRC = RemCRC % 10;
    RemCRC = TempCRC;
    TempCRC = RemCRC ;
    crc_array [4] = TempCRC + 0x30;
    for(k=0;k<5;k++)
    {
      
      write ("CRC Byte value [%d], = 0x%x",k,crc_array[k]);
    }
    
    return (crc);
    
}

