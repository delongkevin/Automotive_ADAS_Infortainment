/*! \fn long lFctn_BUS_CheckSigValue4TimePhysical(Signal* aSignalName, dword aTimeToWaitForSignal, float aSignalValue, char aBusContext[], char aMappedResponseInfo[])
*  \brief Function Wait and check if a physical signal value is not changing his value during a given time.
*  \param[in]  aSignalName          - Signal name from the database.
*  \param[in]  aTimeToWaitForSignal - The given time that the tester expects that the signal value is not changed
*  \param[in]  aSignalValue         - the expected signal value
*  \param[in]  aBusContext          - the bus name context
*  \param[out] aMappedResponseInfo  - the information which is going to be printed in the report 
*
*  \return  0 (NotOk) - if the signal values are changed
*  \return  1 (Ok)    - if the signal values are not changed
*  \return -1 (Error) - error (the bus context name is wrong / the time to wait for signal is zero / the signal does not have the expected value)
*
*  \note 
*          - An timeout must be set before this step
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  23.11.18              GrAn        Changed the comments for check part of the condition.
*  14.05.19              CrJu        Refactoring the code / Added new debug functions
*/

long lFctn_BUS_CheckSigValue4TimePhysical(Signal* aSignalName, dword aTimeToWaitForSignal, float aSignalValue, char aBusContext[], char aMappedResponseInfo[])
{
  long lResult;
  float fSignalValue;
  byte bResult_SetContext;
  dword dwResultChk;
  byte bDebugFlag;
  
  fSignalValue = 0;
  dwResultChk = NotOk;
  bResult_SetContext = NotOk;
  bDebugFlag = tsc_bBUS_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function lFctn_BUS_CheckSigValue4TimePhysical called.");
  
  if( (byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: Signal* aSignalName --%s--, dword aTimeToWaitForSignal --%d--, float aSignalValue --%u--, char aBusContext[] --%s-- ",aSignalName.name, aTimeToWaitForSignal,aSignalValue,aBusContext );  
  
  //Setting the bus Context
  bResult_SetContext = bFctn_BUS_SetContext(aBusContext);
 
  //Check if the bus context name is wrong
  if (bResult_SetContext == NotOk)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: The bus context name is wrong.");
    return Error;
  }
  
  //If the time to wait for signal is zero, return an error
  if (0 == aTimeToWaitForSignal)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: The time to wait for signal is zero.");
    return Error;
  }
  
  fSignalValue = getSignal(aSignalName);
  
  //if the signal does not have the expected value return an error
  if (aSignalValue != fSignalValue)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal value: %10.3f is different than the expected one: %10.3f.", fSignalValue, aSignalValue);
    return NotOk;
  }
  
  //if signal value has the exepected value, check if the signal value changes during aTimeToWaitForSignal ms
  dwResultChk = ChkStart_SignalValueChange (aSignalName);

  //check was created successfull
  if(dwResultChk)
  {
    //Check whether the specified condition was already broken (at least one time the condition was not fulfilled).
		TestAddCondition(dwResultChk);
	  //Wait the specified time
    TestWaitForTimeout(aTimeToWaitForSignal);
    
    if (0 == testCheckCondition(dwResultChk))  /*Condition was not broken (all checks were OK) */
    {
      //Remove the event object that was added as condition
      TestRemoveCondition(dwResultChk);
      snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal searched %s doesn't change his value %10.2f during %d ms.", aSignalName.name, aSignalValue, aTimeToWaitForSignal);
      return Ok;
    }
    else//Condition was broken (at least one time the condition was not fulfilled).
    {
      //Remove the event object that was added as condition
      TestRemoveCondition(dwResultChk);
      snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal searched %s has changed his value %10.2f during %d ms.", aSignalName.name, aSignalValue, aTimeToWaitForSignal);
      return NotOk;
    }
  }
	else//General Error
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "General Error!");
    return Error;
  }
}

/*! \fn long lFctn_BUS_CheckSigValue4TimeRaw(Signal* aSignalName, dword aTimeToWaitForSignal,dword aMsgCycleTime, int64 aSignalValue, char aMappedResponseInfo[])
*  \brief Function Wait and check if a raw signal value is not changing his value during a given time.
*  \param[in]  aSignalName          - Signal name from the database.
*  \param[in]  aTimeToWaitForSignal - Maximum time to be waited (if the value is 0 the function should get the first value of the signal)
*  \param[in]  aMsgCycleTime        - The message cycle time (from database)
*  \param[in]  aSignalValue         - The value that will be compared with the value of the signal.
*  \param[out] aMappedResponseInfo  - the information which is going to be printed in the report 
*
*  \return  0(NotOk) - if the signal does not have the expected value
*  \return  1(Ok)    - if the signal has the expected value
*  \return -1(Error) - the timeout provided is smaller than message cycle time or is zero / the message cycle time is zero
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  04.12.18              GrAn        The function was rewritten. Some unneded code parts were removed. More comments were added.
*  14.05.19              CrJu        Refactoring the code / Added new debug functions
*/

long lFctn_BUS_CheckSigValue4TimeRaw(Signal* aSignalName, dword aTimeToWaitForSignal, dword aMsgCycleTime, int64 aSignalValue, char aMappedResponseInfo[])
{
  long lResult;
  int64 i64RawSignalValue;
  dword dwNoOfIteration;
  dword dwLastWaitTimeout;
  dword dwCheckIteration;
  byte bDebugFlag;
  
  //Initialization of local variables
  lResult = NotOk;
  i64RawSignalValue = 0;
  bDebugFlag = tsc_bBUS_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function bFctn_BUS_CheckSigValue4TimeRaw called.");
  
  if( (byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters:  Signal* aSignalName --%s--, dword aTimeToWaitForSignal --%d--, dword aMsgCycleTime --%d--, int64 aSignalValue --%lld-- ",aSignalName.name, aTimeToWaitForSignal,aMsgCycleTime,aSignalValue);  
  
  //if the cycle time is bigger than time to wait for signal, return an error
  if ((aTimeToWaitForSignal > 0) && (aTimeToWaitForSignal < aMsgCycleTime))
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: The cycle time is bigger than time to wait for signal.");
    return Error;
  }
  
  //if cycle time is zero, return an error
  if (0 == aMsgCycleTime)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: Cycle time is zero.");
    return Error;
  }
  
  //If aTimeToWaitForSignal is zero, return an error
  if (0 == aTimeToWaitForSignal)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: The time to wait for signal is zero.");
    return Error;
  }
  else//if aTimeToWaitForSignal is greater than zero
  {
    //How many cycle time checks iterations to wait for signal
    dwNoOfIteration = aTimeToWaitForSignal / aMsgCycleTime;
    
    //Last Timeout to be waited
    dwLastWaitTimeout = aTimeToWaitForSignal - (dwNoOfIteration * aMsgCycleTime);
    
    //Test the signal value every cycle time
    for (dwCheckIteration = 0; dwCheckIteration <= dwNoOfIteration; dwCheckIteration++ )
    {
      //Test the signal value every cycle time
      if (dwCheckIteration != dwNoOfIteration)
      {
        //Get the signal value
        i64RawSignalValue = getRawSignal(aSignalName);

        //Test that the signal value is the expected one or not
        if (i64RawSignalValue == aSignalValue)//the signal value is equal with given one as expected
        {
          //Success, remain in loop
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal searched %s doesn't change his raw value %lld during %d ms.", aSignalName.name, aSignalValue, aTimeToWaitForSignal);
          lResult = Ok;
        }
        else//the signal value is not equal with given one as not expected
        {
          //Not Ok, exit the function
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal searched %s has changed his raw value %lld during %d ms.", aSignalName.name, aSignalValue, aTimeToWaitForSignal);
          return NotOk;
        }
        
        //Wait for the message cycle time, to test the signal value again
        testWaitForTimeout(aMsgCycleTime);
      }
      else
      {
        //Wait for remaining time
        if (dwLastWaitTimeout != 0 )
        {
          //wait for last remaining time
          testWaitForTimeout(dwLastWaitTimeout);
        }
         
        //Get the signal value
        i64RawSignalValue = getRawSignal(aSignalName);
      
        //Test that the signal value is the expected one or not
        if (i64RawSignalValue == aSignalValue)//the signal value is equal with given one as expected
        {
          //Success
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal searched %s doesn't change his raw value %lld during %d ms.", aSignalName.name, aSignalValue, aTimeToWaitForSignal);
          lResult = Ok;
        }
        else//the signal value is not equal with given one as not expected
        {
          //Not Ok, exit the function
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The signal searched %s has changed his raw value %lld during %d ms.", aSignalName.name, aSignalValue, aTimeToWaitForSignal);
          return NotOk;
        }
      }
    }
  }
  
  return lResult;
}

