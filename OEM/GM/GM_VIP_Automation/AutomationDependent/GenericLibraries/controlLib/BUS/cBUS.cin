/*! \fn long lFctn_BUS_WaitForSignalMatchInRangeRaw(Signal* aSignalName, dword aTimeToWaitForSignal, dword aMsgCycleTime, int64 aMinValue, int64 aMaxValue, char aBusContext[], char aMappedResponseInfo[])
*  \brief Function Wait and check if a message is send with his values inside of a given range or not. Function is used for raw values.
*  \param[in]  aSignalName          - Signal name from the database.
*  \param[in]  aTimeToWaitForSignal - Maximum time to be waited (if the value is 0 the function should get the first value of the signal)
*  \param[in]  aMsgCycleTime        - The message cycle time (from database)
*  \param[in]  aMinValue            - The minimum of the signal.
*  \param[in]  aMaxValue            - The maximum of the signal.
*  \param[in]  aBusContext          - the bus name context
*  \param[out] aMappedResponseInfo  - the information which is going to be printed in the report 
*
*  \return  0(NotOk) - if the signal values are not in range
*  \return  1(Ok)    - if the signal values are in range
*  \return -1(Error) - an error occured (Message cycle time is zero / lower limit is bigger than higher limit / timeout provided is smaller than message cycle time / bus cotext name is wrong)
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  12.04.18              GrAn        The function was rewritten. Some unneded code parts were removed. More comments were added.
*  10.05.19              CrJu        Refactoring the code / Added new debug functions
*/

long lFctn_BUS_WaitForSignalMatchInRangeRaw(Signal* aSignalName, dword aTimeToWaitForSignal, dword aMsgCycleTime, int64 aMinValue, int64 aMaxValue, char aBusContext[], char aMappedResponseInfo[])
{
  byte bResult;
  int64 i64RawSignalValue;
  byte bResult_SetContext;
  dword dwNoOfIteration;
  dword dwLastWaitTimeout;
  dword dwCheckIteration;
  byte bDebugFlag;

  //Initialization of local variables
  bResult = NotOk;
  i64RawSignalValue = 0;
  bResult_SetContext =  NotOk;
  bDebugFlag = tsc_bBUS_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function bFctn_BUS_WaitForSignalMatchInRangeRaw called.");
  
  if( (byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: Signal* aSignalName --%s--, dword aTimeToWaitForSignal --%d--, dword aMsgCycleTime --%d--, int64 aMinValue --%lld-- , int64 aMaxValue --%lld--, char aBusContext[] --%s-- ",aSignalName.name, aTimeToWaitForSignal, aMsgCycleTime, aMinValue, aMaxValue, aBusContext);

  //Setting the bus Context
  bResult_SetContext = bFctn_BUS_SetContext(aBusContext);
 
  //Check if the bus context name is wrong
  if (bResult_SetContext == NotOk)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: The bus context name is wrong.");
    return Error;
  }

  //if the cycle time is bigger than time to wait for signal, return an error
  if ((aTimeToWaitForSignal > 0) && (aTimeToWaitForSignal < aMsgCycleTime))
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: The cycle time is bigger than time to wait for signal.");
    return Error;
  }
  
  //if lower limit is bigger than higher limit, return an error
  if (aMinValue > aMaxValue)
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: Lower limit is bigger than higher limit.");
    return Error;
  }
  
  if (0 == aMsgCycleTime)//if cycle time is zero, return an error
  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: Cycle time is zero.");
    return Error;
  }
  
  if (0 == aTimeToWaitForSignal)//if aTimeToWaitForSignal is 0 - the function should get the first value of the signal
  {
    //Wait for the first signal value
    testWaitForTimeout(aMsgCycleTime);
    
    //Take the signal value
    i64RawSignalValue = getRawSignal(aSignalName);

    //Test if the signal value is inside given limits
    if ((i64RawSignalValue >= aMinValue) && (i64RawSignalValue <= aMaxValue))//The value of signal is in range
    {
      snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The raw value of the signal: %lld, is inside the given limits: %lld - %lld.", i64RawSignalValue, aMinValue, aMaxValue);
      return Ok;
    }
    else//The value of signal is not in range
    {
      snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The raw value of the signal: %lld, is not inside the given limits: %lld - %lld.", i64RawSignalValue, aMinValue, aMaxValue);
      return NotOk;
    }
  }
  else//if aTimeToWaitForSignal is greater than zero
  {
    //How many cycle time checks iterations to wait for signal
    dwNoOfIteration = aTimeToWaitForSignal / aMsgCycleTime;
    
    //Last Timeout to be waited
    dwLastWaitTimeout = aTimeToWaitForSignal - (dwNoOfIteration * aMsgCycleTime);
    
    //Test the signal value every cycle time
    for (dwCheckIteration = 0; dwCheckIteration <= dwNoOfIteration; dwCheckIteration++ )
    {
      //Test the signal value every cycle time, except the last Iteration
      if (dwCheckIteration != dwNoOfIteration)
      {
        //Take the signal value
        i64RawSignalValue = getRawSignal(aSignalName);
      
        //Test if the signal value is in range or not
        if ((i64RawSignalValue >= aMinValue) && (i64RawSignalValue <= aMaxValue))//The value of signal is in range
        {
          //Success, remain in loop
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The raw value of the signal: %lld, is inside the given limits: %lld - %lld.", i64RawSignalValue, aMinValue, aMaxValue);
          bResult = Ok;
        }
        else //The value of signal is not in range
        {
          //Error, exit from function
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The raw value of the signal: %lld, is not inside the given limits: %lld - %lld.", i64RawSignalValue, aMinValue, aMaxValue);
          return NotOk;
        }
          
        //Wait the message cycle time
        testWaitForTimeout(aMsgCycleTime);        
      }
      else //it's the last Iteration
      {
        //Wait the remaining time 
        if (dwLastWaitTimeout != 0)
        {
          testWaitForTimeout(dwLastWaitTimeout);
        }
          
        //Take the signal value
        i64RawSignalValue = getRawSignal(aSignalName);
      
        //Test if the signal value is in range or not
        if ((i64RawSignalValue >= aMinValue) && (i64RawSignalValue <= aMaxValue))//The value of signal is in range
        {
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The raw value of the signal: %lld, is inside the given limits: %lld - %lld.", i64RawSignalValue, aMinValue, aMaxValue);
          bResult = Ok;
        }
        else//The value of signal is not in range
        {
          //Error, exit from function
          snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The raw value of the signal: %lld, is not inside the given limits: %lld - %lld.", i64RawSignalValue, aMinValue, aMaxValue);
          return NotOk;
        }
      }
    }
  }
  
  return bResult;  
}

