  {
    snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Error: Lower limit is bigger than higher limit.");
    return Error;
  }

  if (0 == aTimeToWaitForSignal)//if aTimeToWaitForSignal is 0 - the function should get the first value of the signal
  {
    fSignalInRange = getSignal(aSignalName);

    //Test if the signal value is inside given limits
    if ((fSignalInRange < aMinValue) || (fSignalInRange > aMaxValue))
    {
      snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The value of the signal: %10.3f, is outside the given limits: %10.2f - %10.2f.", fSignalInRange, aMinValue, aMaxValue);
      return Ok;
    }
    else
    {
      snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The value of the signal: %10.3f, is inside the given limits: %10.2f - %10.2f.", fSignalInRange, aMinValue, aMaxValue);
      return NotOk;
    }
  }
  else//if aTimeToWaitForSignal is greater than zero
  {
    //Test if the signal values are outside given limits
    dwResultChk = ChkStart_MsgSignalValueInvalid (aSignalName,aMinValue,aMaxValue); 

    //check was created successfull
    if(dwResultChk)
    {
      //Check whether the specified condition was already broken (at least one time the condition was not fulfilled).
		  TestAddCondition(dwResultChk);
      //Wait the specified time
	    TestWaitForTimeout(aTimeToWaitForSignal);  
    
      if (0 == testCheckCondition(dwResultChk))  /*Condition was not broken (all checks were OK) */
      {
        //Remove the event object that was added as condition
        TestRemoveCondition(dwResultChk);
        snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "The value of the signal is outside the given limits: %10.2f - %10.2f.", aMinValue, aMaxValue);
        return Ok;
      }
      else//Condition was broken (at least one time the condition was not fulfilled).
      {
        //Remove the event object that was added as condition
        TestRemoveCondition(dwResultChk);
        snprintf(aMappedResponseInfo, elcount(aMappedResponseInfo), "Condition was broken (the value of the signal might be INSIDE the limits).");
        return NotOk;
      }
