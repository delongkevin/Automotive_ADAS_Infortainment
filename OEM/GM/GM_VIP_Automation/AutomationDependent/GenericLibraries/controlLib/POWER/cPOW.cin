/*! \fn int iFctn_ConvertFromFixedFormatToMilli(char chNumber[])
*  \brief Function converts a string with floating point to an integer value .
*  \param[in] chNumber - Value to be converted.
*
*  \return a number in mili or -1 in case of error
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  11.04.18              SeNi        Created and implemented
*  01.11.23            CiCo        Fix for conversion using a regex pattern
*/

int iFctn_ConvertFromFixedFormatToMilli (char chNumber[])
{
  float fValue      = NotOk;
  long lStartIndex; //string index from which conversion to start - for General Type Power Supply format answer is X YY.YY where X is letter and Y are numbers
  char chFormatedNumber[20];
  
  lStartIndex = strstr_regex(chNumber, "[0-9]*\\.[0-9]");// search for a pattern in form ddd.ddd
  writeDbgLevel (DebugFuncCalls, "Function iFctn_ConvertFromFixedFormatToMilli called.");
  writeDbgLevel (DebugFuncParam, "Parameters: Array of char to be converted -- %s --.", chNumber);  
  if( -1 != lStartIndex ){
    substr_cpy(chFormatedNumber, chNumber, lStartIndex, -1, elcount(chFormatedNumber));
    strtod(chFormatedNumber, fValue);
    fValue = fValue * 1000;
  }
  else
    fValue = -1; // error in finding the pattern
  
  writeDbgLevel (DebugFuncInternal, "Converted value is: --%d --.", fValue);
  
  return fValue;
}


/*! \fn void vFctn_ConvertFromMilliToFixedFormat(long lValue)
*  \brief Function converts an integer value to an array of bytes with floating point.
*  \param[in] lValue - Value to be converted.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  21.03.18              SeNi        Created and implemented
*/

void vFctn_ConvertFromMilliToFixedFormat (long lValue)
{
  int iIndex;
  byte bTemp;
  
  writeDbgLevel (DebugFuncCalls, "Function vFctn_ConvertFromMilliToFixedFormat called.");
  writeDbgLevel (DebugFuncParam, "Parameters: Value to be converted: -- %d --.", lValue);
  
  for(iIndex=0; iIndex<elcount(cv_bPOWSendDataValue);iIndex++)
    cv_bPOWSendDataValue[iIndex] = NotOk;
  
  iIndex = NotOk;
  
  bTemp = lValue / 10000;
  if( bTemp > NotOk )
  {
    cv_bPOWSendDataValue[iIndex] = bTemp + 0x30;
    writeDbgLevel (DebugFuncInternal, "Byte %d from the conversion is: -- %c --",iIndex,cv_bPOWSendDataValue[iIndex]);
    iIndex++;
  }
  lValue -= bTemp*10000;

  bTemp = lValue / 1000;
  cv_bPOWSendDataValue[iIndex] = bTemp + 0x30;
  writeDbgLevel (DebugFuncInternal, "Byte %d from the conversion is: -- %c --",iIndex,cv_bPOWSendDataValue[iIndex]);
  iIndex++;
  lValue -= bTemp*1000;
   
  cv_bPOWSendDataValue[iIndex] = '.';
  writeDbgLevel (DebugFuncInternal, "Byte %d from the conversion is: -- %c --",iIndex,cv_bPOWSendDataValue[iIndex]);
  iIndex++;

  bTemp = lValue / 100;
  cv_bPOWSendDataValue[iIndex] = bTemp + 0x30;
  writeDbgLevel (DebugFuncInternal, "Byte %d from the conversion is: -- %c --",iIndex,cv_bPOWSendDataValue[iIndex]);
  iIndex++;
  lValue -= bTemp*100;
   
  bTemp = lValue / 10;
  cv_bPOWSendDataValue[iIndex] = bTemp + 0x30;
  writeDbgLevel (DebugFuncInternal, "Byte %d from the conversion is: -- %c --",iIndex,cv_bPOWSendDataValue[iIndex]);
  iIndex++;
  lValue -= bTemp*10;
   
  bTemp = lValue / 1;
  cv_bPOWSendDataValue[iIndex] = bTemp + 0x30;
  writeDbgLevel (DebugFuncInternal, "Byte %d from the conversion is: -- %c --",iIndex,cv_bPOWSendDataValue[iIndex]);
  iIndex++;

}


/*! \fn byte bFctn_POWSetVoltage(long lVoltage)
*  \brief Function sets command to set voltage from PowerSupply
*  \param[in] lVoltage - Voltage to set (in milivolts).
*
*  \return  0 - Voltage is not set / Voltage is over maximum
*  \return  1 - Voltage is set
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  21.03.18              SeNi        Created and implemented
*  03.02.20              CrJu        Added a new type of power supply
*  07.07.20              CrJu        Updated with new control function: bFctn_POW_SetCommand() and added debug functions
*/

byte bFctn_POWSetVoltage(long lVoltage)
{
  byte bResult;
  byte bDebugFlag;
  double dVoltageToSet;
  char chValueToSet[25];
  char chMappedResponseInfo[250];
  
  bResult = NotOk;
  bDebugFlag = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Function bFctn_POWSetVoltage called.");
  
  if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncParam, "Parameters: Voltage in milivolts to set: -- %d --.", lVoltage);
  
  if (cv_lPOWmaxVoltage < lVoltage)
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "Voltage is over maximum voltage supported by PowerSupply: %d.", cv_lPOWmaxVoltage);
    return NotOk;
  }
  
  dVoltageToSet = (float)(lVoltage); //transform the mV to V(with floating point)
  dVoltageToSet = dVoltageToSet / 1000;
  
  // BK Precision 1687b: voltage is sent as a 3-digit integer in units of 0.1 V
  // e.g. 12.0 V (lVoltage = 12000 mV) -> lVoltage / 100 = 120 -> "VOLT120\r"
  if(cv_bPOWType == cc_bTypeBKPrecision)
    snprintf(chValueToSet, elCount(chValueToSet), "%03d", (int)(lVoltage / 100));
  else
    snprintf(chValueToSet, elCount(chValueToSet), "%f", dVoltageToSet);
  bResult = bFctn_POW_SetCommand(eSetVoltage, chValueToSet, chMappedResponseInfo);
  
  if(bResult)
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return Ok;
  }
  else
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return NotOk;
  }
}

/*! \fn byte bFctn_POWSetCurrent(int iCurrent)
*  \brief Function sets command to set max current from PowerSupply
*  \param[in] iCurrent - Current to set (in miliamps).
*
*  \return  0 - Current is not set / Current is over maximum
*  \return  1 - Current is set
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  21.03.18              SeNi        Created and implemented
*  03.02.20              CrJu        Added a new type of power supply
*  07.07.20              CrJu        Updated with new control function: bFctn_POW_SetCommand() and added debug functions
*/

byte bFctn_POWSetCurrent(int iCurrent)
{
  byte bResult;
  byte bDebugFlag;
  double dCurrentToSet;
  char chValueToSet[25];
  char chMappedResponseInfo[250];
  
  bResult = NotOk;
  bDebugFlag = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Function bFctn_POWSetCurrent called.");
  
  if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncParam, "Parameters: Current in miliamps to set: -- %d --.", iCurrent);
  
  if (cv_lPOWmaxCurrent < iCurrent)
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "Current is over maximum current supported by PowerSupply: %d.", cv_lPOWmaxCurrent);
    return NotOk;
  }
  
  dCurrentToSet = (float)(iCurrent); //transform the mV to V(with floating point)
  dCurrentToSet = dCurrentToSet / 1000;
  
  // BK Precision 1687b: current is sent as a 3-digit integer in units of 0.1 A
  // e.g. 2.5 A (iCurrent = 2500 mA) -> iCurrent / 100 = 25 -> "CURR025\r"
  if(cv_bPOWType == cc_bTypeBKPrecision)
    snprintf(chValueToSet, elCount(chValueToSet), "%03d", (int)(iCurrent / 100));
  else
    snprintf(chValueToSet, elCount(chValueToSet), "%f", dCurrentToSet);
  bResult = bFctn_POW_SetCommand(eSetCurrent, chValueToSet, chMappedResponseInfo);
  
  if(bResult)
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return Ok;
  }
  else
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return NotOk;
  }
}


/*! \fn void vFctn_POWSetActivePOW(byte bPort, int iBaudRate, byte bDataBits, byte bParity, byte bStopBits, byte bType, byte bWaitTime, long lMaxVoltage, long lMaxCurrent, int iSCPIAddress, int iFlowControl, long lWaitForCommand)
*  \brief Function sets the parameters for communication on RS232
*  \param[in] bPort - port number.
*  \param[in] iBaudRate - baud rate for selected device.
*  \param[in] bDataBits - number of data bits.
*  \param[in] bParity - parity.
*  \param[in] bStopBits - number of stop bits.
*  \param[in] bType - type of POW.
*  \param[in] bWaitTime - wait time for answers.
*  \param[in] lMaxVoltage - Maximum voltage allowed.
*  \param[in] lMaxCurrent - Maximum current allower.
*  \param[in] iSCPIAddress - The address of the SCPI power supply. (It is used only for SCPI PS)
*  \param[in] iFlowControl - The FlowControl of the power supply. ( 0 - no FlowControl at all, 1 - hardware FlowControl, use DTR<->DSR )
*  \param[in] lWaitForCommand - The waiting time between seding commands 
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  28.03.18              SeNi        Created and implemented
*  03.02.20              CrJu        Added a new type of power supply
*  21.06.23              CiCo        Add select commands
*/

void vFctn_POWSetActivePOW(byte bPort, int iBaudRate, byte bDataBits, byte bParity, byte bStopBits, byte bType, byte bWaitTime, long lMaxVoltage, long lMaxCurrent, int iSCPIAddress, int iFlowControl, long lWaitForCommand)
{
  char chMappedResponseInfo[250];
  byte bDebugFlag;
  bDebugFlag = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Function vFctn_POWSetActivePOW called.");
  writeDbgLevel (DebugFuncParam, "Parameters: byte bPort -- %d --, int iBaudRate -- %d --, byte bDataBits -- %d --, byte bParity -- %d --, byte bStopBits -- %d --, byte bType -- %d --, byte bWaitTime -- %d --, long lMaxVoltage -- %d --, int lMaxCurrent -- %d --", bPort, iBaudRate, bDataBits, bParity, bStopBits, bType, bWaitTime, lMaxVoltage, lMaxCurrent);  

  cv_bPOWPort           =       bPort;    
  cv_iPOWBaudRate       =   iBaudRate;    
  cv_bPOWDataBits       =   bDataBits;    
  cv_bPOWParity         =     bParity;    
  cv_bPOWStopBits       =   bStopBits;   
  cv_bPOWwaitTime       =   bWaitTime; 
  cv_lPOWmaxVoltage     = lMaxVoltage;
  cv_lPOWmaxCurrent     = lMaxCurrent; 
  cv_iPOWSCPIAddress    = iSCPIAddress;
  cv_iPOWFlowControl    = iFlowControl;
  cv_iPOWWaitForCommand = lWaitForCommand;
  
  if(cc_bTypeSCPI != bType)
  {
    cv_bPOWType = bType;   
    //set power supply command number of bytes

    //Define Max Voltage and Max Current in the power supply panel
    bFctn_POW_GetPSCommands((enum cc_ePStype) cv_bPOWType, chMappedResponseInfo);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    sysDefineVariableFloat("PowGeneral_Variables", "VoltageVal", 1, 0, @sysvar::PowGeneral_Variables::MaxVoltage);
    sysDefineVariableFloat("PowGeneral_Variables", "CurrentVal", 1, 0, @sysvar::PowGeneral_Variables::MaxCurrent);
  }
  else if(cc_bTypeSCPI == bType)
  {
    cv_bPOWType = bType;
    bFctn_POW_GetPSCommands((enum cc_ePStype) cv_bPOWType, chMappedResponseInfo);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    //set the Address for SCPI power supply only if the port was closed before
    if(@sysvar::RS232_SYSVariables::sv_RS232PortStatus == Disable)
    {
      lFctn_POW_SetAddressForSCPI(cv_iPOWSCPIAddress);
    }
    else
    {
      @sysvar::PowGeneral_Variables::SCPICommand = 0; //The command for setting address is not sent
    }
    
    //Define Max Voltage and Max Current in the power supply panel
    sysDefineVariableFloat("PowGeneral_Variables", "VoltageVal", 1, 0, @sysvar::PowGeneral_Variables::MaxVoltage);
    sysDefineVariableFloat("PowGeneral_Variables", "CurrentVal", 1, 0, @sysvar::PowGeneral_Variables::MaxCurrent);
  }
  else
  {
    //to be added case - default case at this moment  
  }
}

