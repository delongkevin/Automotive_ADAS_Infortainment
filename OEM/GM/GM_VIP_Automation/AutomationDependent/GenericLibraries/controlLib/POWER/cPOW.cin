/*! \fn long lFctn_POW_SetAddressForSCPI(byte aSCPIAddress)
*  \brief Function send the command (INSTrument:NSELect x) for setting the Address of the SCPI power supply
*
*  \param[in] aSCPIAddress - Address of the SCPI power supply.
*
*  \return  1 (Ok)     - The command for setting the Address of the SCPI power supply has been succesfully sent.
*  \return -1 (Error)  - An error occured.
* 
*  \note This function must be CALLED FIRST for SCPI language.
*  \note The  address can be from 1 to 31.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  02.03.20              CrJu        Created and implemented
*  08.07.20              CrJu        Update with the new control function: bFctn_POW_SetCommand()
*/

long lFctn_POW_SetAddressForSCPI(byte aSCPIAddress)
{
  byte bIndex;
  int iIndex;
  int iDigit;
  byte bDebugFlag;
  byte bResult;
  char chValueToSet[25];
  char chMappedResponseInfo[250];
  
  iDigit = NotOk;
  bIndex = NotOk;
  bResult = NotOk;
  bDebugFlag = NotOk;
    
  writeDbgLevel (DebugFuncCalls, "Function lFctn_POW_SetAddressForSCPI called.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: SCPI Address: %d.", aSCPIAddress);
  
  snprintf(chValueToSet, elCount(chValueToSet), "%d", aSCPIAddress);
  bResult = bFctn_POW_SetCommand(eSelectAddress, chValueToSet, chMappedResponseInfo);
  
  //Set the flag for openning the port
  @sysvar::RS232_SYSVariables::sv_RS232PortStatus = Enable;
  
  if(bResult)
  {
    //Set the flag for sending the SCPI command
    @sysvar::PowGeneral_Variables::SCPICommand = 1;
    
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return Ok;
  }
  else
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return Error;
  }
}
  
/*! \fn byte bFctn_POW_SetCommand(enum cc_eCommandToSend aCommandToSend, char aValue[], char aMappedResponseInfo[])
*  \brief Function sends a Command to the Power Supply, with a specific Value.
*  \param[in] aCommandToSend       - Commands to send can be: eSetVoltage / eSetCurrent / ePowerSupply_ON / ePowerSupply_OFF
*  \param[in] aValue               - Value to be sent for setting voltage/current. It must be format of: XX.xxx V/A. For ON or OFF, it can be empty
*  \param[out] aMappedResponseInfo - Extra information regarding the function output (displayed in the test report).
*
*  \return 
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  23.06.20              CrJu        Created and implemented
*  21.06.23              CiCo        Updated with predifined commands
*/

byte bFctn_POW_SetCommand(enum cc_eCommandToSend aCommandToSend, char aValue[], char aMappedResponseInfo[])
{
  byte bDebugFlag;
  char chCMD[50]; 
  char chTerminates[4];
  
  bDebugFlag = NotOk;
  
  // BK Precision 1687b uses CR (\r) only as command terminator; all others use CR+LF
  if(cv_bPOWType == cc_bTypeBKPrecision)
    strncpy(chTerminates, "\r", elCount(chTerminates));
  else
    strncpy(chTerminates, "\r\n", elCount(chTerminates));
  
  writeDbgLevel (DebugFuncCalls, "Function bFctn_POW_SetCommand called.");
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: Command to send: -- %d -- with value: %s.", aCommandToSend, aValue);
  
  switch (aCommandToSend){
    case ePowerSupply_ON:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Set Power Supply ON.");
      snprintf(chCMD, elCount(chCMD), "%s%s", cv_stGenericCommands.chSetOn, chTerminates);
      break;
    }
    case ePowerSupply_OFF:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Set Power Supply OFF.");
      snprintf(chCMD, elCount(chCMD), "%s%s", cv_stGenericCommands.chSetOff, chTerminates);
      break;
    }
    case eSetVoltage:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Set Voltage of Power Supply to: %s V.", aValue);
      snprintf(chCMD, elCount(chCMD), "%s%s%s", cv_stGenericCommands.chSetVoltage, aValue, chTerminates);
      break;
    }
    case eSetCurrent:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Set Current of Power Supply to: %s A.", aValue);
      snprintf(chCMD, elCount(chCMD), "%s%s%s", cv_stGenericCommands.chSetCurrent, aValue, chTerminates);
      break;
    }
    case eGetPSCurrent:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Read Current consumption from Power Supply.");
      snprintf(chCMD, elCount(chCMD), "%s%s", cv_stGenericCommands.chGetCurrent, chTerminates);
      break;
    }
    case eGetPSVoltage:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Read Voltage from Power Supply.");
      snprintf(chCMD, elCount(chCMD), "%s%s", cv_stGenericCommands.chGetVoltage, chTerminates);
      write("chCMD %s",chCMD);
      break;
    }
    case eGetPSStatus:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Read Status of Power Supply.");
      snprintf(chCMD, elCount(chCMD), "%s%s", cv_stGenericCommands.chGetStatus, chTerminates);
      break;
    }
    case eSelectAddress:
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Select SCPI addres for Power Supply.");
      snprintf(chCMD, elCount(chCMD), "%s%s", cv_stGenericCommands.chSelectAddress, chTerminates);
      break;
    }
    default:
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Request command not set. Invalid request. Only setter requests can be used for this function.");
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, aMappedResponseInfo);
      return NotOk; 
  }
  
  // debug for command to send
  if((byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal,"%s %s" ,aMappedResponseInfo, chCMD); 
  
  if(Ok == bFctn_RS232OpenPort(cv_bPOWPort, cv_iPOWBaudRate, cv_bPOWDataBits, cv_bPOWStopBits, cv_bPOWParity, cv_iPOWFlowControl))
  {
    if(Ok == bFctn_RS232SendData(cv_bPOWPort, chCMD))
    {
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, aMappedResponseInfo);
      return Ok;
    }
    else
    {
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Failed to send data on port: %d. Check the ini. file to be correct.", cv_bPOWPort);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, aMappedResponseInfo);
      return NotOk;
    }
  }
  else
  {
    snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Failed to open port: %d. Check the ini. file to be correct.", cv_bPOWPort);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, aMappedResponseInfo);
    return NotOk; 
  }
}

/*! \fn byte bFctn_POW_GetPSCommands(enum cc_ePStype aPStype, char aMappedResponseInfo[])
*  \brief Function to set the availble commands for power supply.
*  \param[in]  aPStype       - Power Supply type: eGeneral, eSCPI, eGeneralDual_1, eGeneralDual_2
*  \param[out] aMappedResponseInfo - Extra information regarding the function output.
*
*  \return  1 (Ok)     - Commands available for use.
*  \return  0 (NotOk)  - An error occured.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  21.06.23              CiCo        Created and implemented
*/
byte bFctn_POW_GetPSCommands(enum cc_ePStype aPStype, char aMappedResponseInfo[])
{
  byte bDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function bFctn_POW_GetPSCommands called.");
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: PS Type: -- %d --", aPStype);
  
  switch (aPStype) {
    case eGeneral:
      memcpy(cv_stGenericCommands, cc_stPS_General);
      break;
    case eGeneralDual_1:
      memcpy(cv_stGenericCommands, cc_stPS_GeneralDual_1);
      break;
    case eGeneralDual_2:
      memcpy(cv_stGenericCommands, cc_stPS_GeneralDual_2);
      break;
    case eSCPI :
      memcpy(cv_stGenericCommands, cc_stPS_SCPI);
      break;
    case eBKPrecision:
      memcpy(cv_stGenericCommands, cc_stPS_BKPrecision);
      break;
    default :
      snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Commands for power supply are not defined %d", aPStype);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, aMappedResponseInfo);
      return NotOk;
      break;
  }
  snprintf(aMappedResponseInfo, elCount(aMappedResponseInfo), "Commands for power supply available for -> %d", aPStype);
  if((byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal, aMappedResponseInfo);
  return Ok;
}

