/*! \fn byte bFctn_POWInit(byte bPOWNumber) 
*  \brief Function initializes link to power supply.
*  \param[in] bPOWNumber - PSNumber from ini file to set active.
*
*  \return  0 - PS could not be initialized
*  \return  1 - PS is initialized with success
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  12.09.18              SeNi        Created and implemented
*  04.12.19              CiCo        Updated to init the PS with data from ini file only once
*  22.09.20              CrJu        Add doxygen and write debug levels.
*/

byte bFctn_POWInit(byte bPOWNumber) 
{
  byte bResult;
  char chIniFile[256];
  
  writeDbgLevel (DebugFuncCalls, "Function vFctn_POWInit called");
  writeDbgLevel (DebugFuncParam, "Parameters: byte bPOWNumber: %d.", bPOWNumber);
  
  if( NotOk == cv_bGetPowIniStatus )// read from ini only if was not readed
    if( Ok == bFctn_POWReadINI() )
      cv_bGetPowIniStatus = Ok;
    
  if(bPOWNumber < cv_iPOWPSNumber)
  {
    writeDbgLevel (DebugFuncInternal, "The initialization of Power Supply number: %d was successfully done.");
    return Ok;
  }
  else
  {
    writeDbgLevel (DebugFuncInternal, "The initialization of Power Supply number: %d was not completed. Check bFctn_POWReadINI() for more information.");
    return NotOk;
  }
}


/*! \fn byte bFctn_POWReadINI()
*  \brief Function reads power source params from ini file.
*
*  \return  0 - Error reading the ini file
*  \return  1 - All parameters of Power Supply were read ok
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  13.09.18              SeNi        Created and implemented
*  23.09.20              CrJu        Complete the doxygen and added the write debug levels
*/

byte bFctn_POWReadINI() 
{
  byte bIndex;
  byte bReturn;
  char chIniFile[256];
  char chEntry[64];
  
  writeDbgLevel (DebugFuncCalls, "Function bFctn_POWReadINI called");

  bReturn = bFctn_READFILELastINIused(chIniFile);
  if(!bReturn)
    return NotOk;
  
  writeDbgLevel (DebugFuncInternal, "Reading from .ini file PSNumber.");
  cv_iPOWPSNumber = lFctn_READFILEiniParameterNumber(chIniFile, "PSNumber", "POWERSUPPLY");
  
  if(Error == cv_iPOWPSNumber)
    return NotOk;
  else
  {
    for(bIndex = 0; bIndex < cv_iPOWPSNumber; bIndex++)
    {
      snprintf(chEntry, elCount(chEntry), "PS%dPresent", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSPresentArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSPresentArray[bIndex])
        return NotOk;
      
      snprintf(chEntry, elCount(chEntry), "PS%dType", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSTypeArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSTypeArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dCOMPort", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSCOMPortArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSCOMPortArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dDataBits", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSDataBitsArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSDataBitsArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dParity", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSParityArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSParityArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dStopBits", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSStopBitsArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSStopBitsArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dBaudRate", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSBaudRateArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSBaudRateArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dMaxVoltage", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_lPOWPSMaxVoltageArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_lPOWPSMaxVoltageArray[bIndex])
        return NotOk;
        
      snprintf(chEntry, elCount(chEntry), "PS%dMaxCurrent", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_lPOWPSMaxCurrentArray[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_lPOWPSMaxCurrentArray[bIndex])
        return NotOk; 
      
      if(cv_iPOWPSTypeArray[bIndex] == 2) //Read SCPI parameter only if SCPI Type is selected
      {
        snprintf(chEntry, elCount(chEntry), "PS%dSCPIAddress", bIndex);
        writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
        cv_iPOWPSSCPIAddress[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
        if(Error == cv_iPOWPSSCPIAddress[bIndex])
          return NotOk;
      }
      
      snprintf(chEntry, elCount(chEntry), "PS%dFlowControl", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSFlowControl[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSFlowControl[bIndex])
        return NotOk;
      
      snprintf(chEntry, elCount(chEntry), "PS%dWaitForCommand", bIndex);
      writeDbgLevel (DebugFuncInternal, "Reading from .ini file %s.",chEntry);
      cv_iPOWPSWaitForCommand[bIndex] = lFctn_READFILEiniParameterNumber(chIniFile, chEntry, "POWERSUPPLY");
      if(Error == cv_iPOWPSWaitForCommand[bIndex])
        return NotOk;
    }
    return Ok;
  }
}

/*! \fn byte bFctn_POWSelectPowerSupply(byte bPOWNumber) 
*  \brief Function selects from ini file which Power Supply to set active (0, 1... 8).
*  \param[in] bPOWNumber - PSNumber from ini file to set active.
*
*  \return  0 - PS could not be selected
*  \return  1 - PS was successfully selected
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  12.09.18              SeNi        Created and implemented
*  04.12.19              CiCo        Updated with bFctn_POWInit to read data from ini file
*  23.09.20              CrJu        Updated the doxygen and added new debug levels
*/

byte bFctn_POWSelectPowerSupply(byte bPOWNumber) 
{
  byte bResult;
  char chIniFile[256];
  bResult = NotOk;
  writeDbgLevel (DebugFuncCalls, "Function bFctn_POWSelectPowerSupply called");
  writeDbgLevel (DebugFuncParam, "Parameters: byte bPOWNumber: %d.", bPOWNumber);
  
  bResult = bFctn_POWInit( bPOWNumber );
  if(Ok == bResult)
  {
    if(bPOWNumber < cv_iPOWPSNumber)
    {
      writeDbgLevel (DebugFuncInternal, "Power Supply selected is available in ini file, number: %d.", bPOWNumber);
      vFctn_POWSetActivePOW(cv_iPOWPSCOMPortArray[bPOWNumber], cv_iPOWPSBaudRateArray[bPOWNumber], cv_iPOWPSDataBitsArray[bPOWNumber], cv_iPOWPSParityArray[bPOWNumber], cv_iPOWPSStopBitsArray[bPOWNumber], cv_iPOWPSTypeArray[bPOWNumber], cv_wPOWPSWaitTimeForResponse, cv_lPOWPSMaxVoltageArray[bPOWNumber], cv_lPOWPSMaxCurrentArray[bPOWNumber], cv_iPOWPSSCPIAddress[bPOWNumber], cv_iPOWPSFlowControl[bPOWNumber], cv_iPOWPSWaitForCommand[bPOWNumber]);
      return Ok;
    }
    else
    {
      writeDbgLevel (DebugFuncInternal, "Power Supply selected is NOT available in ini file, number selected: %d, number of power supplies: %d.", bPOWNumber, cv_iPOWPSNumber);
      return NotOk;
    }
  }
  else
  {
    writeDbgLevel (DebugFuncInternal, "Error in initialize power supply: %d. See the bFctn_POWInit for more info.", bPOWNumber, cv_iPOWPSNumber);
    return NotOk;  
  }
}

/*! \fn long lFctn_POW_ReadActualVoltage()
*  \brief Function send the command (V?) for reading the voltage of the source.
*
*  \return  1 (Ok)     - The command for read curent voltage has been succesfully sent.
*  \return -1 (Error)  - An error occured.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  23.01.20              CrJu        Created and implemented
*  08.07.20              CrJu        Update with the new control function: bFctn_POW_SetCommand()
*/

long lFctn_POW_ReadActualVoltage()
{
  byte bDebugFlag;
  byte bResult;
  char chMappedResponseInfo[250];
  
  bResult = NotOk;
  bDebugFlag = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Function lFctn_POW_ReadActualVoltage called.");
 
  bResult = bFctn_POW_SetCommand(eGetPSVoltage, "", chMappedResponseInfo);
  
  if(bResult)
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return Ok;
  }
  else
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chMappedResponseInfo);
    return Error;
  }
}

