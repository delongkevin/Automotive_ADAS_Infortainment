    else //Expect the PDU to be absent
    {
      //PDU has arrived, as the user didn't expect.
      if ( Ok == lResult )
      {
        vFctn_REPORTStepEvaluation(chPDUPresenceInfo, FAIL);
      }
      else //PDU has not arrived, as the user expected.
      {
        vFctn_REPORTStepEvaluation(chPDUPresenceInfo, PASS);
      }
    }
