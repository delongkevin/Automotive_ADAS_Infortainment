/*! \fn void A_PDU_WaitForAutosarPDUByName(dbPDU* aPDUNameFromDB, dword aTimeout, enum eExpectedPresence aExpectedPDUPresence, char aBusContext[])
*  \brief Function that executes the action to check if a Autosar PDU name is received in a specific time or not.
*  \param[in] aPDUNameFromDB        - Name of the Autosar PDU from the arxml database.
*  \param[in] aTimeout              - Maximum wait time to check if the Autosar PDU is absent or not.
*  \param[in] aExpectedPDUPresence  - The expected presence of the Autosar PDU: Present or Absent.
* 
*  \return None
*
*  \note 
*     - The aPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in the test file: tsPDU_Tests.can for more details.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 20.05.2019             CrJu           Created and implemented
*/

void A_PDU_WaitForAutosarPDUByName(dbPDU* aPDUNameFromDB, dword aTimeout, enum eExpectedPresence aExpectedPDUPresence)
{
  char chAction[250];
  char chFailText[250];
  char chPDUPresenceInfo[250];
  long lResult;
  byte bDebugFlag;
  byte bResultAction;
  
  // Initialization of local variables
  lResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_PDU_WaitForPDUByName().");
  
  if ((byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel(DebugFuncParam, "Parameters: PDU* aPDUNameFromDB, dword aTimeout: -- %d --, eExpectedState aExpectedPDUPresence -- %d -- (0 - ABSENT; 1 - PRESENT)", aTimeout, aExpectedPDUPresence);
  
  snprintf(chAction, elcount(chAction), "Check if the specified Autosar PDU Name is evaluated as: %d (0 - Absent, 1 - Present), within the specified wait time.", aExpectedPDUPresence);
  bResultAction = bFctn_REPORTAction(chAction);

  if(Ok == bResultAction)
  {
    lResult = lFctn_PDU_WaitForAutosarPDUByName(aPDUNameFromDB, aTimeout, chPDUPresenceInfo);
    
    if( Error != lResult)
    {
      if(Present == aExpectedPDUPresence) //Expect the PDU to be present
      {
        //PDU has arrived, as the user expected.
        if ( Ok == lResult )
        {
          vFctn_REPORTActionEvaluation(chPDUPresenceInfo, PASS);
        }
        else //PDU has not arrived, as the user didn't expect.
        {
          vFctn_REPORTActionEvaluation(chPDUPresenceInfo, FAIL);
        }
      }
      else //Expect the PDU to be absent
      {
        //PDU has arrived, as the user didn't expect.
        if ( Ok == lResult )
        {
          vFctn_REPORTActionEvaluation(chPDUPresenceInfo, FAIL);
        }
        else //PDU has not arrived, as the user expected.
        {
          vFctn_REPORTActionEvaluation(chPDUPresenceInfo, PASS);
        }
      }
    }
    else //an error occurred
    {
      vFctn_REPORTActionEvaluation(chPDUPresenceInfo, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_PDU_WaitForAutosarPDUByName(dbPDU* aPDUNameFromDB, dword aTimeout, enum eExpectedPresence aExpectedPDUPresence, char aBusContext[])
