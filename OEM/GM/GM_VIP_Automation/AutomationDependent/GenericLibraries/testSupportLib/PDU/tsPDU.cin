/*! \fn void A_PDU_WaitForFrPDUDataByName(dbFrPDU* aFrPDUNameFromDB, byte aExpectedPayloadData[], dword aWaitingTime, enum eCompareType aExpectedCompareAction)
*  \brief Function that executes the action to check if a Autosar PDU is received in a specific time or not, with the expected Equal/NotEqual payload data.
*  \param[in] aFrPDUNameFromDB       - Name of the FrPDU from the arxml database.
*  \param[in] aExpectedPayloadData[] - Byte array with the exact size and desired content of what the received payload should be identical/different.
*  \param[in] aWaitingTime           - Maximum wait time to check if the Autosar PDU is absent or not.
*  \param[in] aExpectedCompareAction - The expected presence of the Fr PDU: Present or Absent.
* 
*  \return None
*
*  \note 
*     - The aFrPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in the test file: tsPDU_Tests.can for more details.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 13.06.2019             CrJu           Created and implemented
*/

void A_PDU_WaitForFrPDUDataByName(dbFrPDU* aFrPDUNameFromDB, byte aExpectedPayloadData[], dword aWaitingTime, enum eCompareType aExpectedCompareAction)
{
  char chAction[250];
  char chFailText[250];
  char chFrPDUDataCompareInfo[250];
  long lResult;
  byte bDebugFlag;
  byte bResultAction;
  
  // Initialization of local variables
  lResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_PDU_WaitForFrPDUDataByName().");
  
  if ((byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel(DebugFuncParam, "Parameters: FrPDU* aFrPDUNameFromDB, byte aExpectedPayloadData[], dword aWaitingTime: -- %d --, eCompareType aExpectedCompareAction -- %d -- (0 - ABSENT; 1 - PRESENT)", aWaitingTime, aExpectedCompareAction);
  
  snprintf(chAction, elcount(chAction), "Wait: %dms (if 0, default %d is used) for FrPDU and check if Payload is: %d (0-Equal, 1-NotEqual) with the expected array.", aWaitingTime, cc_dwPDU_DefaultWaitTime, aExpectedCompareAction);
  bResultAction = bFctn_REPORTAction(chAction);

  if(Ok == bResultAction)
  {
    lResult = lFctn_PDU_WaitForFrPDUDataByName(aFrPDUNameFromDB, aExpectedPayloadData, aWaitingTime, chFrPDUDataCompareInfo);
    
    if( Error != lResult)
    {
      if(Equal == aExpectedCompareAction) //Expect the data of FrPDU to be equal with the the expected payload
      {
        //SUCCESS: FrPDU data has identified as IDENTICAL
        if ( Ok == lResult )
        {
          vFctn_REPORTActionEvaluation(chFrPDUDataCompareInfo, PASS);
        }
        else //FAIL: FrPDU data has identified as NOT IDENTICAL, or an error occured, as not expected
        {
          vFctn_REPORTActionEvaluation(chFrPDUDataCompareInfo, FAIL);
        }
      }
      else //Expect the data of FrPDU to NOT be equal with the the expected payload
      {
        //FAIL: FrPDU data has identified as IDENTICAL, as not expected
        if ( Ok == lResult )
        {
          vFctn_REPORTActionEvaluation(chFrPDUDataCompareInfo, FAIL);
        }
        else //SUCCESS: FrPDU data has identified as NOT IDENTICAL, as expected
        {
          vFctn_REPORTActionEvaluation(chFrPDUDataCompareInfo, PASS);
        }
      }
    }
    else //an error occurred
    {
      vFctn_REPORTActionEvaluation(chFrPDUDataCompareInfo, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

