/*! \fn void A_PDU_GetData (dbPDU* aPDUNameFromDB, byte aArrayToStorePayloadData[], dword aWaitingTime, char aBusContext[])
*  \brief Function that executes the action to wait an amount of time for the specified Autosar PDU Name and store the payload data in the output byte array.
*  \param[in] aPDUNameFromDB            - Name of the Autosar PDU from the arxml database.
*  \param[in] aArrayToStorePayloadData  - The byte array in which the payload data is copied.
*  \param[in] aWaitingTime              - Maximum wait time, in miliseconds, to check if the Autosar PDU arrives or not (cannot be < 1).
*  \param[in] aBusContext               - The bus context.
* 
*  \return None
*
*  \note 
*     - The aPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in the test file: tsPDU_Tests.can for more details.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 22.01.19              GrAn            Created and implemented
*/
void A_PDU_GetData (dbPDU* aPDUNameFromDB, byte aArrayToStorePayloadData[], dword aWaitingTime, char aBusContext[])
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  char chGetPDUDataInfo[250];
  int iResult;
  byte bDebugFlag;
  byte bResultAction;
  word wPayloadSize;
  char chPrintBusContext[26];
  byte bResultPrint;
 
  iResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  bResultPrint = NotOk;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_PDU_GetData().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: dword aWaitingTime: -- %d --", aWaitingTime);
  
  bResultPrint = bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars, chPrintBusContext);
  
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam,"chPrintBusContext is %s",chPrintBusContext);
  
  snprintf(chAction, elcount(chAction), "Wait: %dms (if 0, default %dms is used) for specified Autosar PDU and copy the Payload data in the output array on bus context %s.", aWaitingTime, cc_dwPDU_DefaultWaitTime,chPrintBusContext);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if( Ok == bResultAction && Ok == bResultPrint)
  {
    iResult = iFctn_PDU_GetData(aPDUNameFromDB, aArrayToStorePayloadData, aWaitingTime, wPayloadSize, aBusContext, chGetPDUDataInfo);
    
    // Autosar PDU has arrived and the payload data has been successfully copied
    if ( Ok == iResult )
    {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: %s", chGetPDUDataInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_PDU_GetData(): %s", chGetPDUDataInfo);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // Autosar PDU didn't arrive, payload could not be copied or an internal error has occurred
    {
      snprintf(chFailText, elcount(chFailText),"FAILED: %s", chGetPDUDataInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Result A_PDU_GetData(): %s", chGetPDUDataInfo);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result A_PDU_GetData(): %s", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_PDU_WaitForDataByName (dbPDU* aPDUNameFromDB, byte aExpectedPayload[], enum eCompareType aExpectedCompareAction, dword aWaitingTime, char aBusContext[])
*  \brief Function that executes the action to check if a Autosar PDU is received in a specific time or not, with the expected Equal/NotEqual payload data.
*  \param[in] aPDUNameFromDB          - Name of the Autosar PDU from the arxml database.
*  \param[in] aExpectedPayload        - Byte array with the exact size and desired content of what the received payload should be identical/different (depending on the aExpectedCompareAction).
*  \param[in] aExpectedCompareAction  - The compare action between the provided array and received payload: Equal or NotEqual.
*  \param[in] aWaitingTime            - Maximum wait time, in miliseconds, to check if the Autosar PDU arrives or not.
*  \param[in] aBusContext             - The bus context.
* 
*  \return None
*
*  \note 
*     - The aPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in test file: tsPDU_Tests.can for more details.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 28.01.19              GrAn           Created and implemented
*/
void A_PDU_WaitForDataByName (dbPDU* aPDUNameFromDB, byte aExpectedPayload[], enum eCompareType aExpectedCompareAction, dword aWaitingTime, char aBusContext[])
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  char chPDUDataCompareInfo[250];
  int iResult;
  byte bDebugFlag;
  byte bResultAction;
  char chPrintBusContext[26];
  byte bResultPrint;
 
  iResult	= NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  bResultPrint = NotOk;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_PDU_WaitForDataByName().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: dword aWaitingTime: -- %d --, enum eCompareType aExpectedCompareAction -- %d -- (0 - Equal, 1 - NotEqual).", aWaitingTime, aExpectedCompareAction);
  
  bResultPrint = bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars,chPrintBusContext);
  
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "chPrintBusContext is %s", chPrintBusContext);
  
  snprintf(chAction, elcount(chAction), "Wait: %dms (if 0, default %d is used) for Autosar PDU and check if Payload is: %d (0-Equal, 1-NotEqual) with the expected array on the bus context %s.", aWaitingTime, cc_dwPDU_DefaultWaitTime, aExpectedCompareAction, chPrintBusContext);
  bResultAction = bFctn_REPORTAction(chAction);

  if( Ok == bResultAction && Ok == bResultPrint)
  {
    iResult = iFctn_PDU_WaitForDataByName(aPDUNameFromDB, aExpectedPayload, aExpectedCompareAction, aWaitingTime, aBusContext, chPDUDataCompareInfo);
    
    // Autosar PDU has arrived within the waiting time and its data is as expected (based on aExpectedCompareAction: 0-Equal, 1-NotEqual)
    if ( Ok == iResult )
    {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: %s", chPDUDataCompareInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_PDU_WaitForDataByName(): %s", chPDUDataCompareInfo);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // the result is not as expected, incorrect array size, Autosar PDU did not arrive or an internal error has occurred
    {
      snprintf(chFailText, elcount(chFailText),"FAILED: %s", chPDUDataCompareInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Result A_PDU_WaitForDataByName(): %s", chPDUDataCompareInfo);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result A_PDU_WaitForDataByName(): %s", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_PDU_WaitForDataByName(dbPDU* aPDUNameFromDB, byte aExpectedPayload[], enum eCompareType aExpectedCompareAction, dword aWaitingTime, char aBusContext[])
*  \brief Function that checks if a Autosar PDU is received in a specific time or not, with the expected Equal/NotEqual payload data.
*  \param[in] aPDUNameFromDB          - Name of the Autosar PDU from the arxml database.
*  \param[in] aExpectedPayload        - Byte array with the exact size and desired content of what the received payload should be identical/different (depending on the aExpectedCompareAction).
*  \param[in] aExpectedCompareAction  - The compare action between the provided array and received payload: Equal or NotEqual.
*  \param[in] aWaitingTime            - Maximum wait time, in milliseconds, to check if the  Autosar PDU arrives or not.
*  \param[in] aBusContext             - The bus context.
* 
*  \return None
*
*  \note 
*     - The aPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in test file: tsPDU_Tests.can for more details.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 28.01.19              GrAn            Created and implemented
*/
void E_PDU_WaitForDataByName(dbPDU* aPDUNameFromDB, byte aExpectedPayload[], enum eCompareType aExpectedCompareAction, dword aWaitingTime, char aBusContext[])
{
  char chPassText[250];
  char chFailText[250];
  char chPDUDataCompareInfo[250];
  byte iResult;
  byte bDebugFlag;
  char chPrintBusContext[26];
  byte bResultPrint;
  
  iResult = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  bResultPrint = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_PDU_WaitForDataByName().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: dword aWaitingTime: -- %d --, enum eCompareType aExpectedCompareAction -- %d -- (0 - Equal, 1 - NotEqual).", aWaitingTime, aExpectedCompareAction);
  
  bResultPrint = bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars,chPrintBusContext);
  
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam,"chPrintBusContext is %s",chPrintBusContext);
  
  if (Ok ==  bResultPrint)
  {
    iResult = iFctn_PDU_WaitForDataByName(aPDUNameFromDB, aExpectedPayload, aExpectedCompareAction, aWaitingTime, aBusContext, chPDUDataCompareInfo);
  }
  else
  {
    snprintf(chPDUDataCompareInfo, elcount(chPDUDataCompareInfo),"The print part of the bus context failed !!!");
  }
    
  // Autosar PDU has arrived within the waiting time and its data is as expected (based on aExpectedCompareAction: 0-Equal, 1-NotEqual)
  if ( Ok == iResult )
  {
    snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chPDUDataCompareInfo);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "PASSED! Result E_PDU_WaitForDataByName(): %s",chPDUDataCompareInfo);
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else // the result is not as expected, incorrect array size, Autosar PDU did not arrive or an internal error has occurred
  {
    snprintf(chFailText,elcount(chFailText),"FAILED: %s", chPDUDataCompareInfo);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result E_PDU_WaitForDataByName(): %s",chPDUDataCompareInfo);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/*! \fn int A_PDU_SendFrPDU(dbFrPDU* aFrPDUName, byte aPayloadToBeSent[], byte aNrOfSendingRequests, byte aFlexRayCluster, enum eFlexRayChannels aChannel, char aFrPDUDataCompareInfo[])
*  \brief Function that sends a dynamic FlexRay frame with the desired payload data, on the specified cluster and channel (A or B).
*  \param[in]   aFrPDUName              - The dynamic frame which is going to be sent.
*  \param[in]   aPayloadToBeSent        - Byte array with the desired payload to be sent with the dynamic frame (payload length is determined from the size of the array, which should not be greater than 254 bytes).
*  \param[in]   aNrOfSendingRequests    - How many times the FrPDU to be transmitted. ( N>0: The PDU is transmitted at least n times / -1: The PDU is transmitted in every configured slot / 0: The PDU's default value is transmitted )
*  \param[in]   aFlexRayCluster         - The cluster of the FlexRay protocol. Ex: 1(CH_Flexray), 2(CH_Flexray2).
*  \param[in]   aChannel                - The channel of the flexray (Ex: A or B).
* 
*  \return None
*
*  \note  - If a FrPDU is already on the BUS, it can not be resend for a specific number of times.
*         - The defaul value can not be tested, or it is 0
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 19.06.19              CrJu            Created and implemented
*/

void A_PDU_SendFrPDU(FrPDU* aFrPDUName, byte aPayloadToBeSent[], byte aNrOfSendingRequests, byte aFlexRayCluster, enum eFlexRayChannels aChannel)
{
  long lResult;
  byte bDebugFlag;
  byte bResultAction;
  char chAction[250];
  char chFailText[250];
  char chPassText[250];
  char chSentPayloadData[250];
  char chFrPDUSentInfo[250];
  
  bDebugFlag = cc_bPDU_GlobalDebugFlag;
  lResult = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Entered A_PDU_SendFrPDU().");
  
  snprintf(chAction, elcount(chAction), "Send the FrPDU with the specific payload on Cluster: %d and Channel: %d.", aFlexRayCluster, aChannel);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if( bResultAction == Ok )
  {
    lResult = lFctn_PDU_SendFrPDU(aFrPDUName, aPayloadToBeSent, aNrOfSendingRequests, aFlexRayCluster, aChannel, chFrPDUSentInfo);
    
    // The FrPDU was succesfully sent on the bus
    if(lResult == Ok)
    {
      snprintf(chPassText, elcount(chPassText),"SUCCESS: %s", chFrPDUSentInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_PDU_GetData(): %s", chFrPDUSentInfo);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // An error occured
    {
      snprintf(chFailText, elcount(chFailText),"SUCCESS: %s", chFrPDUSentInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_PDU_GetData(): %s", chFrPDUSentInfo);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result A_PDU_GetData(): %s", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_PDU_VerifyCycleTime(dbPDU* aPDUNameFromDB, dword aNumberOfSampleTimes, dword aPDUCycleTimeMS, byte aPermittedTimeDiffPerCent, char aBusContext[])
*  \brief Function that checks if an Autosar PDU cycle time is in a given range [aPDUCycleTimeMS - (aPDUCycleTimeMS * aPermittedTimeDiffPerCent/100), aPDUCycleTimeMS + (aPDUCycleTimeMS * aPermittedTimeDiffPerCent/100)] or not for a given number sample times.
*  \param[in]   aPDUNameFromDB                   - Name of the Autosar PDU from the arxml database.
*  \param[in]   aNumberOfSampleTimes             - The number of samples time to test that the cycle time of Autosar PDU is in range or not
*  \param[in]   aPDUCycleTimeMS                  - The Autosar PDU cycle time from data base (in milliseconds)
*  \param[in]   aPermittedTimeDiffPerCent        - The permitted time difference of the upper and lower limit of the cycle time range (per cent).
*  \param[in]   aBusContext                      - The bus context.
* 
*  \return  no return
*
*  \note 
*     - The aPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in the test file: tsPDU_Tests.can for more details.'
*  *  \note 
*     - Example: if a Autosar PDU has a cycle time of 100 milliseconds and the procent is 15. The calculated lower accepted \n
*     value for cycle time is 85ms and upper accepted value for cycle time is 115 ms.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 04.02.19              GrAn            Created and implemented
* 06.02.19              GrAn            The implementation is changed. Use a cycle time from database and the number of samples time to be waited instead of the given time to wait. 
*/

void E_PDU_VerifyCycleTime(dbPDU* aPDUNameFromDB, dword aNumberOfSampleTimes, dword aPDUCycleTimeMS, byte aPermittedTimeDiffPerCent, char aBusContext[])
{
  char chPassText[250];
  char chFailText[250];
  char chPDUVerifyCyclicTime[250];
  byte bResult;
  byte bDebugFlag;
  char chPrintBusContext[26];
  byte bResultPrint;
  
  bResult = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  bResultPrint = NotOk;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_PDU_VerifyCycleTime().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: dword aNumberOfSampleTimes: -- %d --, dword aPDUCycleTimeMS  --%d--, byte aPermittedTimeDiffPerCent --%d (per cent)--", aNumberOfSampleTimes, aPDUCycleTimeMS,aPermittedTimeDiffPerCent);

  bResultPrint = bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars,chPrintBusContext);
  
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam,"chPrintBusContext is %s",chPrintBusContext);
  
  if (Ok == bResultPrint)//bFctn_CONV_PrintPartOfArray was executed succesfully
  {
    bResult = iFctn_PDU_VerifyCycleTime(aPDUNameFromDB, aNumberOfSampleTimes, aPDUCycleTimeMS, aPermittedTimeDiffPerCent, aBusContext, chPDUVerifyCyclicTime);
  }
  else
  {
    snprintf(chPDUVerifyCyclicTime, elcount(chPDUVerifyCyclicTime),"The print part of the bus context failed !!!");
  }
    
  // Autosar PDU cycletime is in range as expected
  if ( Ok == bResult )
  {
    snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chPDUVerifyCyclicTime);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "PASSED! Result E_PDU_VerifyCycleTime(): %s",chPassText);
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else // the result is not as expected or an error has occurred
  {
    snprintf(chFailText,elcount(chFailText),"FAILED: %s", chPDUVerifyCyclicTime);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result E_PDU_VerifyCycleTime(): %s",chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_PDU_VerifyCycleTimeForFrPDU(dbFrPDU* aFrPDUNameFromDB, dword aNumberOfSampleTimes, dword aFrPDUCycleTimeMS, byte aPermittedTimeDiffPerCent)
*  \brief Function that checks if an Autosar PDU cycle time is in a given range [aPDUCycleTimeMS - (aPDUCycleTimeMS * aPermittedTimeDiffPerCent/100), aPDUCycleTimeMS + (aPDUCycleTimeMS * aPermittedTimeDiffPerCent/100)] or not for a given number sample times.
*  \param[in]   aFrPDUNameFromDB                 - Name of the FrPDU from the arxml database.
*  \param[in]   aNumberOfSampleTimes             - The number of samples time to test that the cycle time of Autosar PDU is in range or not
*  \param[in]   aFrPDUCycleTimeMS                - The FrPDU cycle time from data base (in milliseconds)
*  \param[in]   aPermittedTimeDiffPerCent        - The permitted time difference of the upper and lower limit of the cycle time range (per cent).
* 
*  \return  no return
*
*  \note 
*     - The aPDUNameFromDB parameter should be dragged/dropped from arxml database listed in CAPL Network Symbols window.\n
*     Check the example in the test file: tsPDU_Tests.can for more details.'
*  *  \note 
*     - Example: if a Autosar PDU has a cycle time of 100 milliseconds and the procent is 15. The calculated lower accepted \n
*     value for cycle time is 85ms and upper accepted value for cycle time is 115 ms.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 17.07.19              CrJu            Created and implemented*/

void E_PDU_VerifyCycleTimeForFrPDU(dbFrPDU* aFrPDUNameFromDB, dword aNumberOfSampleTimes, dword aFrPDUCycleTimeMS, byte aPermittedTimeDiffPerCent)
{
  char chPassText[250];
  char chFailText[250];
  char chFrPDUVerifyCyclicTime[250];
  byte bResult;
  byte bDebugFlag;
  
  bResult = NotOk;
  bDebugFlag = tsc_bPDU_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Entered E_PDU_VerifyCycleTimeForFrPDU().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: dword aNumberOfSampleTimes: -- %d --, dword aFrPDUCycleTimeMS  --%d--, byte aPermittedTimeDiffPerCent --%d (per cent)--", aNumberOfSampleTimes, aFrPDUCycleTimeMS, aPermittedTimeDiffPerCent);
 
  bResult = lFctn_PDU_VerifyCycleTimeForFrPDU(aFrPDUNameFromDB, aNumberOfSampleTimes, aFrPDUCycleTimeMS, aPermittedTimeDiffPerCent, chFrPDUVerifyCyclicTime);
    
  // FrPDU cycletime is in range as expected
  if (Ok == bResult)
  {
    snprintf(chPassText,elcount(chPassText),"SUCCESS: %s", chFrPDUVerifyCyclicTime);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "PASSED! Result E_PDU_VerifyCycleTimeForFrPDU(): %s", chPassText);
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else // the result is not as expected or an error has occurred
  {
    snprintf(chFailText,elcount(chFailText),"FAILED: %s", chFrPDUVerifyCyclicTime);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result E_PDU_VerifyCycleTimeForFrPDU(): %s", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

