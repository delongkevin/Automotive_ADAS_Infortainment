/*! \fn void A_GENERIC_SetTimeout()
*  \brief Function sets timeout.
*  \param[in] lTimeout - Timeout to wait in ms.
*  \param[in] chComment - Custom text to be added in report.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  07.06.18              SeNi        Created and implemented
*/

void A_GENERIC_SetTimeout(long lTimeout, char chComment[])
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  byte bResult;
  byte bResultAction; 
  
  bResultAction = 0;
  bResult = 0;

  writeDbgLevel (tsc_eGENERICDebugFuncCalls, "Function A_GENERIC_SetTimeout called");
  writeDbgLevel (tsc_eGENERICDebugFuncParam, "Parameters: long lTimeout: -- %d --, char chComment[]: -- %s --.", lTimeout, chComment);
  
  if(strlen(chComment) != 0)
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "chComment is not empty, writing parameter to report. chComment: -- %s --.", chComment);
    snprintf(chAction, elcount(chAction), chComment);
  }
  else
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "chComment is empty, writing default Action to repport.");
    snprintf(chAction, elcount(chAction), "Set timeout: %ld ms.", lTimeout);
  }
    
  bResultAction = bFctn_REPORTAction(chAction);
  writeDbgLevel (tsc_eGENERICDebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
    
  if(bResultAction)
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Calling function TestWaitForTimeout.");
    bResult = TestWaitForTimeout(lTimeout);  
  } 
  
  snprintf(chPassText, elcount(chPassText), "Resumed due to timeout: %ld ms.", lTimeout);
  snprintf(chFailText, elcount(chFailText), "Resumed due to an error, please check testcase.");  
  
  if(!bResult)
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test action passed. Calling function vFctn_REPORTActionEvaluation.");
    vFctn_REPORTActionEvaluation(chPassText, PASS);
  }
  else
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test action failed. Calling function vFctn_REPORTActionEvaluation.");
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_GENERIC_ManualExpected(char chText[], char chPassText[], char chFailText[]) 
*  \brief Function shows manual confirmation window and writes in report the result.
*  \param[in] chText - Text to ask tester.
*  \param[in] chPassText - Text to be written in report if PASS case.
*  \param[in] chFailText - Text to be written in report if FAIL case.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  13.06.18              SeNi        Created and implemented
*/

void E_GENERIC_ManualExpected(char chText[], char chPassText[], char chFailText[]) 
{
  byte bResponse;
  
  writeDbgLevel (tsc_eGENERICDebugFuncCalls, "Function E_GENERIC_ManualExpected called");
  writeDbgLevel (tsc_eGENERICDebugFuncParam, "Parameters: char chText[]: -- %s --, char chPassText[] -- %s --, char chFailText[] -- %s --.", chText, chPassText, chFailText);
  
  writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Add to test report Manual Intervention.");
  TestStep("", "Manual Intervention"); 
  
  bResponse = TestWaitForTesterConfirmation(chText);
  writeDbgLevel (tsc_eGENERICDebugFuncInternal, "bResponse: -- %d --, return value from function TestWaitForTesterConfirmation().");
  
  if(PASS == bResponse)
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test step passed. Calling function vFctn_REPORTStepEvaluation.");
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test step failed. Calling function vFctn_REPORTStepEvaluation.");
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_GENERIC_ManualExpectedTimeout(char chText[], char chPassText[], char chFailText[], long lTimeout)  
*  \brief Function shows manual confirmation window for an amount of time and writes in report the result.
*  \param[in] chText - Text to ask tester.
*  \param[in] chPassText - Text to be written in report if PASS case.
*  \param[in] chFailText - Text to be written in report if FAIL case.
*  \param[in] lTimeout - Timeout to wait in ms.
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  13.06.18              SeNi        Created and implemented
*/

void E_GENERIC_ManualExpectedTimeout(char chText[], char chPassText[], char chFailText[], long lTimeout) 
{
  byte bResponse;
  
  writeDbgLevel (tsc_eGENERICDebugFuncCalls, "Function E_GENERIC_ManualExpected called");
  writeDbgLevel (tsc_eGENERICDebugFuncParam, "Parameters: char chText[]: -- %s --, char chPassText[] -- %s --, char chFailText[] -- %s --, long lTimeout: -- %d --.", chText, chPassText, chFailText, lTimeout);  
  
  writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Add to test report Manual Intervention.");  
  TestStep("", "Manual Intervention"); 
  
  bResponse = TestWaitForTesterConfirmation(chText, lTimeout);
  writeDbgLevel (tsc_eGENERICDebugFuncInternal, "bResponse: -- %d --, return value from function TestWaitForTesterConfirmation().");
  
  if(PASS == bResponse)
  {
    writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test step passed. Calling function vFctn_REPORTStepEvaluation.");
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else
  {
    if (FAIL == bResponse)
    {
      writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test step failed. Timeout occured. Calling function vFctn_REPORTStepEvaluation.");
      vFctn_REPORTStepEvaluation("Timeout occured. No tester response.", FAIL);
    }
    else
    {
      writeDbgLevel (tsc_eGENERICDebugFuncInternal, "Test step failed. Calling function vFctn_REPORTStepEvaluation.");
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
}


