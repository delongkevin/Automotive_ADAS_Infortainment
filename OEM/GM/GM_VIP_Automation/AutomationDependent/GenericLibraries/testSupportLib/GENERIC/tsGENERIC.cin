/*! \fn void E_GENERIC_CheckLastWaitTime( float aTimeToCompare, enum cc_eTimeFormat aTimeFormat, enum cc_eTimeCmp aTimeCmpType )
*  \brief Function that check if the requested time for the last wait instruction is as expected or not.
*  \param[in]  aTimeToCompare   - Time to compare.
*  \param[in]  aTimeFormat      - How the time will be compared in [nS, uS, mS, S] -> see definition of enum cc_eTimeFormat.
*  \param[in]  aTimeCmpType     - Compare Type - TimeLessEq, TimeMoreEq (less or equal then last elapsed time, more or equal then last elapsed time)
*
*  \note Use this function when is needed to see if the event is occured after a certain time.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*  
*  26.02.20             CiCo            Created and implemented
*/
void E_GENERIC_CheckLastWaitTime( float aTimeToCompare, enum cc_eTimeFormat aTimeFormat, enum cc_eTimeCmp aTimeCmpType )
{
  char chMapedResponse[50];
  float fWaitTimeLastInstruction;
  float fMinTime;
  char chTempText[256];
  byte bDebugFlag;
  
  bDebugFlag = tsc_bBUS_GlobalDebugFlag;// debug only
  
  writeDbgLevel (DebugFuncCalls, "Entered E_Generic_CheckLastWaitTime()");
  
  if ( (byte)DebugFuncParam & bDebugFlag)
	  writeDbgLevel(DebugFuncInternal, "Params -> TimeToCompare %f \nTime Format: %d \nCompare Type: %d", aTimeToCompare, aTimeFormat, aTimeCmpType );
  
  fWaitTimeLastInstruction = fFctn_Generic_GetLastWaitTime( aTimeFormat, chMapedResponse );
  
  if ( (byte)DebugFuncInternal & bDebugFlag )
	  writeDbgLevel( DebugFuncInternal, "fFctn_Generic_GetLastWaitTime ->Return %f, Response: %s", fWaitTimeLastInstruction, chMapedResponse );
  
  if ( Error != fWaitTimeLastInstruction )
  {
    if( TimeLessEq == aTimeCmpType )
      snprintf( chTempText, elcount(chTempText),"less or equal then %s", chMapedResponse );
    else if ( TimeMoreEq == aTimeCmpType )
      snprintf( chTempText, elcount(chTempText),"greather or equal then %s", chMapedResponse );
    else
      snprintf( chTempText, elcount(chTempText),"Compare type not defined" );// tbd 
    
    fMinTime =  _min( aTimeToCompare, fWaitTimeLastInstruction );
    
    if ( (byte)DebugFuncInternal & bDebugFlag)
	    writeDbgLevel(DebugFuncInternal, "Min Time -> %f", fMinTime );
    
    if( aTimeToCompare == fMinTime && TimeLessEq == aTimeCmpType )
    {
      // requested val is as expected, less
      snprintf( chTempText, elcount(chTempText), "SUCCESS: Expected time %f is %s.", aTimeToCompare, chTempText );
      vFctn_REPORTStepEvaluation( chTempText, PASS );
    }
    else if ( fWaitTimeLastInstruction == fMinTime && TimeMoreEq == aTimeCmpType )
    {
      // requested val is as expected, more
      snprintf( chTempText, elcount(chTempText), "SUCCESS: Expected time %f is %s.", aTimeToCompare, chTempText );
      vFctn_REPORTStepEvaluation( chTempText, PASS );
    } 
    else
    {
      // is not as expected
      snprintf( chTempText, elcount(chTempText), "FAILED: Expected time %f is not %s as requested.", aTimeToCompare, chTempText );
      vFctn_REPORTStepEvaluation( chTempText, FAIL );
    }
  }
  else// error in fFctn_Generic_GetLastWaitTime
  {
    snprintf( chTempText, elcount(chTempText), "FAILED: %s", chMapedResponse );
    vFctn_REPORTStepEvaluation( chTempText, FAIL );
  }
}

