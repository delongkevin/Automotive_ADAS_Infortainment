/*! \fn void A_CAN_GetMessageDataByID(dword aMsgID, char aBusContext[], dword aTimeToWaitForMessage, byte aOutputData[], dword aNumberOfBytesCopied )
*  \brief Function Gets the content for a searched message ID on required CAN channel.
*  \param[in]  aMsgID                - ID of message from database
*  \param[in]  aBusContext           - The bus context
*  \param[in]  aTimeToWaitForMessage - max time to wait for message.
*  \param[out] aOutputData           - The Message payload.
*  \param[out] aNumberOfBytesCopied  -  Number of bytes copied
*
*  \return  no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  01.10.18              GrAn        Resolve some remarks after tests done for this function.
*  05.11.18              GrAn        Update test decision of the covertion error.
*  04.09.19              CrJu        Refactoring the code.
*/

void A_CAN_GetMessageDataByID(dword aMsgID, char aBusContext[], dword aTimeToWaitForMessage, byte aOutputData[], dword &aNumberOfBytesCopied )
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  char chOutputString[100];
  char chPrintBusContext[25];
  byte bDebugFlag;
  
  lResult = NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function A_CAN_GetMessageDataByID entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: --0x%X --, char aBusContext[]: -- %s --, dword aTimeToWaitForMessage: --%d-- ",aMsgID,aBusContext,aTimeToWaitForMessage);

  //If the bus context name is too big, print in the raport just first 25 chars
  bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars - 1, chPrintBusContext);
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Take the payload of CAN message: 0x%X on bus %s", aMsgID, chPrintBusContext);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction )
  {
    lResult = lFctn_CAN_GetMessageDatabyID(aMsgID,aBusContext, aTimeToWaitForMessage, aOutputData, aNumberOfBytesCopied); 
    
    //Convert bytes array to string
    bFctn_CONV_ByteArrayToSpecificNumberBaseString(aOutputData, cc_eCONV_Hex, " 0x", chOutputString, aNumberOfBytesCopied);
    if(lResult != Error)
    {
      if(lResult == Ok)//The data message was extracted succesfully 
      {
        snprintf(chPassText, elcount(chPassText), "The CAN message 0x%X was found on the bus %s with %d number of bytes and following data: 0x%s.", aMsgID, chPrintBusContext,aNumberOfBytesCopied, chOutputString);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASSED: %s", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else//The data message could not be extracted succesfully or it is not found on the bus
      {
        snprintf(chFailText, elcount(chFailText), "The CAN message 0x%X could not be found on the bus %s or his data could not be extracted succesfully.", aMsgID, chPrintBusContext);  
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAILED: %s", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else//An error occured
    {
      snprintf(chFailText, elcount(chFailText), "An error occured in the control function lFctn_CAN_GetMessageDatabyID(). Check his debug message.");  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "ERROR: %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);  
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_CAN_WaitForMessageDataByID(dword aMsgID, char aBusContext[], dword aTimeToWaitForMessage, byte aCompareBytesArray[])
*  \brief Function Wait and check if a message is send on a required bus context with an expected content
*  \param[in]  aMsgID                - ID of message
*  \param[in]  aBusContext           - The bus context
*  \param[in]  aTimeToWaitForMessage - time to wait for message.
*  \param[in]  aCompareBytesArray    - The array of bytes to be compared.
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  01.10.18              GrAn        Resolve some remarks after tests done for this function.
*  03.09.19              CrJu        Refactoring the code.
*/
void E_CAN_WaitForMessageDataByID(dword aMsgID, char aBusContext[], dword aTimeToWaitForMessage, byte aCompareBytesArray[])
{
  byte bDebugFlag;
  long lResult;
  char chMappedResponseInfo[250];
  
  lResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function E_CAN_WaitForMessageDataByID entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%x--, char aBusContext[]: -- %s --, dword aTimeToWaitForMessage -- %d --.", aMsgID, aBusContext, aTimeToWaitForMessage);    
  
  lResult = lFctn_CAN_WaitForMessageDatabyID(aMsgID, aBusContext, aTimeToWaitForMessage, aCompareBytesArray, chMappedResponseInfo);

  if (Error != lResult)
  {
    if(Ok == lResult)//The message was found with correct content
    {
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Return: E_CAN_WaitForMessageDataByID. %s", chMappedResponseInfo);
      vFctn_REPORTStepEvaluation(chMappedResponseInfo, PASS);
    }
    else//The message was not found with correct content
    {
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Return: E_CAN_WaitForMessageDataByID. %s", chMappedResponseInfo);
      vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);
    }
  }
  else//An error occured
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR! Return: E_CAN_WaitForMessageDataByID. %s", chMappedResponseInfo);
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL); 
  }
}

