/*! \fn void A_CAN_SendBurstMessage(dword aMsgID[], byte aBytesToBeSend[], dword aTimeBetweenFrames, byte aDataLengthOfMessage, word aCANChannel)
*  \brief Sends specific volume of bytes (more than 8 bytes) on specific CAN channel, on every aMsgID is given.
*  \param[in] aMsgID               - The array of ID of message that will be sent.
*  \param[in] aBytesToBeSend       - content of messages to be sent.
*  \param[in] aTimeBetweenFrames   - time waited between frames
*  \param[in] aDataLengthOfMessage - DLC of message (maximum 8 bytes)
*  \param[in] aCANChannel          - required CAN channel.
*
*  \return no return
*
*  \note
*       -Example: For aMsgID: 0x55, 0x67, aDataLengthOfMessage: 2 and aBytesToBeSend: (AA, BB, CC, DD), the message 0x55 will be sent with payload (AA, BB)
*                                                                                                   and the message 0x67 will be sent with payload (CC, DD).
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  12.09.19              CrJu        Refactoring the code.
*/

void A_CAN_SendBurstMessage(dword aMsgID[], byte aBytesToBeSend[], dword aTimeBetweenFrames, byte aDataLengthOfMessage, word aCANChannel)
{
  long lResult;
  byte bResultAction;
  byte bDebugFlag;
  byte bLastIniFileUsed;
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  char chOutputString[150];
  char chPrintOutput[150];
  char chOutputString_Msg[150];
  char chPrintString_Msg[150];
  char chIniFilePath[100];
  long lCANChannelAvailable;
  
  lResult = NotOk;
  bResultAction = NotOk;  
  bLastIniFileUsed = NotOk;
  lCANChannelAvailable = 0;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_SendBurstMessageConsecutiveID entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aTimeBetweenFrames --%d--, byte aDataLengthOfMessage --%d--, word aCANChannel --%d--.", aTimeBetweenFrames, aDataLengthOfMessage, aCANChannel);   
  
  //Read the value of the parameter 'CANChannelsAvailable' from INI File
  bLastIniFileUsed = bFctn_READFILELastINIused (chIniFilePath); 
  
  lCANChannelAvailable = lFctn_READFILEiniParameterNumber (chIniFilePath, "CANChannelsAvailable", "CAN_COMMUNICATION");
  
  //Convert bytes array to string
  bFctn_CONV_ConvertByteArrToStringByLength(aBytesToBeSend, elcount(chOutputString), chOutputString);
  
  //if Output String is too big write just first 128 characters
  bFctn_CONV_GetSubString(chOutputString, 0, cc_wPrintedArrayElements - 1, chPrintOutput); 
  
  //Convert messages id array to string 
  bFctn_CONV_ConvertDwordArrayToString(aMsgID, chOutputString_Msg);
  
  //if Output String is too big displayed just first 128 elements
  bFctn_CONV_GetSubString(chOutputString_Msg, 0, elcount(chOutputString_Msg) - 1, chPrintString_Msg);
  
  snprintf(chAction, elcount(chAction),"Send messages IDs -0x%s- with data -0x%s- on CAN Channel %d.", chPrintString_Msg, chPrintOutput, aCANChannel);
  bResultAction = bFctn_REPORTAction(chAction);
   
  if(bResultAction)
  {
    //The CAN Channel is unavailable or ini path is not given
    if (( aCANChannel > lCANChannelAvailable) || (Ok != bLastIniFileUsed))
    {
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Error occured in the INI file. Check the last INI file used.");
      lResult = Error;
    }
    else
    {
      //Send the message
      lResult = lFctn_CAN_SendBurstMessage(aMsgID, aBytesToBeSend, aTimeBetweenFrames, aDataLengthOfMessage, aCANChannel);
    }
    
    if(lResult != Error)
    {
      if(lResult == Ok)
      {
        snprintf(chPassText, elcount(chPassText), "All data bytes -0x%s- are succesfully sent on messages -0x%s-.", chPrintOutput, chPrintString_Msg);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "PASSED! Result: A_CAN_SendBurstMessage. %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "Something went wrong, the messages -0x%s- could not be succesfully sent.", chOutputString_Msg); 
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "FAILED! Result: A_CAN_SendBurstMessage. %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else//An error occured
    {
      snprintf(chFailText, elcount(chFailText), "An error occurred, the aMsgDLC is wrong -%d-(must be between 1 and 8) or the CAN Channel number is wrong -%d-(must be between 1 and 32).", aDataLengthOfMessage, aCANChannel);  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "ERROR: %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);  
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_DeleteLog (char aFilePath[])
*  \brief Function delete a log file.
*  \param[in] aFilePath - The file path to the log results
*
*  \return no return
*
*  \note 
*         - To start to logg information, first call the  function A_CAN_StartLoggingMessages.
*  \note 
*          - Use File path like: C:\\Test\\LogMessages.csv.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  16.10.18              GrAn        Add the close of command line window after the file is deleted.
*  13.09.19              CrJu        Refactoring the code.
*/

void A_CAN_DeleteLog (char aFilePath[])
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  byte bDebugFlag;
  byte bResult;
  
  bResult = NotOk;
  bResultAction = NotOk;  
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_DeleteLog entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: char aFilePath[] --'%s'-- ", aFilePath); 
  
  snprintf(chAction, elcount(chAction), "The command to delete the file '%s' is send to command prompt.", aFilePath);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    bResult = bFctn_CAN_DeleteLog(aFilePath);
    
    if(Ok == bResult)
    {
      snprintf(chPassText, elcount(chPassText), "The command to delete the file '%s' is send succesfully to command prompt.", aFilePath);     
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Return A_CAN_DeleteLog. %s", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "The command to delete the file '%s' could not be send succesfully to command prompt.", aFilePath); 
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Return A_CAN_DeleteLog. %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_StartLoggingMessages(dword aArrayMessageIDs[], byte aChannelNumber, int64 aNumberOfLogEntries)
*  \brief Function that executes the action to enable the CAN Message Logging functionality, based on a specified filter (MsgID's and ChannelNr).
*  \param[in]   aArrayMessageIDs      - Array with the MessageID's which are going to be logged (if first element of the array is 0, all messages are logged).
*  \param[in]   aChannelNumber        - The Channel/Cluster number where the message(s) is expected to arrive (if 0, it will log every occurrence of the MsgID, regardless of the cluster it arrives).
*  \param[in]   aNumberOfLogEntries   - The maximum number of how many message(s) log entries is expected to arrive ( > 0 and recommended to not go over 500.000 as it could influence the environment and memory allocation). 
* 
*  \return None
*
*  \note
*   - After enabling the logging functionality it is necessary to use: testWaitForTimeout(WaitTimeInMs) - only within this time the frames are added in the buffer structure.
*
*  \note
*   - Even though dynamic memory allocation is used for the buffer structure array, a limit of maximum: 500.000 entries should suffice in order to avoid excessive memory allocation. \n
*
*  \note
*   - Example of correct function call sequence: \n
*   1. A_CAN_StartLoggingMessages(dwLogSlotIDsArray_3Elem, ChannelNr, NrOfLogEntries); \n
*   2. testWaitForTimeout(5000); // Only during this time, the log is active. Expected data which arrives within 5 seconds, is saved in the back-end buffer. \n
*   3. A_CAN_StopLoggingMessages(strSaveLogData_1500Elem, i64NumberOfExtractedLogEntries); \n
*   4. A_CAN_SaveLogDataToCSVFile(chAbsPathOf_CSVLogFile, strSaveLogData_1500Elem, i64NumberOfLogEntriesToSave); \n
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 02.04.19              RoBi            Created and implemented
*/

void A_CAN_StartLoggingMessages(dword aArrayMessageIDs[], byte aChannelNumber, int64 aNumberOfLogEntries)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  char chStartLoggingMsgInfo[250];
  int iResult;
  byte bDebugFlag;
 
  iResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_CAN_StartLoggingMessages().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: byte aChannelNumber --%d--, int64 aNumberOfLogEntries: --%I64d--.", aChannelNumber, aNumberOfLogEntries);

  snprintf(chAction, elcount(chAction), "Start CAN Logging, on Channel: %d (if 0, logs on all channels) and expect maximum: %I64d messages to arrive.", aChannelNumber, aNumberOfLogEntries);

  // Check if the action text is added into the report
  if( Ok == bFctn_REPORTAction(chAction) )
  {
    iResult = iFctn_CAN_StartLoggingMessages(aArrayMessageIDs, aChannelNumber, aNumberOfLogEntries, chStartLoggingMsgInfo);
    
    // The CAN Logging mechanism is successfully enabled
    if ( Ok == iResult )
    {
      snprintf(chPassText, elcount(chPassText), "SUCCESS: %s", chStartLoggingMsgInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_CAN_StartLoggingMessages(): %s", chStartLoggingMsgInfo);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // Logging mechanism is already enabled, incorrect parameter values or an internal error occurred
    {
      snprintf(chFailText, elcount(chFailText), "FAILED: %s", chStartLoggingMsgInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Result A_CAN_StartLoggingMessages(): %s", chStartLoggingMsgInfo);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report.");
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result A_CAN_StartLoggingMessages(): %s", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_StopLoggingMessages(struct cv_strCAN_LoggingBuffer aStructureArrayToSaveLoggedData[], int64 &aNumberOfMessagesLogged)
*  \brief Function that executes the action to disable the CAN message logging mechanism (disabling the logging functionality is only possible if it has been previously enabled).
*  \param[in]   aStructureArrayToSaveLoggedData - Structure where the logged data is dumped from the back-end buffer.
*  \param[out]  aNumberOfMessagesLogged         - Number of messages logged and copied within the provided output structure.
* 
*  \return None
*
*  \note
*   - Disabling is successfully done only if it was previously enabled, provided output structure is large enough and number of frames logged is > 0.
*
*  \note
*   - Example of correct function call sequence: \n
*   1. A_CAN_StartLoggingMessages(dwLogSlotIDsArray_3Elem, ChannelNr, NrOfLogEntries); \n
*   2. testWaitForTimeout(5000); // Only during this time, the log is active. Expected data which arrives within 5 seconds, is saved in the back-end buffer. \n
*   3. A_CAN_StopLoggingMessages(strSaveLogData_1500Elem, i64NumberOfExtractedLogEntries); \n
*   4. A_CAN_SaveLogDataToCSVFile(chAbsPathOf_CSVLogFile, strSaveLogData_1500Elem, i64NumberOfLogEntriesToSave); \n
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 02.04.19              RoBi            Created and implemented
*/

void A_CAN_StopLoggingMessages(struct cv_strCAN_LoggingBuffer aStructureArrayToSaveLoggedData[], int64 &aNumberOfMessagesLogged)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  char chStopLoggingMsgInfo[250];
  int iResult;
  byte bDebugFlag;
 
  iResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_CAN_StopLoggingMessages().");

  snprintf(chAction, elcount(chAction), "Stop logging mechanism and store: %I64d entries of logged CAN messages data into output structure.", aNumberOfMessagesLogged);

  // Check if the action text is added into the report
  if( Ok == bFctn_REPORTAction(chAction) )
  {
    iResult = iFctn_CAN_StopLoggingMessages(aStructureArrayToSaveLoggedData, aNumberOfMessagesLogged, chStopLoggingMsgInfo);
    
    // The CAN Logging mechanism is successfully disabled and data is saved in the output structure
    if ( Ok == iResult )
    {
      snprintf(chPassText, elcount(chPassText), "SUCCESS: %s", chStopLoggingMsgInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_CAN_StopLoggingMessages(): %s", chStopLoggingMsgInfo);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // Logging mechanism is already disabled, incorrect parameter values or an internal error occurred
    {
      snprintf(chFailText, elcount(chFailText), "FAILED: %s", chStopLoggingMsgInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Result A_CAN_StopLoggingMessages(): %s", chStopLoggingMsgInfo);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report.");
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result A_CAN_StopLoggingMessages(): %s", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}


/*! \fn void A_CAN_SaveLogDataToCSVFile(char aAbsoluteCSVFilePath[], struct cv_strCAN_LoggingBuffer aLogDataToSaveInCSV[], int64 aNrOfLogEntriesToWriteInCSV)
*  \brief Function that executes the action to save in a CSV file, the specified number of log entries from the already populated CAN Message log structure.
*  \param[in]   aAbsoluteCSVFilePath        - The absolute path to the CSV file. Only .csv extension allowed (Example: C:\\UserName\\Desktop\\MyLogFile.csv).
*  \param[in]   aLogDataToSaveInCSV         - Structure from where the specified CAN message log entries are extracted and written in the CSV file (has to be already populated using: A_CAN_StartLoggingMessages() and A_CAN_StopLoggingMessages()).
*  \param[in]   aNrOfLogEntriesToWriteInCSV - Number of log entries to be written in the CSV file (cannot be 0 or larger than the total size of the array structure: aLogDataToSaveInCSV).
* 
*  \return None
*
*  \note
*   - Recommended to open the saved CSV file with Excel (make use of WordWrap feature in case of large payload data).
*
*  \note
*   - Example of correct function call sequence: \n
*   1. A_CAN_StartLoggingMessages(dwLogSlotIDsArray_3Elem, ChannelNr, NrOfLogEntries); \n
*   2. testWaitForTimeout(5000); // Only during this time, the log is active. Expected data which arrives within 5 seconds, is saved in the back-end buffer. \n
*   3. A_CAN_StopLoggingMessages(strSaveLogData_1500Elem, i64NumberOfExtractedLogEntries); \n
*   4. A_CAN_SaveLogDataToCSVFile(chAbsPathOf_CSVLogFile, strSaveLogData_1500Elem, i64NumberOfLogEntriesToSave); \n
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 02.04.19              RoBi            Created and implemented
*/

void A_CAN_SaveLogDataToCSVFile(char aAbsoluteCSVFilePath[], struct cv_strCAN_LoggingBuffer aLogDataToSaveInCSV[], int64 aNrOfLogEntriesToWriteInCSV)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  char chSaveLogDataInfo[250];
  int iResult;
  byte bDebugFlag;
 
  iResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel(DebugFuncCalls, "Entered A_CAN_SaveLogDataToCSVFile().");
  if ( (byte)DebugFuncParam & bDebugFlag )
    writeDbgLevel (DebugFuncParam, "Parameters: int64 aNrOfLogEntriesToWriteInCSV: --%I64d--, char aAbsoluteCSVFilePath[] --%s--.", aNrOfLogEntriesToWriteInCSV, aAbsoluteCSVFilePath);

  snprintf(chAction, elcount(chAction), "Save: %I64d log entries, to CSV file: %s", aNrOfLogEntriesToWriteInCSV, aAbsoluteCSVFilePath);

  // Check if the action text is added into the report
  if( Ok == bFctn_REPORTAction(chAction) )
  {
    iResult = iFctn_CAN_SaveLogDataToCSVFile(aAbsoluteCSVFilePath, aLogDataToSaveInCSV, aNrOfLogEntriesToWriteInCSV, chSaveLogDataInfo);
    
    // The specified number of log entries have been successfully saved to the CSV file
    if ( Ok == iResult )
    {
      snprintf(chPassText, elcount(chPassText), "SUCCESS: %s", chSaveLogDataInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result A_CAN_SaveLogDataToCSVFile(): %s", chSaveLogDataInfo);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // Incorrect parameters provided (relative file path, empty structure, NrOfLogEntries > SizeOfStructure) or an internal error occurred
    {
      snprintf(chFailText, elcount(chFailText), "FAILED: %s", chSaveLogDataInfo);
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Result A_CAN_SaveLogDataToCSVFile(): %s", chSaveLogDataInfo);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // the reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report.");
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result A_CAN_SaveLogDataToCSVFile(): %s", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

