/*! void E_CAN_WaitForMessageByID(dword aMsgID, dword aTimeout, enum cc_ePresentAbsentCAN aPresentAbsent, char aBusContext[])
*  \brief Function evaluate if a can messageID is present on the bus in a specific time or not
*  \param[in] aMsgID         - ID of message
*  \param[in] aTimeout       - Max wait time for the message(in milliseconds).
*  \param[in] aPresentAbsent - cc_eCAN_ABSENT = Expects message to be absent, cc_eCAN_PRESENT = Expects message to be present
*  \param[in] aBusContext    - The bus name context
* 
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 06.07.18              GrAn        Created and implemented.
* 01.10.18              GrAn        Resolve some remarks after tests done for this function.
* 26.08.19              CrJu        Refactoring the code.
*/

void E_CAN_WaitForMessageByID(dword aMsgID, dword aTimeout, enum cc_ePresentAbsentCAN aPresentAbsent, char aBusContext[])
{
  int iResult;
  byte bDebugFlag;
  char chMappedResponse[250];
  
  iResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function E_CAN_WaitForMessageByID entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: --0x%x--, dword aTimeout: -- %d --, cc_ePresentAbsentCAN aPresentAbsent -- %d --, char aBusContext[] --%s--.", aMsgID, aTimeout, aPresentAbsent, aBusContext);    
  
  iResult = iFctn_CAN_WaitForMessagebyID(aMsgID, aTimeout, aPresentAbsent, aBusContext, chMappedResponse);
  
  if(iResult == Ok)//PASS
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "PASSED! Result E_CAN_WaitForMessageByID(): %s.", chMappedResponse);
    vFctn_REPORTStepEvaluation(chMappedResponse, PASS);
  }
  else//FAILED
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result E_CAN_WaitForMessageByID(): %s.", chMappedResponse);
    vFctn_REPORTStepEvaluation(chMappedResponse, FAIL);
  }
}

/*! \fn void E_CAN_WaitForMessageByName(dbMsg* aMessageName, dword aTimeout, enum cc_ePresentAbsentCAN aPresentAbsent)
*  \brief Function evaluate if a can message name is present on the bus in a specific time or not
*  \param[in] aMessageName   - name of message from database
*  \param[in] aTimeout       - max wait time for the message.
*  \param[in] aPresentAbsent - Absent = Expects message to be absent, Present = Expects message to be present
* 
*  \return no return
*
*  \note 
*         - The aMessage parameter must be sent in following structure: [Data Base Name] :: [Data Base Node] :: Message Name \n
*         (example: CANCluster_PrivA(Data Base Name - optional) :: Tester(Data Base Node-optional) :: Test_frame1(Message Name).
*  \note
*         - The optional attributes must be used if messages with the same name are present on different data bases/CAN nodes.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 06.07.18              GrAn        Created and implemented
* 01.10.18              GrAn        Resolve some remarks after tests done for this function.
* 27.08.19              CrJu        Refactoring the code.
*/

void E_CAN_WaitForMessageByName(dbMsg* aMessageName, dword aTimeout, enum cc_ePresentAbsentCAN aPresentAbsent)
{
  byte bDebugFlag;
  char chMappedResponseInfo[250];
  byte iResult;
  
  iResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function E_CAN_WaitForMessageByName entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dbMsg* aMessageName: -- Message searched --, dword aTimeout: -- %d --, cc_ePresentAbsentCAN aPresentAbsent -- %d --.", aTimeout, aPresentAbsent);    
  
  iResult = iFctn_CAN_WaitForMessagebyName(aMessageName, aTimeout, aPresentAbsent, chMappedResponseInfo);

  if(iResult == Ok)//PASS
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "PASSED! Result E_CAN_WaitForMessageByName(): %s.", chMappedResponseInfo);
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, PASS);
  }
  else//FAILED
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAILED! Result E_CAN_WaitForMessageByName(): %s.", chMappedResponseInfo);
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);
  }
}

/*! \fn void A_CAN_DisableMessage(dword aMsgID, char aBusContext[])
*   \brief Function disables sending of a message from database on a specific CAN bus.
*   \param[in] aMsgID      - ID of message.
*   \param[in] aBusContext - the bus name context
*
*   \return no return
*
*  \note 
*         - This function can be used just for dbc messages.
*
*  Change History: 
*  Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  28.08.19              CrJu        Refactoring the code.
*/

void A_CAN_DisableMessage (dword aMsgID, char aBusContext[])
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  byte bDebugFlag;
  char chPrintBusContext[25];
  
  lResult = NotOk;
  bResultAction = NotOk; 
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function A_CAN_DisableMessage entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%X --, char aBusContext --%s-- .", aMsgID, aBusContext);  
  
  //If the bus context name is too big, print in the raport just first 25 chars
  bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars - 1, chPrintBusContext);

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Disable CAN message: 0x%X on required bus %s.", aMsgID, chPrintBusContext);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    lResult = lFctn_CAN_DisableMessage(aMsgID,aBusContext);
    
    if (Error != lResult)
    {
      if(lResult)
      {
        snprintf(chPassText, elcount(chPassText), "CAN message 0x%X disabled on required bus %s.", aMsgID, chPrintBusContext);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASSED! Result: A_CAN_DisableMessage. %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "CAN message 0x%X could not be disabled on required bus %s.", aMsgID, chPrintBusContext);  
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAILED! Result: A_CAN_DisableMessage. %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "Disable CAN message: 0x%X on required bus %s.", aMsgID, chPrintBusContext);
      if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAILED! Result: A_CAN_DisableMessage. %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_EnableMessage(dword aMsgID, char aBusContext[])
*  \brief Function enables sending of a message from database on a specific CAN bus.
*  \param[in] aMsgID      - ID of message.
*  \param[in] aBusContext - the bus name context
*
*  \return no return
*
*  \note
*         - This function can be used just for dbc messages.
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  28.08.19              CrJu        Refactoring the code.
*/

void A_CAN_EnableMessage (dword aMsgID, char aBusContext[])
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  byte bDebugFlag;
  char chPrintBusContext[25];
  
  lResult = NotOk;
  bResultAction = NotOk;  
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls , "Function A_CAN_EnableMessage entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%x --, char aBusContext --%s-- .", aMsgID, aBusContext);   

  //If the bus context name is too big, print in the raport just first 25 chars
  bFctn_CONV_GetSubString(aBusContext, 0, tsc_wPrintBusContextChars - 1, chPrintBusContext);
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Enables CAN message: 0x%X on required bus %s.", aMsgID, chPrintBusContext);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    lResult = lFctn_CAN_EnableMessage(aMsgID, aBusContext);
    
    if (Error != lResult)
    {
      if(lResult)
      {
        snprintf(chPassText, elcount(chPassText), "CAN message 0x%X was enabled on required bus %s.", aMsgID, chPrintBusContext);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASSED! Result: A_CAN_EnableMessage. %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "CAN message 0x%X cannot be enabled on required bus %s.", aMsgID, chPrintBusContext);  
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAILED! Result: A_CAN_EnableMessage. %s.",chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "The bus context %s does not exists. Check the name in function call aBusContext.", chPrintBusContext);  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! Result: A_CAN_EnableMessage. %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_SetBaudrate(dword aCANChannel, float aBaudrate)
*  \brief Function that sets the baudrate for requested CAN channel.
*  \param[in] aCANChannel - number of CAN channel.
*  \param[in] aBaudrate   - the new value of the baudrate.
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  01.10.18              GrAn        Change the implementation for availability of CAN channel.
*  30.08.19              CrJu        Refactoring the code.
*/
void A_CAN_SetBaudrate(dword aCANChannel, float aBaudrate)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  char chIniFilePath[500];
  byte bLastIniFileUsed;
  byte bDebugFlag;
  long lCANChannelAvailable;
  
  lResult = NotOk;
  bResultAction = NotOk; 
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  bLastIniFileUsed = NotOk;
  lCANChannelAvailable = 0;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_SetBaudrate entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aCANChannel: -- %d --, float aBaudrate --%12.2f-- .", aCANChannel, aBaudrate);     
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Set the baudrate for CAN channel %d with the value %12.2f.", aCANChannel, aBaudrate);
  bResultAction = bFctn_REPORTAction(chAction);
  
  //Read the value of the parameter 'CANChannelsAvailable' from INI File
  bLastIniFileUsed = bFctn_READFILELastINIused(chIniFilePath); 
    
  lCANChannelAvailable = lFctn_READFILEiniParameterNumber(chIniFilePath, "CANChannelsAvailable", "CAN_COMMUNICATION");
  
  if(bResultAction)
  {
    lResult = lFctn_CAN_SetBaudrate((long)aCANChannel, aBaudrate); 
  
    if(Ok == lResult)
    {
      snprintf(chPassText, elcount(chPassText), "CAN channel %d baudrate is set to value %12.2f.", aCANChannel, aBaudrate );
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! Result: A_CAN_SetBaudrate. %s.",chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else
    {
      if(NotOk == lResult)
      {
        snprintf(chFailText, elcount(chFailText), "CAN channel %d baudrate cannot be set to value %12.2f. Check the aCANChannel parameter if it is OK called.", aCANChannel, aBaudrate);  
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAILED! Result: A_CAN_SetBaudrate. %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "FAILED! The control function: lFctn_CAN_SetBaudrate has failed. Check the error code.");  
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAILED! Result: A_CAN_SetBaudrate. %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_SendMessage(dword aMsgID, byte aBytesToBeSend[], byte aMsgDLC, word aCANChannel)
*  \brief Function that sends a CAN message with the maximum length of 8 bytes on required CAN channel.
*  \param[in] aMsgID         - The ID of message that will be sent.
*  \param[in] aBytesToBeSend - content of message to be sent.
*  \param[in] aMsgDLC        - number of bytes to be sent (max. 8 bytes) .
*  \param[in] aCANChannel    - required CAN channel.
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  01.10.18              GrAn        Change the implementation for availability of CAN channel.
*  14.11.18              GrAn        Check the return from CONV function bFctn_CONVConvertByteArrToStringByLength.
*  14.02.19              GrAn        Check that the message DLC and the number of elements of byte array to be sent are ok before the byte array to be converted
*  05.09.19              CrJu        Refactoring the code.
*  14.11.19              CrJu        Eliminate the verification of INI, but added it in the control function. 
*/

void A_CAN_SendMessage(dword aMsgID, byte aBytesToBeSend[], byte aMsgDLC, word aCANChannel)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  char chBytesToBeSend[100];
  byte bDebugFlag;
  
  lResult = NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_SendMessage entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%X --, byte aMsgDLC -- %d --, word aCANChannel --%d--.", aMsgID, aMsgDLC, aCANChannel);   
  
  //Convert bytes array to string
  bFctn_CONV_ConvertByteArrayToStringByDLC(aBytesToBeSend, chBytesToBeSend, aMsgDLC);
  
  snprintf(chAction, elcount(chAction), "The message 0x%X is send with %s data on CAN channel %d. ", aMsgID, chBytesToBeSend, aCANChannel);
  bResultAction = bFctn_REPORTAction(chAction);
 
  if(bResultAction)
  {
    //Send the message
    lResult = lFctn_CAN_SendMessage(aMsgID, aBytesToBeSend, aMsgDLC, aCANChannel); 
    
    if(lResult != Error)
    {
      //The message was sent succesfully
      if(lResult == Ok)
      {
        snprintf(chPassText, elcount(chPassText), "Send message 0x%X with %s data on CAN channel %d.", aMsgID, chBytesToBeSend, aCANChannel);   
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASSED! Result: A_CAN_SendMessage. %s", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      //No other return might be
    }
    else//An error occured
    {
      snprintf(chFailText, elcount(chFailText), "Something went wrong. Check the error code from the control function: lFctn_CAN_SendMessage(), using debug function.");  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "ERROR! Result: A_CAN_SendMessage. %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_SendMessage(dword aMsgID, byte aBytesToBeSend[], byte aMsgDataLength, word aCANChannel, enum cc_eCanTYPE aType_CAN)
*  \brief Function that sends a CAN or CAN_FD message with the maximum length of 8 bytes, respective 64 bytes on required CAN channel.
*  \param[in] aMsgID         - The ID of message that will be sent.
*  \param[in] aBytesToBeSend - content of message to be sent.
*  \param[in] aMsgDataLength - The length of the message. (On noraml CAN, it is equivalent with the DLC of the message. For CAN: max 8bytes. For CAN_FD: max 64bytes)
*  \param[in] aCANChannel    - required CAN channel.
*  \param[in] aType_CAN      - The CAN type you want to used: cc_eCAN_NORMAL / cc_eCAN_FD
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  14.11.19              CrJu        Created and implemented
*/

void A_CAN_SendMessage(dword aMsgID, byte aBytesToBeSend[], byte aMsgDataLength, word aCANChannel, enum cc_eCanTYPE aType_CAN)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  char chBytesToBeSend[250];
  byte bDebugFlag;
  
  lResult = NotOk;
  bResultAction = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_SendMessage entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%X --, byte aMsgDataLength -- %d --, word aCANChannel --%d--.", aMsgID, aMsgDataLength, aCANChannel);   
  
  //Convert bytes array to string
  bFctn_CONV_ConvertByteArrayToStringByDLC(aBytesToBeSend, chBytesToBeSend, aMsgDataLength);
  
  snprintf(chAction, elcount(chAction), "The message 0x%X is send with %s data on CAN channel %d. ", aMsgID, chBytesToBeSend, aCANChannel);
  bResultAction = bFctn_REPORTAction(chAction);
 
  if(bResultAction)
  {
    //Send the message
    lResult = lFctn_CAN_SendMessage(aMsgID, aBytesToBeSend, aMsgDataLength, aCANChannel, aType_CAN); 
    
    if(lResult != Error)
    {
      //The message was sent succesfully
      if(lResult == Ok)
      {
        snprintf(chPassText, elcount(chPassText), "Send message 0x%X with %s data on CAN channel %d.", aMsgID, chBytesToBeSend, aCANChannel);   
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASSED! Result: A_CAN_SendMessage. %s", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      //No other return might be
    }
    else//An error occured
    {
      snprintf(chFailText, elcount(chFailText), "Something went wrong. Check the error code from the control function: lFctn_CAN_SendMessage(), using debug function.");  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "ERROR! Result: A_CAN_SendMessage. %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_SendBurstMessage(dword aMsgID, byte aBytesToBeSend[], dword aTimeBetweenFrames, byte aDataLengthOfMessage, word aCANChannel)
*  \brief Function for sending specific volume of bytes more than 8 bytes.
*  \param[in] aMsgID               - The ID of message that will be sent.
*  \param[in] aBytesToBeSend       - content of messages to be sent.
*  \param[in] aTimeBetweenFrames   - time waited between frames
*  \param[in] aDataLengthOfMessage - DLC of message (maximum 8 bytes)
*  \param[in] aCANChannel          - required CAN channel.
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              GrAn        Created and implemented
*  01.10.18              GrAn        Change the implementation for availability of CAN channel.
*  09.09.19              CrJu        Refactoring the code.
*  21.11.19              CrJu        Eliminate the conditions for INI file. They are verified in control fct. Modified the function, for the new returns of control fct: only -1 and 1.
*/

void A_CAN_SendBurstMessage(dword aMsgID, byte aBytesToBeSend[], dword aTimeBetweenFrames, byte aDataLengthOfMessage, word aCANChannel)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  char chOutputString[150];
  char chPrintOutput[150];
  byte bDebugFlag;
  
  lResult = NotOk;
  bResultAction = NotOk;  
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_SendBurstMessage entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%x --, dword aTimeBetweenFrames --%d--,byte aDataLengthOfMessage --%d--, word aCANChannel --%d--.", aMsgID,aTimeBetweenFrames,aDataLengthOfMessage,aCANChannel);   
  
  //Convert bytes array to string
  bFctn_CONV_ConvertByteArrToStringByLength(aBytesToBeSend, elcount(chOutputString) ,chOutputString);
  
  //if Output String is too big write just first 128 characters
  bFctn_CONV_GetSubString(chOutputString, 0, elcount(chOutputString) - 1, chPrintOutput);

  snprintf(chAction, elcount(chAction),"Send %d bytes on message 0x%x with a frame length of %d bytes.",elcount(aBytesToBeSend), aMsgID, aDataLengthOfMessage);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    //Send the message
    lResult = lFctn_CAN_SendBurstMessage(aMsgID, aBytesToBeSend, aTimeBetweenFrames, aDataLengthOfMessage, aCANChannel);

    if(Error != lResult)
    {
      if(Ok == lResult)
      {
        snprintf(chPassText, elcount(chPassText), "All data bytes are succesfully sent.");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "PASSED! Result: A_CAN_SendBurstMessage. %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      //No other return might be
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "Something went wrong. Check the error code from the control function: lFctn_CAN_SendBurstMessage(), using debug function.");  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "ERROR! Result: A_CAN_SendBurstMessage. %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_CAN_SendBurstMessage(dword aMsgID, byte aBytesToBeSend[], dword aTimeBetweenFrames, byte aDataLengthOfMessage, word aCANChannel, enum cc_eCanTYPE aType_CAN)
*  \brief Function for sending specific volume of bytes more than 8 bytes.
*  \param[in] aMsgID               - The ID of message that will be sent.
*  \param[in] aBytesToBeSend       - content of messages to be sent.
*  \param[in] aTimeBetweenFrames   - time waited between frames
*  \param[in] aDataLengthOfMessage - The length of the message. (On noraml CAN, it is equivalent with the DLC of the message. For CAN: max 8bytes. For CAN_FD: max 64bytes)
*  \param[in] aCANChannel          - required CAN channel.
*  \param[in] aType_CAN            - The CAN type you want to used: cc_eCAN_NORMAL / cc_eCAN_FD
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  06.07.18              CrJu        Created and implemented
*/

void A_CAN_SendBurstMessage(dword aMsgID, byte aBytesToBeSend[], dword aTimeBetweenFrames, byte aDataLengthOfMessage, word aCANChannel, enum cc_eCanTYPE aType_CAN)
{
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  long lResult;
  char chOutputString[150];
  char chPrintOutput[150];
  byte bDebugFlag;
  
  lResult = NotOk;
  bResultAction = NotOk;  
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function A_CAN_SendBurstMessage entered.");
  
  if((byte)DebugFuncParam & bDebugFlag)
    writeDbgLevel (DebugFuncParam, "Parameters: dword aMsgID: -- 0x%x --, dword aTimeBetweenFrames --%d--,byte aDataLengthOfMessage --%d--, word aCANChannel --%d--.", aMsgID,aTimeBetweenFrames,aDataLengthOfMessage,aCANChannel);   
  
  //Convert bytes array to string
  bFctn_CONV_ConvertByteArrToStringByLength(aBytesToBeSend, elcount(chOutputString) ,chOutputString);
  
  //if Output String is too big write just first 128 characters
  bFctn_CONV_GetSubString(chOutputString, 0, elcount(chOutputString) - 1, chPrintOutput);

  snprintf(chAction, elcount(chAction),"Send %d bytes on message 0x%x with a frame length of %d bytes.",elcount(aBytesToBeSend), aMsgID, aDataLengthOfMessage);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    //Send the message
    lResult = lFctn_CAN_SendBurstMessage(aMsgID, aBytesToBeSend, aTimeBetweenFrames, aDataLengthOfMessage, aCANChannel, aType_CAN);

    if(Error != lResult)
    {
      if(Ok == lResult)
      {
        snprintf(chPassText, elcount(chPassText), "All data bytes are succesfully sent.");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel(DebugFuncInternal, "PASSED! Result: A_CAN_SendBurstMessage. %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      //No other return might be
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "Something went wrong. Check the error code from the control function: lFctn_CAN_SendBurstMessage(), using debug function.");  
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "ERROR! Result: A_CAN_SendBurstMessage. %s", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void E_CAN_CycleTimeCheckByMessageID(dword aMsgID, dword aTimeout, float aMinAbsCycleTime, float aMaxAbsCycleTime, char aBusContext[] )
*  \brief Function waits for a specific message to be sent on CAN.
*  \param[in]  aMsgID           - ID of message
*  \param[in]  aTimeout         - max wait time for the message.
*  \param[in]  aMinAbsCycleTime - maximum time for message cycle.
*  \param[in]  aMaxAbsCycleTime - minimum time for message cycle.
*  \param[in]  aBusContext      - the specific bus context
*
*  \return no return
*
*  \note
*          - Event is generated if the time between sends of message is smaller than aMinAbsCycleTime and aMaxAbsCycleTime (example: if Message cycle \n
*            time is 50ms and difference between aMinAbsCycleTime and aMaxAbsCycleTime is 60ms the event is not generated)
*  \note 
*          - If the limits (aMinAbsCycleTime or/and aMaxAbsCycleTime) are zero, this function does not check those limits.
*
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  21.06.18              GrAn        Created and implemented
*  10.09.19              CrJu        Refactoring the code.
*/

void E_CAN_CycleTimeCheckByMessageID(dword aMsgID, dword aTimeout, float aMinAbsCycleTime, float aMaxAbsCycleTime, char aBusContext[] )
{ 
  char chCheckMessageInfo[250];
  int iResult;
  byte bDebugFlag;
  
  iResult = NotOk;
  bDebugFlag = tsc_bCAN_GlobalDebugFlag;
  
  writeDbgLevel (DebugFuncCalls, "Function E_CAN_CycleTimeCheckByMessageID entered.");

  iResult = iFctn_CAN_CycleTimeCheckByMessageID((long)aMsgID, aTimeout, aMinAbsCycleTime, aMaxAbsCycleTime, aBusContext, chCheckMessageInfo);
  
  if(iResult != Error)
  {
    if(iResult == Ok)
    {
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASSED! %s.", chCheckMessageInfo);
      vFctn_REPORTStepEvaluation(chCheckMessageInfo, PASS);
    }
    else
    {
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAILED! %s.", chCheckMessageInfo);
      vFctn_REPORTStepEvaluation(chCheckMessageInfo, FAIL);
    }
  }
  else
  {
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR! %s.", chCheckMessageInfo);
    vFctn_REPORTStepEvaluation(chCheckMessageInfo, FAIL);
  }
}


