/*! \fn void A_POW_SetVoltage(long lVoltage, byte bPSNumber)
*  \brief Function sets power supply voltage.
*  \param[in] lVoltage - voltage to be set.
*  \param[in] bPSNumber - power supply selected (0,1,...7 - from ini file).
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  12.04.18              SeNi        Created and implemented
*  07.07.20              CrJu        Added debug functions
*  14.07.20              CrJu        Added a time to wait after commands if it is not zero from ini file
*/

void A_POW_SetVoltage(long lVoltage, byte bPSNumber)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128];
  char chMappedResponseInfo[250];
  char chVoltageToSet[50];
  double dVoltageToSet;
  byte bResult;
  byte bResultAction;  
  byte bDebugFlag;
  
  bResult       = NotOk;
  bResultAction = NotOk;   
  bDebugFlag    = NotOk;
  
  writeDbgLevel (DebugFuncCalls , "Function A_POW_SetVoltage called.");
  writeDbgLevel (DebugFuncParam, "Parameters: long lVoltage: -- %d --.", lVoltage);
  
  snprintf(chAction, elcount(chAction), "Set voltage to %d mV.", lVoltage);      
  
  bResultAction = bFctn_REPORTAction(chAction);
  if ( (byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal, "bResultAction: -- %d -- is the result from adding action to report.", bResultAction);
  
  if(bResultAction)
  {
    bResult = bFctn_POWSelectPowerSupply(bPSNumber); 
        
    //The SCPI command for setting the address has been sent
    if(cv_iPOWWaitForCommand > 0 && @sysvar::PowGeneral_Variables::SCPICommand == 1)
      testWaitForTimeout(cv_iPOWWaitForCommand);
    
    if(bResult)
    { 
      bResult = bFctn_POWSetVoltage(lVoltage);
      
      if(cv_iPOWWaitForCommand > 0)
        testWaitForTimeout(cv_iPOWWaitForCommand);
      
      if(Ok == bResult)
      {
        snprintf(chPassText, elcount(chPassText), "Voltage set to %d mV. ", lVoltage);
        if ( (byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "There was an error setting voltage to desired value. Please check connection to power supply and ini file.");  
        if ( (byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);  
      }
    }
    else // Selecting power supply failed
    {
      snprintf(chFailText, elcount(chFailText), "ERROR: Power Supply selected is NOT available in ini file or Power Supply could not be initialize.");
      if ( (byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else // The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ( (byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/*! \fn void A_POW_SetCurrent(int iCurrent, byte bPSNumber)
*  \brief Function sets power supply current.
*  \param[in] iCurrent - current to be set.
*  \param[in] bPSNumber - power supply selected (0,1,...7 - from ini file).
* 
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
*  12.04.18              SeNi        Created and implemented
*  07.07.20              CrJu        Added debug functions
*  14.07.20              CrJu        Added a time to wait after commands if it is not zero from ini file
*/

void A_POW_SetCurrent(int iCurrent, byte bPSNumber)
{
  char chAction[128];
  char chPassText[128];
  char chFailText[128]; 
  char chMappedResponseInfo[250];
  double dCurrentToSet;
  char chCurrentToSet[50];
  byte bDebugFlag;
  byte bResult;
