/***************************************************************************************************
----------------------------------------------------------------------------------------------------
Test case name:  TC_L30SW_IT_36631001: Test_case_To_verify_the_control_flow_through_the_interface_GetHWIO_e_WakeupSigSt()
----------------------------------------------------------------------------------------------------
Description:   Test_case_To_verify_the_control_flow_through_the_interface_GetHWIO_e_WakeupSigSt().

***************************************************************************************************/
testcase Test_case_To_verify_the_control_flow_through_the_interface_GetHWIO_e_WakeupSigSt()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "Test_case_To_verify_the_control_flow_through_the_interface_GetHWIO_e_WakeupSigSt()" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:Test_case_To_verify_the_control_flow_through_the_interface_GetHWIO_e_WakeupSigSt()");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_IT_36631001", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo(); 
  E_DBGR_CheckState(T32_State_Running);
  


  /**************************************************************************************************************************************************************/    
    // Test Step 1 to 3: set breakpoint in file test_wakeup_hwio.c in function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line if (CheckWakeup == (boolean)TRUE)
  /**************************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file test_wakeup_hwio.c in function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line if (CheckWakeup == (boolean)TRUE)"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line if (CheckWakeup == (boolean)TRUE)"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_R();
  A_DBGR_BreakpointSet("Test_GetHWIO_e_WakeupSigSt\\5"); //Test_GetHWIO_e_WakeupSigSt\5
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("Test_GetHWIO_e_WakeupSigSt\\5");
  
  
   /*******************************************************************************************************************************************************/    
    // Test Step 4: Add CheckWakeup Variable in watch window and update value to TRUE or 1.
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Add CheckWakeup Variable in watch window and update value to TRUE or 1."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Variable added in watch window and updated the value CheckWakeup = 1"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_BreakpointDeleteAll();
  A_DBGR_VariableSet("CheckWakeup", "1");
  A_DBGR_Go();
  E_DBGR_VariableCheck("CheckWakeup", 0, Equal);   //variable is not updating in watch window when we disable task as TRUE, therfore checking 0 value here
  
    
  /******************************************************************************************************************************************************************/    
    // Test Step 5 to 7: set breakpoint in file test_wakeup_hwio.c in function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line wakeEvent = GetHWIO_e_WakeupSigSt();
  /******************************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file test_wakeup_hwio.c in function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line wakeEvent = GetHWIO_e_WakeupSigSt();"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line wakeEvent = GetHWIO_e_WakeupSigSt();"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("Test_GetHWIO_e_WakeupSigSt\\8"); //Test_GetHWIO_e_WakeupSigSt\8
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("Test_GetHWIO_e_WakeupSigSt\\8"); 
  
  
  /*******************************************************************************************************************************************************/    
    // Test Step 8 to 10: set breakpoint in file wakeup_hwio.c in function BYTE GetHWIO_e_WakeupSigSt( void ) at line wakeEvent = GetHWIO_e_WakeupSigSt();
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file test_wakeup_hwio.c in function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line wakeEvent = GetHWIO_e_WakeupSigSt();"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function uint8 Test_GetHWIO_e_WakeupSigSt(void) at line wakeEvent = GetHWIO_e_WakeupSigSt();"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("GetHWIO_e_WakeupSigSt"); 
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("GetHWIO_e_WakeupSigSt"); 
  
  

}
    
 

