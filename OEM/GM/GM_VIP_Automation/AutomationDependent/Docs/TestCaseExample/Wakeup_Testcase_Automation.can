Description:   To_verify_the_GetHWIO_e_WakeupSigSt_sequence_flow_through_the_interface_TCAN114x_Interrupts_ClearAll(int).

***************************************************************************************************/
testcase To_verify_the_GetHWIO_e_WakeupSigSt_sequence_flow_through_the_interface_TCAN114x_Interrupts_ClearAll()
{
  /***************************************************************************************************************/    
                                                // Variable Definition
  /***************************************************************************************************************/ 
  
  long taskvalue;
  
  /***************************************************************************************************************/    
                                               // Local Values
  /***************************************************************************************************************/ 
  

  
  /***************************************************************************************************************/    
                                              // Test Case Info
  /***************************************************************************************************************/
  setWriteDbgLevel(DebugOff);
  snprintf( chTestTitle, elCount(chTestTitle), "To_verify_the_GetHWIO_e_WakeupSigSt_sequence_flow_through_the_interface_TCAN114x_Interrupts_ClearAll(int)" );
  snprintf( chTestDescription, elCount(chTestDescription), "Purpose:To_verify_the_GetHWIO_e_WakeupSigSt_sequence_flow_through_the_interface_TCAN114x_Interrupts_ClearAll(int)");
  TestCaseAddInfo( chTestTitle, "TC_L30SW_IT_36740599", chTestDescription );

  /***************************************************************************************************************/    
                                              // Start of Test Case
  /***************************************************************************************************************/
  
  /***************************************************************************************************************/    
                                              // Test Step 1 PRECONDITIONS
  /***************************************************************************************************************/
  
  snprintf( chActionText, elCount(chActionText), "Flash the Software and ECU is running"); 
  snprintf( chExpectedText, elCount(chExpectedText), "ECU should be in running state"); 
  TestStepAddActionExpected( chActionText, chExpectedText );

  A_DBGR_BreakpointDeleteAll();
  A_DBGR_RnGo(); 
  E_DBGR_CheckState(T32_State_Running);
  


  /**************************************************************************************************************************************************************/    
    // Test Step 1 to 3: set breakpoint in file wakeup_hwio.c in function uint8 GetHWIO_e_WakeupSigSt( void ) at line if ( OsRunningStatus == Hwio_Os_Running )
  /**************************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file wakeup_hwio.c in function uint8 GetHWIO_e_WakeupSigSt( void ) at line if ( OsRunningStatus == Hwio_Os_Running )"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function uint8 GetHWIO_e_WakeupSigSt( void ) at line if ( OsRunningStatus == Hwio_Os_Running )"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  A_DBGR_R();
  A_DBGR_BreakpointSet("GetHWIO_e_WakeupSigSt"); 
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("GetHWIO_e_WakeupSigSt");
  
  
   /*******************************************************************************************************************************************************/    
    // Test Step 4: Add OsRunningStatus Variable in watch window and update value to other 1.
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "Add OsRunningStatus Variable in watch window and update value to other than 1."); 
  snprintf( chExpectedText, elCount(chExpectedText), "Variable added in watch window and updated the value OsRunningStatus != 1"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
 // A_DBGR_BreakpointDeleteAll();
  A_DBGR_VariableSet("OsRunningStatus", "2");   // other than 1.
  E_DBGR_VariableCheck("OsRunningStatus", 0, Equal);   //variable is not updating in watch window when we disable task as TRUE, therfore checking 0 value here
  
    
  /******************************************************************************************************************************************************************/    
    // Test Step 5 to 7: set breakpoint in file wakeup_hwio.c in function uint8 GetHWIO_e_WakeupSigSt( void ) at line CanTrcv_checkTrcvIntruptsSync();
  /******************************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file wakeup_hwio.c in function uint8 GetHWIO_e_WakeupSigSt( void ) at line CanTrcv_checkTrcvIntruptsSync();"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function uint8 GetHWIO_e_WakeupSigSt( void ) at line CanTrcv_checkTrcvIntruptsSync();"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("GetHWIO_e_WakeupSigSt\\34");
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("GetHWIO_e_WakeupSigSt\\34"); 
  
  
  /*******************************************************************************************************************************************************/    
    // Test Step 8 to 10: set breakpoint in file Hwio_can.c in function void CanTrcv_checkTrcvIntruptsSync( void ) at line TCAN114x_Interrupts_ClearAll(int)
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file Hwio_can.c in function void CanTrcv_checkTrcvIntruptsSync( void ) at line TCAN114x_Interrupts_ClearAll(int)"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function void CanTrcv_checkTrcvIntruptsSync( void ) at line TCAN114x_Interrupts_ClearAll(int)"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("CanTrcv_checkTrcvIntruptsSync\\16"); 
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("CanTrcv_checkTrcvIntruptsSync\\16"); 
  
  
 /*******************************************************************************************************************************************************/    
    // Test Step 11 to 13: set breakpoint in file tcan114x.c in function TCAN114x_eStatus TCAN114x_Device_Interrupts_ClearAll( uint8_t canTrcvIndex ) at line TCAN114x_eStatus TCAN114x_Device_Interrupts_ClearAll( uint8_t canTrcvIndex )
  /*******************************************************************************************************************************************************/

  snprintf( chActionText, elCount(chActionText), "set breakpoint in file Hwio_can.c in function TCAN114x_eStatus TCAN114x_Interrupts_ClearAll() at line TCAN114x_eStatus TCAN114x_Interrupts_ClearAll( uint8_t canTrcvIndex )"); 
  snprintf( chExpectedText, elCount(chExpectedText), "Verify Breakpoint got hit at function TCAN114x_eStatus TCAN114x_Interrupts_ClearAll() at line TCAN114x_eStatus TCAN114x_Interrupts_ClearAll( uint8_t canTrcvIndex )"); 
  TestStepAddActionExpected( chActionText, chExpectedText );
  //A_DBGR_R();
  A_DBGR_BreakpointSet("TCAN114x_Interrupts_ClearAll"); 
  A_DBGR_Go(); 
  E_DBGR_BreakpointCheckForHalt("TCAN114x_Interrupts_ClearAll"); 
  
}
 















    
    






