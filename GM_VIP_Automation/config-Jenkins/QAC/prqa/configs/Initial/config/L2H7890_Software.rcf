    <rule id="M3CM-1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.2.html">
      <text>MISRA Mandatory</text>
      <enforcement>
        <rule id="M3CM-1_1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.2.CMSubGroup.1.html">
          <text>Rules</text>
          <enforcement>
            <rule id="Rule-9.1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-9.1.html">
              <text>The value of an object with automatic storage duration shall not be read before it has been set</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Initialization</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2961" mapped="yes"/>
                <message component="dataflow" id="2962" mapped="yes"/>
                <message component="dataflow" id="2963" mapped="yes"/>
                <message component="dataflow" id="2966" mapped="yes"/>
                <message component="dataflow" id="2967" mapped="yes"/>
                <message component="dataflow" id="2968" mapped="yes"/>
                <message component="dataflow" id="2971" mapped="yes"/>
                <message component="dataflow" id="2972" mapped="yes"/>
                <message component="dataflow" id="2973" mapped="yes"/>
                <message component="qac" id="2883" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-12.5" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-12.5.html">
              <text>The sizeof operator shall not have an operand which is a function parameter declared as 'array of type'</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Side-effects</category>
              </categories>
              <enforcement>
                <message component="qac" id="1321" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-17.4" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-17.4.html">
              <text>All exit paths from a function with non-void return type shall have an explicit return statement with an expression</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Functions</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2887" mapped="yes"/>
                <message component="dataflow" id="2888" mapped="yes"/>
                <message component="qac" id="0745" mapped="yes"/>
                <message component="qac" id="3113" mapped="yes"/>
                <message component="qac" id="3114" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-19.1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-19.1.html">
              <text>An object shall not be assigned or copied to an overlapping object</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Overlapping storage</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2776" mapped="yes"/>
                <message component="dataflow" id="2777" mapped="yes"/>
                <message component="dataflow" id="2778" mapped="yes"/>
                <message component="qac" id="0681" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.13" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.13.html">
              <text>Any value passed to a function in &lt;ctype.h> shall be representable as an unsigned char or be the value EOF</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2796" mapped="yes"/>
                <message component="dataflow" id="2797" mapped="yes"/>
                <message component="dataflow" id="2798" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.17" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.17.html">
              <text>Use of the string handling functions from &lt;string.h> shall not result in accesses beyond the bounds of the objects referenced by their pointer parameters</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2835" mapped="yes"/>
                <message component="dataflow" id="2836" mapped="yes"/>
                <message component="dataflow" id="2935" mapped="yes"/>
                <message component="dataflow" id="2936" mapped="yes"/>
                <message component="dataflow" id="2937" mapped="yes"/>
                <message component="dataflow" id="2938" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.18" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.18.html">
              <text>The size_t argument passed to any function in &lt;string.h> shall have an appropriate value</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2865" mapped="yes"/>
                <message component="dataflow" id="2866" mapped="yes"/>
                <message component="dataflow" id="2867" mapped="yes"/>
                <message component="dataflow" id="2868" mapped="yes"/>
                <message component="dataflow" id="4880" mapped="yes"/>
                <message component="dataflow" id="4881" mapped="yes"/>
                <message component="dataflow" id="4882" mapped="yes"/>
                <message component="dataflow" id="4883" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.19" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.19.html">
              <text>The pointers returned by the Standard Library functions lovaleconv, getenv, setlocale or strerror shall only be used as if they have pointer to const-qualified type</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="qac" id="1492" mapped="yes"/>
                <message component="qac" id="1493" mapped="yes"/>
                <message component="qac" id="1494" mapped="yes"/>
                <message component="qac" id="1498" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.20" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.20.html">
              <text>The pointer returned by the Standard Library functions asctime, ctime, gmtime, localtime, localeconv, getenv, setlocale, or strerror shall not be used following a subsequent call to the same function</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2681" mapped="yes"/>
                <message component="dataflow" id="2682" mapped="yes"/>
                <message component="dataflow" id="2683" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.2" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.2.html">
              <text>A block of memory shall only be freed if it was allocated by means of a Standard Library function</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2716" mapped="yes"/>
                <message component="dataflow" id="2717" mapped="yes"/>
                <message component="dataflow" id="2718" mapped="yes"/>
                <message component="dataflow" id="2721" mapped="yes"/>
                <message component="dataflow" id="2722" mapped="yes"/>
                <message component="dataflow" id="2723" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.4" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.4.html">
              <text>There shall be no attempt to write to a stream which has been opened as read-only</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2686" mapped="yes"/>
                <message component="dataflow" id="2687" mapped="yes"/>
                <message component="dataflow" id="2688" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.5" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.5.html">
              <text>A pointer to a FILE object shall not be dereferenced</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="qac" id="1485" mapped="yes"/>
                <message component="qac" id="1486" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.6" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.6.html">
              <text>The value of a pointer to a FILE shall not be used after the associated stream has been closed</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2696" mapped="yes"/>
                <message component="dataflow" id="2697" mapped="yes"/>
                <message component="dataflow" id="2698" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
    <rule id="M3CM-1-C99-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.4.html">
      <text>MISRA Mandatory</text>
      <enforcement>
        <rule id="M3CM-1_1-C99-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.4.CMSubGroup.1.html">
          <text>C99 and C11 Specific Rules</text>
          <enforcement>
            <rule id="Rule-7.5" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-7.5.html">
              <text>The argument of an integer-constant macro shall have an appropriate form</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Literals and constants</category>
              </categories>
              <enforcement>
                <message component="qac" id="3185" mapped="yes"/>
                <message component="qac" id="3186" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-17.6" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-17.6.html">
              <text>The declaration of an array parameter shall not contain the static keyword between the [ ]</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Functions</category>
              </categories>
              <enforcement>
                <message component="qac" id="1058" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-18.10" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.10.html">
              <text>Pointers to variably-modified array types shall not be used</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Pointers and arrays</category>
              </categories>
              <enforcement>
                <message component="qac" id="1187" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.22" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.22.html">
              <text>All operand arguments to any type-generic macros declared in &lt;tgmath.h> shall have an appropriate essential type</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="qac" id="1160" mapped="yes"/>
                <message component="qac" id="1161" mapped="yes"/>
                <message component="qac" id="1162" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
    <rule id="M3CM-1-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.5.html">
      <text>MISRA Mandatory</text>
      <enforcement>
        <rule id="M3CM-1_1-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.5.CMSubGroup.1.html">
          <text>C11 Specific Rules</text>
          <enforcement>
            <rule id="Rule-17.9-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-17.9-C11.html">
              <text>A function declared with a _Noreturn function specifier shall not return to its caller</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Functions</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2886" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-9.7" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-9.7.html">
              <text>Atomic objects shall be appropriately initialized before being accessed</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Initialization</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4836" mapped="yes"/>
                <message component="dataflow" id="4837" mapped="yes"/>
                <message component="dataflow" id="4838" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.12" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.12.html">
              <text>Thread objects, thread synchronization objects, and thread-specific storage pointers shall only be accessed by the appropriate Standard Library functions</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="qac" id="2035" mapped="yes"/>
                <message component="qac" id="2036" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.14" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.14.html">
              <text>Thread synchronization objects shall be initialized before being accessed</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4936" mapped="yes"/>
                <message component="dataflow" id="4937" mapped="yes"/>
                <message component="mta" id="1787" mapped="yes"/>
                <message component="mta" id="1788" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.20" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.20.html">
              <text>Thread-specific storage pointers shall be created before being accessed</text>
              <categories>
                <category>MISRA Mandatory Rules</category>
                <category>Mandatory</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="mta" id="1785" mapped="yes"/>
                <message component="mta" id="1786" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
