              </enforcement>
            </rule>
            <rule id="Rule-18.4" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.4.html">
              <text>The +, -, += and -= operators should not be applied to an expression of pointer type</text>
