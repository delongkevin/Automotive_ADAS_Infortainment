              </enforcement>
            </rule>
            <rule id="Rule-2.8" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-2.8.html">
              <text>A project should not contain unused object definitions</text>
              <categories>
                <category>Advisory</category>
