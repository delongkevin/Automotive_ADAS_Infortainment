            <rule id="Rule-18.3" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.3.html">
              <text>The relational operators >, >=, &lt; and &lt;= shall not be applied to expressions of pointer type except where they point into the same object</text>
