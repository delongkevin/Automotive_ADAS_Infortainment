            <rule id="Dir-4.3" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.3.html">
              <text>Assembly language shall be encapsulated and isolated</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement>
                <message component="qac" id="3006" mapped="yes"/>
                <message component="qac" id="3008" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-4.7" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.7.html">
              <text>If a function returns error information, then that error information shall be tested</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement>
                <message component="qac" id="2504" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-4.10" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.10.html">
              <text>Precautions shall be taken in order to prevent the contents of a header file being included more then once</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement>
                <message component="qac" id="0883" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-4.11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.11.html">
              <text>The validity of values passed to library functions shall be checked</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement/>
            </rule>
            <rule id="Dir-4.12" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.12.html">
              <text>Dynamic memory allocation shall not be used</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement>
                <message component="m3cm" id="5118" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-4.14" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.14.html">
              <text>The validity of values received from external sources shall be checked</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="2956" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-4.15" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-4.15.html">
              <text>Evaluation of floating-point expressions shall not lead to the undetected generation of infinities and NaNs</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Code design</category>
              </categories>
              <enforcement/>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
    <rule id="M3CM-2-C99" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.8.html">
      <text>MISRA Required</text>
      <enforcement>
        <rule id="M3CM-2_1-C99" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.8.CMSubGroup.1.html">
          <text>C99 Specific Rules</text>
          <enforcement>
            <rule id="Rule-1.1-C99" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-1.1-C99.html">
              <text>The program shall contain no violations of the standard C syntax and constraints, and shall not exceed the implementation's translation limits</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>A standard C environment</category>
              </categories>
              <enforcement>
                <message component="qac" id="2050" mapped="yes"/>
                <message component="qac" id="2051" mapped="yes"/>
                <message component="qac" id="3335" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-20.4-C99" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-20.4-C99.html">
              <text>A macro shall not be defined with the same name as a keyword</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Preprocessing directives</category>
              </categories>
              <enforcement>
                <message component="qac" id="3468" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
