              </enforcement>
            </rule>
            <rule id="Rule-5.9" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-5.9.html">
              <text>Identifiers that define objects or functions with internal linkage should be unique</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
                <category>Rules</category>
                <category>Identifiers</category>
              </categories>
              <enforcement>
                <message component="rcma" id="1525" mapped="yes"/>
                <message component="rcma" id="1527" mapped="yes"/>
                <message component="rcma" id="1528" mapped="yes"/>
                <message component="rcma" id="1759" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-8.7" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-8.7.html">
              <text>Functions and objects should not be defined with external linkage if they are referenced in only one translation unit</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
                <category>Rules</category>
                <category>Declarations and definitions</category>
              </categories>
              <enforcement>
                <message component="rcma" id="1504" mapped="yes"/>
                <message component="rcma" id="1505" mapped="yes"/>
                <message component="rcma" id="1514" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-8.9" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-8.9.html">
              <text>An object should be declared at block scope if its identifier only appears in a single function</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
                <category>Rules</category>
