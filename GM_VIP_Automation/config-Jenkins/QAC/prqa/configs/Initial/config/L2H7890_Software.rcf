            <rule id="Rule-11.4" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-11.4.html">
              <text>A conversion should not be performed between a pointer to object and an integer type</text>
              <categories>
                <category>Advisory</category>
