                <category>Pointers and arrays</category>
              </categories>
              <enforcement>
                <message component="qac" id="0488" mapped="yes"/>
                <message component="qac" id="0489" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-18.5" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.5.html">
              <text>Declarations should contain no more than two levels of pointer nesting</text>
              <categories>
                <category>Advisory</category>
