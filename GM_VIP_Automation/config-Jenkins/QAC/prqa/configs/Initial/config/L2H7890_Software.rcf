            </rule>
            <rule id="Rule-8.15-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-8.15-C11.html">
              <text>All declarations of an object with an explicit alignment specification shall specify the same alignment.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Declarations and definitions</category>
              </categories>
              <enforcement>
                <message component="qac" id="1166" mapped="yes"/>
                <message component="qac" id="1167" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-11.3-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-11.3-C11.html">
              <text>A conversion shall not be performed between a pointer to object type and a pointer to a different object type.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Pointer type conversions</category>
              </categories>
              <enforcement>
                <message component="qac" id="2041" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-11.8-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-11.8-C11.html">
              <text>A conversion shall not remove any const, volatile or _Atomic qualification from the type pointed to by a pointer.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Pointer type conversions</category>
              </categories>
              <enforcement>
                <message component="qac" id="2039" mapped="yes"/>
                <message component="qac" id="2040" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-11.10-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-11.10-C11.html">
              <text>The _Atomic qualifier shall not be applied to the incomplete type void.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Pointer type conversions</category>
              </categories>
              <enforcement>
                <message component="qac" id="2038" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-12.6-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-12.6-C11.html">
              <text>Structure and union members of atomic objects shall not be directly accessed.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Expressions</category>
              </categories>
              <enforcement>
                <message component="qac" id="2037" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-17.10-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-17.10-C11.html">
              <text>A function declared with a _Noreturn function specifier shall have void return type</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Functions</category>
              </categories>
              <enforcement>
                <message component="qac" id="1085" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-20.4-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-20.4-C11.html">
              <text>A macro shall not be defined with the same name as a keyword</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Preprocessing directives</category>
              </categories>
              <enforcement>
                <message component="qac" id="3468" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.26-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.26-C11.html">
              <text>The Standard Library function mtx_timedlock() shall only be invoked on mutex objects of appropriate mutex type</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="3537" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-23.2-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-23.2-C11.html">
              <text>A generic selection that is not expanded from a macro shall not contain potential side effects in the controlling expression</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Generic selections</category>
              </categories>
              <enforcement>
                <message component="qac" id="1172" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-23.4-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-23.4-C11.html">
              <text>A generic association shall list an appropriate type</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Generic selections</category>
              </categories>
              <enforcement>
                <message component="qac" id="1128" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-23.6-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-23.6-C11.html">
              <text>The controlling expression of a generic selection shall have an essential type that matches its standard type</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Generic selections</category>
              </categories>
              <enforcement>
                <message component="qac" id="1175" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-23.8-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-23.8-C11.html">
              <text>A default association shall appear as either the first or the last association of a generic selection</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Generic selections</category>
              </categories>
              <enforcement>
                <message component="qac" id="1178" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.25" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.25.html">
              <text>All memory synchronization operations shall be executed in sequentially consistent order.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="qac" id="1193" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.11.html">
              <text>A thread that was previously either joined or detached shall not be subsequently joined nor detached</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="mta" id="1776" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.13" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.13.html">
              <text>Thread objects, thread synchronization objects and thread-specific storage pointers shall have appropriate storage duration</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="qac" id="2034" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.15" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.15.html">
              <text>Thread synchronization objects and thread-specific storage pointers shall not be destroyed until after all threads accessing them have terminated</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4961" mapped="yes"/>
                <message component="dataflow" id="4962" mapped="yes"/>
                <message component="mta" id="1789" mapped="yes"/>
                <message component="mta" id="1790" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.16" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.16.html">
              <text>All mutex objects locked by a thread shall be explicitly unlocked by the same thread</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4946" mapped="yes"/>
                <message component="dataflow" id="4947" mapped="yes"/>
                <message component="dataflow" id="4971" mapped="yes"/>
                <message component="dataflow" id="4972" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.17" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.17.html">
              <text>No thread shall unlock a mutex or call cnd_wait() or cnd_timedwait() for a mutex it has not locked before</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4981" mapped="yes"/>
                <message component="dataflow" id="4982" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.18" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.18.html">
              <text>Non-recursive mutexes shall not be recursively locked</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4986" mapped="yes"/>
                <message component="dataflow" id="4987" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-22.19" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-22.19.html">
              <text>A condition variable shall be associated with at most one mutex object</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="mta" id="1769" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
        <rule id="M3CM-2_2-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.10.CMSubGroup.2.html">
          <text>C11 Specific Directives</text>
          <enforcement>
            <rule id="Dir-1.1-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-1.1-C11.html">
              <text>Any implementation-defined behaviour on which the output of the program depends shall be documented and understood</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>The implementation</category>
              </categories>
              <enforcement>
                <message component="qac" id="0371" mapped="yes"/>
                <message component="qac" id="0372" mapped="yes"/>
                <message component="qac" id="0375" mapped="yes"/>
                <message component="qac" id="0380" mapped="yes"/>
                <message component="qac" id="0388" mapped="yes"/>
                <message component="qac" id="0390" mapped="yes"/>
                <message component="qac" id="0391" mapped="yes"/>
                <message component="qac" id="0392" mapped="yes"/>
                <message component="qac" id="0613" mapped="yes"/>
                <message component="qac" id="0615" mapped="yes"/>
                <message component="qac" id="0786" mapped="yes"/>
                <message component="qac" id="0789" mapped="yes"/>
                <message component="qac" id="0793" mapped="yes"/>
                <message component="qac" id="0796" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-5.1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-5.1.html">
              <text>There shall be no data races between threads</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4976" mapped="yes"/>
                <message component="dataflow" id="4977" mapped="yes"/>
                <message component="mta" id="1765" mapped="yes"/>
                <message component="mta" id="1766" mapped="yes"/>
                <message component="mta" id="1770" mapped="yes"/>
                <message component="mta" id="1774" mapped="yes"/>
                <message component="mta" id="1775" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-5.2" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-5.2.html">
              <text>There shall be no deadlocks between threads</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Resources</category>
              </categories>
              <enforcement>
                <message component="mta" id="1767" mapped="yes"/>
                <message component="mta" id="1768" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Dir-5.3" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Dir-5.3.html">
              <text>There shall be no dynamic thread creation</text>
              <categories>
                <category>Directives</category>
                <category>MISRA Required Directives</category>
                <category>Required</category>
                <category>Resources</category>
              </categories>
              <enforcement/>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
