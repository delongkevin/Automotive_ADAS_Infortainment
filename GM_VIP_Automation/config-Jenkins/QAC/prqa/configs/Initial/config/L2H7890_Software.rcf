            <rule id="Rule-18.6" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.6.html">
              <text>The address of an object with automatic or thread-local storage shall not be copied to another object that persists after the first object has ceased to exist</text>
