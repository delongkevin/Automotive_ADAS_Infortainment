    <rule id="01_PRE" active="yes" help="certccm-3.5.0-rule_help-en_US\rules\certccm.CMGroup.2.html">
      <text>Preprocessor (PRE)</text>
      <enforcement>
        <rule id="Rule" active="yes" help="certccm-3.5.0-rule_help-en_US\rules\certccm.CMGroup.2.CMSubGroup.1.html">
          <text>Rule</text>
          <enforcement>
            <rule id="PRE30" active="yes" help="certccm-3.5.0-rule_help-en_US\rules\PRE30.html">
              <text>Do not create a universal character name through concatenation</text>
              <categories>
                <category>Guideline:Rule</category>
                <category>Severity:Low</category>
                <category>Priority:P2</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="0905" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE31" active="yes" help="certccm-3.5.0-rule_help-en_US\rules\PRE31.html">
              <text>Avoid side effects in arguments to unsafe macros</text>
              <categories>
                <category>Guideline:Rule</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3462" mapped="yes"/>
                <message component="qac" id="3463" mapped="yes"/>
                <message component="qac" id="3464" mapped="yes"/>
                <message component="qac" id="3465" mapped="yes"/>
                <message component="qac" id="3466" mapped="yes"/>
                <message component="qac" id="3467" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE32" active="yes" help="certccm-3.5.0-rule_help-en_US\rules\PRE32.html">
              <text>Do not use preprocessor directives in invocations of function-like macros</text>
              <categories>
                <category>Guideline:Rule</category>
                <category>Severity:Low</category>
                <category>Priority:P2</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="0853" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
        <rule id="Recommendation" active="no" help="certccm-3.5.0-rule_help-en_US\rules\certccm.CMGroup.2.CMSubGroup.2.html">
          <text>Recommendation</text>
          <enforcement>
            <rule id="PRE00" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE00.html">
              <text>Prefer inline or static functions to function-like macros</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Medium</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3453" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE01" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE01.html">
              <text>Use parentheses within macros around parameter names</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Medium</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3410" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE02" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE02.html">
              <text>Macro replacement lists should be parenthesized</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Medium</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3409" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE03" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE03.html">
              <text>Prefer typedefs to defines for encoding non-pointer types</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3413" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE04" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE04.html">
              <text>Do not reuse a standard header file name</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="certccm" id="5001" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE05" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE05.html">
              <text>Understand macro replacement when concatenating tokens or performing stringification</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="0341" mapped="yes"/>
                <message component="qac" id="0342" mapped="yes"/>
                <message component="qac" id="0801" mapped="yes"/>
                <message component="qac" id="0802" mapped="yes"/>
                <message component="qac" id="0803" mapped="yes"/>
                <message component="qac" id="0811" mapped="yes"/>
                <message component="qac" id="0872" mapped="yes"/>
                <message component="qac" id="0880" mapped="yes"/>
                <message component="qac" id="0881" mapped="yes"/>
                <message component="qac" id="0884" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE06" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE06.html">
              <text>Enclose header files in an inclusion guard</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="0883" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE07" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE07.html">
              <text>Avoid using repeated question marks</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3601" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE08" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE08.html">
              <text>Guarantee that header file names are unique</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="certccm" id="5002" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE09" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE09.html">
              <text>Do not replace secure functions with deprecated or obsolescent functions</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:High</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="certccm" id="5003" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE10" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE10.html">
              <text>Wrap multi-statement macros in a do-while loop</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Medium</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3412" mapped="yes"/>
                <message component="qac" id="3458" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE11" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE11.html">
              <text>Do not conclude macro definitions with a semicolon</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Medium</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3412" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="PRE12" active="no" help="certccm-3.5.0-rule_help-en_US\rules\PRE12.html">
              <text>Do not define unsafe macros</text>
              <categories>
                <category>Guideline:Recommendation</category>
                <category>Severity:Low</category>
                <category>Priority:P3</category>
                <category>Level:L3</category>
              </categories>
              <enforcement>
                <message component="qac" id="3456" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
