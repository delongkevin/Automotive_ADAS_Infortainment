            <rule id="Rule-2.3" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-2.3.html">
              <text>A project should not contain unused type declarations</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
