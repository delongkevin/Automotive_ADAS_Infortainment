    <rule id="M3CM-2-C99-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.9.html">
      <text>MISRA Required</text>
      <enforcement>
        <rule id="M3CM-2_1-C99-C11" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\m3cm.CMGroup.9.CMSubGroup.1.html">
          <text>C99 and C11 Specific Rules</text>
          <enforcement>
            <rule id="Rule-1.5" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-1.5.html">
              <text>Obsolescent language features shall not be used</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>A standard C environment</category>
              </categories>
              <enforcement>
                <message component="dataflow" id="4871" mapped="yes"/>
                <message component="dataflow" id="4872" mapped="yes"/>
                <message component="dataflow" id="4873" mapped="yes"/>
                <message component="m3cm" id="5142" mapped="yes"/>
                <message component="qac" id="1169" mapped="yes"/>
                <message component="qac" id="3001" mapped="yes"/>
                <message component="qac" id="3002" mapped="yes"/>
                <message component="qac" id="3224" mapped="yes"/>
                <message component="qac" id="3228" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-3.2" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-3.2.html">
              <text>Line-splicing shall not be used in // comments.</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Comments</category>
              </categories>
              <enforcement>
                <message component="qac" id="0247" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-7.6" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-7.6.html">
              <text>The small integer variants of the minimum-width integer constant macros shall not be used</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Literals and constants</category>
              </categories>
              <enforcement>
                <message component="qac" id="3187" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-8.10" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-8.10.html">
              <text>An inline function shall be declared with the static storage class</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Declarations and definitions</category>
              </categories>
              <enforcement>
                <message component="qac" id="3240" mapped="yes"/>
                <message component="qac" id="3241" mapped="yes"/>
                <message component="qac" id="3242" mapped="yes"/>
                <message component="qac" id="3243" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-8.14" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-8.14.html">
              <text>The restrict type qualifier shall not be used</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Declarations and definitions</category>
              </categories>
              <enforcement>
                <message component="qac" id="1057" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-9.4" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-9.4.html">
              <text>An element of an object shall not be initialized more than once</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Initialization</category>
              </categories>
              <enforcement>
                <message component="qac" id="1397" mapped="yes"/>
                <message component="qac" id="1398" mapped="yes"/>
                <message component="qac" id="1399" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-9.5" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-9.5.html">
              <text>Where designated initializers are used to initialize an array object the size of the array shall be specified explicitly</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Initialization</category>
              </categories>
              <enforcement>
                <message component="qac" id="3676" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-13.1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-13.1.html">
              <text>Initializer lists shall not contain persistent side-effects</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Side-effects</category>
              </categories>
              <enforcement>
                <message component="qac" id="3421" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-18.7" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.7.html">
              <text>Flexible array members shall not be declared</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Pointers and arrays</category>
              </categories>
              <enforcement>
                <message component="qac" id="1060" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-18.8" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.8.html">
              <text>Variable-length arrays shall not be used</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Pointers and arrays</category>
              </categories>
              <enforcement>
                <message component="qac" id="1051" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.12" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.12.html">
              <text>The standard header file &lt;fenv.h> shall not be used</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="m3cm" id="5136" mapped="yes"/>
              </enforcement>
            </rule>
            <rule id="Rule-21.23" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-21.23.html">
              <text>All operand arguments to any multi-argument type-generic macros declared in &lt;tgmath.h> shall have the same standard type</text>
              <categories>
                <category>MISRA Required Rules</category>
                <category>Required</category>
                <category>Rules</category>
                <category>Standard libraries</category>
              </categories>
              <enforcement>
                <message component="qac" id="1163" mapped="yes"/>
              </enforcement>
            </rule>
          </enforcement>
        </rule>
      </enforcement>
    </rule>
