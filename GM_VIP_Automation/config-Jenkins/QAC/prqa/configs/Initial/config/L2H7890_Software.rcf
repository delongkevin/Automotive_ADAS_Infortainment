            <rule id="Rule-12.1" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-12.1.html">
              <text>The precedence of operators within expressions should be made explicit</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
