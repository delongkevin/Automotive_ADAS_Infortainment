              </enforcement>
            </rule>
            <rule id="Rule-4.2" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-4.2.html">
              <text>Trigraphs should not be used</text>
              <categories>
                <category>Advisory</category>
