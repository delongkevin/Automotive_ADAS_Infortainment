            <rule id="Rule-2.5" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-2.5.html">
              <text>A project should not contain unused macro definitions</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
