            <rule id="Rule-2.6" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-2.6.html">
              <text>A function should not contain unused label declarations</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
