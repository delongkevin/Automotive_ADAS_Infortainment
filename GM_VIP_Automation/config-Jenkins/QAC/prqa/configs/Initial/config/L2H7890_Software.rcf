            <rule id="Rule-18.1" active="yes" help="..\..\doc-en_US\doc\m3cm\rules\Rule-18.1.html">
              <text>A pointer resulting from arithmetic on a pointer operand shall address an element of the same array as that pointer operand</text>
              <categories>
