            </rule>
            <rule id="Rule-2.7" active="no" help="..\..\doc-en_US\doc\m3cm\rules\Rule-2.7.html">
              <text>A function should not contain unused parameters</text>
              <categories>
                <category>Advisory</category>
                <category>MISRA Advisory Rules</category>
