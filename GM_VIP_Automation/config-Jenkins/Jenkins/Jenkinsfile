// Pipeline state flags (set by simplify_actions_from_parameters)
@Field boolean is_mainline = false
@Field boolean is_merge = false
@Field boolean is_head = false
@Field boolean is_tag = false
@Field boolean is_branch = false

// Pipeline action flags (set by simplify_actions_from_parameters)
@Field boolean ACTION_RUN_QAC = false
@Field boolean ACTION_QAC_REPORTS = false
@Field boolean ACTION_UPLOAD_TO_QAV = false
@Field boolean ACTION_RUN_VECTORCAST = false
