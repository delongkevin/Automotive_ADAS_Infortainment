      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
  // No post-write wait: ECU remains halted after PER.Set.simple.
}

/// <REGISTER>
/*! void A_DBGR_RegisterSetByMask(char aAddress[], char aMask[])
*  \brief Function that SET a value of a specific mask from register by address in TRACE32.
* 
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[in] aMask - the mask
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 15.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_RegisterSetByMask(char aAddress[], char aMask[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  char chT32Cmd[128] = "";
  char chT32Cmd1[128]= "";
  char chT32Cmd2[128]= "";
  char chT32Cmd3[128]= "";
  char chT32Cmd4[128]= "";
  
  bDebugFlag = NotOk;
  bResultAction = NotOk;
  snprintf(chT32Cmd1, elcount(chT32Cmd1), "\"PER.Set.simple %s %%", aAddress);
  snprintf(chT32Cmd2, elcount(chT32Cmd2), "Long (d.l(%s)", aAddress);
  snprintf(chT32Cmd3, elcount(chT32Cmd3), "&~%s)", aMask);
  snprintf(chT32Cmd4, elcount(chT32Cmd4), "|%s\"", aMask);
  strncat(chT32Cmd1, chT32Cmd2, elcount(chT32Cmd));
  strncat(chT32Cmd1, chT32Cmd3, elcount(chT32Cmd));
  strncat(chT32Cmd1, chT32Cmd4, elcount(chT32Cmd));
  strncpy(chT32Cmd, chT32Cmd1, elcount(chT32Cmd));
  
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RegisterSetByMask() entered.");
  
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Set a value of a specific mask: '%s' from register by address: '%s'.", aMask, aAddress);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Register with address: %s was set to value: 0x%s.", aAddress, aMask);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
  // No post-write wait: ECU remains halted after PER.Set.simple mask operation.
}

/// <REGISTER>
/*! void A_DBGR_RegisterRead(char aAddress[], int64 &aRegisterValue)
*  \brief Function that read the value of a register by address in TRACE32.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[out] aRegisterValue - the value of the register
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 08.09.20              CrJu         Refactoring the code.
* 28.04.22              GaMo         Updated the strncat part to save the entire value of the register.
* 20.05.22              AnPa         Updated to use low level function
*/
void A_DBGR_RegisterRead(char aAddress[], int64 &aRegisterValue)
{
  long lApiExitCode[1];
  byte bResultAction;
  char chFailText[250];
  char chAction[250];
  char chMappedResponse[256];
 
  bResultAction = NotOk;

  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RegisterRead() entered.");
  
  //Print the action text to the report
  snprintf(chAction, elcount(chAction), "Read register value from address: %s.", aAddress);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    if (lFctn_T32_ReadRegister_AddressValue(aAddress, aRegisterValue, chMappedResponse) == 0)
      vFctn_REPORTActionEvaluation(chMappedResponse, PASS);
    else // API Command Fail
      vFctn_REPORTActionEvaluation(chMappedResponse, FAIL);
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <REGISTER>
/*! void E_DBGR_RegisterReadCheck(char aAddress[], char aValueToCompare[])
*  \brief Function that read & check the value of a register by address.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[in] aValueToCompare - the expected value of the register
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 07.09.20              CrJu         Refactoring the code.
*/
void E_DBGR_RegisterCheck(char aAddress[], char aValueToCompare[])
{
  byte bDebugFlag;
  long lCompareValue;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  char chPassText[250];
  char chFailText[250];

  bDebugFlag = NotOk;
  snprintf(chT32Cmd, elcount(chT32Cmd),  "\"EVAL data.long(%s)==%s\"", aAddress, aValueToCompare);
 
  writeDbgLevel(DebugFuncCalls , "Function E_DBGR_RegisterCheck() entered.");
  
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

  if (lApiExitCode[0] == 0)
  {
    lCompareValue = atol(chApiMessage); 
    
    if(lCompareValue)
    {
      snprintf(chPassText, elcount(chPassText), "Register with address: %s has the expected value: %s", aAddress, aValueToCompare);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTStepEvaluation(chPassText, PASS);
    }
    else 
    {
      snprintf(chFailText, elcount(chFailText), "Register with address: %s was read his value is DIFFERENT from expected value: %s", aAddress, aValueToCompare);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
  else // API Command Fail
  {
    snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/// <REGISTER>
/*! \fn void E_DBGR_RegisterCheckBitStatus(char aAddress[], int aBit_Number, enum eBitStatus aBitStatus)
*  \brief Function that will check the status of a specific bit number of a specific address
*  \param[in]  char aAddress[]            - address from where the register value is read
*  \param[in]  byte aBit_Number            - the bit number to be verified. (bit numbers start from 0, e.g. to verify the Port2 Pin7 the aBit_Number param should be 8 )
*                                                                                                    (e.g. to verify bit 0 of an address the aBit_Number param should be 1)
*  \param[in]  enum eBitStatus aBitStatus -   BitStatus_NotSet = 0 
*                                             BitStatus_Set = 1
* Change History: 
* Date(DD.MM.YY)        Author              Change info                                                          
* 20.05.22               AnPa            Created and implemented
*/
void E_DBGR_RegisterCheckBitStatus(char aAddress[], byte aBit_Number, enum eBitStatus aBitStatus)
{
  int iRet_val;
  char chMappedResponseInfo[256];
  
  writeDbgLevel (DebugFuncCalls , "Function E_DBGR_RegisterCheckBitStatus() called.");
  
  iRet_val = lFctn_T32_Register_Check_Bit_Status( aAddress, aBit_Number, aBitStatus,chMappedResponseInfo);

  if(iRet_val == Ok)    
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, PASS); 
  else
    vFctn_REPORTStepEvaluation(chMappedResponseInfo, FAIL);  
}


/**
 * Helper function to poll for STATE.RUN()==FALSE() with timeout
 * Returns 1 if not running, 0 if still running after timeout
 * Poll interval is 250 ms (reduced from 500 ms) to detect halt state faster.
 * Each failed iteration advances elapsed by pollInterval only (avoids double-counting
 * apiWait on top of pollInterval, which previously caused premature timeout expiry).
 */
long waitForNotRunning(long timeoutMs)
{
  long elapsed;
  long pollInterval;
  int apiWait = 60;

  pollInterval = 250;
  elapsed = 0;

  while (elapsed < timeoutMs)
  {
    if (!isRunning())
      return 1; // Not running

    testWaitForTimeoutSilent(pollInterval - apiWait);
    elapsed += pollInterval; // one full poll interval per iteration
  }
  return 0; // Timed out, still running
}

long waitForRunning(long timeoutMs)
{
  long elapsed;
  long pollInterval;
  int apiWait = 60;

  pollInterval = 100;
  elapsed = 0;

  while (elapsed < timeoutMs)
  {
    if (isRunning())
      return 1; // Running

    testWaitForTimeoutSilent(pollInterval - apiWait);
    elapsed += pollInterval; // one full poll interval per iteration
  }
  return 0; // Timed out, still not running
}

long isRunning()
{
  long lApiExitCode[1];
  char chApiMessage[128];
  char chT32Cmd[32] =  "\"EVAL STATE.RUN()==TRUE()\"";
  long result;

  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  return atol(chApiMessage);
}

/// <GENERIC>
/*! void readPPRegister(char aResult[])
*  \brief Function that reads the PP (Program Pointer) register value.
*
*  \param[out] aResult - the PP register value as a string
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 31.01.26              Copilot         Created function to support A_DBGR_Go_Safe reset detection.
*/
void readPPRegister(char aResult[])
{
  long lApiExitCode[1];
  char chApiMessage[128];
  char chT32Cmd[32] = "\"PRINT Register(PP)\"";

  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  strncpy(aResult, chApiMessage, elcount(aResult));
}

/// <GENERIC>
/*! void E_DBGR_CheckCmmScriptResult(char aScript[], char aCore[], long aTimeOut, char aParams[])
*  \brief Runs a CMM script via lFctn_G_T32_RUN_CMM_CORE() and records the result as a
*         PASS or FAIL step in the CANoe test report. This guarantees that every CMM
*         script invocation is consistently captured in the report, making it straightforward
*         to verify reporting accuracy across all 20 benches.
*
*  \param[in] aScript   - CMM script filename (relative to the Cmm_Commands folder)
*  \param[in] aCore     - Target core identifier (e.g., "0", "1")
*  \param[in] aTimeOut  - Maximum wait time in ms for the CMM script to complete
*  \param[in] aParams   - Parameters to pass to the CMM script (use "" for none)
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 04.03.26              Copilot         Created for CMM script reporting consistency check.
*/
void E_DBGR_CheckCmmScriptResult(char aScript[], char aCore[], long aTimeOut, char aParams[])
{
  long lResult;
  char chPassText[250];
  char chFailText[250];
  byte bDebugFlag;

  bDebugFlag = NotOk;
  writeDbgLevel(DebugFuncCalls, "Function E_DBGR_CheckCmmScriptResult() entered.");

  lResult = lFctn_G_T32_RUN_CMM_CORE(aScript, aCore, aTimeOut, aParams);

  if (lResult == Ok)
  {
    snprintf(chPassText, elcount(chPassText), "CMM script '%s' completed successfully.", aScript);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else if (lResult == NotOk)
  {
    snprintf(chFailText, elcount(chFailText), "CMM script '%s' did not complete within timeout (%ld ms).", aScript, aTimeOut);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
  else if (lResult == Error)
  {
    snprintf(chFailText, elcount(chFailText), "CMM script '%s' could not be started. Check path and T32 connection.", aScript);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
  else if (lResult == -2)
  {
    snprintf(chFailText, elcount(chFailText), "CMM script '%s' exited with an unexpected exit code.", aScript);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
  else if (lResult == -999)
  {
    snprintf(chFailText, elcount(chFailText), "CMM script '%s' aborted: measurement ended before script completed.", aScript);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
  else
  {
    snprintf(chFailText, elcount(chFailText), "CMM script '%s' returned unexpected result: %ld.", aScript, lResult);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

