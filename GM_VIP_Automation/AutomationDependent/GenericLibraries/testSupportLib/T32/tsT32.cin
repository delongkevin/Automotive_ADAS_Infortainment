/// <GENERIC>
/*! void A_DBGR_R()
*  \brief Function that reset the ECU without reloading symbols
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 16.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_R()
{
  long lResult;
  char chCommand[1024];
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  long lEvaluationResult;
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  long lApiExitCode[1];
  byte bResultAction;
  byte bDebugFlag;
  
  // initial values
  lResult = Error;
  bResultAction = NotOk;
  bDebugFlag = NotOk;
  lEvaluationResult = Error;
  
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_R() entered.");
  
  snprintf(chT32Cmd, elcount(chT32Cmd),"\"SYStem.RESetTarget\"");
  lResult = lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  // Brief wait to allow SYStem.RESetTarget to complete the target reset transition.
  // After reset the ECU briefly passes through Down state (0) before reaching Halted/Stopped.
  // isRunning() checks STATE.RUN()==TRUE(), so both Down and Halted satisfy "not running".
  // This wait ensures the state machine has advanced past any transient Running phase.
  testWaitForTimeoutSilent(250);

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Send the 'R' command to T32.");
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  { 
    if ((lResult==Ok)||(lResult==NotOk))
    {

      if ((waitForNotRunning(cc_dwT32_MaxTimeout)) && (NotOk != lFctn_G_T32_GET_STATE())) // condition evaluation has returned: True
      {
        snprintf(chPassText, elcount(chPassText), "The ECU has been reseted.");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command R !!!");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command R !!!");
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Error: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void A_DBGR_RnGo()
*  \brief Function that reset the ECU without reloading symbols, deletes all the BPs & put the ECU in running mode.
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 16.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_RnGo()
{
  long lResult;
  char chCommand[1024];
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  long lEvaluationResult;
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  long lApiExitCode[1];
  byte bResultAction;
  byte bDebugFlag;
  
  // initial values
  lResult = Error;
  bResultAction = NotOk;
  bDebugFlag = NotOk;
  lEvaluationResult = Error;
  
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RnGo() entered.");


  A_DBGR_R();
  A_DBGR_Go();

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Send the 'RnGO' command to T32.");
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  { 
    if ((lResult==Ok)||(lResult==NotOk))
    {
      lEvaluationResult = isRunning();

      if (lEvaluationResult) // condition evaluation has returned: True 
      {
        snprintf(chPassText, elcount(chPassText), "The ECU has been reseted and now is in Running.");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTActionEvaluation(chPassText, PASS);
      }
      else
      {
        snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command RnGO !!!");
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTActionEvaluation(chFailText, FAIL);
      }
    }
    else
    {
      snprintf(chFailText, elcount(chFailText), "API is missing or couldn't be executed for command RnGO !!!");
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "Error: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void  A_DBGR_RunCommand(char aCommand[])
*  \brief Function that RUN practice command line.
* 
*  \param[in] aCommand - the command to run
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 10.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_RunCommand(char aCommand[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  char chT32Cmd[128] = "";
 
  bDebugFlag = NotOk;
  bResultAction = NotOk;
  snprintf(chT32Cmd, elcount(chT32Cmd), "\"%s\"", aCommand);
 
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_RunCommand() entered.");
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Run practice cmm line: '%s'.", aCommand);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Command '%s' was succesfully executed.", aCommand);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void E_DBGR_CheckState(char aAddress[])
*  \brief Function to verify current T32 state
*  \param[in]   aT32State      - Expected T32 State (Values : T32_State_Down, ..., T32_State_Running --> See eT32State)
*  \return None
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
* 03.11.21              AnPu            Created and implemented
* 24.11.21				      AnPu			      Implement remarks after review
*/
void E_DBGR_CheckState(enum eT32State aT32State)
{
  long lState;
  char chPassText[250];
  char chFailText[250];
  byte bDebugFlag;
  
  bDebugFlag = NotOk;
  lState = Error;
  
  writeDbgLevel (DebugFuncCalls , "Function E_DBGR_CheckState() called.");
  lState = lFctn_G_T32_GET_STATE(msgInfo);
  if (lState == aT32State)
    {
      snprintf(chPassText, elcount(chPassText),  msgInfo);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTStepEvaluation(chPassText, PASS);
    }
    else{
      snprintf(chFailText, elcount(chFailText),  msgInfo);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }

  
  if((byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel (DebugFuncInternal, msgInfo);
}

/// <GENERIC>
/*! void E_DBGR_CheckConnection()
*  \brief Verifies that the Lauterbach Trace32 debugger is connected to the ECU.
*         T32 is considered connected when its state is Halted (1), Stopped (2),
*         or Running (3). A Down (0) or Error (-1) state indicates the debugger is
*         not attached. Use at bench startup to confirm hardware is ready before
*         running tests.
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 04.03.26              Copilot         Created for bench pre-deployment consistency check.
*/
void E_DBGR_CheckConnection()
{
  long lState;
  char chPassText[250];
  char chFailText[250];
  byte bDebugFlag;

  bDebugFlag = NotOk;
  writeDbgLevel(DebugFuncCalls, "Function E_DBGR_CheckConnection() entered.");

  lState = lFctn_G_T32_GET_STATE(msgInfo);

  if (lState == T32_State_Halted || lState == T32_State_Stopped || lState == T32_State_Running)
  {
    snprintf(chPassText, elcount(chPassText), "Lauterbach debugger connected. %s", msgInfo);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
    vFctn_REPORTStepEvaluation(chPassText, PASS);
  }
  else
  {
    snprintf(chFailText, elcount(chFailText), "Lauterbach debugger NOT connected (T32 state: %ld). %s Check hardware connection and T32 startup.", lState, msgInfo);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/// <GENERIC>
/*! void A_DBGR_EnsureT32Running_AutoDetect()
*  \brief Zero-argument variant of A_DBGR_EnsureT32Running() that automatically
*         discovers the Trace32 installation without requiring the caller to
*         hard-code any paths.
*
*         Algorithm:
*           1. Searches standard installation directories for a config.t32 and
*              a matching T32 executable via lFctn_T32_AutoDetect().  Directories
*              searched (in order): C:\T32\bin, C:\T32, C:\t32\bin, C:\t32.
*           2. Parses the NETASSIST PORT= value from the found config.t32 using
*              lFctn_T32_ParseConfigPort() and rewrites t32.ini with the correct
*              port via vFctn_T32_SyncT32ini() so that every T32_API.exe call
*              connects to the right socket without any API errors.
*           3. Delegates to A_DBGR_EnsureT32Running(exePath, configPath) which
*              checks the T32 state and launches Trace32 if it is not yet running.
*
*         Call this function at the start of a testcase or in a testcase setup
*         block when the T32 installation path is unknown or may vary between
*         test benches.
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 15.03.26              Copilot         Created â€“ zero-arg wrapper using lFctn_T32_AutoDetect().
*/
export testfunction A_DBGR_EnsureT32Running_AutoDetect()
{
  char chFoundExePath[256];
  char chFoundConfigPath[256];
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  long lDetectResult;
  long lPort;
  byte bResultAction;
  byte bDebugFlag;

  bDebugFlag = NotOk;
  writeDbgLevel(DebugFuncCalls, "Function A_DBGR_EnsureT32Running_AutoDetect() entered.");

  // Step 1: report the auto-detect action.
  snprintf(chAction, elcount(chAction), "Auto-detect Trace32 installation and synchronize t32.ini.");
  bResultAction = bFctn_REPORTAction(chAction);

  if (!bResultAction)
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "ERROR: %s.", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
    return;
  }

  // Step 2: search for a T32 installation.
  lDetectResult = lFctn_T32_AutoDetect(chFoundExePath, chFoundConfigPath);

  if (lDetectResult != Ok)
  {
    snprintf(chFailText, elcount(chFailText),
             "Trace32 installation not found. "
             "Checked: C:\\T32\\bin, C:\\T32, C:\\t32\\bin, C:\\t32. "
             "Verify that Trace32 is installed and config.t32 is present.");
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
    return;
  }

  write("A_DBGR_EnsureT32Running_AutoDetect: found exe='%s', config='%s'.",
        chFoundExePath, chFoundConfigPath);

  // Step 3: parse PORT= from config.t32 and sync t32.ini so T32_API.exe
  // uses the correct NETASSIST port (prevents API connection errors).
  lPort = lFctn_T32_ParseConfigPort(chFoundConfigPath);
  if (lPort > 0)
  {
    write("A_DBGR_EnsureT32Running_AutoDetect: config.t32 PORT=%d. Updating t32.ini.", lPort);
    vFctn_T32_SyncT32ini(lPort);
    snprintf(chPassText, elcount(chPassText),
             "Trace32 installation detected at '%s'. t32.ini synchronized with PORT=%d.",
             chFoundConfigPath, lPort);
  }
  else
  {
    write("A_DBGR_EnsureT32Running_AutoDetect: PORT not found in config.t32 â€“ t32.ini not updated.");
    snprintf(chPassText, elcount(chPassText),
             "Trace32 installation detected at '%s'. PORT not in config.t32; t32.ini unchanged.",
             chFoundConfigPath);
  }

  vFctn_REPORTActionEvaluation(chPassText, PASS);

  // Step 4: delegate to A_DBGR_EnsureT32Running which checks the T32 state
  // and launches Trace32 if it is not yet running.
  A_DBGR_EnsureT32Running(chFoundExePath, chFoundConfigPath);
}


/// <GENERIC>
/*! void A_DBGR_EnsureT32Running(char aT32ExePath[], char aT32ConfigFile[])
*  \brief Ensures that Trace32 is connected before running test cases.
*         Checks the current T32 state.  If the state is Down (0) or Error (-1)
*         (i.e. T32 is not running / not connected), it automatically launches T32
*         using lFctn_T32_Launch() and reports the result as a test step.
*         If T32 is already connected the step is reported as PASS immediately.
*
*         Call this function at the start of a testcase or in a testcase setup
*         block to guarantee that T32 is available before issuing any debugger
*         commands.
*
*  \param[in] aT32ExePath    - Full path to the Trace32 executable
*                              (e.g. "C:\\T32\\t32marm.exe").
*  \param[in] aT32ConfigFile - Full path to the T32 configuration file
*                              (e.g. "C:\\T32\\config.t32").
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 10.03.26              Copilot         Created â€“ auto-starts T32 when not connected.
*/
export testfunction A_DBGR_EnsureT32Running(char aT32ExePath[], char aT32ConfigFile[])
{
  long lState;
  long lLaunchResult;
  char chAction[250];
  char chPassText[250];
  char chFailText[250];
  byte bResultAction;
  byte bDebugFlag;

  bDebugFlag = NotOk;
  writeDbgLevel(DebugFuncCalls, "Function A_DBGR_EnsureT32Running() entered.");

  // Add the action to the report before any evaluation call.
  snprintf(chAction, elcount(chAction), "Ensure Trace32 is connected and running.");
  bResultAction = bFctn_REPORTAction(chAction);

  if (!bResultAction)
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "ERROR: %s.", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
    return;
  }

  lState = lFctn_G_T32_GET_STATE(msgInfo);

  if (lState == T32_State_Halted || lState == T32_State_Stopped || lState == T32_State_Running)
  {
    snprintf(chPassText, elcount(chPassText), "Trace32 already connected (state=%ld). %s", lState, msgInfo);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
    vFctn_REPORTActionEvaluation(chPassText, PASS);
    return;
  }

  // T32 is down or unreachable â€“ try to launch it.
  write("A_DBGR_EnsureT32Running: T32 state=%ld. Attempting to launch '%s'...", lState, aT32ExePath);
  lLaunchResult = lFctn_T32_Launch(aT32ExePath, aT32ConfigFile);

  if (lLaunchResult == Ok)
  {
    snprintf(chPassText, elcount(chPassText), "Trace32 launched and connected successfully.");
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
    vFctn_REPORTActionEvaluation(chPassText, PASS);
  }
  else
  {
    snprintf(chFailText, elcount(chFailText),
             "Trace32 could not be launched or did not connect within %d ms. "
             "Verify the exe path ('%s') and config file ('%s').",
             cc_dwT32_LaunchTimeout, aT32ExePath, aT32ConfigFile);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}


/// <BREAKPOINTS>
/*! void  A_DBGR_BreakpointSet(char aAddress[])
*  \brief Function that SET a specific BP.
*         Retries up to cc_nT32_BPSetMaxRetries times with cc_dwT32_BPSetRetryInterval ms
*         delay to handle the case where Trace32 symbol tables are still being resolved
*         after a load.  The module variable sv_T32_LastBreakpointSetOk is set to Ok on
*         success and NotOk on failure so callers can react without changing the return type.
*
*         If all retries up to cc_nT32_BPSetSymbolReloadAt fail, the function issues a
*         SYMBOL.RELOAD command (equivalent to the manual "Reload Symbols" action in the
*         T32 IDE) and waits cc_dwT32_SymbolReloadWait ms before continuing to retry.
*         This eliminates false "symbol not found" failures caused by transient delays
*         in ELF symbol table resolution that occur during unattended automation runs.
* 
*  \param[in] aAddress - name of the BP ("Symbol")
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 31.08.20              CrJu         Refactoring the code.
* 10.03.26              Copilot      Added retry loop and sv_T32_LastBreakpointSetOk status.
* 10.03.26              Copilot      Added SYMBOL.RELOAD on mid-retry to recover from slow symbol loading.
*/
export testfunction A_DBGR_BreakpointSet(char aAddress[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  char chT32Cmd[128] = "";
  // Outer double-quotes are required by T32_API.exe to pass the command as a
  // single argument (consistent with all other chT32Cmd strings in this module).
  char chReloadCmd[32] = "\"SYMBOL.RELOAD\"";
  int  nAttempt;
  int  bSymbolReloadDone;
  // Runtime-clamped reload threshold: guards against misconfiguration where
  // cc_nT32_BPSetSymbolReloadAt >= cc_nT32_BPSetMaxRetries (which would silently
  // disable the reload path).  The effective value is always strictly less than
  // cc_nT32_BPSetMaxRetries so at least one retry occurs after SYMBOL.RELOAD.
  int  nEffectiveReloadAt;

  bDebugFlag = NotOk;
  bResultAction = NotOk;
  bSymbolReloadDone = 0;
  sv_T32_LastBreakpointSetOk = NotOk; // pessimistic default

  // Clamp the reload threshold to ensure the invariant: nEffectiveReloadAt < cc_nT32_BPSetMaxRetries.
  if (cc_nT32_BPSetSymbolReloadAt < cc_nT32_BPSetMaxRetries)
    nEffectiveReloadAt = cc_nT32_BPSetSymbolReloadAt;
  else
  {
    nEffectiveReloadAt = cc_nT32_BPSetMaxRetries - 1;
    write("A_DBGR_BreakpointSet: WARNING â€“ cc_nT32_BPSetSymbolReloadAt (%d) >= cc_nT32_BPSetMaxRetries (%d). "
          "Clamping reload threshold to %d.",
          cc_nT32_BPSetSymbolReloadAt, cc_nT32_BPSetMaxRetries, nEffectiveReloadAt);
  }

  writeDbgLevel(DebugFuncCalls, "Function A_DBGR_BreakpointSet() entered.");

  //Print the action text to the report once, before the retry loop.
  snprintf(chAction, elcount(chAction), "Set a specific BreakPoint: %s.", aAddress);
  bResultAction = bFctn_REPORTAction(chAction);

  if (!bResultAction)
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if ((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel(DebugFuncInternal, "ERROR: %s.", chFailText);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
    return;
  }

  snprintf(chT32Cmd, elcount(chT32Cmd), "\"BREAK.SET %s\"", aAddress);

  // Retry loop: T32 symbol tables may still be loading right after a DO/load script.
  // After cc_nT32_BPSetSymbolReloadAt failures a SYMBOL.RELOAD is issued to trigger
  // T32 to re-process the ELF symbol database (the same action as the manual
  // "Reload Symbols" in the T32 IDE).  Retries continue for the remaining attempts.
  for (nAttempt = 1; nAttempt <= cc_nT32_BPSetMaxRetries; nAttempt++)
  {
    // Trigger SYMBOL.RELOAD once, after nEffectiveReloadAt failed attempts,
    // to recover from slow ELF symbol table loading.
    if (!bSymbolReloadDone && nAttempt > nEffectiveReloadAt)
    {
      write("A_DBGR_BreakpointSet: BREAK.SET still failing after %d attempts for '%s' (last error: %s). Issuing SYMBOL.RELOAD and waiting %d ms...",
            nEffectiveReloadAt, aAddress, chApiMessage, cc_dwT32_SymbolReloadWait);
      lFctn_CallT32API(chReloadCmd, chApiMessage, lApiExitCode);
      if (lApiExitCode[0] != 0)
      {
        write("A_DBGR_BreakpointSet: SYMBOL.RELOAD failed for '%s' (exit=%ld, msg='%s').",
              aAddress, lApiExitCode[0], chApiMessage);
      }
      testWaitForTimeoutSilent(cc_dwT32_SymbolReloadWait);
      bSymbolReloadDone = 1;
    }

    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Breakpoint '%s' set (attempt %d/%d).", aAddress, nAttempt, cc_nT32_BPSetMaxRetries);
      if ((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel(DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
      sv_T32_LastBreakpointSetOk = Ok;
      return; // success â€“ no further retries needed
    }

    // Failed on this attempt
    if (nAttempt < cc_nT32_BPSetMaxRetries)
    {
      write("A_DBGR_BreakpointSet: attempt %d/%d failed for '%s' (%s). Retrying in %d ms...",
            nAttempt, cc_nT32_BPSetMaxRetries, aAddress, chApiMessage, cc_dwT32_BPSetRetryInterval);
      testWaitForTimeoutSilent(cc_dwT32_BPSetRetryInterval);
    }
  }

  // All retries exhausted
  snprintf(chFailText, elcount(chFailText), "BREAK.SET '%s' failed after %d attempt(s). Last error: %s",
           aAddress, cc_nT32_BPSetMaxRetries, chApiMessage);
  if ((byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel(DebugFuncInternal, "FAIL: %s.", chFailText);
  vFctn_REPORTActionEvaluation(chFailText, FAIL);
  sv_T32_LastBreakpointSetOk = NotOk;
  // No wait needed: BREAK.SET does not change ECU run state.
}

/// <BREAKPOINTS>
/*! void A_DBGR_BreakpointSet_AbortOnFail(char aAddress[])
*  \brief Convenience wrapper around A_DBGR_BreakpointSet() that aborts the current
*         test case immediately when the symbol cannot be found after all retries.
*         Use this instead of A_DBGR_BreakpointSet() in test cases where there is
*         no point continuing execution (GO / waitForNotRunning / CheckForHalt) if
*         the breakpoint was never placed.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*
*  \return no return (test case is aborted on failure)
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 10.03.26              Copilot         Created.
*/
export testfunction A_DBGR_BreakpointSet_AbortOnFail(char aAddress[])
{
  char chAbortMsg[512];

  A_DBGR_BreakpointSet(aAddress);

  if (sv_T32_LastBreakpointSetOk != Ok)
  {
    snprintf(chAbortMsg, elcount(chAbortMsg),
             "Symbol '%s' not found in T32 after %d attempt(s) â€“ aborting test case to avoid 20-second GO timeout.",
             aAddress, cc_nT32_BPSetMaxRetries);
    write("ABORT: %s", chAbortMsg);
    testCaseFail();
  }
}

/// <BREAKPOINTS>
/*! void  A_DBGR_BreakpointWrite(char aAddress[])
*  \brief Function that SET a specific BP to write.
* 
*  \param[in] aAddress - name of the BP ("Symbol")
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 10.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_BreakpointWrite(char aAddress[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];
  char chT32Cmd[128] = "";
 
  bDebugFlag = NotOk;
  bResultAction = NotOk;
  snprintf(chT32Cmd, elcount(chT32Cmd),  "\"VAR.BREAK.SET %s /W\"", aAddress);
 
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_BreakpointWrite() entered.");
  
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Set a specific BreakPoint: %s to write.", aAddress);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Breakpoint write access at adress: %s is set.", aAddress);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
  // No wait needed: VAR.BREAK.SET does not change ECU run state.
}

