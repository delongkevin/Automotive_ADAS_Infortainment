/// <BREAKPOINTS>
/*! void E_DBGR_BreakpointCheckForHalt(char aAddress[])
*  \brief Function that verify if a specific BP is halted.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 09.09.20              CrJu         Refactoring the code.
*/
void E_DBGR_BreakpointCheckForHalt(char aAddress[])
{
  byte bDebugFlag;
  long lEvaluationResult;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[500] = "";
  char chPassText[500];
  char chFailText[500];

  bDebugFlag = NotOk;
  writeDbgLevel(DebugFuncCalls , "Function E_DBGR_BreakpointCheckForHalt() entered.");

  // Poll for not running with timeout
  if ( waitForNotRunning(cc_dwT32_BP_HaltTimeout))
  {
    snprintf(chT32Cmd, elcount(chT32Cmd),"\"EVAL (P:R(PC)==%s)\"", aAddress);
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
    
    if (lApiExitCode[0] == 0)
    {
      snprintf(chT32Cmd, elcount(chT32Cmd),  "\"PRINT EVAL()\"");
      lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
      lEvaluationResult = atol(chApiMessage);
      if(lEvaluationResult)
      {
        snprintf(chPassText, elcount(chPassText), "Breakpoint at: %s was reached.", aAddress);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTStepEvaluation(chPassText, PASS);
      }
      else 
      {
        snprintf(chFailText, elcount(chFailText), "Breakpoint at: %s was NOT reached. API error message: %s", aAddress, chApiMessage);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTStepEvaluation(chFailText, FAIL);
      }
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
  else 
  {
    snprintf(chFailText, elcount(chFailText), "Timeout: ECU did not halt (STATE.RUN()!=FALSE) within %d ms.", cc_dwT32_BP_HaltTimeout);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/// <BREAKPOINTS>
/*! void E_DBGR_BreakpointCheckForHaltCore(char aAddress[], char aCore[])
*  \brief Function that verify if a specific BP is halted on a specific core.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[in] aCore - the core where BP should be
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 09.09.20              CrJu         Refactoring the code.
*/
void E_DBGR_BreakpointCheckForHaltCore(char aAddress[], char aCore[])
{
  byte bDebugFlag;
  long lEvaluationResult;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  char chPassText[250];
  char chFailText[250];

  bDebugFlag = NotOk;
  if( waitForNotRunning(cc_dwT32_BP_HaltTimeout))
  {
    snprintf(chT32Cmd, elcount(chT32Cmd),"\"EVAL P:R(PC)==%s&&CORE()==%s\"", aAddress, aCore);
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
    
    if (lApiExitCode[0] == 0)
    {
      snprintf(chT32Cmd, elcount(chT32Cmd),  "\"PRINT EVAL()\"");
      lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
      lEvaluationResult = atol(chApiMessage);
      if(lEvaluationResult)
      {
        snprintf(chPassText, elcount(chPassText), "Breakpoint at: %s was reached.", aAddress);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
        vFctn_REPORTStepEvaluation(chPassText, PASS);
      }
      else 
      {
        snprintf(chFailText, elcount(chFailText), "Breakpoint at: %s was NOT reached. API error message: %s", aAddress, chApiMessage);
        if((byte)DebugFuncInternal & bDebugFlag)
          writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
        vFctn_REPORTStepEvaluation(chFailText, FAIL);
      }
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
  else 
  {
    snprintf(chFailText, elcount(chFailText), "Timeout: ECU did not halt (STATE.RUN()!=FALSE) within %d ms.", cc_dwT32_BP_HaltTimeout);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/// <VARIABLE>
/*! void A_DBGR_VariableSet(char aAddress[], char aValue[])
*  \brief Function that set a value of a variable in TRACE32.
*
*  \param[in] aAddress - name of the variable
*  \param[in] aValue - the value to set
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 07.09.20              CrJu         Refactoring the code.
*/
void A_DBGR_VariableSet(char aAddress[], char aValue[])
{
  long lApiExitCode[1];
  char chApiMessage[512];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[500];
  char chT32Cmd[500] = "";

  // ECU must be halted for VAR.SET; wait up to cc_dwT32_MaxTimeout.
  waitForNotRunning(cc_dwT32_MaxTimeout);

  bDebugFlag = NotOk;
  bResultAction = NotOk;
  snprintf(chT32Cmd, elcount(chT32Cmd), "\"VAR.SET %s=%s\"", aAddress, aValue);

  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_VariableSet() entered.");

  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Set value: %s to register: %s.", aValue, aAddress);
  bResultAction = bFctn_REPORTAction(chAction);

  if(bResultAction)
  {
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Variable '%s' was successfully set with value: '%s'", aAddress, aValue);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
  // No post-write wait: ECU remains halted after VAR.SET.
}

/// <VARIABLE>
/*! void  A_DBGR_VariableRead( char aAddress[], long& aVarValue)
*  \brief Function that read the value of a variable.
*
*  \param[in] aAddress - name of the variable
*  \param[out] aVarValue - value of the variable
*
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
* 09.09.20              CrJu         Refactoring the code.
* 15.11.21              AnPu         Update function
*/
void  A_DBGR_VariableRead( char aAddress[], long& aVarValue)
{
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[128];
  byte bResultAction;
  byte bDebugFlag;
  char chPassText[250];
  char chFailText[250];
  char chAction[250];

  bDebugFlag = NotOk;
  bResultAction = NotOk;

  // ECU must be halted for var.PRINT; wait up to cc_dwT32_MaxTimeout.
  waitForNotRunning(cc_dwT32_MaxTimeout);

  snprintf(chT32Cmd, elcount(chT32Cmd),"\"var.PRINT %s\"", aAddress);
  writeDbgLevel (DebugFuncCalls , "Function A_DBGR_VariableRead() entered.");
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  
  //Print the action text to the raport
  snprintf(chAction, elcount(chAction), "Read the value of variable: %s.", aAddress);
  bResultAction = bFctn_REPORTAction(chAction);
  
  if(bResultAction)
  {
    if (lApiExitCode[0] == 0)
    {
      snprintf(chPassText, elcount(chPassText), "Variable value is: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      aVarValue=atol(chApiMessage);
      vFctn_REPORTActionEvaluation(chPassText, PASS);
    }
    else // API Command Fail
    {
      snprintf(chFailText, elcount(chFailText), "ECU is NOT running!.\nAPI error message: %s", chApiMessage);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      aVarValue = -9999;
      vFctn_REPORTActionEvaluation(chFailText, FAIL);
    }
  }
  else//The reporting function has failed
  {
    snprintf(chFailText, elcount(chFailText), "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "ERROR: The action text could not be added in the Report. bFctn_REPORTAction() return: %d.", bResultAction);
    aVarValue = -9999;
    vFctn_REPORTActionEvaluation(chFailText, FAIL);
  }
}

/// <VARIABLE>
/*! void E_DBGR_VariableReadCheck(char aAddress[], long aValueToCompare, enum eCompareType aCompareType)
*  \brief Function that read the value at address & compares it with expected value.
*
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[in] aValueToCompare - the expected value of the register
*  \param[in] aCompareType - compare type (e.q. equal, not equal, greatter, smaller)
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 08.09.20              CrJu         Refactoring the code.
* 17.11.21              AnPu         Update function
* 27.02.25              SeSu         Update function
*/
void E_DBGR_VariableCheck(char aAddress[], long aValueToCompare, enum eCompareType aCompareType)
{
  byte bDebugFlag;
  long lReadValue;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[500] = "";
  char chPassText[500];
  char chFailText[500];

  bDebugFlag = cc_bT32_GlobalDebugFlag;

  // ECU must be halted for var.value read; wait up to cc_dwT32_MaxTimeout.
  waitForNotRunning(cc_dwT32_MaxTimeout);

  writeDbgLevel(DebugFuncCalls , "Function E_DBGR_VariableCheck() entered.");
  
  snprintf(chT32Cmd, elcount(chT32Cmd),  "\"print var.value(%s)*1.\"", aAddress);
  writeDbgLevel (DebugFuncInternal, "Calling function lFctn_CallT32API.");
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

  if (lApiExitCode[0] == 0)
  {
    if ( (byte)DebugFuncParam & bDebugFlag )
        writeDbgLevel (DebugFuncParam, "Parameters: char aAddress[]: -- %s --, long aValueToCompare: -- %d --,  enum eCompareType aCompareType: -- %d -- (Equal = 0, NotEqual = 1, Greater = 2, Smaller = 3).", aAddress, aValueToCompare, aCompareType);
    
    lReadValue = atol(chApiMessage); 
    switch(aCompareType){
      case Equal:
        if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Case Equal: Variable aAddress -- %s -- has value lReadValue: -- %d --, compare value: aValueToCompare: -- %d --.", aAddress, lReadValue, aValueToCompare);
        
        if(lReadValue == aValueToCompare)
        {
          snprintf(chPassText, elcount(chPassText), "Variable %s has the expected value: %d", aAddress, lReadValue);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected passed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chPassText, PASS);
        }
        else 
        {
          snprintf(chFailText, elcount(chFailText), "Variable %s has the value: %d, DIFFERENT than expected: %d.", aAddress, lReadValue, aValueToCompare);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected failed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chFailText, FAIL);
        }
        break;
      case NotEqual:
        if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Case NotEqual: Variable aAddress -- %s -- has value lReadValue: -- %d --, compare value: aValueToCompare: -- %d --.", aAddress, lReadValue, aValueToCompare);
        
        if(lReadValue != aValueToCompare)
        {
          snprintf(chPassText, elcount(chPassText), "Variable %s is different than expected value: %d", aAddress, lReadValue);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected passed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chPassText, PASS);
        }
        else 
        {
          snprintf(chFailText, elcount(chFailText), "Variable %s has the value: %d, EQUAL to: %d.", aAddress, lReadValue, aValueToCompare);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected failed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chFailText, FAIL);
        }
        break;
       case Greater:
        if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Case Greater: Variable aAddress -- %s -- has value lReadValue: -- %d --, compare value: aValueToCompare: -- %d --.", aAddress, lReadValue, aValueToCompare);
        
        if(lReadValue > aValueToCompare)
        {
          snprintf(chPassText, elcount(chPassText), "Variable %s is Greater then expected value: %d", aAddress, lReadValue);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected passed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chPassText, PASS);
        }
        else 
        {
          snprintf(chFailText, elcount(chFailText), "Variable %s has the value: %d, smaller or equal with: %d.", aAddress, lReadValue, aValueToCompare);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected failed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chFailText, FAIL);
        }
        break;
       case Smaller:
        if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Case Smaller: Variable aAddress -- %s -- has value lReadValue: -- %d --, compare value: aValueToCompare: -- %d --.", aAddress, lReadValue, aValueToCompare);
        
        if(lReadValue < aValueToCompare)
        {
          snprintf(chPassText, elcount(chPassText), "Variable %s is smaller then expected value: %d", aAddress, lReadValue);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected passed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chPassText, PASS);
        }
        else 
        {
          snprintf(chFailText, elcount(chFailText), "Variable %s has the value: %d, greater or equal with: %d.", aAddress, lReadValue, aValueToCompare);
          if((byte)DebugFuncInternal & bDebugFlag)
            writeDbgLevel (DebugFuncInternal, "Test Expected failed. Calling function vFctn_REPORTStepEvaluation.");
          vFctn_REPORTStepEvaluation(chFailText, FAIL);
        }
        break;
    }
  }
  else // API Command Fail
  {
    snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "Test Expected failed. API error message: %s. Calling function vFctn_REPORTStepEvaluation.", chApiMessage);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

/// <VARIABLE>
/*! void E_DBGR_VariableCheck_until(char aAddress[], long aValueToCompare, enum eCompareType aCompareType)
*  \brief Function that repeatedly checks the value at address until the expected condition is met.
*         Useful when hitting a breakpoint multiple times waiting for a specific value (e.g., channelId == 1).
*         Waits for ECU to halt, checks condition, if not met issues GO and retries up to max attempts.
*
*  \param[in] aAddress - name of the variable ("Symbol")
*  \param[in] aValueToCompare - the expected value of the variable
*  \param[in] aCompareType - compare type (e.q. equal, not equal, greater, smaller)
*  \return no return
*
* Change History:
* Date(DD.MM.YY)        Author          Change info
*
* 01.02.26              Copilot        Initial creation based on E_DBGR_VariableCheck
*/
void E_DBGR_VariableCheck_until(char aAddress[], long aValueToCompare, enum eCompareType aCompareType)
{
  byte bDebugFlag;
  long lReadValue;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[500] = "";
  char chPassText[500];
  char chFailText[500];
  int nMaxRetries = 25;
  int nRetryCount;
  byte bConditionMet;

  bDebugFlag = cc_bT32_GlobalDebugFlag;
  bConditionMet = 0;

  writeDbgLevel(DebugFuncCalls , "Function E_DBGR_VariableCheck_until() entered.");

  for (nRetryCount = 0; nRetryCount < nMaxRetries; nRetryCount++)
  {
    // Wait for ECU to stop at breakpoint
    if (!waitForNotRunning(cc_dwT32_BP_HaltTimeout))
    {
      write("Retry %d/%d: ECU did not halt within timeout, issuing GO.", nRetryCount + 1, nMaxRetries);
      snprintf(chT32Cmd, elcount(chT32Cmd), "\"GO\"");
      lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
      continue;
    }

    // Read the variable value
    snprintf(chT32Cmd, elcount(chT32Cmd), "\"print var.value(%s)*1.\"", aAddress);
    writeDbgLevel(DebugFuncInternal, "Calling function lFctn_CallT32API.");
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

    if (lApiExitCode[0] != 0)
    {
      write("Retry %d/%d: API error reading variable, issuing GO. Error: %s", nRetryCount + 1, nMaxRetries, chApiMessage);
      snprintf(chT32Cmd, elcount(chT32Cmd), "\"GO\"");
      lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
      continue;
    }

    lReadValue = atol(chApiMessage);

    if ((byte)DebugFuncParam & bDebugFlag)
      writeDbgLevel(DebugFuncParam, "Retry %d/%d: Variable %s has value %d, comparing to %d with type %d.", nRetryCount + 1, nMaxRetries, aAddress, lReadValue, aValueToCompare, aCompareType);

    // Check condition based on compare type
    switch(aCompareType)
    {
      case Equal:
        if (lReadValue == aValueToCompare)
          bConditionMet = 1;
        break;
      case NotEqual:
        if (lReadValue != aValueToCompare)
          bConditionMet = 1;
        break;
      case Greater:
        if (lReadValue > aValueToCompare)
          bConditionMet = 1;
        break;
      case Smaller:
        if (lReadValue < aValueToCompare)
          bConditionMet = 1;
        break;
    }

    if (bConditionMet)
    {
      // Condition met - report success and return
      switch(aCompareType)
      {
        case Equal:
          snprintf(chPassText, elcount(chPassText), "Variable %s has the expected value: %d (after %d attempt(s))", aAddress, lReadValue, nRetryCount + 1);
          break;
        case NotEqual:
          snprintf(chPassText, elcount(chPassText), "Variable %s is different than expected value: %d (after %d attempt(s))", aAddress, lReadValue, nRetryCount + 1);
          break;
        case Greater:
          snprintf(chPassText, elcount(chPassText), "Variable %s is greater than expected value: %d (after %d attempt(s))", aAddress, lReadValue, nRetryCount + 1);
          break;
        case Smaller:
          snprintf(chPassText, elcount(chPassText), "Variable %s is smaller than expected value: %d (after %d attempt(s))", aAddress, lReadValue, nRetryCount + 1);
          break;
      }
      if ((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel(DebugFuncInternal, "Condition met. Calling function vFctn_REPORTStepEvaluation.");
      vFctn_REPORTStepEvaluation(chPassText, PASS);
      return;
    }

    // Condition not met - log retry message and issue GO
    writeDbgLevel(DebugFuncInternal, "Retry %d/%d: Variable %s has value %d, expected condition not met. Retrying...", nRetryCount + 1, nMaxRetries, aAddress, lReadValue);
    write("E_DBGR_VariableCheck_until: Retry %d/%d - Variable %s = %d, condition not met. Retrying...", nRetryCount + 1, nMaxRetries, aAddress, lReadValue);

    snprintf(chT32Cmd, elcount(chT32Cmd), "\"GO\"");
    lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);
  }

  // Max retries exceeded - report failure
  snprintf(chFailText, elcount(chFailText), "Variable %s did not meet expected condition after %d attempts. Last value: %d, expected: %d.", aAddress, nMaxRetries, lReadValue, aValueToCompare);
  if ((byte)DebugFuncInternal & bDebugFlag)
    writeDbgLevel(DebugFuncInternal, "Max retries exceeded. Calling function vFctn_REPORTStepEvaluation.");
  vFctn_REPORTStepEvaluation(chFailText, FAIL);
}

/// <VARIABLE>
/*! void E_DBGR_VariableCheckArrayElement(char aAddress[], long aIndex, long aValueToCompare)
*  \brief Function that reads the value at address[index] & compares it with expected value
*
*  \param[in] aAddress - name of the BP ("Symbol")
*  \param[in] aIndex - index in the array
*  \param[in] aValueToCompare - the expected value of the register
*
*  \return no return
*
* Change History: 
* Date(DD.MM.YY)        Author          Change info                                                          
*   
* 09.09.20              CrJu         Refactoring the code.
*/
void E_DBGR_VariableCheckArrayElement(char aAddress[], long aIndex, long aValueToCompare)
{
  byte bDebugFlag;
  long lReadValue;
  long lApiExitCode[1];
  char chApiMessage[512];
  char chT32Cmd[128] = "";
  char chPassText[250];
  char chFailText[250];

  bDebugFlag = NotOk;

  // ECU must be halted for var.PRINT; wait up to cc_dwT32_MaxTimeout.
  waitForNotRunning(cc_dwT32_MaxTimeout);

  snprintf(chT32Cmd, elcount(chT32Cmd),  "\"var.PRINT %s[%d]\"", aAddress, aIndex);
 
  writeDbgLevel(DebugFuncCalls , "Function E_DBGR_VariableCheckArrayElement() entered.");
  
  lFctn_CallT32API(chT32Cmd, chApiMessage, lApiExitCode);

  if (lApiExitCode[0] == 0)
  {
    lReadValue = atol(chApiMessage); 
    
    if(lReadValue == aValueToCompare)
    {
      snprintf(chPassText, elcount(chPassText), "Variable %s has the expected value: %d", aAddress, lReadValue);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "PASS: %s.", chPassText);
      vFctn_REPORTStepEvaluation(chPassText, PASS);
    }
    else 
    {
      snprintf(chFailText, elcount(chFailText), "Variable %s has the value: %d, DIFFERENT than expected: %d.", aAddress, lReadValue, aValueToCompare);
      if((byte)DebugFuncInternal & bDebugFlag)
        writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
      vFctn_REPORTStepEvaluation(chFailText, FAIL);
    }
  }
  else // API Command Fail
  {
    snprintf(chFailText, elcount(chFailText), "API error message: %s", chApiMessage);
    if((byte)DebugFuncInternal & bDebugFlag)
      writeDbgLevel (DebugFuncInternal, "FAIL: %s.", chFailText);
    vFctn_REPORTStepEvaluation(chFailText, FAIL);
  }
}

